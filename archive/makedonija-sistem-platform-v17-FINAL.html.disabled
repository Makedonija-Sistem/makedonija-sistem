    /* ── i18n Language Switcher (v17 — robust) ── */
  // Read lang from URL ?lang= first, then localStorage, then browser, then default mk
  const SUPPORTED_LANGS = ['mk', 'en', 'al', 'sr', 'de'];
  function detectInitialLang(){
    try {
      const url = new URL(location.href);
      const q = (url.searchParams.get('lang') || '').toLowerCase();
      if (SUPPORTED_LANGS.includes(q)) return q;
    } catch(e){}
    try {
      const stored = (localStorage.getItem('mks_lang') || '').toLowerCase();
      if (SUPPORTED_LANGS.includes(stored)) return stored;
    } catch(e){}
    try {
      const nav = (navigator.language || 'mk').slice(0,2).toLowerCase();
      const map = {sq:'al', bs:'sr', hr:'sr', me:'sr'};
      const mapped = map[nav] || nav;
      if (SUPPORTED_LANGS.includes(mapped)) return mapped;
    } catch(e){}
    return 'mk';
  }
  let currentLang = detectInitialLang();
  const htmlEl = document.documentElement;

  // Translation getter with fallback chain
  function t(key, lang){
    lang = lang || currentLang;
    if (i18n[lang] && i18n[lang][key] != null) return i18n[lang][key];
    if (i18n.mk && i18n.mk[key] != null) return i18n.mk[key];
    return key; // last resort: show key so missing translations are visible
  }
  // expose for other modules
  window.t = t;
  window.getCurrentLang = () => currentLang;

  // RTL languages would go here; none of mk/en/al/sr/de are RTL
  function setLanguage(lang){
    if (!SUPPORTED_LANGS.includes(lang) || !i18n[lang]) return;
    currentLang = lang;
    htmlEl.setAttribute('data-lang', lang);
    htmlEl.setAttribute('lang', lang);
    try { localStorage.setItem('mks_lang', lang); } catch(e){}

    // Update active language button
    document.querySelectorAll('.lang-btn').forEach(btn => {
      const isActive = btn.dataset.lang === lang;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });

    // Translate text content (data-i18n)
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      const val = t(key, lang);
      if (val === key) return; // no translation, leave existing text
      const tag = el.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA'){
        // For inputs, translate placeholder unless it's a button input
        if (el.type === 'submit' || el.type === 'button'){
          el.value = val;
        } else {
          el.placeholder = val;
        }
      } else if (tag === 'META'){
        el.setAttribute('content', val);
      } else if (tag === 'IMG' || tag === 'SVG'){
        el.setAttribute('alt', val);
      } else if (tag === 'OPTION'){
        el.textContent = val;
      } else {
        // Use innerHTML to preserve <em>, <br>, etc. in translations.
        // Translations come from a controlled dictionary, not user input.
        el.innerHTML = val;
      }
    });

    // Translate attributes via data-i18n-attr="attribute:key,attribute2:key2"
    document.querySelectorAll('[data-i18n-attr]').forEach(el => {
      const spec = el.getAttribute('data-i18n-attr');
      spec.split(',').forEach(pair => {
        const [attr, key] = pair.split(':').map(s => s.trim());
        if (attr && key){
          const val = t(key, lang);
          if (val !== key) el.setAttribute(attr, val);
        }
      });
    });

    // Specific aliases (common attrs)
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const k = el.getAttribute('data-i18n-placeholder');
      const v = t(k, lang);
      if (v !== k) el.placeholder = v;
    });
    document.querySelectorAll('[data-i18n-title]').forEach(el => {
      const k = el.getAttribute('data-i18n-title');
      const v = t(k, lang);
      if (v !== k) el.title = v;
    });
    document.querySelectorAll('[data-i18n-aria]').forEach(el => {
      const k = el.getAttribute('data-i18n-aria');
      const v = t(k, lang);
      if (v !== k) el.setAttribute('aria-label', v);
    });

    // Update <title>
    const titleVal = t('meta.title', lang);
    if (titleVal && titleVal !== 'meta.title') document.title = titleVal;

    // Update OG / twitter meta
    const ogTitle = document.querySelector('meta[property="og:title"]');
    if (ogTitle) ogTitle.setAttribute('content', titleVal);
    const ogDesc = document.querySelector('meta[property="og:description"]');
    if (ogDesc) ogDesc.setAttribute('content', t('meta.desc', lang));
    const twTitle = document.querySelector('meta[name="twitter:title"]');
    if (twTitle) twTitle.setAttribute('content', titleVal);
    const twDesc = document.querySelector('meta[name="twitter:description"]');
    if (twDesc) twDesc.setAttribute('content', t('meta.desc', lang));

    // Notify other modules
    window.dispatchEvent(new CustomEvent('langchange', {detail:{lang}}));
  }

  // Wire up language buttons
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang;
      setLanguage(lang);
      const names = {mk:'Македонски', en:'English', al:'Shqip', sr:'Srpski', de:'Deutsch'};
      if (typeof showToast === 'function'){
        showToast('🌍 ' + names[lang] + ' ' + t('toast.lang.activated', lang), 'info', 1800);
      }
    });
  });

  // Keyboard shortcut: Alt + 1..5 to switch language quickly
  document.addEventListener('keydown', (e) => {
    if (e.altKey && !e.ctrlKey && !e.shiftKey && !e.metaKey){
      const idx = ['1','2','3','4','5'].indexOf(e.key);
      if (idx >= 0 && SUPPORTED_LANGS[idx]){
        e.preventDefault();
        setLanguage(SUPPORTED_LANGS[idx]);
      }
    }
  });

  // Initialize
  setLanguage(currentLang);

  /* ── Runtime text translator for un-tagged common phrases ── */
  // Maps Macedonian text → translations for the other 4 languages.
  // Used as a fallback for elements without data-i18n.
  const COMMON_PHRASES = {
