<style>
/* ────────────────────────────────────────────────────────────
   МАКЕДОНИЈА — СИСТЕМ · v2.0 ULTRA · Editorial Statesmanship
   ──────────────────────────────────────────────────────────── */

:root{
  --navy-deep:#071529;
  --navy:#0a1d3a;
  --navy-mid:#142a4f;
  --navy-soft:#1e3a66;
  --gold:#d4ad4a;
  --gold-soft:#e9c977;
  --gold-deep:#a8861f;
  --cream:#f6efde;
  --cream-soft:#faf6ec;
  --paper:#fffdf6;
  --ink:#0e1422;
  --ink-soft:#2a3142;
  --muted:#5a6478;
  --muted-soft:#8b94a8;
  --line:#e3d8b8;
  --line-soft:#efe7cf;
  --rule:#d4c794;
  --shadow-sm:0 4px 14px rgba(8,26,51,.08);
  --shadow:0 18px 50px rgba(8,26,51,.14);
  --shadow-lg:0 30px 80px rgba(8,26,51,.22);
  --radius:18px;
  --radius-lg:26px;
  --max:1240px;
  --serif:'Playfair Display','PT Serif',Georgia,'Times New Roman',serif;
  --sans:'Manrope','Segoe UI',system-ui,sans-serif;
  --mono:'JetBrains Mono',ui-monospace,monospace;
  /* Theme-aware tokens */
  --bg:var(--cream);
  --bg-soft:var(--cream-soft);
  --surface:var(--paper);
  --text:var(--ink);
  --text-soft:var(--ink-soft);
  --text-muted:var(--muted);
  --border:var(--line);
  --border-soft:var(--line-soft);
}

[data-theme="dark"]{
  --cream:#0e1a2e;
  --cream-soft:#0a1525;
  --paper:#152743;
  --ink:#f1ead8;
  --ink-soft:#d4cdb7;
  --muted:#9aa3b8;
  --muted-soft:#6c768c;
  --line:#1f3358;
  --line-soft:#162947;
  --rule:#2a4373;
  --shadow-sm:0 4px 14px rgba(0,0,0,.4);
  --shadow:0 18px 50px rgba(0,0,0,.55);
  --shadow-lg:0 30px 80px rgba(0,0,0,.7);
  --bg:var(--cream);
  --bg-soft:var(--cream-soft);
  --surface:var(--paper);
  --text:var(--ink);
  --text-soft:var(--ink-soft);
  --text-muted:var(--muted);
  --border:var(--line);
  --border-soft:var(--line-soft);
}

*,*::before,*::after{box-sizing:border-box}
html{scroll-behavior:smooth;scroll-padding-top:90px}
body{
  margin:0;
  font-family:var(--sans);
  color:var(--ink);
  background:var(--cream);
  line-height:1.7;
  font-size:16px;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
  overflow-x:hidden;
  /* Cyrillic-aware feature settings */
  font-feature-settings:"kern" 1,"liga" 1,"calt" 1,"locl" 1;
  text-rendering:optimizeLegibility;
}

/* Cyrillic-specific tweaks for serif headings */
h1, h2, h3, h4, h5, h6{
  font-feature-settings:"kern" 1,"liga" 1,"locl" 1;
}

::selection{background:var(--navy);color:var(--gold-soft)}

a{color:inherit;text-decoration:none;transition:color .22s ease}
.container{width:min(var(--max),calc(100% - 40px));margin:0 auto}

/* ─── Scroll progress ─── */
.scroll-progress{
  position:fixed;top:0;left:0;height:3px;width:0%;
  background:linear-gradient(90deg,var(--gold),var(--gold-soft));
  z-index:200;transition:width .15s linear;
  box-shadow:0 0 12px rgba(212,173,74,.5);
}

/* ─── Topbar ─── */
.topbar{
  background:var(--navy-deep);
  color:rgba(255,255,255,.78);
  font-size:12.5px;
  padding:11px 0;
  letter-spacing:.3px;
  border-bottom:1px solid rgba(212,173,74,.12);
}
.topbar .inner{display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;align-items:center}
.topbar strong{color:var(--gold-soft);font-weight:700;letter-spacing:1.2px}
.topbar a{color:var(--gold-soft)}
.topbar a:hover{color:#fff}
.topbar .doctrine{font-family:var(--serif);font-style:italic;font-size:13.5px;color:rgba(255,255,255,.6)}

/* ─── Header ─── */
header{
  position:sticky;top:0;z-index:50;
  background:rgba(247,242,232,.92);
  border-bottom:1px solid var(--line);
  backdrop-filter:blur(16px) saturate(140%);
  -webkit-backdrop-filter:blur(16px) saturate(140%);
}
header.scrolled{box-shadow:0 4px 24px rgba(8,26,51,.08)}
nav{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:14px 0;min-height:64px;flex-wrap:wrap}

.brand{display:flex;align-items:center;gap:12px}
.brand-mark{
  width:48px;height:48px;border-radius:12px;
  background:linear-gradient(135deg,var(--navy),var(--navy-mid));
  display:grid;place-items:center;
  box-shadow:0 6px 20px rgba(8,26,51,.25);
  flex-shrink:0;
  position:relative;
  overflow:hidden;
}
.brand-mark::after{
  content:"";position:absolute;inset:0;
  background:radial-gradient(ellipse at 30% 25%,rgba(212,173,74,.18),transparent 60%);
  pointer-events:none;
}
.brand-mark svg{width:32px;height:32px;display:block;position:relative;z-index:1}
.brand-text{display:flex;flex-direction:column;line-height:1.05}
.brand-text b{color:var(--navy);font-size:17px;letter-spacing:1.2px;font-weight:800}
.brand-text span{color:var(--muted);font-size:11px;margin-top:4px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600}

.links{display:flex;gap:4px;align-items:center;flex-wrap:wrap}
.links a{
  font-size:12.5px;font-weight:700;color:var(--navy);
  padding:8px 12px;border-radius:8px;
  letter-spacing:.4px;
  position:relative;
}
.links a:hover{background:rgba(10,29,58,.06);color:var(--navy-deep)}
.links a.active{background:var(--navy);color:var(--gold-soft)}

.menu-toggle{
  display:none;background:transparent;border:1.5px solid var(--navy);
  color:var(--navy);width:42px;height:42px;border-radius:10px;
  cursor:pointer;padding:0;align-items:center;justify-content:center;
}
.menu-toggle svg{width:20px;height:20px}

/* ─── Buttons ─── */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  border-radius:999px;padding:13px 22px;
  font-weight:700;font-size:13px;letter-spacing:.6px;
  text-transform:uppercase;
  cursor:pointer;border:none;
  transition:all .25s cubic-bezier(.4,0,.2,1);
  font-family:var(--sans);
}
.btn.gold{background:var(--gold);color:var(--navy-deep);box-shadow:0 8px 24px rgba(212,173,74,.35)}
.btn.gold:hover{background:var(--gold-soft);transform:translateY(-2px);box-shadow:0 12px 32px rgba(212,173,74,.45)}
.btn.dark{background:var(--navy);color:var(--cream-soft);box-shadow:0 8px 24px rgba(8,26,51,.25)}
.btn.dark:hover{background:var(--navy-mid);transform:translateY(-2px);box-shadow:0 12px 32px rgba(8,26,51,.35)}
.btn.light{
  border:1.5px solid rgba(255,255,255,.32);
  color:#fff;background:rgba(255,255,255,.04);
  backdrop-filter:blur(8px);
}
.btn.light:hover{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.5);transform:translateY(-2px)}
.btn.ghost{
  background:transparent;border:1.5px solid var(--navy);color:var(--navy);
}
.btn.ghost:hover{background:var(--navy);color:var(--cream-soft)}
.btn.sm{padding:9px 16px;font-size:11.5px}

/* ─── Hero ─── */
.hero{
  background:
    radial-gradient(ellipse at 85% 15%,rgba(212,173,74,.18),transparent 45%),
    radial-gradient(ellipse at 15% 85%,rgba(30,58,102,.6),transparent 50%),
    linear-gradient(160deg,var(--navy-deep) 0%,var(--navy) 45%,var(--navy-mid) 100%);
  color:#fff;padding:110px 0 96px;
  overflow:hidden;position:relative;
  border-bottom:1px solid rgba(212,173,74,.14);
}
.hero::before{
  content:"";position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px);
  background-size:80px 80px;
  mask-image:radial-gradient(ellipse at center,#000 30%,transparent 70%);
}
.hero::after{
  content:"";position:absolute;
  top:-200px;right:-200px;width:600px;height:600px;
  background:radial-gradient(circle,rgba(212,173,74,.12),transparent 65%);
  pointer-events:none;
}
.hero .grid{
  position:relative;z-index:2;
  display:grid;grid-template-columns:1.25fr .85fr;gap:56px;align-items:center;
}

.eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  border:1px solid rgba(212,173,74,.4);
  border-radius:999px;padding:8px 16px;
  color:var(--gold-soft);
  font-weight:700;font-size:11px;
  text-transform:uppercase;letter-spacing:1.6px;
  margin-bottom:28px;
  background:rgba(212,173,74,.06);
}
.eyebrow .dot{width:7px;height:7px;border-radius:50%;background:var(--gold-soft);box-shadow:0 0 12px var(--gold-soft);animation:pulse 2.4s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:.6;transform:scale(.9)}50%{opacity:1;transform:scale(1.15)}}

h1,h2,h3,h4{font-family:var(--serif);color:var(--navy);line-height:1.06;font-weight:600;letter-spacing:-.01em}
.hero h1{
  color:#fff;font-size:clamp(40px,6vw,78px);
  margin:0 0 24px;font-weight:600;
  letter-spacing:-.02em;
}
.hero h1 em{color:var(--gold-soft);font-style:italic;font-weight:500}
.hero p.lede{
  color:rgba(255,255,255,.86);font-size:clamp(16px,1.6vw,19px);
  max-width:680px;margin:0;line-height:1.65;font-weight:400;
}
.actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:38px}

.hero-card{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.22);
  border-radius:var(--radius-lg);
  padding:32px;
  box-shadow:var(--shadow-lg);
  backdrop-filter:blur(12px);
  position:relative;
  overflow:hidden;
}
.hero-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.hero-card .seal{
  position:absolute;top:18px;right:18px;
  font-family:var(--mono);font-size:10px;
  color:var(--gold-soft);letter-spacing:2px;
  opacity:.7;
}
.hero-sigil{
  position:absolute;
  top:-30px;right:-30px;
  width:160px;height:160px;
  opacity:0.12;
  pointer-events:none;
  transform:rotate(8deg);
}
.hero-sigil svg{width:100%;height:100%;display:block}
.hero-card h3{color:#fff;margin:0 0 18px;font-size:26px;font-weight:600}
.hero-card ul{margin:0;padding:0;list-style:none}
.hero-card ul li{
  color:rgba(255,255,255,.84);
  padding:10px 0 10px 26px;
  position:relative;font-size:14.5px;
  border-bottom:1px solid rgba(255,255,255,.08);
}
.hero-card ul li:last-child{border-bottom:none}
.hero-card ul li::before{
  content:"";position:absolute;left:0;top:18px;
  width:14px;height:1.5px;background:var(--gold);
}

/* Hero KPI ribbon */
.hero-kpi{
  margin-top:64px;display:grid;
  grid-template-columns:repeat(4,1fr);gap:0;
  border-top:1px solid rgba(212,173,74,.22);
  border-bottom:1px solid rgba(212,173,74,.22);
  padding:24px 0;
  position:relative;z-index:2;
}
.kpi-cell{
  text-align:center;
  border-right:1px solid rgba(212,173,74,.14);
  padding:8px 16px;
}
.kpi-cell:last-child{border-right:none}
.kpi-num{
  font-family:var(--serif);font-size:36px;
  color:var(--gold-soft);font-weight:600;
  letter-spacing:-.02em;display:block;line-height:1;
}
.kpi-label{
  display:block;margin-top:8px;
  font-size:10.5px;letter-spacing:2px;
  text-transform:uppercase;
  color:rgba(255,255,255,.62);font-weight:600;
}

/* ─── Sections ─── */
section{padding:96px 0;position:relative}
section.tight{padding:64px 0}
.accent{
  background:
    linear-gradient(180deg,var(--cream) 0%,var(--cream-soft) 50%,var(--cream) 100%);
  border-top:1px solid var(--line-soft);
  border-bottom:1px solid var(--line-soft);
  position:relative;
}
.accent::before,.accent::after{
  content:"";position:absolute;left:50%;transform:translateX(-50%);
  width:80px;height:1px;background:var(--gold);
}
.accent::before{top:32px}
.accent::after{bottom:32px}

.section-head{max-width:780px;margin-bottom:48px;position:relative}
.section-head.center{margin-left:auto;margin-right:auto;text-align:center}

.label{
  display:inline-flex;align-items:center;gap:10px;
  color:var(--gold-deep);
  text-transform:uppercase;letter-spacing:2.4px;
  font-weight:700;font-size:11px;
  margin-bottom:16px;font-family:var(--sans);
}
.label::before{
  content:"";width:24px;height:1.5px;background:var(--gold-deep);
}
.section-head h2{
  margin:0 0 16px;
  font-size:clamp(30px,4vw,50px);
  font-weight:600;letter-spacing:-.015em;
}
.section-head h2 em{color:var(--gold-deep);font-style:italic;font-weight:500}
.section-head p{
  margin:0;color:var(--muted);
  font-size:17px;line-height:1.7;
  max-width:680px;
}
.section-head.center p{margin-left:auto;margin-right:auto}

/* ─── Grids ─── */
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}

/* ─── Cards ─── */
.card{
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:28px;
  box-shadow:var(--shadow-sm);
  height:100%;
  position:relative;
  transition:all .3s ease;
  overflow:hidden;
}
.card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}
.card::before{
  content:"";position:absolute;top:0;left:0;width:0;height:3px;
  background:var(--gold);transition:width .4s ease;
}
.card:hover::before{width:100%}

.card .icon{
  width:48px;height:48px;border-radius:12px;
  display:grid;place-items:center;
  background:linear-gradient(135deg,var(--cream),#ece2c4);
  color:var(--navy);font-size:24px;
  margin-bottom:16px;
  border:1px solid var(--line);
}
.card h3{margin:0 0 10px;font-size:22px;font-weight:600;letter-spacing:-.005em}
.card p,.card li{color:var(--muted);font-size:14.5px;margin:0;line-height:1.65}
.card ul{margin:14px 0 0;padding-left:18px}
.card ul li{margin-bottom:6px}

/* Principle card */
.principle{
  display:grid;grid-template-columns:62px 1fr;gap:18px;align-items:start;
}
.num{
  width:54px;height:54px;border-radius:50%;
  background:linear-gradient(135deg,var(--navy),var(--navy-mid));
  color:var(--gold-soft);
  display:grid;place-items:center;
  font-weight:700;font-size:20px;
  font-family:var(--serif);
  box-shadow:0 6px 18px rgba(8,26,51,.22);
  border:2px solid var(--gold);
}

/* Timeline */
.timeline{display:grid;gap:18px;position:relative}
.step{
  display:grid;grid-template-columns:160px 1fr;gap:24px;
  background:var(--paper);
  border:1px solid var(--line);
  border-left:4px solid var(--gold);
  border-radius:var(--radius);
  padding:24px 28px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
}
.step:hover{transform:translateX(6px);box-shadow:var(--shadow);border-left-color:var(--navy)}
.step .day{
  font-family:var(--serif);font-style:italic;
  color:var(--gold-deep);font-size:20px;font-weight:600;
  letter-spacing:-.005em;
}
.step .day small{display:block;font-family:var(--sans);font-style:normal;font-size:10.5px;color:var(--muted);letter-spacing:1.6px;text-transform:uppercase;margin-bottom:4px;font-weight:700}
.step strong{color:var(--navy);font-size:17px;font-weight:700;display:block;margin-bottom:6px}
.step p{margin:0;color:var(--muted);font-size:14.5px}

/* Pills */
.pills-wrap{display:flex;flex-wrap:wrap;gap:10px;margin-top:8px}
.pill{
  display:inline-flex;align-items:center;
  padding:9px 16px;border-radius:999px;
  background:var(--paper);
  border:1px solid var(--line);
  color:var(--navy);
  font-size:12.5px;font-weight:700;
  letter-spacing:.3px;
  transition:all .25s ease;
}
.pill:hover{background:var(--navy);color:var(--gold-soft);border-color:var(--navy);transform:translateY(-2px)}

/* Quote / Editorial block */
.quote{
  background:
    radial-gradient(ellipse at top right,rgba(212,173,74,.18),transparent 40%),
    linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;
  border-radius:var(--radius-lg);
  padding:56px 48px;
  box-shadow:var(--shadow-lg);
  position:relative;
  overflow:hidden;
  border:1px solid rgba(212,173,74,.2);
}
.quote::before{
  content:"\201E";
  position:absolute;
  top:-30px;left:24px;
  font-family:var(--serif);
  font-size:240px;color:rgba(212,173,74,.16);
  line-height:1;font-weight:700;
}
.quote h2{
  color:#fff;margin:0 0 18px;
  font-size:clamp(26px,3.4vw,40px);
  font-weight:500;font-style:italic;
  position:relative;
  letter-spacing:-.01em;
}
.quote p{color:rgba(255,255,255,.86);margin:0;font-size:17px;line-height:1.7;position:relative;max-width:780px}
.quote .actions{margin-top:36px}
.quote .signature{
  margin-top:32px;padding-top:24px;
  border-top:1px solid rgba(212,173,74,.25);
  font-family:var(--mono);font-size:11px;
  color:var(--gold-soft);letter-spacing:2px;
  text-transform:uppercase;
}

/* ─── Membership / Card preview ─── */
/* ═══ Member card — Standard ID card size 95×65mm (9.5×6.5 cm) ═══
   ISO 7810 ID-1 standard is 85.60×53.98mm (credit card)
   Premium membership card: 95×65mm — authoritative, visible, prestigious */
.member-card-preview{
  background:
    radial-gradient(ellipse at top right,rgba(212,173,74,.22),transparent 50%),
    linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;
  border-radius:18px;
  padding:22px 24px 18px;
  box-shadow:var(--shadow-lg);
  border:1px solid rgba(212,173,74,.28);
  position:relative;
  overflow:hidden;
  /* Fixed aspect ratio 95:65 ≈ 1.46:1 */
  aspect-ratio: 95 / 65;
  max-width: 430px;
  min-height: 280px;
  display:flex;flex-direction:column;justify-content:space-between;
  margin: 0 auto;
}
.member-card-preview::before{
  content:"";position:absolute;
  top:-1px;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.member-card-preview::after{
  content:"";position:absolute;
  bottom:-80px;right:-80px;
  width:240px;height:240px;
  background:radial-gradient(circle,rgba(212,173,74,.1),transparent 70%);
  pointer-events:none;
}
/* ─═══ Card inner layout for 95×65mm ═══─ */
.mc-head{display:flex;justify-content:space-between;align-items:start;gap:12px;position:relative;z-index:2;margin-bottom:8px}
.mc-brand{font-family:var(--serif);font-size:18px;font-weight:600;line-height:1.1;letter-spacing:.2px}
.mc-brand small{display:block;font-family:var(--sans);font-size:9px;color:var(--gold-soft);letter-spacing:2px;margin-top:4px;text-transform:uppercase;font-weight:700}
.mc-mark{
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:grid;place-items:center;
  box-shadow:0 4px 12px rgba(0,0,0,.3);
  flex-shrink:0;
}
.mc-mark svg{display:block;width:20px;height:20px}

/* Card body: photo (left) + info (right) — QR moved to footer */
.mc-body{display:flex;gap:14px;align-items:flex-start;position:relative;z-index:2;flex:1}
.mc-body .member-photo-wrap{
  width:110px;height:142px; /* ~29×37mm at 96dpi, close to 35×45mm passport */
  border-radius:6px;
  flex-shrink:0;
}
.mc-body .member-photo-wrap img{
  width:100%;height:100%;object-fit:cover;object-position:center top;border-radius:6px;
}
.mc-info{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center}
.mc-info p{font-size:12px;margin:2px 0;color:rgba(255,255,255,.86);line-height:1.5}
.mc-info strong{color:var(--gold-soft);font-weight:600;letter-spacing:.3px;font-size:10px;text-transform:uppercase;display:inline-block;min-width:60px}

/* QR column — bottom right, in footer */
.mc-qr-col{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:4px;
  flex-shrink:0;
}
.mc-qr-col .qr-real{
  width:64px;
  height:64px;
  background:#fff;
  border-radius:8px;
  padding:3px;
  border:1.5px solid rgba(212,173,74,.4);
  box-shadow:0 4px 10px rgba(0,0,0,.25);
}
.mc-qr-col .qr-fallback{
  width:64px;
  height:64px;
  background:linear-gradient(135deg,#f8f6f3,#eae7e0);
  border-radius:8px;
  border:1.5px solid rgba(212,173,74,.3);
}
.mc-qr-col .qr-label{
  font-size:8px;
  color:rgba(255,255,255,.55);
  text-transform:uppercase;
  letter-spacing:1px;
  font-weight:600;
}

/* Card footer — text on the left, QR on the right */
.mc-foot{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  gap:14px;
  position:relative;
  z-index:2;
  margin-top:10px;
  padding-top:10px;
  border-top:1px solid rgba(212,173,74,.15);
}
.mc-foot .mc-foot-text{flex:1;min-width:0}
.mc-foot .mc-id{font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.6);letter-spacing:1.2px}
.qr-real{
  width:64px;height:64px;background:#fff;
  border-radius:8px;padding:4px;
  border:2px solid rgba(212,173,74,.4);
  box-shadow:0 4px 12px rgba(0,0,0,.3);
}
.qr-fallback{
  width:64px;height:64px;
  background:linear-gradient(135deg,#f8f6f3,#eae7e0);
  border-radius:8px;
  position:relative;
  border:2px solid rgba(212,173,74,.3);
  overflow:hidden;
}
  background:repeating-conic-gradient(var(--navy-deep) 0% 25%,#fff 0% 50%);
  background-size:14px 14px;
  border-radius:10px;
  border:2px solid rgba(212,173,74,.4);
}

/* Form */
.form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:14px}
.form-grid input,.form-grid select,.form-grid textarea{
  width:100%;
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:13px 14px;
  background:var(--paper);
  color:var(--ink);
  font:inherit;font-size:14px;
  transition:border-color .2s ease,box-shadow .2s ease;
  font-family:var(--sans);
}
.form-grid input:focus,.form-grid select:focus,.form-grid textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.form-grid textarea{grid-column:1/-1;min-height:100px;resize:vertical}
.form-grid button[type=submit]{grid-column:1/-1}
.form-note{color:var(--muted);font-size:12.5px;margin-top:14px;line-height:1.55}
.form-success{
  display:none;
  background:linear-gradient(135deg,#1a3a1f,#2d5a37);
  color:#d4f5cb;border:1px solid #4a8056;
  border-radius:12px;padding:14px 16px;margin-top:14px;
  font-size:13.5px;font-weight:600;
}
.form-success.show{display:block;animation:fadeUp .4s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

.diaspora-link{
  display:inline-flex;align-items:center;gap:8px;
  margin-top:14px;
  border-radius:999px;background:var(--gold);
  color:var(--navy-deep);
  padding:10px 18px;
  font-weight:700;font-size:12px;letter-spacing:.4px;
  text-transform:uppercase;
  transition:all .25s ease;
}
.diaspora-link:hover{background:var(--gold-soft);transform:translateY(-2px);box-shadow:0 8px 20px rgba(212,173,74,.4)}

.payment-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:18px}
.pay-pill{
  display:inline-flex;align-items:center;gap:8px;
  border:1.5px solid var(--line);
  background:var(--paper);
  border-radius:999px;padding:10px 16px;
  font-weight:700;font-size:12px;
  color:var(--navy);letter-spacing:.4px;
  transition:all .25s ease;
}
.pay-pill:hover{background:var(--navy);color:var(--gold-soft);border-color:var(--navy)}

/* ─── Poll tool ─── */
.poll-box{
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:30px;
  box-shadow:var(--shadow-sm);
}
.poll-box h3{font-size:22px;margin:0 0 6px}
.poll-box .sublede{color:var(--muted);font-size:13.5px;margin:0 0 18px}
.poll-controls{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.poll-controls input,.poll-controls select{
  width:100%;border:1.5px solid var(--line);border-radius:10px;
  padding:11px 13px;background:var(--paper);color:var(--ink);
  font:inherit;font-size:13.5px;font-family:var(--sans);
}
.poll-controls input:focus,.poll-controls select:focus{outline:none;border-color:var(--gold)}
.poll-controls select{grid-column:1/-1}
.poll-controls .btn{width:100%}

.model-tabs{display:flex;gap:6px;flex-wrap:wrap;margin:18px 0 14px;padding:6px;background:var(--cream);border-radius:14px;border:1px solid var(--line)}
.model-tabs button{
  flex:1;min-width:120px;
  border:0;background:transparent;
  border-radius:10px;padding:10px 12px;
  font-weight:700;font-size:12.5px;
  color:var(--navy);cursor:pointer;
  letter-spacing:.4px;transition:all .25s ease;
  font-family:var(--sans);
}
.model-tabs button:hover{background:rgba(10,29,58,.06)}
.model-tabs button.active{background:var(--navy);color:var(--gold-soft);box-shadow:0 4px 12px rgba(8,26,51,.2)}

.poll-list{display:grid;gap:8px;margin-top:8px;max-height:340px;overflow-y:auto;padding-right:6px}
.poll-list::-webkit-scrollbar{width:6px}
.poll-list::-webkit-scrollbar-track{background:var(--cream);border-radius:3px}
.poll-list::-webkit-scrollbar-thumb{background:var(--rule);border-radius:3px}
.poll-row{display:grid;grid-template-columns:1.6fr 2fr 64px;gap:10px;align-items:center;padding:6px 0}
.poll-row strong{font-size:12.5px;color:var(--navy);font-weight:700}
.poll-row.lead strong{color:var(--gold-deep)}
.poll-row span{font-family:var(--mono);font-size:12.5px;color:var(--muted);text-align:right;font-weight:600}
.bar{height:11px;background:var(--cream);border-radius:999px;overflow:hidden;border:1px solid var(--line-soft)}
.bar i{display:block;height:100%;background:linear-gradient(90deg,var(--navy),var(--gold));border-radius:999px;width:0%;transition:width .6s cubic-bezier(.4,0,.2,1)}
.poll-row.lead .bar i{background:linear-gradient(90deg,var(--gold-deep),var(--gold))}

.seat-grid{display:grid;gap:6px;margin-top:12px;max-height:280px;overflow-y:auto}
.seat-row{display:grid;grid-template-columns:1.6fr 2fr 60px;gap:10px;align-items:center;padding:5px 0}
.seat-row strong{font-size:12.5px;font-weight:700;color:var(--navy)}
.seat-row span{font-family:var(--mono);font-size:12.5px;color:var(--navy);font-weight:700;text-align:right}
.seat-row .bar i{background:linear-gradient(90deg,var(--gold-deep),var(--navy))}

.note-legal{
  background:#fdf6e3;
  border:1px solid #e8d180;border-left:4px solid var(--gold-deep);
  color:#5a4310;border-radius:10px;padding:14px 16px;
  margin-top:18px;font-size:12.5px;line-height:1.6;
}

/* ─── Statute ─── */
.statute-list{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.statute-item{
  background:var(--paper);
  border:1px solid var(--line);
  border-left:4px solid var(--gold);
  border-radius:14px;
  padding:22px 24px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  position:relative;
}
.statute-item:hover{transform:translateX(4px);border-left-color:var(--navy);box-shadow:var(--shadow)}
.statute-item .num-mark{
  position:absolute;top:18px;right:20px;
  font-family:var(--serif);font-size:32px;
  color:var(--cream);font-weight:700;line-height:1;
  pointer-events:none;
}
.statute-item h3{margin:0 0 6px;font-size:18px;font-weight:600;color:var(--navy)}
.statute-item p{margin:0;color:var(--muted);font-size:14px;line-height:1.65}

/* Statute Article 1 — Symbol (special expanded layout) */
.statute-symbol{
  background:
    radial-gradient(ellipse at top right,rgba(212,173,74,.06),transparent 50%),
    var(--paper);
  border-left-width:6px;
  padding:30px 34px;
}
.statute-symbol .num-mark{
  font-size:48px;color:var(--gold);opacity:0.9;
  top:20px;right:24px;
}
.statute-symbol h3{
  font-size:22px;
  margin-bottom:22px;
  padding-bottom:14px;
  border-bottom:1px solid var(--line);
  letter-spacing:-.005em;
  max-width:calc(100% - 80px);
}
.symbol-grid{
  display:grid;
  grid-template-columns:240px 1fr;
  gap:36px;
  align-items:start;
}
.symbol-visual{
  position:sticky;top:90px;
  display:flex;flex-direction:column;align-items:center;gap:18px;
  padding:24px 16px;
  background:linear-gradient(180deg,#f6efde,#efe6c9);
  border:1px solid var(--line);
  border-radius:14px;
}
.symbol-visual svg{
  filter:drop-shadow(0 8px 24px rgba(8,26,51,.18));
}
.symbol-caption{text-align:center;width:100%}
.symbol-caption .sc-name{
  margin:0;font-family:var(--serif);font-size:15px;font-weight:600;
  color:var(--navy);letter-spacing:.6px;line-height:1.3;
}
.symbol-caption .sc-sub{
  margin:4px 0 0;font-family:var(--mono);font-size:9.5px;
  color:var(--muted);letter-spacing:1.6px;text-transform:uppercase;
}
.symbol-caption .sc-doctrine{
  margin:12px 0 0;padding-top:12px;
  border-top:1px solid var(--rule);
  font-family:var(--serif);font-size:13px;font-style:italic;
  color:var(--gold-deep);
}
.symbol-text p{
  margin:0 0 14px;
  color:var(--ink-soft);
  font-size:14px;
  line-height:1.78;
}
.symbol-text p:last-child{margin-bottom:0}
.symbol-text p strong{
  color:var(--navy);
  font-weight:700;
  font-family:var(--mono);
  font-size:13px;
  background:var(--cream);
  padding:1px 6px;
  border-radius:4px;
  border:1px solid var(--line);
  margin-right:2px;
  display:inline-block;
}
.symbol-text p em{
  color:var(--navy);
  font-style:italic;
  font-weight:600;
  font-family:var(--serif);
  font-size:14.5px;
}
@media(max-width:920px){
  .statute-symbol{padding:24px 22px}
  .symbol-grid{grid-template-columns:1fr;gap:24px}
  .symbol-visual{position:static;padding:20px}
  .symbol-visual svg{width:140px;height:140px}
  .statute-symbol h3{max-width:100%;font-size:19px}
  .statute-symbol .num-mark{font-size:36px;top:14px;right:18px}
}

/* ─── Channels ─── */
.channel-group{margin-bottom:36px}
.channel-group:last-of-type{margin-bottom:0}
.channel-group-head{
  display:flex;align-items:center;gap:14px;
  margin-bottom:18px;padding-bottom:14px;
  border-bottom:1px solid var(--line);
  flex-wrap:wrap;
}
.channel-group-head .cg-num{
  font-family:var(--serif);font-size:28px;
  color:var(--gold-deep);font-weight:600;
  line-height:1;letter-spacing:-.02em;
}
.channel-group-head h3{
  margin:0;font-size:20px;font-weight:600;
  color:var(--navy);letter-spacing:-.005em;flex:1;
}
.channel-group-head .cg-meta{
  font-family:var(--sans);font-size:11px;
  color:var(--muted);text-transform:uppercase;
  letter-spacing:1.6px;font-weight:600;
}
.social-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
}
.channel{
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:14px;
  padding:14px 16px;
  box-shadow:var(--shadow-sm);
  display:flex;align-items:center;gap:12px;
  transition:all .28s ease;
  position:relative;overflow:hidden;
  min-height:64px;
}
.channel::before{
  content:"";position:absolute;left:0;top:0;bottom:0;width:3px;
  background:var(--gold);transform:scaleY(0);transform-origin:bottom;
  transition:transform .3s ease;
}
.channel:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}
.channel:hover::before{transform:scaleY(1)}
.channel:hover .ch-ico{transform:scale(1.08) rotate(-3deg)}
.ch-ico{
  width:38px;height:38px;border-radius:10px;
  display:grid;place-items:center;flex-shrink:0;
  box-shadow:0 4px 12px rgba(8,26,51,.15);
  transition:transform .35s cubic-bezier(.34,1.56,.64,1);
}
.ch-ico svg{width:22px;height:22px;display:block}
.ch-text{
  display:flex;flex-direction:column;gap:2px;
  min-width:0;flex:1;
  line-height:1.2;
}
.ch-text b{
  font-weight:700;color:var(--navy);
  font-size:13.5px;letter-spacing:.2px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.ch-text small{
  color:var(--muted);font-weight:500;
  font-size:11.5px;letter-spacing:.2px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}

/* ─── Footer ─── */
footer{
  background:var(--navy-deep);
  color:rgba(255,255,255,.72);
  padding:64px 0 32px;
  border-top:3px solid var(--gold);
  position:relative;
}
footer::before{
  content:"";position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
footer h3{color:#fff;margin:0 0 14px;font-size:18px;font-weight:600;letter-spacing:.3px}
footer .footer-brand{display:flex;align-items:center;gap:14px}
footer .footer-brand svg{flex-shrink:0;filter:drop-shadow(0 4px 12px rgba(212,173,74,.25))}
footer a,footer p{font-size:13.5px;color:rgba(255,255,255,.72);line-height:1.7}
footer a:hover{color:var(--gold-soft)}
footer .grid-3{gap:36px;margin-bottom:36px}
footer .doctrine-line{
  font-family:var(--serif);font-style:italic;
  color:var(--gold-soft);font-size:18px;
  margin-top:8px;letter-spacing:.3px;
}
.foot-bottom{
  border-top:1px solid rgba(212,173,74,.16);
  padding-top:24px;display:flex;justify-content:space-between;
  flex-wrap:wrap;gap:16px;align-items:center;
}
.small{font-size:11.5px;color:rgba(255,255,255,.5);letter-spacing:.3px}

/* ─── Bot Agent ─── */
.bot-agent-float{
  position:fixed;right:22px;bottom:22px;z-index:90;
  width:min(360px,calc(100% - 44px));
  background:linear-gradient(160deg,var(--navy-deep),var(--navy-mid));
  color:#fff;
  border:1px solid rgba(212,173,74,.3);
  border-radius:20px;
  box-shadow:0 24px 60px rgba(8,26,51,.4);
  overflow:hidden;
  transition:all .35s cubic-bezier(.4,0,.2,1);
}
.bot-agent-float.minimized{width:min(220px,calc(100% - 44px))}
.bot-agent-head{
  display:flex;align-items:center;justify-content:space-between;
  gap:10px;padding:14px 18px;
  background:rgba(212,173,74,.08);
  font-weight:700;font-size:13px;
  border-bottom:1px solid rgba(212,173,74,.18);
  cursor:pointer;
}
.bot-agent-head .bot-mark{
  width:32px;height:32px;border-radius:8px;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:grid;place-items:center;
  flex-shrink:0;
}
.bot-agent-head .bot-mark svg{display:block}
.bot-agent-head .bot-title{flex:1;display:flex;flex-direction:column;line-height:1.2;overflow:hidden}
.bot-agent-head .bot-title b{color:#fff;font-size:13px;font-weight:700;letter-spacing:.3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bot-agent-head .bot-title small{color:var(--gold-soft);font-size:10px;letter-spacing:1.4px;text-transform:uppercase;font-weight:600}
.bot-agent-head .bot-status{
  display:inline-block;width:8px;height:8px;border-radius:50%;
  background:#5fce7e;box-shadow:0 0 8px #5fce7e;
  flex-shrink:0;
}
.bot-toggle{
  border:0;background:var(--gold);color:var(--navy-deep);
  border-radius:8px;padding:7px 12px;
  font-weight:800;font-size:11px;cursor:pointer;
  letter-spacing:.4px;text-transform:uppercase;
  transition:all .2s ease;flex-shrink:0;
}
.bot-toggle:hover{background:var(--gold-soft)}
.bot-agent-body{
  padding:16px 18px;
  color:rgba(255,255,255,.88);
  font-size:13px;
  display:none;
  max-height:480px;overflow-y:auto;
}
.bot-agent-float.open .bot-agent-body{display:block}
.bot-msg{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.18);
  border-radius:12px;padding:12px 14px;
  margin-bottom:10px;font-size:13px;line-height:1.55;
}
.bot-msg.user{
  background:rgba(212,173,74,.15);
  border-color:rgba(212,173,74,.3);
  margin-left:24px;
}
.bot-msg.bot{margin-right:24px}
.bot-msg b{color:var(--gold-soft);font-weight:700}
.bot-input-row{display:flex;gap:8px;margin-top:10px}
.bot-input-row input{
  flex:1;border:1px solid rgba(212,173,74,.25);
  background:rgba(255,255,255,.06);color:#fff;
  border-radius:10px;padding:10px 12px;
  font:inherit;font-size:13px;
}
.bot-input-row input::placeholder{color:rgba(255,255,255,.5)}
.bot-input-row input:focus{outline:none;border-color:var(--gold)}
.bot-input-row button{
  border:0;background:var(--gold);color:var(--navy-deep);
  border-radius:10px;padding:0 14px;
  font-weight:700;font-size:12px;cursor:pointer;
  letter-spacing:.3px;text-transform:uppercase;
}
.bot-quick{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.bot-quick button{
  border:1px solid rgba(212,173,74,.25);
  background:rgba(212,173,74,.08);color:var(--gold-soft);
  border-radius:999px;padding:6px 12px;
  font-size:11px;cursor:pointer;font-weight:600;
  transition:all .2s ease;
}
.bot-quick button:hover{background:var(--gold);color:var(--navy-deep)}

/* ─── Reveal animation ─── */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .8s ease,transform .8s ease}
.reveal.visible{opacity:1;transform:none}

/* ─── Responsive ─── */
/* ─── Theme toggle ─── */
.theme-toggle{
  width:38px;height:38px;border-radius:10px;
  border:1.5px solid var(--line);
  background:transparent;color:var(--navy);
  cursor:pointer;display:grid;place-items:center;
  margin-left:6px;transition:all .25s ease;
  padding:0;
}
.theme-toggle:hover{background:var(--navy);color:var(--gold-soft);border-color:var(--navy)}
.theme-toggle svg{width:18px;height:18px}
.theme-toggle .th-moon{display:none}
[data-theme="dark"] .theme-toggle{color:var(--gold-soft);border-color:var(--gold-deep)}
[data-theme="dark"] .theme-toggle .th-sun{display:none}
[data-theme="dark"] .theme-toggle .th-moon{display:block}

/* Dark mode adaptations */
[data-theme="dark"] body{background:var(--cream)}
[data-theme="dark"] header{background:rgba(14,26,46,.92);border-bottom-color:var(--line)}
[data-theme="dark"] .brand-text b{color:var(--gold-soft)}
[data-theme="dark"] .brand-text span{color:var(--muted)}
[data-theme="dark"] .links a{color:var(--ink-soft)}
[data-theme="dark"] .links a:hover{background:rgba(212,173,74,.08);color:var(--gold-soft)}
[data-theme="dark"] .links a.active{background:var(--gold-deep);color:var(--navy-deep)}
[data-theme="dark"] h1,[data-theme="dark"] h2,[data-theme="dark"] h3,[data-theme="dark"] h4{color:var(--ink)}
[data-theme="dark"] .section-head h2 em{color:var(--gold-soft)}
[data-theme="dark"] .section-head p{color:var(--muted)}
[data-theme="dark"] .label{color:var(--gold-soft)}
[data-theme="dark"] .label::before{background:var(--gold-soft)}
[data-theme="dark"] .accent{background:linear-gradient(180deg,var(--cream-soft),var(--cream),var(--cream-soft));border-color:var(--line)}
[data-theme="dark"] .card{background:var(--paper);border-color:var(--line);color:var(--ink)}
[data-theme="dark"] .card .icon{background:linear-gradient(135deg,var(--navy-mid),var(--navy));color:var(--gold-soft);border-color:var(--gold-deep)}
[data-theme="dark"] .card h3{color:var(--ink)}
[data-theme="dark"] .card p,[data-theme="dark"] .card li{color:var(--muted)}
[data-theme="dark"] .num{background:linear-gradient(135deg,var(--gold-deep),var(--gold));color:var(--navy-deep);border-color:var(--gold-soft)}
[data-theme="dark"] .step{background:var(--paper);border-color:var(--line)}
[data-theme="dark"] .step strong{color:var(--ink)}
[data-theme="dark"] .pill{background:var(--paper);border-color:var(--line);color:var(--ink)}
[data-theme="dark"] .pill:hover{background:var(--gold-deep);color:var(--navy-deep);border-color:var(--gold-deep)}
[data-theme="dark"] .form-grid input,[data-theme="dark"] .form-grid select,[data-theme="dark"] .form-grid textarea{background:var(--paper);border-color:var(--line);color:var(--ink)}
[data-theme="dark"] .pay-pill{background:var(--paper);border-color:var(--line);color:var(--ink)}
[data-theme="dark"] .poll-box{background:var(--paper);border-color:var(--line)}
[data-theme="dark"] .poll-controls input,[data-theme="dark"] .poll-controls select{background:var(--cream-soft);border-color:var(--line);color:var(--ink)}
[data-theme="dark"] .model-tabs{background:var(--cream-soft);border-color:var(--line)}
[data-theme="dark"] .model-tabs button{color:var(--ink)}
[data-theme="dark"] .bar{background:var(--cream-soft);border-color:var(--line)}
[data-theme="dark"] .poll-row strong,[data-theme="dark"] .seat-row strong{color:var(--ink)}
[data-theme="dark"] .note-legal{background:#3d2f10;border-color:#5d4717;color:#e9c977}
[data-theme="dark"] .channel{background:var(--paper);border-color:var(--line)}
[data-theme="dark"] .ch-text b{color:var(--ink)}
[data-theme="dark"] .ch-text small{color:var(--muted)}
[data-theme="dark"] .channel-group-head h3{color:var(--ink)}
[data-theme="dark"] .channel-group-head{border-color:var(--line)}
[data-theme="dark"] .statute-item{background:var(--paper);border-color:var(--line)}
[data-theme="dark"] .statute-item h3{color:var(--ink)}
[data-theme="dark"] .statute-item .num-mark{color:var(--navy-mid)}
[data-theme="dark"] .symbol-visual{background:linear-gradient(180deg,var(--paper),var(--navy-mid));border-color:var(--line)}
[data-theme="dark"] .sc-name{color:var(--gold-soft)}
[data-theme="dark"] .symbol-text p{color:var(--ink-soft)}
[data-theme="dark"] .symbol-text p strong{background:var(--cream-soft);border-color:var(--line);color:var(--gold-soft)}
[data-theme="dark"] .symbol-text p em{color:var(--gold-soft)}
[data-theme="dark"] .form-success{background:linear-gradient(135deg,#0d2818,#163d24);color:#a8e9b3;border-color:#2d6e3d}
[data-theme="dark"] .links{background:var(--cream)}
[data-theme="dark"] .menu-toggle{color:var(--gold-soft);border-color:var(--gold-deep)}

/* ─── Live Dashboard ─── */
.dashboard-strip{
  background:
    radial-gradient(ellipse at 0% 0%,rgba(212,173,74,.12),transparent 60%),
    linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  padding:48px 0 56px;
  border-bottom:3px solid var(--gold);
  position:relative;
  overflow:hidden;
}
.dashboard-strip::before{
  content:"";position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(212,173,74,.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(212,173,74,.04) 1px,transparent 1px);
  background-size:48px 48px;
  pointer-events:none;
}
.dashboard-head{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:14px;margin-bottom:30px;
  position:relative;z-index:2;
}
.dashboard-head h2{
  color:#fff;font-size:24px;margin:0;font-weight:600;
  display:flex;align-items:center;gap:14px;
}
.live-dot{
  display:inline-block;width:10px;height:10px;border-radius:50%;
  background:#5fce7e;box-shadow:0 0 14px #5fce7e;
  animation:pulse 1.6s ease-in-out infinite;
}
.dashboard-head .ts{
  font-family:var(--mono);font-size:11px;
  color:var(--gold-soft);letter-spacing:1.6px;
  text-transform:uppercase;
}
.dash-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:14px;
  position:relative;z-index:2;
}
.dash-card{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(212,173,74,.22);
  border-radius:16px;
  padding:20px;
  position:relative;overflow:hidden;
  transition:all .3s ease;
}
.dash-card:hover{
  background:rgba(212,173,74,.1);
  transform:translateY(-3px);
  border-color:var(--gold);
}
.dash-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.dash-card .dc-label{
  font-size:10px;letter-spacing:1.8px;
  color:var(--gold-soft);text-transform:uppercase;
  font-weight:700;
}
.dash-card .dc-value{
  font-family:var(--serif);font-size:42px;
  color:#fff;font-weight:600;
  line-height:1;margin:10px 0 6px;
  letter-spacing:-.02em;
}
.dash-card .dc-trend{
  font-size:11.5px;color:rgba(255,255,255,.7);
  display:flex;align-items:center;gap:6px;
}
.dash-card .dc-trend.up{color:#5fce7e}
.dash-card .dc-trend.down{color:#f08585}
.dash-card .dc-icon{
  position:absolute;top:18px;right:18px;
  font-size:18px;opacity:.4;
}

/* ─── Initiatives ─── */
.init-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-bottom:24px}
.init-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  padding:24px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  position:relative;
}
.init-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--gold)}
.init-head{display:flex;justify-content:space-between;align-items:start;gap:12px;margin-bottom:14px}
.init-cat{
  background:var(--cream);border:1px solid var(--border);
  border-radius:999px;padding:5px 12px;
  font-size:10.5px;font-weight:700;letter-spacing:1.4px;
  text-transform:uppercase;color:var(--gold-deep);
  white-space:nowrap;flex-shrink:0;
}
[data-theme="dark"] .init-card{background:var(--paper)}
[data-theme="dark"] .init-cat{background:var(--cream-soft);color:var(--gold-soft)}
.init-card h3{margin:0 0 8px;font-size:18px;font-weight:600}
[data-theme="dark"] .init-card h3{color:var(--ink)}
.init-card p{margin:0 0 14px;color:var(--muted);font-size:13.5px;line-height:1.65}
.init-meta{
  display:flex;justify-content:space-between;align-items:center;
  padding-top:14px;border-top:1px solid var(--border-soft);
  font-size:12px;color:var(--muted);
}
.init-vote{
  display:flex;align-items:center;gap:6px;
  font-weight:700;color:var(--navy);
}
[data-theme="dark"] .init-vote{color:var(--gold-soft)}

.init-vote-bar{
  height:6px;background:var(--cream);border-radius:999px;
  overflow:hidden;margin:8px 0 12px;
  border:1px solid var(--border-soft);
}
[data-theme="dark"] .init-vote-bar{background:var(--cream-soft)}

/* Interactive vote button */
.init-vote-btn{
  display:inline-flex;align-items:center;gap:8px;
  background:linear-gradient(135deg,var(--cream),var(--cream-soft));
  border:1.5px solid var(--border);
  border-radius:999px;
  padding:8px 14px 8px 12px;
  font-family:var(--sans);
  font-size:12.5px;
  color:var(--navy);
  font-weight:700;
  cursor:pointer;
  transition:all .25s ease;
  position:relative;
  overflow:hidden;
  user-select:none;
  -webkit-tap-highlight-color:transparent;
}
[data-theme="dark"] .init-vote-btn{
  background:linear-gradient(135deg,var(--cream-soft),var(--paper));
  color:var(--ink);
  border-color:var(--line);
}
.init-vote-btn:hover{
  background:linear-gradient(135deg,var(--gold-soft),var(--gold));
  color:var(--navy-deep);
  border-color:var(--gold-deep);
  transform:translateY(-2px);
  box-shadow:0 8px 18px rgba(212,173,74,.32);
}
.init-vote-btn:active{transform:translateY(0);transition-duration:.05s}

.init-vote-btn .iv-icon{
  display:inline-flex;
  font-size:16px;line-height:1;
  transition:transform .3s cubic-bezier(.34,1.56,.64,1);
}
.init-vote-btn:hover .iv-icon{transform:scale(1.18) rotate(-8deg)}

.init-vote-btn .iv-count{
  font-family:var(--mono);font-size:13px;
  letter-spacing:.2px;
  display:inline-block;
  min-width:42px;text-align:center;
}
.init-vote-btn .iv-count b{font-weight:700}

.init-vote-btn .iv-label{
  font-size:11.5px;color:var(--muted);font-weight:600;
  letter-spacing:.3px;
}
.init-vote-btn:hover .iv-label{color:var(--navy-deep)}

/* Voted state */
.init-vote-btn.voted{
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  border-color:var(--gold-deep);
  cursor:default;
  box-shadow:0 6px 16px rgba(212,173,74,.32);
}
.init-vote-btn.voted .iv-icon{transform:scale(1.1)}
.init-vote-btn.voted .iv-label{color:var(--navy-deep)}
.init-vote-btn.voted::after{
  content:"✓";
  display:inline-flex;align-items:center;justify-content:center;
  width:18px;height:18px;border-radius:50%;
  background:var(--navy-deep);color:var(--gold);
  font-size:11px;font-weight:700;
  margin-left:4px;
  animation:popIn .4s cubic-bezier(.34,1.56,.64,1);
}
.init-vote-btn:disabled{opacity:1;pointer-events:none}

@keyframes popIn{
  0%{transform:scale(0);opacity:0}
  60%{transform:scale(1.3);opacity:1}
  100%{transform:scale(1);opacity:1}
}

/* Burst on click */
.init-vote-btn.bursting::before{
  content:"";position:absolute;inset:0;border-radius:inherit;
  background:radial-gradient(circle at center,var(--gold-soft),transparent 70%);
  animation:burst .6s ease-out forwards;
  pointer-events:none;
}
@keyframes burst{
  0%{opacity:1;transform:scale(.4)}
  100%{opacity:0;transform:scale(1.6)}
}

/* Floating +1 */
.iv-floater{
  position:absolute;left:50%;top:0;
  transform:translate(-50%,0);
  pointer-events:none;
  font-family:var(--serif);font-size:20px;font-weight:700;
  color:var(--gold-deep);
  animation:floatUp 1.2s cubic-bezier(.4,0,.2,1) forwards;
  white-space:nowrap;
  text-shadow:0 2px 8px rgba(212,173,74,.4);
}
@keyframes floatUp{
  0%{opacity:0;transform:translate(-50%,0) scale(.8)}
  20%{opacity:1;transform:translate(-50%,-8px) scale(1.1)}
  100%{opacity:0;transform:translate(-50%,-44px) scale(1)}
}

/* Count change animation */
.iv-count.bumping b{
  display:inline-block;
  animation:countBump .35s cubic-bezier(.34,1.56,.64,1);
}
@keyframes countBump{
  0%{transform:scale(1)}
  50%{transform:scale(1.25);color:var(--gold-deep)}
  100%{transform:scale(1)}
}

/* Initial bar transition */
.init-vote-bar i{
  display:block;height:100%;
  background:linear-gradient(90deg,var(--gold-deep),var(--gold));
  border-radius:999px;
  transition:width 1s cubic-bezier(.4,0,.2,1);
  width:0;
}

.init-loc{
  font-size:12px;color:var(--muted);
  font-weight:500;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  max-width:50%;
}
[data-theme="dark"] .init-loc{color:var(--muted)}
.init-cta{
  text-align:center;margin-top:18px;
}

/* ─── Municipalities map ─── */
.muni-wrap{
  display:grid;grid-template-columns:1.2fr 1fr;gap:30px;align-items:start;
}
.muni-map-frame{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:20px;
  padding:24px;
  box-shadow:var(--shadow-sm);
  position:sticky;top:90px;
}
.muni-map-frame svg{width:100%;height:auto;display:block;max-height:480px}
.muni-region{
  fill:var(--cream);stroke:var(--gold-deep);stroke-width:1.5;
  cursor:pointer;transition:all .25s ease;
}
.muni-region:hover{fill:var(--gold-soft);stroke:var(--navy)}
.muni-region.active{fill:var(--gold);stroke:var(--navy);stroke-width:2}
.muni-label{
  font-family:var(--sans);font-size:9px;font-weight:700;
  fill:var(--navy);pointer-events:none;text-anchor:middle;
}
[data-theme="dark"] .muni-region{fill:var(--navy-mid);stroke:var(--gold-deep)}
[data-theme="dark"] .muni-region:hover{fill:var(--gold-deep);stroke:var(--gold-soft)}
[data-theme="dark"] .muni-label{fill:var(--gold-soft)}
.muni-info{
  background:var(--paper);border:1px solid var(--border);
  border-radius:18px;padding:24px;box-shadow:var(--shadow-sm);
}
.muni-info h3{margin:0 0 6px;font-size:22px;font-weight:600}
.muni-info .mi-pop{font-size:13px;color:var(--muted);margin:0 0 16px}
.muni-info .mi-status{
  background:var(--cream);border:1px solid var(--border);
  border-left:4px solid var(--gold);
  border-radius:10px;padding:14px 16px;margin:14px 0;font-size:14px;
}
[data-theme="dark"] .muni-info .mi-status{background:var(--cream-soft)}

/* ═══════════════════════════════════════════════════════════
   DIGITAL NOTARY ENROLLMENT · 1000 Members System
   ═══════════════════════════════════════════════════════════ */

/* Progress bar */
.enroll-progress-wrap{
  background:var(--cream);
  border:1px solid var(--line);
  border-radius:var(--radius-lg);
  padding:24px 28px;
  margin-bottom:36px;
  box-shadow:var(--shadow);
}
.enroll-progress-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:12px;
  font-size:15px;
  font-weight:700;
  color:var(--navy);
}
.enroll-progress-bar{
  height:16px;
  background:var(--cream-soft);
  border-radius:100px;
  overflow:hidden;
  border:1px solid var(--line);
}
.enroll-progress-fill{
  height:100%;
  background:linear-gradient(90deg,var(--gold),var(--gold-deep));
  border-radius:100px;
  transition:width 1s cubic-bezier(.4,0,.2,1);
  position:relative;
}
.enroll-progress-fill::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);
  animation:shimmer 2s infinite;
}
@keyframes shimmer{
  0%{transform:translateX(-100%)}
  100%{transform:translateX(100%)}
}
.enroll-progress-sub{
  font-size:13px;
  color:var(--slate);
  margin-top:10px;
  text-align:center;
}

/* Digital enrollment grid */
.enroll-digital-grid{
  display:grid;
  grid-template-columns:1.4fr 1fr;
  gap:28px;
  align-items:start;
}
.enroll-form-panel{
  background:var(--cream);
  border:1.5px solid var(--line);
  border-radius:var(--radius-lg);
  padding:28px;
  box-shadow:var(--shadow);
}
.enroll-info-panel{
  display:flex;
  flex-direction:column;
  gap:20px;
  position:sticky;
  top:100px;
}
.enroll-info-card{
  background:var(--cream);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:22px;
  box-shadow:var(--shadow-sm);
}
.enroll-info-card h4{
  font-family:var(--serif);
  font-size:17px;
  color:var(--navy);
  margin:0 0 14px;
}

/* Steps navigation */
.enroll-steps-nav{
  display:flex;
  gap:8px;
  margin-bottom:24px;
  flex-wrap:wrap;
}
.enroll-step-btn{
  padding:10px 18px;
  border-radius:100px;
  border:1.5px solid var(--line);
  background:var(--cream-soft);
  color:var(--slate);
  font-family:var(--sans);
  font-size:13px;
  font-weight:600;
  cursor:pointer;
  transition:all .25s ease;
  white-space:nowrap;
}
.enroll-step-btn:hover{
  border-color:var(--gold-soft);
  color:var(--navy);
}
.enroll-step-btn.active{
  background:var(--navy);
  color:var(--gold-soft);
  border-color:var(--navy);
  box-shadow:0 4px 14px rgba(8,26,51,.25);
}

/* Step content */
.enroll-step-content{
  display:none;
}
.enroll-step-content.active{
  display:block;
  animation:fadeIn .35s ease;
}
.enroll-step-content h4{
  font-family:var(--serif);
  font-size:20px;
  color:var(--navy);
  margin:0 0 18px;
}

/* Document upload boxes */
.enroll-doc-grid{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:14px;
  margin-bottom:20px;
}
.enroll-doc-box{
  border:2px dashed var(--line);
  border-radius:var(--radius);
  padding:20px;
  text-align:center;
  position:relative;
  cursor:pointer;
  transition:all .25s ease;
  background:var(--cream-soft);
  min-height:160px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
}
.enroll-doc-box:hover{
  border-color:var(--gold-soft);
  background:rgba(212,173,74,.04);
}
.enroll-doc-box.has-file{
  border-style:solid;
  border-color:var(--gold);
  background:rgba(212,173,74,.06);
}
.enroll-doc-input{
  position:absolute;
  inset:0;
  opacity:0;
  cursor:pointer;
  z-index:2;
}
.enroll-doc-placeholder{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:8px;
  color:var(--slate);
}
.enroll-doc-placeholder svg{
  width:32px;
  height:32px;
  opacity:.5;
}
.enroll-doc-placeholder strong{
  font-size:12px;
  font-weight:700;
}
.enroll-doc-placeholder span{
  font-size:11px;
  opacity:.7;
}
.enroll-doc-preview{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:var(--radius);
  display:none;
  z-index:3;
}
.enroll-doc-preview.show{
  display:block;
}

/* Verification status */
.enroll-verification-status{
  padding:14px 18px;
  border-radius:var(--radius);
  background:var(--cream-soft);
  border:1px solid var(--line);
  margin-bottom:20px;
  font-size:13px;
  font-weight:600;
}
.enroll-verification-status .v-pending{color:var(--slate)}
.enroll-verification-status .v-success{color:#27ae60;background:rgba(39,174,96,.08);border-color:rgba(39,174,96,.25)}
.enroll-verification-status .v-error{color:#c0392b;background:rgba(192,57,43,.06);border-color:rgba(192,57,43,.2)}

/* Navigation buttons */
.enroll-nav-btns{
  display:flex;
  gap:12px;
  justify-content:space-between;
  margin-top:20px;
}

/* Signature canvas */
.enroll-signature-wrap{
  position:relative;
  border:2px solid var(--line);
  border-radius:var(--radius);
  background:#fff;
  margin-bottom:20px;
  overflow:hidden;
}
#deSignatureCanvas{
  width:100%;
  height:180px;
  cursor:crosshair;
  display:block;
}
.enroll-sig-clear{
  position:absolute;
  top:8px;
  right:8px;
  padding:6px 12px;
  font-size:12px;
  font-weight:600;
  background:rgba(255,255,255,.9);
  border:1px solid var(--line);
  border-radius:100px;
  cursor:pointer;
  z-index:5;
  transition:all .2s ease;
}
.enroll-sig-clear:hover{
  border-color:#c0392b;
  color:#c0392b;
}

/* Contract preview */
.enroll-contract-preview{
  background:var(--cream-soft);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:18px;
  margin-bottom:16px;
}
.enroll-contract-preview h5{
  font-family:var(--serif);
  font-size:15px;
  color:var(--navy);
  margin:0 0 10px;
}
.contract-text{
  font-size:13px;
  line-height:1.7;
  color:var(--slate);
  font-family:var(--mono);
  background:#fff;
  padding:14px;
  border-radius:8px;
  border:1px solid var(--line);
}

/* Success card */
.enroll-success-card{
  text-align:center;
  padding:32px;
}
.enroll-success-icon{
  width:64px;
  height:64px;
  border-radius:50%;
  background:linear-gradient(135deg,#27ae60,#2ecc71);
  color:#fff;
  font-size:32px;
  display:grid;
  place-items:center;
  margin:0 auto 20px;
  box-shadow:0 8px 24px rgba(39,174,96,.3);
}
.enroll-success-card h4{
  font-family:var(--serif);
  font-size:22px;
  color:var(--navy);
  margin:0 0 10px;
}
.enroll-success-card > p{
  font-size:14px;
  color:var(--slate);
  margin:0 0 24px;
  max-width:420px;
  margin-left:auto;
  margin-right:auto;
}
.enroll-blockchain-hash{
  background:var(--cream-soft);
  border:1.5px solid var(--line);
  border-radius:var(--radius);
  padding:16px;
  margin-bottom:20px;
  text-align:left;
}
.enroll-blockchain-hash strong{
  display:block;
  font-size:12px;
  text-transform:uppercase;
  letter-spacing:1px;
  color:var(--slate);
  margin-bottom:8px;
}
.enroll-blockchain-hash code{
  display:block;
  font-family:var(--mono);
  font-size:12px;
  color:var(--navy);
  background:#fff;
  padding:10px;
  border-radius:6px;
  border:1px solid var(--line);
  word-break:break-all;
  margin-bottom:10px;
}
.enroll-qr-generated{
  margin-bottom:20px;
}
.enroll-qr-generated img{
  width:140px;
  height:140px;
  border-radius:var(--radius);
  border:2px solid var(--gold);
  padding:6px;
  background:#fff;
}
.enroll-member-id{
  font-size:16px;
  color:var(--navy);
}
.enroll-member-id .mc-id{
  font-size:22px;
  color:var(--gold-soft);
}

/* Next steps */
.enroll-next-steps{
  margin-top:28px;
  padding-top:28px;
  border-top:1px solid var(--line);
}
.enroll-next-steps h5{
  font-family:var(--serif);
  font-size:18px;
  color:var(--navy);
  margin:0 0 16px;
}
.next-step-grid{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:16px;
}
.next-step-card{
  background:var(--cream-soft);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:20px;
  text-align:center;
  transition:all .3s ease;
}
.next-step-card:hover{
  border-color:var(--gold-soft);
  transform:translateY(-2px);
}
.next-step-num{
  width:36px;
  height:36px;
  border-radius:50%;
  background:var(--navy);
  color:var(--gold-soft);
  font-weight:700;
  font-size:16px;
  display:grid;
  place-items:center;
  margin:0 auto 10px;
}
.next-step-card strong{
  display:block;
  font-size:14px;
  color:var(--navy);
  margin-bottom:6px;
}
.next-step-card span{
  display:block;
  font-size:12px;
  color:var(--slate);
  margin-bottom:12px;
}

/* Step info sidebar */
.enroll-step-info{
  display:flex;
  flex-direction:column;
  gap:14px;
}
.esi-row{
  display:flex;
  gap:12px;
  align-items:flex-start;
}
.esi-num{
  width:28px;
  height:28px;
  border-radius:50%;
  background:var(--navy);
  color:var(--gold-soft);
  font-size:13px;
  font-weight:700;
  display:grid;
  place-items:center;
  flex-shrink:0;
}
.esi-row strong{
  display:block;
  font-size:13px;
  color:var(--navy);
  margin-bottom:2px;
}
.esi-row span{
  font-size:12px;
  color:var(--slate);
}

/* Terrain QR */
.terrain-qr{
  text-align:center;
  margin:12px 0;
}
.terrain-qr img{
  width:140px;
  height:140px;
  border-radius:var(--radius);
  border:2px solid var(--gold);
  padding:6px;
  background:#fff;
}

/* Security list */
.enroll-security-list{
  list-style:none;
  padding:0;
  margin:0;
  display:flex;
  flex-direction:column;
  gap:8px;
}
.enroll-security-list li{
  font-size:13px;
  color:var(--slate);
  padding:8px 12px;
  background:var(--cream-soft);
  border-radius:8px;
  border-left:3px solid var(--gold);
}

/* Mobile: digital enrollment */
@media (max-width: 768px){
  .enroll-digital-grid{
    grid-template-columns:1fr;
  }
  .enroll-info-panel{
    position:static;
    order:-1;
  }
  .enroll-doc-grid{
    grid-template-columns:1fr;
  }
  .next-step-grid{
    grid-template-columns:1fr;
  }
  .enroll-steps-nav{
    gap:6px;
  }
  .enroll-step-btn{
    font-size:11px;
    padding:8px 12px;
  }
  .enroll-form-panel{
    padding:18px;
  }
}

/* ═══ Muni list (80 municipalities) ═══─ */
.muni-list-wrap{
  max-height:380px;
  overflow-y:auto;
  border:1px solid var(--line);
  border-radius:var(--radius);
  background:var(--cream);
  padding:4px;
}
.muni-list-wrap::-webkit-scrollbar{width:6px}
.muni-list-wrap::-webkit-scrollbar-track{background:transparent}
.muni-list-wrap::-webkit-scrollbar-thumb{background:var(--line);border-radius:100px}
.muni-region-group{border-bottom:1px solid var(--line)}
.muni-region-group:last-child{border-bottom:none}
.muni-region-group summary{
  padding:12px 14px;
  font-size:13px;
  font-weight:700;
  color:var(--navy);
  cursor:pointer;
  user-select:none;
  list-style:none;
  display:flex;
  align-items:center;
  gap:8px;
  transition:background .2s ease;
  border-radius:8px;
}
.muni-region-group summary:hover{background:rgba(212,173,74,.06)}
.muni-region-group summary::-webkit-details-marker{display:none}
.muni-region-group[open] summary{background:rgba(212,173,74,.08)}
.muni-tags{
  display:flex;
  flex-wrap:wrap;
  gap:6px;
  padding:8px 14px 14px;
}
.muni-tag{
  padding:5px 10px;
  border-radius:100px;
  font-size:12px;
  font-weight:600;
  background:var(--cream-soft);
  color:var(--slate);
  border:1px solid var(--line);
  transition:all .2s ease;
}
.muni-tag.active{
  background:rgba(39,174,96,.1);
  color:#27ae60;
  border-color:rgba(39,174,96,.25);
}
.muni-tag em{
  font-style:normal;
  font-size:10px;
  opacity:.7;
  font-weight:500;
  margin-left:3px;
}
.muni-tag:hover{
  transform:scale(1.05);
  border-color:var(--gold-soft);
}

/* ─── Diaspora special section ─── */
.diaspora-hero{
  background:
    radial-gradient(ellipse at 70% 30%,rgba(212,173,74,.18),transparent 50%),
    linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 100%);
  color:#fff;
  border-radius:var(--radius-lg);
  padding:48px;
  margin-bottom:36px;
  position:relative;overflow:hidden;
  border:1px solid rgba(212,173,74,.22);
}
.diaspora-hero::before{
  content:"";position:absolute;
  bottom:-100px;left:-100px;width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.1),transparent 70%);
  pointer-events:none;
}
.diaspora-hero h3{
  color:#fff;margin:0 0 14px;
  font-size:32px;font-weight:600;
  letter-spacing:-.01em;
  position:relative;
}
.diaspora-hero h3 em{color:var(--gold-soft);font-style:italic}
.diaspora-hero p{
  color:rgba(255,255,255,.85);
  font-size:17px;line-height:1.7;
  max-width:760px;margin:0;
  position:relative;
}
.diaspora-hero .actions{margin-top:28px;position:relative}

.country-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
}
.country-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:16px;
  padding:22px;
  box-shadow:var(--shadow-sm);
  transition:all .35s ease;
  position:relative;overflow:hidden;
  cursor:pointer;
}
.country-card:hover{
  transform:translateY(-5px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}
.country-card::before{
  content:"";position:absolute;top:0;left:0;width:0;height:3px;
  background:linear-gradient(90deg,var(--gold-deep),var(--gold));
  transition:width .4s ease;
}
.country-card:hover::before{width:100%}
.country-flag{
  width:52px;height:36px;border-radius:6px;
  display:grid;place-items:center;
  margin-bottom:14px;font-size:28px;
  border:1px solid var(--border);
  background:var(--cream);
  overflow:hidden;
  box-shadow:0 3px 10px rgba(8,26,51,.12);
}
.country-flag svg{width:100%;height:100%;display:block}
.country-card h4{
  margin:0 0 4px;font-size:18px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;
}
[data-theme="dark"] .country-card{background:var(--paper)}
[data-theme="dark"] .country-card h4{color:var(--gold-soft)}
.country-card .cn{
  font-size:11px;color:var(--muted-soft);
  letter-spacing:1.4px;text-transform:uppercase;
  font-weight:600;
  display:block;margin-bottom:12px;
}
.country-card .cstats{
  display:flex;justify-content:space-between;
  font-size:12px;padding:10px 0;
  border-top:1px solid var(--border-soft);
}
.country-card .cstats span{color:var(--muted)}
.country-card .cstats b{color:var(--navy);font-weight:700}
[data-theme="dark"] .country-card .cstats b{color:var(--ink)}
.country-card .clinks{
  display:flex;gap:6px;flex-wrap:wrap;margin-top:12px;
}
.country-card .clinks a{
  font-size:11px;padding:5px 10px;border-radius:6px;
  background:var(--cream);border:1px solid var(--border);
  color:var(--navy);font-weight:700;
  letter-spacing:.3px;
  transition:all .2s ease;
}
[data-theme="dark"] .country-card .clinks a{background:var(--cream-soft);color:var(--ink)}
.country-card .clinks a:hover{background:var(--navy);color:var(--gold-soft);border-color:var(--navy)}

/* ─── Best Practices Databank ─── */
.bp-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:18px;
}
.bp-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:16px;
  padding:24px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  position:relative;overflow:hidden;
}
.bp-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--gold)}
.bp-card::before{
  content:"";position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold-deep),var(--gold));
  transform:scaleX(0);transform-origin:left;
  transition:transform .35s ease;
}
.bp-card:hover::before{transform:scaleX(1)}
.bp-flag{
  font-size:36px;line-height:1;margin-bottom:12px;
  display:inline-block;
}
.bp-meta{
  display:flex;align-items:center;gap:10px;
  margin-bottom:10px;flex-wrap:wrap;
}
.bp-country{
  font-family:var(--mono);font-size:11px;
  color:var(--gold-deep);font-weight:700;
  letter-spacing:1.6px;text-transform:uppercase;
}
.bp-area{
  font-size:11px;
  background:var(--cream);border:1px solid var(--border);
  padding:3px 10px;border-radius:999px;
  color:var(--muted);font-weight:600;letter-spacing:.4px;
}
[data-theme="dark"] .bp-card{background:var(--paper)}
[data-theme="dark"] .bp-area{background:var(--cream-soft)}
[data-theme="dark"] .bp-country{color:var(--gold-soft)}
.bp-card h3{
  margin:0 0 10px;font-size:18px;font-weight:600;
  color:var(--navy);letter-spacing:-.005em;
  font-family:var(--serif);
}
[data-theme="dark"] .bp-card h3{color:var(--ink)}
.bp-card p{
  margin:0 0 14px;color:var(--muted);
  font-size:13.5px;line-height:1.65;
}
.bp-takeaway{
  background:linear-gradient(135deg,rgba(212,173,74,.08),rgba(212,173,74,.02));
  border-left:3px solid var(--gold);
  border-radius:8px;padding:12px 14px;
  font-size:12.5px;line-height:1.6;
  color:var(--ink-soft);
}
.bp-takeaway strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .bp-takeaway{
  background:linear-gradient(135deg,rgba(212,173,74,.12),rgba(212,173,74,.04));
  color:var(--ink);
}
[data-theme="dark"] .bp-takeaway strong{color:var(--gold-soft)}

/* ─── Индекс на благосостојба ─── */
.wb-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:14px;
  margin-bottom:30px;
}
.wb-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:16px;
  padding:22px 18px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  text-align:center;
}
.wb-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--gold)}
[data-theme="dark"] .wb-card{background:var(--paper)}
.wb-icon{font-size:32px;margin-bottom:10px;line-height:1}
.wb-card h3{
  margin:0 0 14px;font-size:15px;font-weight:700;
  color:var(--navy);letter-spacing:-.005em;
}
[data-theme="dark"] .wb-card h3{color:var(--ink)}
.wb-score{
  font-family:var(--serif);font-size:42px;font-weight:600;
  color:var(--gold-deep);line-height:1;
  letter-spacing:-.02em;
  margin-bottom:12px;
}
[data-theme="dark"] .wb-score{color:var(--gold-soft)}
.wb-score span{font-size:16px;color:var(--muted-soft);font-weight:500;letter-spacing:0;font-family:var(--sans)}
.wb-bar{
  height:8px;background:var(--cream);border-radius:999px;
  overflow:hidden;margin-bottom:14px;
  border:1px solid var(--border-soft);
}
[data-theme="dark"] .wb-bar{background:var(--cream-soft)}
.wb-bar i{
  display:block;height:100%;
  background:linear-gradient(90deg,var(--gold-deep),var(--gold));
  border-radius:999px;
  transition:width 1s cubic-bezier(.4,0,.2,1);
}
.wb-details{
  list-style:none;padding:0;margin:0;
  display:flex;flex-direction:column;gap:6px;
  text-align:left;
}
.wb-details li{
  display:flex;justify-content:space-between;
  font-size:11.5px;color:var(--muted);
  padding:5px 0;
  border-bottom:1px solid var(--border-soft);
}
.wb-details li:last-child{border-bottom:none}
.wb-details b{color:var(--navy);font-weight:700;font-family:var(--mono);font-size:11px}
[data-theme="dark"] .wb-details b{color:var(--gold-soft)}

.wb-summary{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  border-radius:18px;
  padding:30px 36px;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow);
}
.wb-summary-row{
  display:flex;justify-content:space-between;align-items:center;
  flex-wrap:wrap;gap:16px;
  padding-bottom:18px;border-bottom:1px solid rgba(212,173,74,.18);
  margin-bottom:14px;
}
.wb-sum-label{
  display:block;font-size:11px;letter-spacing:1.8px;
  color:var(--gold-soft);text-transform:uppercase;font-weight:700;
}
.wb-sum-value{
  display:block;font-family:var(--serif);font-size:42px;
  color:#fff;font-weight:600;line-height:1;margin-top:6px;
  letter-spacing:-.02em;
}
.wb-sum-trend{text-align:right}
.wb-sum-trend>span:first-child{
  display:block;font-size:11px;color:rgba(255,255,255,.6);
  letter-spacing:1px;text-transform:uppercase;font-weight:600;
}
.wb-sum-delta{
  display:block;font-family:var(--mono);font-size:22px;
  font-weight:700;margin-top:6px;letter-spacing:-.5px;
}
.wb-sum-delta.down{color:#f08585}
.wb-sum-delta.up{color:#5fce7e}
.wb-note{
  margin:0;font-size:12px;color:rgba(255,255,255,.65);
  line-height:1.6;
}

@media(max-width:1100px){
  .bp-grid{grid-template-columns:repeat(2,1fr)}
  .wb-grid{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:920px){
  .bp-grid{grid-template-columns:1fr}
  .wb-grid{grid-template-columns:repeat(2,1fr)}
  .wb-summary{padding:24px}
  .wb-sum-value{font-size:32px}
}
@media(max-width:520px){
  .wb-grid{grid-template-columns:1fr}
}
.quote-carousel{
  background:
    radial-gradient(ellipse at 80% 20%,rgba(212,173,74,.1),transparent 50%),
    linear-gradient(135deg,var(--navy),var(--navy-mid));
  color:#fff;
  border-radius:var(--radius-lg);
  padding:48px;
  margin:0 auto;max-width:1100px;
  position:relative;overflow:hidden;
  border:1px solid rgba(212,173,74,.18);
  box-shadow:var(--shadow-lg);
  min-height:240px;
}
.quote-carousel::before{
  content:"\201E";
  position:absolute;top:-40px;left:30px;
  font-family:var(--serif);
  font-size:240px;color:rgba(212,173,74,.14);
  line-height:1;
}
.qc-track{position:relative;min-height:140px}
.qc-slide{
  opacity:0;position:absolute;inset:0;
  transition:opacity .7s ease;
  display:flex;flex-direction:column;justify-content:center;
}
.qc-slide.active{opacity:1;position:relative}
.qc-slide blockquote{
  margin:0;font-family:var(--serif);
  font-style:italic;font-size:clamp(22px,3vw,30px);
  color:#fff;line-height:1.3;font-weight:500;
  max-width:780px;
}
.qc-slide cite{
  display:block;margin-top:18px;
  font-family:var(--mono);font-size:11.5px;
  color:var(--gold-soft);letter-spacing:2px;
  text-transform:uppercase;font-style:normal;
}
.qc-controls{
  display:flex;justify-content:center;gap:10px;
  margin-top:24px;
}
.qc-dot{
  width:8px;height:8px;border-radius:50%;
  background:rgba(212,173,74,.3);border:0;
  cursor:pointer;padding:0;
  transition:all .3s ease;
}
.qc-dot.active{background:var(--gold);width:32px;border-radius:4px}

/* ─── Citizens March / Suggestions ─── */
.cm-process{
  display:grid;
  grid-template-columns:1fr 24px 1fr 24px 1fr 24px 1fr;
  gap:14px;align-items:center;
  margin-bottom:48px;
  padding:24px;
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .cm-process{background:var(--paper)}
.cm-step{
  display:flex;align-items:flex-start;gap:14px;
  padding:14px;
  border-radius:12px;
  transition:background .25s ease;
}
.cm-step:hover{background:var(--cream)}
[data-theme="dark"] .cm-step:hover{background:var(--cream-soft)}
.cm-step-num{
  font-family:var(--serif);font-size:32px;
  color:var(--gold);font-weight:600;line-height:1;
  letter-spacing:-.02em;flex-shrink:0;
  width:48px;text-align:right;
}
.cm-step-body h4{
  margin:0 0 6px;font-size:15px;font-weight:700;
  color:var(--navy);
}
[data-theme="dark"] .cm-step-body h4{color:var(--ink)}
.cm-step-body p{
  margin:0;font-size:12.5px;color:var(--muted);line-height:1.55;
}
.cm-arrow{
  text-align:center;color:var(--gold);
  font-size:22px;font-weight:300;line-height:1;
}

.cm-wrap{
  display:grid;grid-template-columns:1.6fr 1fr;gap:30px;
  align-items:start;
  margin-bottom:48px;
}

.cm-form-box{
  background:var(--paper);
  border:1px solid var(--border);
  border-left:4px solid var(--gold);
  border-radius:18px;
  padding:32px 36px;
  box-shadow:var(--shadow);
}
[data-theme="dark"] .cm-form-box{background:var(--paper)}
.cm-form-head{margin-bottom:24px;padding-bottom:18px;border-bottom:1px solid var(--border)}
.cm-badge{
  display:inline-flex;align-items:center;
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  padding:6px 14px;border-radius:999px;
  font-size:11px;font-weight:700;letter-spacing:1.4px;
  text-transform:uppercase;
  margin-bottom:14px;
}
.cm-form-head h3{margin:0 0 8px;font-size:24px;font-weight:600;letter-spacing:-.005em}
[data-theme="dark"] .cm-form-head h3{color:var(--ink)}
.cm-form-head h3 em{color:var(--gold-deep);font-style:italic}
[data-theme="dark"] .cm-form-head h3 em{color:var(--gold-soft)}
.cm-lede{margin:0;color:var(--muted);font-size:14px;line-height:1.65}

.cm-form{display:flex;flex-direction:column;gap:18px}
.cm-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.cm-label{
  display:flex;flex-direction:column;gap:6px;
  position:relative;
}
.cm-l-text{
  font-size:12px;font-weight:700;
  color:var(--ink-soft);letter-spacing:.4px;
  text-transform:uppercase;
}
.cm-label .req{color:#d4ad4a;font-weight:700}
.cm-form input[type=text],
.cm-form input[type=email],
.cm-form select,
.cm-form textarea{
  width:100%;
  border:1.5px solid var(--border);
  border-radius:10px;
  padding:12px 14px;
  background:var(--paper);
  color:var(--ink);
  font:inherit;font-size:14px;
  font-family:var(--sans);
  transition:border-color .2s,box-shadow .2s;
}
[data-theme="dark"] .cm-form input,
[data-theme="dark"] .cm-form select,
[data-theme="dark"] .cm-form textarea{
  background:var(--cream-soft);
}
.cm-form input:focus,
.cm-form select:focus,
.cm-form textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.cm-form textarea{resize:vertical;min-height:120px;line-height:1.6}
.cm-counter{
  position:absolute;right:0;top:0;
  font-size:11px;color:var(--muted-soft);
  font-family:var(--mono);font-weight:600;
}

.cm-checkbox{
  display:flex;gap:10px;align-items:flex-start;
  font-size:13px;color:var(--ink-soft);line-height:1.55;
  padding:10px 12px;
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-radius:10px;
  cursor:pointer;
  transition:background .2s ease;
}
[data-theme="dark"] .cm-checkbox{background:var(--cream-soft);color:var(--muted)}
.cm-checkbox:hover{background:var(--cream-soft);border-color:var(--gold)}
.cm-checkbox input{margin-top:2px;flex-shrink:0;accent-color:var(--gold-deep)}
.cm-checkbox strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .cm-checkbox strong{color:var(--gold-soft)}

.cm-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px}
.cm-actions .btn{flex:1;min-width:160px}

.cm-side{display:flex;flex-direction:column;gap:18px;position:sticky;top:90px}

.cm-mine,.cm-tips,.cm-stats{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:16px;
  padding:22px 24px;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .cm-mine,
[data-theme="dark"] .cm-tips,
[data-theme="dark"] .cm-stats{background:var(--paper)}

.cm-mine-head{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:8px;
}
.cm-mine-head h3{margin:0;font-size:17px;font-weight:600}
[data-theme="dark"] .cm-mine-head h3{color:var(--ink)}
.cm-mine-count{
  background:var(--gold);color:var(--navy-deep);
  font-family:var(--mono);font-size:13px;font-weight:700;
  padding:3px 10px;border-radius:999px;
  min-width:32px;text-align:center;
}
.cm-mine-lede{
  margin:0 0 14px;font-size:12px;color:var(--muted);
  line-height:1.55;
}
.cm-mine-list{
  display:flex;flex-direction:column;gap:8px;
  max-height:280px;overflow-y:auto;
  padding-right:4px;
}
.cm-mine-list::-webkit-scrollbar{width:5px}
.cm-mine-list::-webkit-scrollbar-thumb{background:var(--rule);border-radius:3px}

.cm-mine-empty{
  text-align:center;padding:24px 14px;
  color:var(--muted-soft);
}
.cm-empty-icon{font-size:32px;display:block;margin-bottom:8px;opacity:0.5}
.cm-mine-empty p{margin:0;font-size:12.5px;line-height:1.55;font-style:italic}

.cm-mine-item{
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-left:3px solid var(--gold);
  border-radius:8px;
  padding:11px 14px;
  font-size:12.5px;
  position:relative;
}
[data-theme="dark"] .cm-mine-item{background:var(--cream-soft)}
.cm-mine-item h5{margin:0 0 4px;font-size:13px;font-weight:700;color:var(--navy);line-height:1.3;padding-right:24px}
[data-theme="dark"] .cm-mine-item h5{color:var(--gold-soft)}
.cm-mine-item .cm-mi-meta{font-size:10.5px;color:var(--muted-soft);font-family:var(--mono);letter-spacing:.4px}
.cm-mi-del{
  position:absolute;top:6px;right:6px;
  background:transparent;border:0;cursor:pointer;
  width:22px;height:22px;border-radius:50%;
  font-size:14px;color:var(--muted-soft);
  display:grid;place-items:center;
  transition:all .2s ease;
}
.cm-mi-del:hover{background:#f08585;color:#fff}

.cm-tips h3{margin:0 0 12px;font-size:16px;font-weight:600}
[data-theme="dark"] .cm-tips h3{color:var(--ink)}
.cm-tip-list{
  list-style:none;padding:0;margin:0;
  display:flex;flex-direction:column;gap:10px;
}
.cm-tip-list li{
  font-size:12.5px;color:var(--muted);line-height:1.6;
  padding-left:18px;position:relative;
}
.cm-tip-list li::before{
  content:"";position:absolute;left:0;top:8px;
  width:8px;height:8px;border-radius:50%;
  background:var(--gold);
}
.cm-tip-list li strong{color:var(--navy);font-weight:700;display:block;margin-bottom:2px}
[data-theme="dark"] .cm-tip-list li strong{color:var(--ink)}

.cm-stats{display:flex;flex-direction:column;gap:10px}
.cm-stat-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 0;
  border-bottom:1px solid var(--border-soft);
}
.cm-stat-row:last-child{border-bottom:none}
.cm-stat-label{font-size:12px;color:var(--muted);letter-spacing:.3px}
.cm-stat-value{
  font-family:var(--serif);font-size:24px;font-weight:600;
  color:var(--gold-deep);line-height:1;
}
[data-theme="dark"] .cm-stat-value{color:var(--gold-soft)}

.cm-recent{
  margin-top:32px;
  padding-top:32px;
  border-top:1px solid var(--border);
}
.cm-recent h3{margin:0 0 24px;font-size:22px;font-weight:600}
[data-theme="dark"] .cm-recent h3{color:var(--ink)}
.cm-recent-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:16px;
}
.cm-recent-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:14px;
  padding:20px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
}
.cm-recent-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--gold)}
[data-theme="dark"] .cm-recent-card{background:var(--paper)}
.cm-rc-head{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:10px;flex-wrap:wrap;gap:6px;
}
.cm-rc-cat{
  background:var(--cream);border:1px solid var(--border);
  border-radius:999px;padding:4px 12px;
  font-size:11px;font-weight:700;letter-spacing:.6px;
  color:var(--gold-deep);
}
[data-theme="dark"] .cm-rc-cat{background:var(--cream-soft);color:var(--gold-soft)}
.cm-rc-date{
  font-size:10.5px;color:var(--muted-soft);
  font-family:var(--mono);letter-spacing:.4px;
}
.cm-recent-card h4{
  margin:0 0 8px;font-size:15px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  line-height:1.35;letter-spacing:-.005em;
}
[data-theme="dark"] .cm-recent-card h4{color:var(--ink)}
.cm-rc-author{
  margin:0 0 12px;font-size:12px;color:var(--muted);
  font-style:italic;
}
.cm-rc-status{
  display:inline-block;padding:5px 12px;
  border-radius:999px;font-size:11px;font-weight:700;
  letter-spacing:.4px;
}
.cm-rc-status.accepted{background:#d4f5cb;color:#1a5d2e;border:1px solid #4a8056}
.cm-rc-status.review{background:#fdf6e3;color:#5a4310;border:1px solid #d4ad4a}
[data-theme="dark"] .cm-rc-status.accepted{background:#163d24;color:#a8e9b3;border-color:#2d6e3d}
[data-theme="dark"] .cm-rc-status.review{background:#3d2f10;color:#e9c977;border-color:#5d4717}

@media(max-width:1100px){
  .cm-process{grid-template-columns:1fr;gap:12px}
  .cm-arrow{transform:rotate(90deg);justify-self:center}
  .cm-wrap{grid-template-columns:1fr}
  .cm-side{position:static}
  .cm-recent-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:920px){
  .cm-form-box{padding:24px}
  .cm-row{grid-template-columns:1fr}
  .cm-recent-grid{grid-template-columns:1fr}
}

/* ─── Sistem Institute ─── */
.inst-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:18px;
  margin-bottom:32px;
}
.inst-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-top:4px solid var(--gold);
  border-radius:14px;
  padding:24px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
}
.inst-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-top-color:var(--navy)}
[data-theme="dark"] .inst-card{background:var(--paper)}
.inst-area{
  display:inline-block;font-size:11px;
  color:var(--gold-deep);font-weight:700;
  letter-spacing:1.6px;text-transform:uppercase;
  padding:4px 10px;border-radius:6px;
  background:rgba(212,173,74,.1);
  margin-bottom:12px;
}
[data-theme="dark"] .inst-area{color:var(--gold-soft);background:rgba(212,173,74,.15)}
.inst-card h3{
  margin:0 0 8px;font-size:18px;font-weight:600;
  color:var(--navy);letter-spacing:-.005em;
}
[data-theme="dark"] .inst-card h3{color:var(--ink)}
.inst-bio{
  margin:0 0 14px;font-size:13px;color:var(--muted);
  line-height:1.6;
}
.inst-publications{
  background:var(--cream);
  border-left:3px solid var(--gold);
  border-radius:8px;
  padding:12px 14px;font-size:12.5px;
}
[data-theme="dark"] .inst-publications{background:var(--cream-soft)}
.inst-pub-label{
  display:block;font-weight:700;color:var(--gold-deep);
  letter-spacing:.4px;font-size:10.5px;
  text-transform:uppercase;margin-bottom:6px;
}
[data-theme="dark"] .inst-pub-label{color:var(--gold-soft)}
.inst-publications ul{
  margin:0;padding-left:18px;color:var(--ink-soft);
}
.inst-publications li{margin-bottom:4px;line-height:1.55}
.inst-cta{margin-top:24px}

/* ─── Junge Sistem ─── */
.junge-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:16px;
  margin-bottom:32px;
}
.junge-card{
  background:linear-gradient(160deg,var(--paper),var(--cream-soft));
  border:1px solid var(--border);
  border-radius:14px;
  padding:24px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  position:relative;overflow:hidden;
}
.junge-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--gold)}
[data-theme="dark"] .junge-card{background:linear-gradient(160deg,var(--paper),var(--cream-soft))}
.junge-icon{
  font-size:30px;line-height:1;margin-bottom:12px;
}
.junge-card h3{
  margin:0 0 8px;font-size:17px;font-weight:600;
  color:var(--navy);
}
[data-theme="dark"] .junge-card h3{color:var(--ink)}
.junge-card p{
  margin:0 0 12px;font-size:13px;color:var(--muted);line-height:1.6;
}
.junge-tag{
  display:inline-block;
  background:var(--navy);color:var(--gold-soft);
  padding:5px 12px;border-radius:999px;
  font-size:11px;font-weight:700;letter-spacing:.4px;
}
.junge-cta{text-align:center;margin-top:8px}

/* ─── Annual Congress ─── */
.congress-hero{
  display:grid;grid-template-columns:1.2fr 1fr;gap:30px;
  margin-bottom:32px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;
  border-radius:22px;padding:36px;
  box-shadow:var(--shadow-lg);
  border:1px solid rgba(212,173,74,.22);
  position:relative;overflow:hidden;
}
.congress-hero::before{
  content:"";position:absolute;
  top:-100px;right:-100px;width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.15),transparent 65%);
  pointer-events:none;
}
.congress-info{position:relative;z-index:2}
.congress-date{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  border-radius:18px;padding:18px 26px;
  text-align:center;margin-bottom:22px;
  box-shadow:0 8px 24px rgba(212,173,74,.32);
}
.cd-day{font-family:var(--serif);font-size:48px;font-weight:700;line-height:1}
.cd-month{font-size:14px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;margin-top:4px}
.cd-year{font-family:var(--mono);font-size:13px;letter-spacing:2px;margin-top:2px;opacity:0.85}
.congress-meta h3{
  color:#fff;font-size:24px;margin:0 0 10px;
  font-weight:600;letter-spacing:-.005em;
}
.congress-meta p{
  color:rgba(255,255,255,.85);
  font-size:14.5px;line-height:1.65;margin:0 0 18px;
  max-width:560px;
}
.congress-stats{
  display:grid;grid-template-columns:repeat(4,1fr);gap:10px;
}
.cs-stat{
  background:rgba(212,173,74,.08);
  border:1px solid rgba(212,173,74,.22);
  border-radius:10px;padding:10px 8px;
  text-align:center;
}
.cs-stat b{
  display:block;font-family:var(--serif);
  font-size:24px;color:var(--gold-soft);font-weight:600;
  line-height:1;margin-bottom:4px;
}
.cs-stat span{
  font-size:10px;color:rgba(255,255,255,.7);
  letter-spacing:1.4px;text-transform:uppercase;font-weight:600;
}

.congress-program{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.22);
  border-radius:14px;padding:22px;
  position:relative;z-index:2;
}
.congress-program h4{
  color:#fff;margin:0 0 14px;font-size:16px;font-weight:600;
}
.cp-day{
  display:flex;gap:12px;align-items:flex-start;
  padding:12px 0;border-bottom:1px solid rgba(212,173,74,.18);
}
.cp-day:last-child{border-bottom:none}
.cp-day-tag{
  background:var(--gold);color:var(--navy-deep);
  padding:4px 10px;border-radius:6px;
  font-size:10.5px;font-weight:700;letter-spacing:1px;
  text-transform:uppercase;flex-shrink:0;
  white-space:nowrap;
}
.cp-day-content strong{
  display:block;color:#fff;font-size:14px;
  font-weight:700;margin-bottom:4px;
}
.cp-day-content p{
  margin:0;font-size:12.5px;color:rgba(255,255,255,.75);
  line-height:1.55;
}

.congress-cta{text-align:center;display:flex;gap:10px;justify-content:center;flex-wrap:wrap}

/* ─── Officina ─── */
.officina-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:14px;
  margin-bottom:32px;
}
.off-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:14px;
  padding:20px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  display:flex;flex-direction:column;gap:10px;
}
.off-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:var(--gold)}
[data-theme="dark"] .off-card{background:var(--paper)}
.off-icon{font-size:28px;line-height:1}
.off-card h3{
  margin:0;font-size:16px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;
}
[data-theme="dark"] .off-card h3{color:var(--ink)}
.off-card p{
  margin:0;font-size:13px;color:var(--muted);
  line-height:1.55;flex:1;
}
.off-meta{
  display:flex;justify-content:space-between;
  font-size:11.5px;color:var(--muted);
  padding:8px 0;border-top:1px solid var(--border-soft);border-bottom:1px solid var(--border-soft);
}
.off-meta b{color:var(--navy);font-weight:700}
[data-theme="dark"] .off-meta b{color:var(--ink)}
.off-deliverable{
  font-size:11.5px;color:var(--gold-deep);
  font-weight:600;line-height:1.5;
  padding:8px 10px;background:rgba(212,173,74,.08);
  border-radius:6px;
}
[data-theme="dark"] .off-deliverable{color:var(--gold-soft);background:rgba(212,173,74,.12)}
.officina-cta{text-align:center}

@media(max-width:1100px){
  .inst-grid{grid-template-columns:repeat(2,1fr)}
  .junge-grid{grid-template-columns:repeat(2,1fr)}
  .officina-grid{grid-template-columns:repeat(2,1fr)}
  .congress-hero{grid-template-columns:1fr}
  .congress-stats{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:920px){
  .inst-grid,.junge-grid,.officina-grid{grid-template-columns:1fr}
  .congress-hero{padding:24px}
  .cd-day{font-size:36px}
}

/* ─── Tier Selector (3-tier membership) ─── */
.tier-selector{
  display:grid;grid-template-columns:repeat(3,1fr);gap:18px;
  margin-bottom:36px;
}
.tier-card{
  background:var(--paper);
  border:1.5px solid var(--border);
  border-radius:18px;
  padding:28px 24px;
  box-shadow:var(--shadow-sm);
  transition:all .35s ease;
  position:relative;
  display:flex;flex-direction:column;
}
[data-theme="dark"] .tier-card{background:var(--paper)}
.tier-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--gold)}
.tier-card.recommended{
  border:2px solid var(--gold);
  box-shadow:0 12px 32px rgba(212,173,74,.22);
  transform:translateY(-3px);
}
.tier-card.recommended:hover{transform:translateY(-7px)}
.tier-badge{
  position:absolute;top:-12px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  font-size:11px;font-weight:700;letter-spacing:1.6px;
  text-transform:uppercase;
  padding:6px 16px;border-radius:999px;
  box-shadow:0 4px 12px rgba(212,173,74,.4);
}
.tier-icon{font-size:36px;margin-bottom:8px;line-height:1}
.tier-rank{
  font-family:var(--mono);font-size:11px;
  color:var(--gold-deep);font-weight:700;
  letter-spacing:1.8px;text-transform:uppercase;
  margin-bottom:6px;
}
[data-theme="dark"] .tier-rank{color:var(--gold-soft)}
.tier-card h3{
  margin:0 0 6px;font-size:22px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;
}
[data-theme="dark"] .tier-card h3{color:var(--ink)}
.tier-time{
  margin:0 0 16px;font-size:12px;color:var(--muted);
  font-weight:600;letter-spacing:.3px;
}
.tier-features{
  list-style:none;padding:0;margin:0 0 18px;
  display:flex;flex-direction:column;gap:7px;
  flex:1;
}
.tier-features li{
  font-size:13px;line-height:1.5;color:var(--ink-soft);
  padding-left:0;
}
[data-theme="dark"] .tier-features li{color:var(--muted)}
.tier-legal{
  background:var(--cream);
  border:1px solid var(--border);
  border-radius:8px;
  padding:10px 12px;
  font-size:11.5px;font-weight:600;
  text-align:center;
  margin-bottom:14px;
  color:var(--ink-soft);
}
[data-theme="dark"] .tier-legal{background:var(--cream-soft);color:var(--muted)}
.tier-card .btn{width:100%}

/* ─── Digital Signature Info ─── */
.ds-info{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  border-radius:20px;
  padding:36px;
  margin-bottom:36px;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow);
}
.ds-info h3{
  color:#fff;margin:0 0 22px;
  font-size:22px;font-weight:600;
  letter-spacing:-.005em;
}
.ds-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:20px;
  margin-bottom:18px;
}
.ds-block{
  background:rgba(255,255,255,.05);
  border:1px solid rgba(212,173,74,.18);
  border-radius:12px;
  padding:18px 20px;
}
.ds-block h4{
  color:var(--gold-soft);margin:0 0 8px;
  font-size:13px;font-weight:700;letter-spacing:1px;
  text-transform:uppercase;
}
.ds-block p{
  margin:0 0 8px;font-size:13px;color:rgba(255,255,255,.85);
  line-height:1.6;
}
.ds-block ul{
  margin:8px 0 0;padding-left:18px;
  font-size:12.5px;color:rgba(255,255,255,.8);
  line-height:1.7;
}
.ds-block strong{color:#fff;font-weight:700}
.ds-disclaimer{
  margin:0;padding-top:14px;border-top:1px solid rgba(212,173,74,.18);
  font-size:11px;color:rgba(255,255,255,.55);font-style:italic;
}

/* ─── Enrollment Form Area ─── */
.enroll-wrap{
  display:grid;grid-template-columns:1fr 1.4fr;gap:28px;
  margin-bottom:36px;
  align-items:start;
}
.enroll-wrap .member-card-preview{
  position:sticky;top:90px;
}

.enroll-form-box{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  box-shadow:var(--shadow);
  overflow:hidden;
}
[data-theme="dark"] .enroll-form-box{background:var(--paper)}

.enroll-tabs{
  display:flex;gap:0;
  background:var(--cream);
  border-bottom:1px solid var(--border);
}
[data-theme="dark"] .enroll-tabs{background:var(--cream-soft)}
.enroll-tab{
  flex:1;padding:14px 12px;
  background:transparent;border:0;
  cursor:pointer;font:inherit;
  font-size:13px;font-weight:700;
  color:var(--muted);
  letter-spacing:.3px;
  transition:all .25s ease;
  border-bottom:3px solid transparent;
}
.enroll-tab:hover{color:var(--navy);background:rgba(212,173,74,.06)}
[data-theme="dark"] .enroll-tab:hover{color:var(--ink)}
.enroll-tab.active{
  color:var(--gold-deep);
  border-bottom-color:var(--gold);
  background:var(--paper);
}
[data-theme="dark"] .enroll-tab.active{color:var(--gold-soft);background:var(--paper)}

.enroll-form{display:none;padding:30px 32px;flex-direction:column;gap:18px}
.enroll-form.active{display:flex}
.enroll-intro{
  margin:0 0 4px;color:var(--muted);
  font-size:14px;line-height:1.65;
  padding:14px 16px;
  background:var(--cream);
  border-left:3px solid var(--gold);
  border-radius:8px;
}
[data-theme="dark"] .enroll-intro{background:var(--cream-soft)}
.enroll-intro strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .enroll-intro strong{color:var(--gold-soft)}

.enroll-form .form-row{
  display:grid;grid-template-columns:1fr 1fr;gap:14px;
}
.enroll-form label{
  display:flex;flex-direction:column;gap:6px;
}
.enroll-form label > span:first-child{
  font-size:12px;font-weight:700;
  color:var(--ink-soft);letter-spacing:.4px;
  text-transform:uppercase;
}
.enroll-form .req{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .enroll-form .req{color:var(--gold-soft)}
.enroll-form input[type=text],
.enroll-form input[type=email],
.enroll-form input[type=tel],
.enroll-form input[type=date],
.enroll-form select,
.enroll-form textarea{
  width:100%;
  border:1.5px solid var(--border);
  border-radius:10px;
  padding:12px 14px;
  background:var(--paper);
  color:var(--ink);
  font:inherit;font-size:14px;
  font-family:var(--sans);
  transition:border-color .2s,box-shadow .2s;
}
[data-theme="dark"] .enroll-form input,
[data-theme="dark"] .enroll-form select,
[data-theme="dark"] .enroll-form textarea{
  background:var(--cream-soft);
}
.enroll-form input:focus,
.enroll-form select:focus,
.enroll-form textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.enroll-form textarea{resize:vertical;min-height:80px;line-height:1.6}

.enroll-consent{
  display:flex;gap:10px;align-items:flex-start;
  font-size:12.5px;color:var(--ink-soft);line-height:1.55;
  padding:12px 14px;
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-radius:10px;
  cursor:pointer;
  transition:background .2s ease;
}
[data-theme="dark"] .enroll-consent{background:var(--cream-soft);color:var(--muted)}
.enroll-consent:hover{border-color:var(--gold)}
.enroll-consent input{margin-top:2px;flex-shrink:0;accent-color:var(--gold-deep)}
.enroll-consent strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .enroll-consent strong{color:var(--gold-soft)}

.btn.full{width:100%}

/* KEP info boxes */
.kep-check,.kep-process,.notary-process{
  background:linear-gradient(135deg,rgba(212,173,74,.06),rgba(212,173,74,.02));
  border:1px solid rgba(212,173,74,.22);
  border-radius:12px;
  padding:18px 22px;
}
[data-theme="dark"] .kep-check,
[data-theme="dark"] .kep-process,
[data-theme="dark"] .notary-process{
  background:linear-gradient(135deg,rgba(212,173,74,.1),rgba(212,173,74,.04));
}
.kep-check h4,.kep-process h4,.notary-process h4{
  color:var(--gold-deep);margin:0 0 10px;
  font-size:14px;font-weight:700;
  letter-spacing:.3px;
}
[data-theme="dark"] .kep-check h4,
[data-theme="dark"] .kep-process h4,
[data-theme="dark"] .notary-process h4{color:var(--gold-soft)}
.kep-check ol,.kep-process ol,.notary-process ol{
  margin:0;padding-left:22px;
  font-size:13px;color:var(--ink-soft);
  line-height:1.7;
}
[data-theme="dark"] .kep-check ol,
[data-theme="dark"] .kep-process ol,
[data-theme="dark"] .notary-process ol{color:var(--muted)}
.kep-check li,.kep-process li,.notary-process li{margin-bottom:5px}
.kep-check em{color:var(--gold-deep);font-style:normal;font-weight:600}
[data-theme="dark"] .kep-check em{color:var(--gold-soft)}
.kep-process strong,.notary-process strong{color:var(--navy);font-weight:700}
[data-theme="dark"] .kep-process strong,
[data-theme="dark"] .notary-process strong{color:var(--ink)}

/* Notary options */
.notary-options{
  display:grid;grid-template-columns:1fr 1fr;gap:14px;
  margin-bottom:8px;
}
.not-opt{
  background:var(--cream);
  border:1px solid var(--border);
  border-radius:12px;
  padding:18px 20px;
}
[data-theme="dark"] .not-opt{background:var(--cream-soft)}
.not-opt h4{
  color:var(--navy);margin:0 0 8px;
  font-size:14px;font-weight:700;
}
[data-theme="dark"] .not-opt h4{color:var(--ink)}
.not-opt p{
  margin:0 0 10px;font-size:12.5px;color:var(--muted);
  line-height:1.6;
}
.not-opt strong{color:var(--gold-deep)}
[data-theme="dark"] .not-opt strong{color:var(--gold-soft)}
.not-link{
  font-size:11.5px;color:var(--gold-deep);
  font-weight:700;letter-spacing:.3px;
  text-decoration:none;
  display:inline-block;
}
[data-theme="dark"] .not-link{color:var(--gold-soft)}
.not-link:hover{text-decoration:underline}

/* ═══════════════════════════════════════════════════════════
   LANGUAGE SWITCHER · i18n
   ═══════════════════════════════════════════════════════════ */

.lang-switcher{
  display:flex;
  align-items:center;
  gap:2px;
  margin-right:4px;
  flex-shrink:0;
}
.lang-btn{
  display:flex;
  align-items:center;
  gap:4px;
  padding:5px 10px;
  border-radius:8px;
  border:1.5px solid transparent;
  background:transparent;
  color:var(--slate);
  font-family:var(--sans);
  font-size:12px;
  font-weight:700;
  cursor:pointer;
  transition:all .25s ease;
  white-space:nowrap;
}
.lang-btn:hover{
  background:rgba(212,173,74,.1);
  border-color:rgba(212,173,74,.3);
  color:var(--navy);
}
.lang-btn.active{
  background:var(--navy);
  color:var(--gold-soft);
  border-color:var(--navy);
  box-shadow:0 2px 8px rgba(8,26,51,.25);
}
.lang-flag{
  font-size:16px;
  line-height:1;
}
.lang-label{
  font-size:11px;
  letter-spacing:.5px;
}

/* Multi-language inline blocks — use data-lang-content (not data-lang)
   to avoid conflict with the language switcher buttons */
html[data-lang="mk"] [data-lang-content]:not([data-lang-content="mk"]),
html[data-lang="en"] [data-lang-content]:not([data-lang-content="en"]),
html[data-lang="al"] [data-lang-content]:not([data-lang-content="al"]),
html[data-lang="sr"] [data-lang-content]:not([data-lang-content="sr"]),
html[data-lang="de"] [data-lang-content]:not([data-lang-content="de"]){
  display:none !important;
}

/* Language labels hidden on smaller desktops to save nav space */
@media (max-width: 1100px){
  .lang-label{display:none}
}

/* Mobile: language switcher */
@media (max-width: 768px){
  .lang-switcher{
    margin-right:2px;
  }
  .lang-btn{
    padding:4px 6px;
  }
}

/* ═══════════════════════════════════════════════════════════
   MONTHLY MAGAZINE · WORLD POLITICAL PARTIES NEWS
   ═══════════════════════════════════════════════════════════ */

/* Month navigation */
.mag-nav{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:36px;
  justify-content:center;
}
.mag-month-btn{
  padding:10px 22px;
  border-radius:100px;
  border:1.5px solid var(--line);
  background:var(--cream-soft);
  color:var(--slate);
  font-family:var(--sans);
  font-size:13px;
  font-weight:600;
  cursor:pointer;
  transition:all .25s ease;
  white-space:nowrap;
}
.mag-month-btn:hover{
  border-color:var(--gold-soft);
  color:var(--navy);
}
.mag-month-btn.active{
  background:var(--navy);
  color:var(--gold-soft);
  border-color:var(--navy);
  box-shadow:0 4px 14px rgba(8,26,51,.25);
}

/* Featured article */
.mag-featured{
  display:grid;
  grid-template-columns: 280px 1fr;
  gap:32px;
  background:var(--cream);
  border:1px solid var(--line);
  border-radius:var(--radius-lg);
  overflow:hidden;
  margin-bottom:40px;
  box-shadow:var(--shadow);
  transition:transform .3s ease,box-shadow .3s ease;
}
.mag-featured:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow-lg);
}
.mag-feat-img{
  min-height:240px;
  border-radius:var(--radius-lg) 0 0 var(--radius-lg);
}
.mag-feat-content{
  padding:32px 32px 32px 0;
  display:flex;
  flex-direction:column;
  justify-content:center;
}
.mag-feat-label{
  display:inline-block;
  padding:6px 14px;
  background:var(--gold);
  color:var(--navy-deep);
  font-size:11px;
  font-weight:700;
  letter-spacing:1.5px;
  text-transform:uppercase;
  border-radius:100px;
  margin-bottom:16px;
  align-self:flex-start;
}
.mag-feat-content h3{
  font-family:var(--serif);
  font-size:22px;
  color:var(--navy);
  margin:0 0 12px;
  line-height:1.3;
}
.mag-feat-content p{
  font-size:14px;
  color:var(--slate);
  line-height:1.7;
  margin:0 0 18px;
}
.mag-feat-meta{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
  font-size:12px;
  color:var(--slate);
  font-weight:500;
}
.mag-feat-meta span{
  display:flex;
  align-items:center;
  gap:4px;
}

/* News grid */
.mag-grid{
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:24px;
  margin-bottom:40px;
}
.mag-card{
  background:var(--cream);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:24px;
  transition:all .3s cubic-bezier(.4,0,.2,1);
  position:relative;
  overflow:hidden;
}
.mag-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow-lg);
  border-color:rgba(212,173,74,.3);
}
.mag-card.mks-highlight{
  border:2px solid var(--gold);
  background:linear-gradient(135deg,var(--cream),rgba(212,173,74,.04));
}
.mag-card.mks-highlight::before{
  content:"";
  position:absolute;
  top:0;left:0;right:0;
  height:3px;
  background:linear-gradient(90deg,var(--gold),var(--gold-deep));
}
.mag-card-header{
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:14px;
}
.mag-flag{
  font-size:28px;
  line-height:1;
  flex-shrink:0;
}
.mag-card-meta{
  flex:1;
  min-width:0;
}
.mag-card-meta strong{
  display:block;
  font-family:var(--serif);
  font-size:14px;
  color:var(--navy);
  margin-bottom:2px;
}
.mag-card-meta span{
  font-size:11px;
  color:var(--slate);
  font-weight:500;
}
.mag-date{
  font-size:11px;
  color:var(--slate);
  font-weight:600;
  white-space:nowrap;
  background:var(--cream-soft);
  padding:4px 10px;
  border-radius:100px;
}
.mag-card h4{
  font-family:var(--serif);
  font-size:16px;
  color:var(--navy);
  margin:0 0 10px;
  line-height:1.35;
}
.mag-card > p{
  font-size:13px;
  color:var(--slate);
  line-height:1.65;
  margin:0 0 16px;
}
.mag-card-tags{
  display:flex;
  flex-wrap:wrap;
  gap:6px;
}
.mag-tag{
  padding:4px 10px;
  background:rgba(212,173,74,.1);
  color:var(--navy);
  font-size:11px;
  font-weight:600;
  border-radius:100px;
  border:1px solid rgba(212,173,74,.2);
}

/* Magazine footer */
.mag-footer{
  text-align:center;
  padding:24px;
  background:var(--cream-soft);
  border-radius:var(--radius);
  border:1px solid var(--line);
  font-size:14px;
  color:var(--slate);
}

/* Magazine Live Feed (V16) */
.mag-livefeed{
  background:linear-gradient(135deg,var(--paper),var(--cream-soft));
  border:1px solid var(--line);
  border-left:4px solid #ef4444;
  border-radius:var(--radius);
  padding:28px 32px;
  margin:32px 0;
}
.mag-livefeed-head{
  display:flex;align-items:center;gap:10px;
  margin-bottom:18px;padding-bottom:14px;
  border-bottom:1px solid var(--line);
}
.mag-livefeed-head h3{
  margin:0;flex:1;font-family:var(--serif);
  font-size:20px;color:var(--navy);font-weight:600;
}
.mag-live-dot{
  width:10px;height:10px;border-radius:50%;
  background:#ef4444;
  animation:pulse 1.5s ease-in-out infinite;
}
@keyframes pulse{
  0%,100%{transform:scale(1);opacity:1}
  50%{transform:scale(1.3);opacity:0.7}
}
.mag-live-label{
  font-size:11px;font-weight:700;
  color:#ef4444;letter-spacing:1.4px;
  text-transform:uppercase;
}
.mag-articles{display:flex;flex-direction:column;gap:14px}
.mag-article{
  display:flex;gap:14px;padding:14px;
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:12px;
  transition:all .25s ease;
}
.mag-article:hover{
  transform:translateX(4px);
  border-color:#ef4444;
  box-shadow:var(--shadow-sm);
}
.mag-flag{
  font-size:32px;line-height:1;
  width:48px;flex-shrink:0;text-align:center;
}
.mag-body{flex:1;min-width:0}
.mag-meta{
  display:flex;justify-content:space-between;
  margin-bottom:6px;font-size:11px;
  color:var(--muted);font-weight:600;
  letter-spacing:.3px;
}
.mag-country{color:var(--gold-deep);text-transform:uppercase}
[data-theme="dark"] .mag-country{color:var(--gold-soft)}
.mag-date{font-family:var(--mono);font-size:10.5px}
.mag-title{
  margin:0 0 6px;font-size:14.5px;font-weight:600;
  color:var(--navy);line-height:1.4;
  font-family:var(--serif);
}
[data-theme="dark"] .mag-title{color:var(--ink)}
.mag-snippet{
  margin:0;font-size:12.5px;
  color:var(--muted);line-height:1.55;
}
@media(max-width:920px){
  .mag-livefeed{padding:20px}
  .mag-article{padding:12px}
  .mag-flag{font-size:24px;width:36px}
}

/* Mobile: magazine */
@media (max-width: 768px){
  .mag-featured{
    grid-template-columns:1fr;
  }
  .mag-feat-img{
    min-height:160px;
    border-radius:var(--radius-lg) var(--radius-lg) 0 0;
  }
  .mag-feat-content{
    padding:24px;
  }
  .mag-grid{
    grid-template-columns:1fr;
  }
  .mag-nav{
    gap:8px;
  }
  .mag-month-btn{
    font-size:12px;
    padding:8px 16px;
  }
}

/* Card tier badge */
.mc-tier-badge{
  display:inline-block;
  background:var(--gold);color:var(--navy-deep);
  padding:2px 10px;border-radius:999px;
  font-size:11px;font-weight:700;letter-spacing:.5px;
  font-family:var(--mono);
}

/* Legal foundation grid */
.legal-foundation{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  padding:30px 32px;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .legal-foundation{background:var(--paper)}
.legal-foundation h3{
  margin:0 0 18px;font-size:18px;font-weight:600;
  color:var(--navy);
}
[data-theme="dark"] .legal-foundation h3{color:var(--ink)}
.lf-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:16px;
}
.lf-item{
  background:var(--cream);
  border-left:3px solid var(--gold);
  border-radius:10px;
  padding:14px 16px;
}
[data-theme="dark"] .lf-item{background:var(--cream-soft)}
.lf-item strong{
  display:block;font-family:var(--mono);
  color:var(--gold-deep);font-weight:700;
  font-size:12px;letter-spacing:1px;
  margin-bottom:6px;
}
[data-theme="dark"] .lf-item strong{color:var(--gold-soft)}
.lf-item p{
  margin:0;font-size:12px;color:var(--muted);
  line-height:1.55;
}

@media(max-width:1100px){
  .tier-selector{grid-template-columns:1fr;gap:14px}
  .tier-card.recommended{transform:none}
  .ds-grid{grid-template-columns:1fr}
  .enroll-wrap{grid-template-columns:1fr}
  .enroll-wrap .member-card-preview{position:static}
  .lf-grid{grid-template-columns:repeat(2,1fr)}
  .notary-options{grid-template-columns:1fr}
}
@media(max-width:920px){
  .enroll-form .form-row{grid-template-columns:1fr}
  .enroll-form{padding:22px}
  .enroll-tab{font-size:11.5px;padding:12px 6px;letter-spacing:.2px}
  .ds-info{padding:24px}
  .legal-foundation{padding:22px}
  .lf-grid{grid-template-columns:1fr}
}

/* ─── Donations ─── */
.don-tiers{
  display:grid;grid-template-columns:repeat(4,1fr);gap:14px;
  margin-bottom:30px;
}
.don-tier{
  background:var(--paper);
  border:2px solid var(--border);
  border-radius:16px;
  padding:24px 20px;
  text-align:center;
  cursor:pointer;
  transition:all .3s ease;
  position:relative;
}
[data-theme="dark"] .don-tier{background:var(--paper)}
.don-tier:hover{
  transform:translateY(-4px);
  border-color:var(--gold);
  box-shadow:var(--shadow);
}
.don-tier.active{
  border-color:var(--gold);
  background:linear-gradient(135deg,rgba(212,173,74,.12),rgba(212,173,74,.04));
  box-shadow:0 8px 22px rgba(212,173,74,.22);
}
.don-tier.recommended{
  border-color:var(--gold);
  background:linear-gradient(135deg,rgba(212,173,74,.08),transparent);
}
.don-badge{
  position:absolute;top:-12px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  padding:5px 14px;border-radius:999px;
  font-size:10.5px;font-weight:700;letter-spacing:1.5px;
  text-transform:uppercase;
  box-shadow:0 4px 12px rgba(212,173,74,.4);
  white-space:nowrap;
}
.don-emoji{font-size:36px;line-height:1;margin-bottom:8px}
.don-amount{
  font-family:var(--serif);font-size:24px;
  color:var(--navy);font-weight:600;
  letter-spacing:-.005em;margin-bottom:4px;
}
[data-theme="dark"] .don-amount{color:var(--ink)}
.don-label{
  font-size:11px;font-weight:700;
  color:var(--gold-deep);letter-spacing:1.4px;
  text-transform:uppercase;margin-bottom:10px;
}
[data-theme="dark"] .don-label{color:var(--gold-soft)}
.don-desc{
  margin:0;font-size:12px;color:var(--muted);
  line-height:1.55;
}

.don-custom-wrap{
  margin-bottom:20px;padding:18px 22px;
  background:var(--cream);
  border:1.5px solid var(--gold);
  border-radius:12px;
}
[data-theme="dark"] .don-custom-wrap{background:var(--cream-soft)}
.don-custom-wrap label{display:flex;flex-direction:column;gap:8px}
.don-custom-wrap label span{
  font-size:13px;font-weight:700;
  color:var(--navy);
}
[data-theme="dark"] .don-custom-wrap label span{color:var(--ink)}
.don-custom-wrap input{
  border:1.5px solid var(--border);border-radius:8px;
  padding:12px 14px;font:inherit;font-size:16px;
  background:var(--paper);color:var(--ink);
}

.don-section-title{
  font-size:18px;font-weight:600;
  color:var(--navy);margin:30px 0 18px;
  font-family:var(--serif);text-align:center;
  letter-spacing:-.005em;
}
[data-theme="dark"] .don-section-title{color:var(--ink)}

/* Payment platform buttons */
.don-platforms{
  display:grid;grid-template-columns:repeat(4,1fr);gap:12px;
  margin-bottom:30px;
}
.don-platform{
  background:var(--paper);
  border:2px solid var(--border);
  border-radius:14px;
  padding:20px 16px;
  text-align:center;
  cursor:pointer;
  transition:all .3s ease;
  display:flex;flex-direction:column;align-items:center;gap:6px;
  font:inherit;
  color:inherit;
}
[data-theme="dark"] .don-platform{background:var(--paper);color:var(--ink)}
.don-platform:not(:disabled):hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow);
}
.don-platform:disabled{
  opacity:0.45;cursor:not-allowed;
  filter:grayscale(0.5);
}
.don-platform.stripe:not(:disabled):hover{border-color:#635bff}
.don-platform.paypal:not(:disabled):hover{border-color:#003087}
.don-platform.visa:not(:disabled):hover{border-color:#1A1F71}
.don-platform.mastercard:not(:disabled):hover{border-color:#EB001B}
.don-platform.active{border-color:var(--gold);background:linear-gradient(135deg,rgba(212,173,74,.1),transparent)}
.dp-logo{
  width:56px;height:28px;
  display:grid;place-items:center;
  margin-bottom:4px;
}
.don-platform strong{font-size:14px;font-weight:700;color:var(--navy)}
[data-theme="dark"] .don-platform strong{color:var(--ink)}
.don-platform small{font-size:11px;color:var(--muted);font-weight:500}

/* Donor info form */
.don-info-form{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  padding:30px 32px;
  margin-bottom:30px;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .don-info-form{background:var(--paper)}
.don-info-form h3{
  margin:0 0 10px;font-size:20px;font-weight:600;
  color:var(--navy);
}
[data-theme="dark"] .don-info-form h3{color:var(--ink)}
.don-info-lede{
  margin:0 0 18px;color:var(--muted);
  font-size:13.5px;line-height:1.65;
  padding:12px 14px;
  background:var(--cream);
  border-left:3px solid var(--gold);
  border-radius:8px;
}
[data-theme="dark"] .don-info-lede{background:var(--cream-soft)}
.don-info-lede strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .don-info-lede strong{color:var(--gold-soft)}

.don-form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.don-info-form label{
  display:flex;flex-direction:column;gap:6px;margin-bottom:14px;
}
.don-info-form label > span:first-child{
  font-size:12px;font-weight:700;
  color:var(--ink-soft);letter-spacing:.4px;
  text-transform:uppercase;
}
.don-info-form .req{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .don-info-form .req{color:var(--gold-soft)}
.don-info-form input,.don-info-form textarea{
  border:1.5px solid var(--border);border-radius:10px;
  padding:11px 14px;font:inherit;font-size:14px;
  background:var(--paper);color:var(--ink);
  transition:border-color .2s ease;
}
[data-theme="dark"] .don-info-form input,
[data-theme="dark"] .don-info-form textarea{background:var(--cream-soft)}
.don-info-form input:focus,.don-info-form textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}

.don-anon,.don-consent{
  display:flex;gap:10px;align-items:flex-start;
  font-size:12.5px;color:var(--ink-soft);line-height:1.55;
  padding:12px 14px;
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-radius:10px;
  cursor:pointer;
  margin-bottom:14px;
}
[data-theme="dark"] .don-anon,
[data-theme="dark"] .don-consent{background:var(--cream-soft);color:var(--muted)}
.don-anon input,.don-consent input{
  margin-top:2px;flex-shrink:0;
  accent-color:var(--gold-deep);
}
.don-anon strong,.don-consent strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .don-anon strong,
[data-theme="dark"] .don-consent strong{color:var(--gold-soft)}

/* Transparency grid */
.don-transparency{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;border-radius:18px;
  padding:30px;margin-bottom:24px;
  border:1px solid rgba(212,173,74,.22);
}
.don-transparency h3{
  color:#fff;margin:0 0 18px;font-size:20px;font-weight:600;
}
.don-trans-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:14px;
}
.don-trans-item{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.22);
  border-radius:12px;
  padding:18px 16px;
}
.dt-icon{font-size:24px;display:block;margin-bottom:8px}
.don-trans-item strong{
  display:block;color:var(--gold-soft);
  font-size:13px;font-weight:700;
  letter-spacing:.4px;margin-bottom:6px;
}
.don-trans-item p{
  margin:0;font-size:12px;
  color:rgba(255,255,255,.78);line-height:1.55;
}

@media(max-width:1100px){
  .don-tiers{grid-template-columns:repeat(2,1fr)}
  .don-platforms{grid-template-columns:repeat(2,1fr)}
  .don-trans-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:920px){
  .don-tiers{grid-template-columns:1fr}
  .don-platforms{grid-template-columns:1fr}
  .don-trans-grid{grid-template-columns:1fr}
  .don-form-row{grid-template-columns:1fr}
  .don-info-form{padding:22px}
  .don-transparency{padding:22px}
}

/* ─── Election Context (DIK official data) ─── */
.ec-stats{
  display:grid;grid-template-columns:repeat(4,1fr);gap:16px;
  margin-bottom:36px;
}
.ec-stat{
  background:linear-gradient(160deg,var(--paper),var(--cream-soft));
  border:1px solid var(--border);
  border-top:4px solid var(--gold);
  border-radius:16px;
  padding:22px;
  text-align:center;
  transition:all .3s ease;
  position:relative;
}
[data-theme="dark"] .ec-stat{background:linear-gradient(160deg,var(--paper),var(--cream-soft))}
.ec-stat:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-top-color:var(--navy)}
.ec-icon{
  font-size:30px;display:block;margin-bottom:8px;
  line-height:1;
}
.ec-num{
  font-family:var(--serif);font-size:32px;font-weight:600;
  color:var(--navy);line-height:1;
  letter-spacing:-.02em;margin-bottom:6px;
}
[data-theme="dark"] .ec-num{color:var(--gold-soft)}
.ec-label{
  font-size:13px;font-weight:700;
  color:var(--ink-soft);letter-spacing:.4px;
  margin-bottom:6px;
}
[data-theme="dark"] .ec-label{color:var(--ink)}
.ec-source{
  font-size:10.5px;color:var(--muted);
  font-style:italic;
  font-family:var(--mono);letter-spacing:.3px;
}

/* Threshold meter */
.ec-threshold{
  background:var(--paper);
  border:1px solid var(--border);
  border-left:4px solid var(--gold);
  border-radius:16px;
  padding:28px 32px;
  margin-bottom:36px;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .ec-threshold{background:var(--paper)}
.ec-threshold h3{
  margin:0 0 12px;font-size:20px;font-weight:600;
  color:var(--navy);
}
[data-theme="dark"] .ec-threshold h3{color:var(--ink)}
.ec-thresh-lede{
  margin:0 0 18px;color:var(--muted);
  font-size:14px;line-height:1.7;
}
.ec-thresh-lede strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .ec-thresh-lede strong{color:var(--gold-soft)}
.ec-meter{display:flex;flex-direction:column;gap:10px}
.ec-meter-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:12px 16px;
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-radius:10px;
  flex-wrap:wrap;gap:8px;
}
[data-theme="dark"] .ec-meter-row{background:var(--cream-soft)}
.ec-meter-label{font-size:13px;color:var(--ink-soft);font-weight:600;flex:1;min-width:200px}
[data-theme="dark"] .ec-meter-label{color:var(--muted)}
.ec-meter-val{
  font-family:var(--mono);font-size:14px;font-weight:700;
  color:var(--gold-deep);letter-spacing:.3px;
  background:rgba(212,173,74,.12);
  padding:4px 12px;border-radius:8px;
  white-space:nowrap;
}
[data-theme="dark"] .ec-meter-val{color:var(--gold-soft)}

/* Links grid */
.ec-links-title{
  font-size:20px;font-weight:600;
  color:var(--navy);margin:0 0 18px;
  font-family:var(--serif);letter-spacing:-.005em;
  text-align:center;
}
[data-theme="dark"] .ec-links-title{color:var(--ink)}
.ec-links-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:12px;
  margin-bottom:36px;
}
.ec-link{
  display:flex;align-items:center;gap:12px;
  padding:14px 16px;
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:12px;
  text-decoration:none;
  color:inherit;
  transition:all .25s ease;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .ec-link{background:var(--paper)}
.ec-link:hover{
  transform:translateY(-3px);
  border-color:var(--gold);
  box-shadow:var(--shadow);
}
.ec-link-icon{
  font-size:24px;line-height:1;
  flex-shrink:0;
}
.ec-link-body strong{
  display:block;font-size:13px;font-weight:700;
  color:var(--navy);margin-bottom:3px;
  letter-spacing:.2px;
}
[data-theme="dark"] .ec-link-body strong{color:var(--gold-soft)}
.ec-link-body p{
  margin:0;font-size:11.5px;color:var(--muted);
  line-height:1.4;
}

/* Voter rights */
.ec-rights{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  border-radius:18px;
  padding:32px;
  margin-bottom:24px;
  box-shadow:var(--shadow);
  border:1px solid rgba(212,173,74,.22);
}
.ec-rights h3{
  color:#fff;margin:0 0 18px;font-size:20px;font-weight:600;
}
.ec-rights-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:12px;
}
.ec-right{
  display:flex;gap:12px;align-items:flex-start;
  padding:12px 14px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(212,173,74,.18);
  border-radius:10px;
}
.ec-r-icon{
  width:28px;height:28px;border-radius:50%;
  display:grid;place-items:center;
  flex-shrink:0;
  font-size:14px;font-weight:700;
}
.ec-right:has(.ec-r-icon:contains("✓")) .ec-r-icon,
.ec-right .ec-r-icon{
  background:rgba(95,206,126,.2);color:#7ce097;
}
.ec-right p{
  margin:0;font-size:13px;color:rgba(255,255,255,.85);
  line-height:1.55;
}
.ec-right p strong{color:var(--gold-soft);font-weight:700}

/* Disclaimer */
.ec-disclaimer{
  background:var(--cream);
  border:1px dashed var(--border);
  border-radius:10px;
  padding:14px 18px;
}
[data-theme="dark"] .ec-disclaimer{background:var(--cream-soft)}
.ec-disclaimer p{
  margin:0;font-size:12px;color:var(--muted);
  line-height:1.6;font-style:italic;
}

@media(max-width:1100px){
  .ec-stats{grid-template-columns:repeat(2,1fr)}
  .ec-links-grid{grid-template-columns:repeat(2,1fr)}
  .ec-rights-grid{grid-template-columns:1fr}
}
@media(max-width:920px){
  .ec-stats{grid-template-columns:1fr}
  .ec-links-grid{grid-template-columns:1fr}
  .ec-threshold{padding:22px}
  .ec-rights{padding:22px}
}

/* ─── Institutional Framework ─── */
.if-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:18px;
  margin-bottom:32px;
}
.if-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  overflow:hidden;
  box-shadow:var(--shadow-sm);
  transition:all .35s ease;
  display:flex;flex-direction:column;
}
[data-theme="dark"] .if-card{background:var(--paper)}
.if-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}

.if-card-head{
  display:flex;gap:18px;align-items:flex-start;
  padding:22px 26px 16px;
  background:linear-gradient(135deg,var(--cream),var(--cream-soft));
  border-bottom:1px solid var(--border-soft);
}
[data-theme="dark"] .if-card-head{background:linear-gradient(135deg,var(--cream-soft),var(--paper))}

/* Color accent per institution */
.if-card.if-azlp .if-card-head{border-left:5px solid #4a90c2}
.if-card.if-nkrm .if-card-head{border-left:5px solid #d4ad4a}
.if-card.if-mba .if-card-head{border-left:5px solid #c2624a}
.if-card.if-mfa .if-card-head{border-left:5px solid #5fce7e}
.if-card.if-uslugi .if-card-head{border-left:5px solid #9b59b6}

.if-icon{
  font-size:32px;line-height:1;flex-shrink:0;
  width:54px;height:54px;
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:12px;
  display:grid;place-items:center;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .if-icon{background:var(--cream-soft)}

.if-meta{flex:1;min-width:0}
.if-tag{
  display:inline-block;font-size:10px;
  color:var(--gold-deep);font-weight:700;
  letter-spacing:1.4px;text-transform:uppercase;
  padding:3px 10px;border-radius:6px;
  background:rgba(212,173,74,.1);
  margin-bottom:8px;
}
[data-theme="dark"] .if-tag{color:var(--gold-soft);background:rgba(212,173,74,.15)}
.if-meta h3{
  margin:0 0 4px;font-size:24px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;
}
[data-theme="dark"] .if-meta h3{color:var(--ink)}
.if-fullname{
  margin:0;font-size:13px;
  color:var(--muted);font-style:italic;
  line-height:1.4;
}

.if-card-body{padding:18px 26px;flex:1}
.if-card-body p{
  margin:0 0 14px;font-size:13.5px;
  color:var(--ink-soft);line-height:1.65;
}
[data-theme="dark"] .if-card-body p{color:var(--muted)}

.if-services{
  background:var(--cream);
  border-left:3px solid var(--gold);
  border-radius:8px;
  padding:12px 16px;
}
[data-theme="dark"] .if-services{background:var(--cream-soft)}
.if-service-label{
  display:block;font-size:11px;font-weight:700;
  color:var(--gold-deep);
  letter-spacing:1px;text-transform:uppercase;
  margin-bottom:6px;
}
[data-theme="dark"] .if-service-label{color:var(--gold-soft)}
.if-services ul{
  margin:0;padding-left:18px;
  font-size:12.5px;color:var(--ink-soft);
  line-height:1.7;
}
[data-theme="dark"] .if-services ul{color:var(--muted)}
.if-services li{margin-bottom:3px}

.if-card-foot{
  padding:16px 26px;
  border-top:1px solid var(--border-soft);
  background:var(--cream);
  display:flex;flex-wrap:wrap;align-items:center;gap:8px;
}
[data-theme="dark"] .if-card-foot{background:var(--cream-soft)}

.if-link{
  font-size:11.5px;color:var(--ink-soft);
  text-decoration:none;font-weight:600;
  padding:5px 10px;
  border-radius:6px;
  background:var(--paper);
  border:1px solid var(--border);
  transition:all .2s ease;
}
[data-theme="dark"] .if-link{background:var(--paper);color:var(--muted)}
.if-link:hover{
  border-color:var(--gold);
  color:var(--gold-deep);
  transform:translateY(-1px);
}
[data-theme="dark"] .if-link:hover{color:var(--gold-soft)}
.if-link.primary{
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  border-color:var(--gold-deep);
}
.if-link.primary:hover{
  color:var(--navy-deep);
  filter:brightness(1.05);
}

.if-contact{
  margin-left:auto;font-size:11px;
  color:var(--muted);
  font-family:var(--mono);
  letter-spacing:.2px;
}

/* Privacy commitment box */
.if-privacy-box{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  border-radius:18px;
  padding:32px 36px;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow);
}
.if-privacy-box h3{
  color:#fff;margin:0 0 14px;
  font-size:22px;font-weight:600;
  letter-spacing:-.005em;
}
.if-privacy-box > p{
  margin:0 0 14px;
  color:rgba(255,255,255,.85);
  font-size:14px;line-height:1.65;
}
.if-privacy-box ul{
  margin:0 0 18px;padding-left:0;
  list-style:none;
  display:grid;grid-template-columns:repeat(2,1fr);gap:10px;
}
.if-privacy-box li{
  font-size:13px;line-height:1.55;
  color:rgba(255,255,255,.85);
  padding:10px 14px 10px 32px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(212,173,74,.18);
  border-radius:8px;
  position:relative;
}
.if-privacy-box li::before{
  content:"✓";
  position:absolute;left:10px;top:9px;
  width:16px;height:16px;
  background:var(--gold);color:var(--navy-deep);
  border-radius:50%;
  display:grid;place-items:center;
  font-size:10px;font-weight:700;
}
.if-privacy-box li strong{color:var(--gold-soft);font-weight:700}
.if-privacy-note{
  margin:0;padding-top:12px;
  border-top:1px solid rgba(212,173,74,.2);
  font-size:12px;color:rgba(255,255,255,.6);
}

@media(max-width:1100px){
  .if-grid{grid-template-columns:1fr}
  .if-privacy-box ul{grid-template-columns:1fr}
}
@media(max-width:920px){
  .if-card-head{flex-direction:column;gap:12px;padding:18px 20px}
  .if-card-body,.if-card-foot{padding:16px 20px}
  .if-privacy-box{padding:24px}
  .if-privacy-box h3{font-size:18px}
}

/* ─── World Parties Atlas ─── */
.wp-filters{
  display:flex;flex-wrap:wrap;gap:8px;
  margin-bottom:24px;
  justify-content:center;
}
.wp-filter{
  background:var(--paper);
  border:1.5px solid var(--border);
  border-radius:999px;
  padding:8px 16px;
  font:inherit;font-size:13px;font-weight:600;
  color:var(--ink-soft);
  cursor:pointer;
  transition:all .2s ease;
}
[data-theme="dark"] .wp-filter{background:var(--paper);color:var(--muted)}
.wp-filter:hover{border-color:var(--gold);color:var(--gold-deep)}
[data-theme="dark"] .wp-filter:hover{color:var(--gold-soft)}
.wp-filter.active{
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  border-color:var(--gold-deep);
  box-shadow:0 4px 12px rgba(212,173,74,.25);
}

/* Continents row */
.wp-continents{
  display:grid;grid-template-columns:repeat(6,1fr);gap:12px;
  margin-bottom:30px;
}
.wp-cont{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px 12px;
  text-align:center;
  display:flex;flex-direction:column;gap:4px;
  align-items:center;
  transition:all .2s ease;
}
[data-theme="dark"] .wp-cont{background:var(--paper)}
.wp-cont:hover{border-color:var(--gold);transform:translateY(-2px)}
.wp-cont.mks-highlight{
  border:2px solid var(--gold);
  background:linear-gradient(135deg,rgba(212,173,74,.12),rgba(212,173,74,.04));
}
[data-theme="dark"] .wp-cont.mks-highlight{
  background:linear-gradient(135deg,rgba(212,173,74,.18),rgba(212,173,74,.06));
}
.wp-cont-flag{font-size:24px;line-height:1}
.wp-cont strong{
  font-size:13px;font-weight:700;color:var(--navy);
  letter-spacing:.2px;
}
[data-theme="dark"] .wp-cont strong{color:var(--ink)}
.wp-cont span{font-size:11px;color:var(--muted);font-weight:600}

/* Parties grid */
.wp-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:14px;
  margin-bottom:30px;
}
.wp-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:14px;
  padding:18px;
  display:flex;gap:14px;align-items:flex-start;
  box-shadow:var(--shadow-sm);
  transition:all .25s ease;
  position:relative;
}
[data-theme="dark"] .wp-card{background:var(--paper)}
.wp-card:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}
.wp-card.highlighted{
  border:2px solid var(--gold);
  background:linear-gradient(135deg,rgba(212,173,74,.08),var(--paper));
  box-shadow:0 6px 20px rgba(212,173,74,.18);
}
[data-theme="dark"] .wp-card.highlighted{
  background:linear-gradient(135deg,rgba(212,173,74,.12),var(--paper));
}
.wp-card.hidden{display:none}

.wp-flag{
  font-size:34px;line-height:1;flex-shrink:0;
  width:48px;text-align:center;
}
.wp-info{flex:1;min-width:0}
.wp-info strong{
  display:block;font-size:14.5px;font-weight:700;
  color:var(--navy);margin-bottom:2px;
  letter-spacing:.1px;line-height:1.3;
}
[data-theme="dark"] .wp-info strong{color:var(--ink)}
.wp-country{
  display:block;font-size:11px;
  color:var(--gold-deep);font-weight:600;
  letter-spacing:1px;text-transform:uppercase;
  margin-bottom:6px;
}
[data-theme="dark"] .wp-country{color:var(--gold-soft)}
.wp-info p{
  margin:0 0 8px;font-size:12px;color:var(--muted);
  line-height:1.5;
}

.wp-block{
  display:inline-block;font-size:10px;
  padding:3px 10px;border-radius:5px;
  font-weight:700;letter-spacing:.4px;
  text-transform:uppercase;
}
.wp-block.cr{background:rgba(58,123,200,.15);color:#2a5e9c}
.wp-block.cl{background:rgba(230,50,28,.15);color:#a3220f}
.wp-block.li{background:rgba(212,173,74,.15);color:var(--gold-deep)}
.wp-block.gr{background:rgba(95,206,126,.15);color:#2d6e3d}
.wp-block.co{background:rgba(155,89,182,.15);color:#7d469f}
.wp-block.me{background:linear-gradient(135deg,rgba(212,173,74,.2),rgba(212,173,74,.1));color:var(--gold-deep)}

[data-theme="dark"] .wp-block.cr{background:rgba(58,123,200,.25);color:#7eb0e0}
[data-theme="dark"] .wp-block.cl{background:rgba(230,50,28,.25);color:#ff7058}
[data-theme="dark"] .wp-block.li{background:rgba(212,173,74,.25);color:var(--gold-soft)}
[data-theme="dark"] .wp-block.gr{background:rgba(95,206,126,.25);color:#7ce097}
[data-theme="dark"] .wp-block.co{background:rgba(155,89,182,.25);color:#c89bd6}
[data-theme="dark"] .wp-block.me{color:var(--gold-soft)}

.wp-empty{
  text-align:center;padding:40px;
  color:var(--muted);
  font-size:14px;font-style:italic;
}

/* Position spectrum */
.wp-position{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;border-radius:18px;
  padding:32px 36px;
  margin-top:30px;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow);
}
.wp-position h3{
  color:#fff;margin:0 0 14px;font-size:20px;font-weight:600;
}
.wp-position-lede{
  margin:0 0 24px;color:rgba(255,255,255,.85);
  font-size:14px;line-height:1.7;
}
.wp-position-lede strong{color:var(--gold-soft);font-weight:700}

.wp-spectrum{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(212,173,74,.22);
  border-radius:12px;
  padding:24px;
}
.wp-spec-axis{
  display:flex;align-items:center;gap:14px;
  margin-bottom:16px;
}
.wp-spec-label{
  font-size:12px;font-weight:700;
  color:rgba(255,255,255,.7);
  white-space:nowrap;letter-spacing:.4px;
  flex-shrink:0;
}
.wp-spec-line{
  flex:1;height:8px;
  background:linear-gradient(90deg,#e6321c 0%,rgba(255,255,255,.2) 50%,#3a7bc8 100%);
  border-radius:999px;
  position:relative;
}
.wp-spec-marker{
  position:absolute;top:50%;transform:translate(-50%,-50%);
  background:var(--paper);color:var(--navy-deep);
  padding:5px 10px;border-radius:8px;
  font-size:11px;font-weight:700;
  white-space:nowrap;
  border:1px solid var(--border);
  box-shadow:0 4px 10px rgba(0,0,0,.18);
}
.wp-spec-marker.traditional{
  background:rgba(255,255,255,.15);
  color:rgba(255,255,255,.85);
  border:1px solid rgba(255,255,255,.25);
  font-size:10px;
  padding:3px 8px;
}
.wp-spec-marker.mks{
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  font-weight:800;
  border:2px solid #fff;
  z-index:2;
  padding:6px 12px;
  font-size:12px;
  box-shadow:0 6px 14px rgba(212,173,74,.5);
}
.wp-spec-note{
  margin:0;font-size:12px;color:rgba(255,255,255,.65);
  font-style:italic;line-height:1.6;
}
.wp-spec-note strong{color:var(--gold-soft);font-style:normal}

@media(max-width:1100px){
  .wp-grid{grid-template-columns:repeat(2,1fr)}
  .wp-continents{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:920px){
  .wp-grid{grid-template-columns:1fr}
  .wp-continents{grid-template-columns:repeat(2,1fr)}
  .wp-spec-axis{flex-direction:column;gap:8px}
  .wp-spec-line{width:100%}
  .wp-position{padding:22px}
}

/* ─── Analytical Center / SWOT ─── */
.ac-scorecard{
  display:grid;grid-template-columns:1fr 1.5fr;gap:24px;
  margin-bottom:36px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;border-radius:22px;
  padding:36px 40px;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow-lg);
  align-items:center;
}
.ac-score{
  display:flex;flex-direction:column;align-items:center;
  text-align:center;
  padding:20px;
  background:rgba(212,173,74,.1);
  border:1px solid rgba(212,173,74,.3);
  border-radius:18px;
}
.ac-score-num{
  font-family:var(--serif);font-size:96px;font-weight:600;
  color:var(--gold-soft);line-height:1;
  letter-spacing:-.04em;
  text-shadow:0 4px 24px rgba(212,173,74,.3);
}
.ac-score-max{
  font-family:var(--mono);font-size:18px;
  color:rgba(255,255,255,.6);font-weight:600;
  margin-top:-10px;margin-bottom:14px;
}
.ac-score-label{
  font-size:13px;font-weight:700;
  color:#fff;letter-spacing:1.6px;
  text-transform:uppercase;margin-bottom:8px;
}
.ac-score-trend{
  font-size:12px;color:#5fce7e;font-weight:700;
  font-family:var(--mono);
}
.ac-meta{
  display:grid;grid-template-columns:1fr 1fr;gap:14px;
}
.ac-meta-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:12px 16px;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(212,173,74,.15);
  border-radius:10px;
  font-size:12.5px;
}
.ac-meta-row span{color:rgba(255,255,255,.7)}
.ac-meta-row strong{color:var(--gold-soft);font-weight:700}

.ac-section-title{
  font-size:22px;font-weight:600;
  color:var(--navy);margin:40px 0 22px;
  font-family:var(--serif);
  letter-spacing:-.005em;text-align:center;
}
[data-theme="dark"] .ac-section-title{color:var(--ink)}

/* SWOT 2x2 grid */
.swot-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:18px;
  margin-bottom:40px;
}
.swot-quad{
  border-radius:18px;
  padding:24px;
  border:2px solid var(--border);
  background:var(--paper);
}
[data-theme="dark"] .swot-quad{background:var(--paper)}
.swot-quad.strengths{border-color:#5fce7e;background:linear-gradient(135deg,rgba(95,206,126,.04),var(--paper))}
.swot-quad.weaknesses{border-color:#e6321c;background:linear-gradient(135deg,rgba(230,50,28,.04),var(--paper))}
.swot-quad.opportunities{border-color:#3a7bc8;background:linear-gradient(135deg,rgba(58,123,200,.04),var(--paper))}
.swot-quad.threats{border-color:#a8861f;background:linear-gradient(135deg,rgba(168,134,31,.04),var(--paper))}
[data-theme="dark"] .swot-quad.strengths{background:linear-gradient(135deg,rgba(95,206,126,.08),var(--paper))}
[data-theme="dark"] .swot-quad.weaknesses{background:linear-gradient(135deg,rgba(230,50,28,.08),var(--paper))}
[data-theme="dark"] .swot-quad.opportunities{background:linear-gradient(135deg,rgba(58,123,200,.08),var(--paper))}
[data-theme="dark"] .swot-quad.threats{background:linear-gradient(135deg,rgba(168,134,31,.08),var(--paper))}

.swot-head{
  display:flex;align-items:center;gap:12px;
  margin-bottom:16px;padding-bottom:14px;
  border-bottom:1px solid var(--border-soft);
}
.swot-icon{font-size:28px;line-height:1}
.swot-head h4{
  margin:0;font-size:18px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  flex:1;letter-spacing:-.005em;
}
[data-theme="dark"] .swot-head h4{color:var(--ink)}
.swot-count{
  background:var(--cream);border:1px solid var(--border);
  border-radius:999px;padding:3px 12px;
  font-size:12px;font-weight:700;
  color:var(--gold-deep);font-family:var(--mono);
}
[data-theme="dark"] .swot-count{background:var(--cream-soft);color:var(--gold-soft)}

.swot-body{
  display:flex;flex-direction:column;gap:10px;
  max-height:520px;overflow-y:auto;
  padding-right:6px;
}
.swot-body::-webkit-scrollbar{width:5px}
.swot-body::-webkit-scrollbar-thumb{background:rgba(212,173,74,.3);border-radius:3px}

.swot-item{
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-radius:10px;
  padding:12px 14px;
  position:relative;
  transition:all .2s ease;
}
[data-theme="dark"] .swot-item{background:var(--cream-soft)}
.swot-item:hover{
  transform:translateX(3px);
  border-color:var(--gold);
}
.swot-rank{
  display:inline-block;
  font-family:var(--mono);font-size:10.5px;
  background:rgba(212,173,74,.15);
  color:var(--gold-deep);font-weight:700;
  padding:2px 8px;border-radius:5px;
  margin-bottom:6px;letter-spacing:.4px;
}
[data-theme="dark"] .swot-rank{background:rgba(212,173,74,.2);color:var(--gold-soft)}
.swot-rank.high{background:rgba(95,206,126,.15);color:#3a8550}
.swot-rank.critical{background:rgba(230,50,28,.15);color:#c52810}
[data-theme="dark"] .swot-rank.high{background:rgba(95,206,126,.2);color:#7ce097}
[data-theme="dark"] .swot-rank.critical{background:rgba(230,50,28,.2);color:#ff7058}

.swot-item strong{
  display:block;font-size:13.5px;font-weight:700;
  color:var(--navy);margin-bottom:4px;
  line-height:1.35;
}
[data-theme="dark"] .swot-item strong{color:var(--ink)}
.swot-item p{
  margin:0;font-size:12px;color:var(--muted);
  line-height:1.55;
}

/* Systems health */
.ac-systems{
  display:grid;grid-template-columns:repeat(2,1fr);gap:12px;
  margin-bottom:40px;
}
.ac-sys{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px 18px;
  display:flex;align-items:center;gap:14px;
  box-shadow:var(--shadow-sm);
  transition:all .2s ease;
}
[data-theme="dark"] .ac-sys{background:var(--paper)}
.ac-sys:hover{border-color:var(--gold)}
.ac-sys-icon{font-size:28px;line-height:1;flex-shrink:0}
.ac-sys-info{flex:1;min-width:0}
.ac-sys-info strong{
  display:block;font-size:13.5px;font-weight:700;
  color:var(--navy);margin-bottom:3px;
  letter-spacing:.2px;
}
[data-theme="dark"] .ac-sys-info strong{color:var(--ink)}
.ac-sys-info p{
  margin:0;font-size:12px;color:var(--muted);line-height:1.45;
}
.ac-sys-status{
  font-family:var(--mono);font-size:13px;font-weight:700;
  padding:6px 12px;border-radius:8px;
  white-space:nowrap;flex-shrink:0;
}
.ac-sys-status.excellent{background:rgba(95,206,126,.15);color:#3a8550}
.ac-sys-status.good{background:rgba(212,173,74,.15);color:var(--gold-deep)}
.ac-sys-status.medium{background:rgba(230,131,28,.15);color:#c25e10}
[data-theme="dark"] .ac-sys-status.excellent{background:rgba(95,206,126,.2);color:#7ce097}
[data-theme="dark"] .ac-sys-status.good{background:rgba(212,173,74,.2);color:var(--gold-soft)}
[data-theme="dark"] .ac-sys-status.medium{background:rgba(230,131,28,.2);color:#ffa050}

/* Strategic recommendations */
.ac-recommendations{
  display:grid;grid-template-columns:repeat(2,1fr);gap:14px;
  margin-bottom:40px;
}
.ac-rec{
  background:var(--paper);
  border:1px solid var(--border);
  border-left:5px solid var(--gold);
  border-radius:12px;
  padding:18px 22px;
  box-shadow:var(--shadow-sm);
  transition:all .25s ease;
}
[data-theme="dark"] .ac-rec{background:var(--paper)}
.ac-rec.priority-high{border-left-color:#e6321c}
.ac-rec.priority-medium{border-left-color:var(--gold)}
.ac-rec.priority-low{border-left-color:#5fce7e}
.ac-rec:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.ac-rec-priority{
  font-size:11px;font-weight:700;
  letter-spacing:1.4px;text-transform:uppercase;
  margin-bottom:8px;color:var(--muted);
}
.ac-rec h4{
  margin:0 0 8px;font-size:15px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;
}
[data-theme="dark"] .ac-rec h4{color:var(--ink)}
.ac-rec p{
  margin:0 0 10px;font-size:12.5px;color:var(--muted);
  line-height:1.6;
}
.ac-rec-time{
  display:inline-block;
  background:var(--cream);
  padding:4px 10px;border-radius:6px;
  font-size:11px;color:var(--ink-soft);
  font-weight:600;font-family:var(--mono);
}
[data-theme="dark"] .ac-rec-time{background:var(--cream-soft);color:var(--muted)}

/* Final note */
.ac-note{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;border-radius:18px;
  padding:32px 36px;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow);
}
.ac-note h3{
  color:#fff;margin:0 0 14px;font-size:20px;font-weight:600;
}
.ac-note p{
  margin:0 0 14px;font-size:14px;line-height:1.7;
  color:rgba(255,255,255,.85);
}
.ac-note p strong{color:var(--gold-soft);font-weight:700}
.ac-note-sign{
  font-size:12px;color:rgba(255,255,255,.55);
  font-style:italic;
  margin:14px 0 0;padding-top:14px;
  border-top:1px solid rgba(212,173,74,.2);
}

@media(max-width:1100px){
  .ac-scorecard{grid-template-columns:1fr;text-align:center}
  .ac-meta{grid-template-columns:1fr}
  .swot-grid{grid-template-columns:1fr}
  .ac-systems{grid-template-columns:1fr}
  .ac-recommendations{grid-template-columns:1fr}
}
@media(max-width:920px){
  .ac-scorecard{padding:24px}
  .ac-score-num{font-size:64px}
  .swot-quad{padding:18px}
  .swot-body{max-height:400px}
  .ac-note{padding:24px}
}

/* ─── Live Poll Platform ─── */
.lp-stats{
  display:grid;grid-template-columns:repeat(4,1fr);gap:14px;
  margin-bottom:32px;
}
.lp-stat{
  background:linear-gradient(135deg,var(--paper),var(--cream-soft));
  border:1px solid var(--border);
  border-top:4px solid var(--gold);
  border-radius:14px;
  padding:20px;
  text-align:center;
  position:relative;overflow:hidden;
  transition:all .3s ease;
}
[data-theme="dark"] .lp-stat{background:linear-gradient(135deg,var(--paper),var(--cream-soft))}
.lp-stat:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.lp-stat-icon{font-size:24px;display:block;margin-bottom:8px;opacity:0.8}
.lp-stat-num{
  font-family:var(--serif);font-size:36px;font-weight:600;
  color:var(--navy);line-height:1;
  letter-spacing:-.02em;margin-bottom:6px;
}
[data-theme="dark"] .lp-stat-num{color:var(--gold-soft)}
.lp-stat-label{
  font-size:11px;font-weight:700;
  color:var(--muted);letter-spacing:1.4px;
  text-transform:uppercase;
}

.lp-main-grid{
  display:grid;grid-template-columns:1.2fr 1fr;gap:24px;
  margin-bottom:32px;
}

/* Vote panel */
.lp-vote-panel{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  padding:30px 32px;
  box-shadow:var(--shadow);
}
[data-theme="dark"] .lp-vote-panel{background:var(--paper)}

.lp-vote-head{margin-bottom:22px;padding-bottom:18px;border-bottom:1px solid var(--border)}
.lp-badge{
  display:inline-block;
  background:linear-gradient(135deg,#5fce7e,#3fa75d);
  color:#fff;
  font-size:10.5px;font-weight:700;letter-spacing:1.6px;
  text-transform:uppercase;
  padding:5px 14px;border-radius:999px;
  margin-bottom:14px;
  box-shadow:0 4px 14px rgba(95,206,126,.3);
}
.lp-vote-head h3{
  margin:0 0 10px;font-size:22px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;line-height:1.3;
}
[data-theme="dark"] .lp-vote-head h3{color:var(--ink)}
.lp-vote-sublede{
  margin:0;font-size:13.5px;color:var(--muted);
  line-height:1.6;
}

.lp-options{
  display:grid;grid-template-columns:1fr 1fr;gap:8px;
  margin-bottom:18px;
}
.lp-option{
  display:flex;align-items:center;gap:12px;
  padding:12px 14px;
  background:var(--cream);
  border:1.5px solid var(--border);
  border-radius:10px;
  cursor:pointer;
  transition:all .2s ease;
  position:relative;
}
[data-theme="dark"] .lp-option{background:var(--cream-soft)}
.lp-option:hover{
  background:var(--paper);
  border-color:var(--gold);
  transform:translateX(2px);
}
[data-theme="dark"] .lp-option:hover{background:var(--paper)}
.lp-option input{
  position:absolute;opacity:0;pointer-events:none;
}
.lp-opt-mark{
  width:18px;height:18px;border-radius:50%;
  border:2px solid var(--border);
  flex-shrink:0;
  position:relative;
  transition:all .2s ease;
}
.lp-option:has(input:checked) .lp-opt-mark{
  border-color:var(--gold-deep);
  background:var(--gold);
}
.lp-option:has(input:checked) .lp-opt-mark::after{
  content:"";position:absolute;
  top:50%;left:50%;transform:translate(-50%,-50%);
  width:8px;height:8px;border-radius:50%;
  background:var(--navy-deep);
}
.lp-option:has(input:checked){
  background:linear-gradient(135deg,rgba(212,173,74,.12),rgba(212,173,74,.04));
  border-color:var(--gold);
  box-shadow:0 4px 12px rgba(212,173,74,.18);
}
.lp-opt-text{flex:1}
.lp-opt-text strong{
  display:block;font-size:13.5px;
  color:var(--navy);font-weight:600;
  line-height:1.3;
}
[data-theme="dark"] .lp-opt-text strong{color:var(--ink)}
.lp-opt-text small{
  display:block;font-size:11px;color:var(--muted);
  letter-spacing:.4px;margin-top:2px;
}

/* Demographics expander */
.lp-demo{
  background:var(--cream);
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px 18px;
  margin-bottom:18px;
}
[data-theme="dark"] .lp-demo{background:var(--cream-soft)}
.lp-demo summary{
  cursor:pointer;font-size:13px;font-weight:700;
  color:var(--navy);user-select:none;
  list-style:none;padding:4px 0;
}
[data-theme="dark"] .lp-demo summary{color:var(--ink)}
.lp-demo summary::-webkit-details-marker{display:none}
.lp-demo summary::before{
  content:"▸";display:inline-block;
  margin-right:8px;color:var(--gold-deep);
  transition:transform .2s ease;
}
.lp-demo[open] summary::before{transform:rotate(90deg)}
.lp-demo-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:12px;
  margin-top:14px;
}
.lp-demo-grid label{display:flex;flex-direction:column;gap:5px}
.lp-demo-grid label > span{
  font-size:11px;font-weight:700;
  color:var(--ink-soft);letter-spacing:.4px;
  text-transform:uppercase;
}
.lp-demo-grid select{
  border:1.5px solid var(--border);
  border-radius:8px;padding:9px 12px;
  background:var(--paper);color:var(--ink);
  font:inherit;font-size:13px;
}
[data-theme="dark"] .lp-demo-grid select{background:var(--cream-soft)}

/* Submit row */
.lp-submit-row{
  display:flex;gap:10px;flex-wrap:wrap;
}
.lp-submit-row .btn{flex:1;min-width:160px;font-size:14px;letter-spacing:.4px}
.lp-submit-row .btn[disabled]{opacity:0.5;cursor:not-allowed;pointer-events:none}

/* Voted message */
.lp-voted-msg{
  display:flex;align-items:center;gap:14px;
  background:linear-gradient(135deg,#d4f5cb,#b9eaad);
  border:1px solid #4a8056;border-left:4px solid #4a8056;
  color:#1a5d2e;
  padding:14px 18px;border-radius:12px;
  margin-top:14px;
}
[data-theme="dark"] .lp-voted-msg{
  background:linear-gradient(135deg,#163d24,#1f5230);
  color:#a8e9b3;border-color:#2d6e3d;
}
.lp-vm-icon{font-size:24px}
.lp-voted-msg strong{display:block;font-size:14px;margin-bottom:2px}
.lp-voted-msg p{margin:0;font-size:12px}
.lp-voted-msg code{
  background:rgba(0,0,0,.1);padding:2px 6px;border-radius:4px;
  font-family:var(--mono);font-size:11px;
}

/* Share row */
.lp-share-row{
  margin-top:18px;padding-top:18px;
  border-top:1px solid var(--border);
}
.lp-share-label{
  display:block;font-size:13px;font-weight:700;
  color:var(--navy);margin-bottom:12px;
}
[data-theme="dark"] .lp-share-label{color:var(--ink)}
.lp-share-btns{
  display:flex;gap:8px;flex-wrap:wrap;
}
.lp-sh{
  background:var(--cream);
  border:1.5px solid var(--border);
  border-radius:8px;
  padding:9px 14px;
  font:inherit;font-size:12.5px;font-weight:700;
  color:var(--navy);cursor:pointer;
  transition:all .2s ease;
}
[data-theme="dark"] .lp-sh{background:var(--cream-soft);color:var(--ink)}
.lp-sh:hover{transform:translateY(-2px);box-shadow:var(--shadow-sm)}
.lp-sh.facebook:hover{background:#1877f2;color:#fff;border-color:#1877f2}
.lp-sh.twitter:hover{background:#000;color:#fff;border-color:#000}
.lp-sh.whatsapp:hover{background:#25d366;color:#fff;border-color:#25d366}
.lp-sh.viber:hover{background:#7360f2;color:#fff;border-color:#7360f2}
.lp-sh.telegram:hover{background:#26a5e4;color:#fff;border-color:#26a5e4}
.lp-sh.linkedin:hover{background:#0a66c2;color:#fff;border-color:#0a66c2}
.lp-sh.copy:hover{background:var(--gold);color:var(--navy-deep);border-color:var(--gold-deep)}

/* Results panel */
.lp-results-panel{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  border-radius:18px;
  padding:30px;
  box-shadow:var(--shadow-lg);
  border:1px solid rgba(212,173,74,.22);
  position:sticky;top:90px;
}
.lp-results-head{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:20px;padding-bottom:14px;
  border-bottom:1px solid rgba(212,173,74,.22);
}
.lp-results-head h3{
  color:#fff;margin:0;font-size:18px;font-weight:600;
  display:flex;align-items:center;gap:10px;
}
.lp-live-dot{
  display:inline-block;width:9px;height:9px;border-radius:50%;
  background:#5fce7e;box-shadow:0 0 12px #5fce7e;
  animation:pulse 1.6s ease-in-out infinite;
}
.lp-refresh{
  background:rgba(212,173,74,.15);
  border:1px solid rgba(212,173,74,.3);
  color:var(--gold-soft);
  width:36px;height:36px;border-radius:8px;
  cursor:pointer;font-size:16px;
  transition:all .25s ease;
  display:grid;place-items:center;
}
.lp-refresh:hover{
  background:var(--gold);color:var(--navy-deep);
  transform:rotate(180deg);
}

.lp-pie-wrap{
  position:relative;
  margin-bottom:22px;
  display:flex;align-items:center;justify-content:center;
  min-height:240px;
}
.lp-pie{width:100%;max-width:240px;height:auto;display:block}
.lp-pie text#lpPieCenterNum{fill:#fff}
.lp-pie text:not(#lpPieCenterNum){fill:rgba(255,255,255,.55)}
.lp-pie circle:first-child{fill:rgba(255,255,255,.05)}
.lp-pie circle:last-child{fill:rgba(7,21,41,.95)}
.lp-pie-empty{
  position:absolute;inset:0;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  color:rgba(255,255,255,.5);text-align:center;
}
.lp-pie-empty.hidden{display:none}
.lp-pe-icon{font-size:48px;opacity:.4;margin-bottom:8px}
.lp-pie-empty p{margin:0;font-size:13px;line-height:1.5}

/* Results list */
.lp-results-list{
  display:flex;flex-direction:column;gap:8px;
  margin-bottom:18px;max-height:300px;overflow-y:auto;
  padding-right:4px;
}
.lp-results-list::-webkit-scrollbar{width:5px}
.lp-results-list::-webkit-scrollbar-thumb{background:rgba(212,173,74,.3);border-radius:3px}
.lp-empty{
  padding:30px 14px;text-align:center;
  color:rgba(255,255,255,.5);font-size:13px;font-style:italic;
}
.lp-result-row{
  display:grid;grid-template-columns:14px 1fr 60px 50px;gap:10px;
  align-items:center;
  padding:8px 10px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(212,173,74,.18);
  border-radius:8px;
  font-size:12.5px;
  transition:background .2s ease;
}
.lp-result-row:hover{background:rgba(212,173,74,.1)}
.lp-result-row.is-mks{
  background:rgba(212,173,74,.15);
  border-color:var(--gold);
}
.lp-rr-color{
  width:14px;height:14px;border-radius:4px;
}
.lp-rr-name{color:#fff;font-weight:600;letter-spacing:.2px}
.lp-result-row.is-mks .lp-rr-name{color:var(--gold-soft)}
.lp-rr-pct{
  text-align:right;font-family:var(--mono);
  font-weight:700;color:var(--gold-soft);
  font-size:13px;
}
.lp-rr-count{
  text-align:right;font-family:var(--mono);
  font-size:11px;color:rgba(255,255,255,.6);
}

/* Sample meter */
.lp-meter{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(212,173,74,.18);
  border-radius:10px;padding:14px 16px;
}
.lp-meter-row{
  display:flex;justify-content:space-between;
  margin-bottom:8px;
}
.lp-meter-label{font-size:11px;color:rgba(255,255,255,.7);letter-spacing:.4px;text-transform:uppercase;font-weight:600}
.lp-meter-status{
  font-size:11px;font-weight:700;letter-spacing:.4px;
  padding:2px 10px;border-radius:999px;
  background:rgba(212,173,74,.2);color:var(--gold-soft);
}
.lp-meter-status.good{background:rgba(95,206,126,.2);color:#7ce097}
.lp-meter-status.excellent{background:linear-gradient(135deg,#5fce7e,#3fa75d);color:#fff}
.lp-meter-bar{
  position:relative;
  height:8px;background:rgba(255,255,255,.1);border-radius:999px;
  overflow:hidden;margin-bottom:6px;
}
.lp-meter-fill{
  height:100%;
  background:linear-gradient(90deg,var(--gold-deep),var(--gold),#5fce7e);
  border-radius:999px;
  transition:width .8s cubic-bezier(.4,0,.2,1);
}
.lp-meter-mark{
  position:absolute;top:-3px;width:2px;height:14px;
  background:rgba(255,255,255,.3);
}
.lp-meter-note{
  margin:0;font-size:11px;color:rgba(255,255,255,.55);font-style:italic;
}

/* Analytics */
.lp-analytics{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:18px;
  padding:30px;
  margin-bottom:24px;
  box-shadow:var(--shadow-sm);
}
[data-theme="dark"] .lp-analytics{background:var(--paper)}
.lp-analytics > h3{color:var(--navy)}
[data-theme="dark"] .lp-analytics > h3{color:var(--ink)}

.lp-an-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:14px;
}
.lp-an-card{
  background:var(--cream);
  border:1px solid var(--border-soft);
  border-radius:12px;
  padding:18px;
}
[data-theme="dark"] .lp-an-card{background:var(--cream-soft)}
.lp-an-head{
  display:flex;align-items:center;gap:8px;
  margin-bottom:12px;
  padding-bottom:10px;
  border-bottom:1px solid var(--border-soft);
}
.lp-an-icon{font-size:18px}
.lp-an-head h4{
  margin:0;font-size:13px;font-weight:700;
  color:var(--navy);letter-spacing:.4px;
  text-transform:uppercase;
}
[data-theme="dark"] .lp-an-head h4{color:var(--ink)}
.lp-an-body{
  display:flex;flex-direction:column;gap:6px;
  min-height:120px;
}
.lp-empty-small{
  text-align:center;color:var(--muted-soft);
  font-size:12px;font-style:italic;padding:24px 10px;
}
.lp-an-row{
  display:flex;justify-content:space-between;align-items:center;
  font-size:12px;padding:5px 0;
  border-bottom:1px dotted var(--border-soft);
}
.lp-an-row:last-child{border-bottom:none}
.lp-an-row .name{color:var(--ink-soft);font-weight:600}
[data-theme="dark"] .lp-an-row .name{color:var(--muted)}
.lp-an-row .val{
  font-family:var(--mono);color:var(--gold-deep);
  font-weight:700;font-size:11.5px;
}
[data-theme="dark"] .lp-an-row .val{color:var(--gold-soft)}

/* Admin panel */
.lp-admin{
  background:var(--cream);
  border:1px dashed var(--border);
  border-radius:12px;
  padding:14px 20px;
  margin-bottom:18px;
}
[data-theme="dark"] .lp-admin{background:var(--cream-soft)}
.lp-admin summary{
  cursor:pointer;font-size:12px;font-weight:700;
  color:var(--muted);letter-spacing:.4px;
  text-transform:uppercase;user-select:none;
  list-style:none;padding:4px 0;
}
.lp-admin summary::-webkit-details-marker{display:none}
.lp-admin summary::before{
  content:"▸";display:inline-block;margin-right:8px;color:var(--gold-deep);
  transition:transform .2s ease;
}
.lp-admin[open] summary::before{transform:rotate(90deg)}
.lp-admin-body{padding-top:14px;font-size:13px;color:var(--muted);line-height:1.6}
.lp-admin-row{
  display:flex;gap:10px;flex-wrap:wrap;margin:14px 0;
}
.lp-admin code{
  background:var(--paper);padding:2px 6px;border-radius:4px;
  font-family:var(--mono);font-size:11.5px;
  border:1px solid var(--border-soft);
}

.lp-disclosure{margin-top:18px}

.lp-legacy{
  background:var(--cream);
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px 20px;
  margin-top:18px;
}
[data-theme="dark"] .lp-legacy{background:var(--cream-soft)}
.lp-legacy summary{
  cursor:pointer;font-size:13px;font-weight:700;
  color:var(--navy);user-select:none;
  list-style:none;
}
[data-theme="dark"] .lp-legacy summary{color:var(--ink)}
.lp-legacy summary::-webkit-details-marker{display:none}
.lp-legacy summary::before{
  content:"▸";display:inline-block;margin-right:8px;color:var(--gold-deep);
  transition:transform .2s ease;
}
.lp-legacy[open] summary::before{transform:rotate(90deg)}

@media(max-width:1100px){
  .lp-stats{grid-template-columns:repeat(2,1fr)}
  .lp-main-grid{grid-template-columns:1fr}
  .lp-results-panel{position:static}
  .lp-an-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:920px){
  .lp-options{grid-template-columns:1fr}
  .lp-vote-panel{padding:22px}
  .lp-results-panel{padding:22px}
  .lp-demo-grid{grid-template-columns:1fr}
  .lp-an-grid{grid-template-columns:1fr}
  .lp-share-btns{justify-content:center}
}

/* ─── Program · Generalen Restart ─── */
.gr-hero{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;
  border-radius:22px;
  padding:40px;
  margin-bottom:48px;
  border:1px solid rgba(212,173,74,.22);
  position:relative;overflow:hidden;
  box-shadow:var(--shadow-lg);
}
.gr-hero::before{
  content:"";position:absolute;
  top:-150px;right:-150px;width:400px;height:400px;
  background:radial-gradient(circle,rgba(212,173,74,.16),transparent 65%);
  pointer-events:none;
}
.gr-hero-icon{
  font-size:48px;line-height:1;margin-bottom:12px;
  position:relative;z-index:1;
}
.gr-hero h3{
  color:#fff;margin:0 0 16px;
  font-size:30px;font-weight:600;
  letter-spacing:-.005em;
  position:relative;z-index:1;
}
.gr-hero-lede{
  margin:0 0 28px;
  color:rgba(255,255,255,.88);
  font-size:16px;line-height:1.7;
  max-width:760px;
  position:relative;z-index:1;
}
.gr-hero-lede strong{
  color:var(--gold-soft);
  font-weight:700;
}

.gr-rules{
  display:grid;grid-template-columns:repeat(4,1fr);gap:16px;
  position:relative;z-index:1;
}
.gr-rule{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.22);
  border-radius:14px;
  padding:18px 20px;
  position:relative;
  transition:all .3s ease;
}
.gr-rule:hover{
  background:rgba(212,173,74,.1);
  transform:translateY(-3px);
  border-color:var(--gold);
}
.gr-rule-num{
  display:inline-block;
  font-family:var(--mono);font-size:11px;
  color:var(--gold-soft);font-weight:700;
  letter-spacing:1.6px;margin-bottom:10px;
}
.gr-rule strong{
  display:block;color:#fff;font-size:14.5px;
  font-weight:700;margin-bottom:6px;
  letter-spacing:.2px;
}
.gr-rule p{
  margin:0;font-size:12.5px;
  color:rgba(255,255,255,.78);
  line-height:1.55;
}

.gr-section-title{
  font-size:24px;font-weight:600;
  margin:48px 0 20px;
  color:var(--navy);
  letter-spacing:-.005em;
  font-family:var(--serif);
  text-align:center;
  position:relative;
}
[data-theme="dark"] .gr-section-title{color:var(--ink)}
.gr-section-title::before,
.gr-section-title::after{
  content:"";display:inline-block;
  width:32px;height:1px;
  background:var(--gold);
  vertical-align:middle;
  margin:0 14px;
  opacity:.6;
}

/* 12 Pillars */
.pillars-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:18px;
  margin-bottom:40px;
}
.pillar-card{
  background:var(--paper);
  border:1px solid var(--border);
  border-top:4px solid var(--gold);
  border-radius:16px;
  padding:24px;
  box-shadow:var(--shadow-sm);
  transition:all .3s ease;
  position:relative;
  display:flex;flex-direction:column;gap:10px;
}
[data-theme="dark"] .pillar-card{background:var(--paper)}
.pillar-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow);
  border-top-color:var(--navy);
}
.pillar-num{
  position:absolute;top:14px;right:18px;
  font-family:var(--serif);font-size:36px;
  color:rgba(212,173,74,.3);
  font-weight:600;line-height:1;
  letter-spacing:-.02em;
  pointer-events:none;
}
.pillar-icon{font-size:26px;line-height:1;margin-bottom:4px}
.pillar-card h4{
  margin:0;font-size:17px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;line-height:1.3;
  padding-right:50px;
}
[data-theme="dark"] .pillar-card h4{color:var(--ink)}
.pillar-card p{
  margin:0;font-size:13px;color:var(--muted);
  line-height:1.6;flex:1;
}
.pillar-kpi{
  background:linear-gradient(135deg,rgba(212,173,74,.1),rgba(212,173,74,.04));
  border-left:3px solid var(--gold);
  border-radius:8px;
  padding:9px 12px;
  font-size:12px;color:var(--ink-soft);
  font-weight:600;
}
[data-theme="dark"] .pillar-kpi{
  background:linear-gradient(135deg,rgba(212,173,74,.15),rgba(212,173,74,.06));
  color:var(--muted);
}
.pillar-kpi b{color:var(--gold-deep);font-weight:700;font-family:var(--mono)}
[data-theme="dark"] .pillar-kpi b{color:var(--gold-soft)}

/* Unique features */
.unique-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:16px;
  margin-bottom:40px;
}
.unique-item{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:14px;
  padding:22px 26px;
  box-shadow:var(--shadow-sm);
  position:relative;
  transition:all .3s ease;
}
[data-theme="dark"] .unique-item{background:var(--paper)}
.unique-item:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}
.uq-num{
  position:absolute;top:-12px;left:24px;
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  width:32px;height:32px;border-radius:50%;
  display:grid;place-items:center;
  font-family:var(--serif);font-size:18px;font-weight:700;
  box-shadow:0 4px 12px rgba(212,173,74,.4);
}
.unique-item h4{
  margin:6px 0 10px;font-size:16px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;line-height:1.3;
}
[data-theme="dark"] .unique-item h4{color:var(--ink)}
.unique-item p{
  margin:0;font-size:13px;color:var(--muted);
  line-height:1.65;
}

/* KPI table */
.gr-kpi-lede{
  text-align:center;color:var(--muted);
  font-size:14px;line-height:1.65;
  max-width:720px;margin:0 auto 24px;
}
.kpi-table-wrap{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:14px;
  padding:6px;
  box-shadow:var(--shadow-sm);
  overflow-x:auto;
  margin-bottom:40px;
}
[data-theme="dark"] .kpi-table-wrap{background:var(--paper)}
.kpi-table{
  width:100%;border-collapse:collapse;
  font-size:13px;
}
.kpi-table thead{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
}
.kpi-table th{
  padding:14px 16px;text-align:left;
  font-size:12px;font-weight:700;
  letter-spacing:1px;text-transform:uppercase;
  color:var(--gold-soft);
}
.kpi-table th:nth-child(2),
.kpi-table th:nth-child(3),
.kpi-table th:nth-child(4){text-align:center}
.kpi-table tbody tr{
  border-bottom:1px solid var(--border-soft);
  transition:background .2s ease;
}
.kpi-table tbody tr:hover{background:var(--cream)}
[data-theme="dark"] .kpi-table tbody tr:hover{background:var(--cream-soft)}
.kpi-table tbody tr:last-child{border-bottom:none}
.kpi-table td{padding:12px 16px;color:var(--ink-soft);line-height:1.5}
[data-theme="dark"] .kpi-table td{color:var(--muted)}
.kpi-table td:nth-child(2),
.kpi-table td:nth-child(3),
.kpi-table td:nth-child(4){text-align:center;font-family:var(--mono);font-size:12px}
.kpi-table td strong{color:var(--gold-deep);font-weight:700}
[data-theme="dark"] .kpi-table td strong{color:var(--gold-soft)}

/* Phases timeline */
.phases-timeline{
  display:grid;grid-template-columns:repeat(5,1fr);gap:14px;
  margin-bottom:40px;
}
.phase-item{
  background:var(--paper);
  border:1px solid var(--border);
  border-radius:14px;
  padding:22px 18px;
  text-align:center;
  position:relative;
  transition:all .3s ease;
}
[data-theme="dark"] .phase-item{background:var(--paper)}
.phase-item:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow);
  border-color:var(--gold);
}
.phase-year{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold-deep),var(--gold));
  color:var(--navy-deep);
  padding:6px 14px;border-radius:999px;
  font-size:11.5px;font-weight:700;letter-spacing:1px;
  text-transform:uppercase;
  margin-bottom:12px;
}
.phase-item h4{
  margin:0 0 8px;font-size:14px;font-weight:600;
  color:var(--navy);font-family:var(--serif);
  letter-spacing:-.005em;line-height:1.3;
}
[data-theme="dark"] .phase-item h4{color:var(--ink)}
.phase-item p{
  margin:0;font-size:12px;color:var(--muted);
  line-height:1.55;
}

/* CTA */
.gr-cta{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy));
  color:#fff;
  border-radius:22px;
  padding:40px;
  text-align:center;
  border:1px solid rgba(212,173,74,.22);
  box-shadow:var(--shadow-lg);
  margin-top:24px;
}
.gr-cta h3{
  color:#fff;margin:0 0 14px;
  font-size:32px;font-weight:600;
  font-family:var(--serif);
  letter-spacing:-.01em;
}
.gr-cta-lede{
  margin:0 auto 28px;
  color:rgba(255,255,255,.85);
  font-size:16px;line-height:1.65;
  max-width:680px;
}
.gr-cta-actions{
  display:flex;gap:10px;justify-content:center;flex-wrap:wrap;
}

@media(max-width:1100px){
  .gr-rules{grid-template-columns:repeat(2,1fr)}
  .pillars-grid{grid-template-columns:repeat(2,1fr)}
  .phases-timeline{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:920px){
  .gr-hero{padding:28px}
  .gr-hero h3{font-size:24px}
  .gr-rules{grid-template-columns:1fr}
  .pillars-grid{grid-template-columns:1fr}
  .unique-grid{grid-template-columns:1fr}
  .phases-timeline{grid-template-columns:1fr}
  .gr-section-title{font-size:20px}
  .gr-cta{padding:28px}
  .gr-cta h3{font-size:24px}
  .kpi-table th,.kpi-table td{padding:10px 8px;font-size:11.5px}
}

/* ─── Newsletter ─── */
.newsletter-box{
  background:
    linear-gradient(135deg,var(--cream),var(--cream-soft));
  border:1px solid var(--border);
  border-radius:var(--radius-lg);
  padding:40px;
  text-align:center;
  position:relative;overflow:hidden;
}
.newsletter-box::before{
  content:"";position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
}
.newsletter-box h3{
  margin:0 0 8px;font-size:28px;font-weight:600;
}
.newsletter-box h3 em{color:var(--gold-deep);font-style:italic}
[data-theme="dark"] .newsletter-box h3 em{color:var(--gold-soft)}
.newsletter-box p{
  color:var(--muted);margin:0 0 24px;font-size:15px;
  max-width:520px;margin-left:auto;margin-right:auto;
}
.newsletter-form{
  display:flex;gap:10px;flex-wrap:wrap;justify-content:center;
  max-width:520px;margin:0 auto;
}
.newsletter-form input[type=email]{
  flex:1;min-width:220px;
  border:1.5px solid var(--border);
  border-radius:999px;padding:13px 22px;
  background:var(--paper);color:var(--ink);
  font-family:var(--sans);font-size:14px;
}
.newsletter-form input:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(212,173,74,.2)}
.newsletter-consent{
  margin:14px auto 0;font-size:11.5px;color:var(--muted);
  display:flex;align-items:center;justify-content:center;gap:6px;
  max-width:520px;
}
.newsletter-consent input{margin:0}

@media(max-width:1100px){
  .dash-grid{grid-template-columns:repeat(3,1fr)}
  .country-grid{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:920px){
  .dash-grid{grid-template-columns:repeat(2,1fr)}
  .init-grid{grid-template-columns:1fr}
  .muni-wrap{grid-template-columns:1fr}
  .muni-map-frame{position:static}
  .country-grid{grid-template-columns:repeat(2,1fr)}
  .diaspora-hero{padding:32px 24px}
  .diaspora-hero h3{font-size:26px}
  .quote-carousel{padding:32px 24px}
  .qc-slide blockquote{font-size:20px}
  .newsletter-box{padding:30px 22px}
  .theme-toggle{margin-left:0;width:38px;height:38px;display:grid;place-items:center;border-radius:10px}
}
@media(max-width:520px){
  .dash-grid{grid-template-columns:1fr}
  .country-grid{grid-template-columns:1fr}
}
@media(max-width:920px){
  .links{display:none;position:absolute;top:100%;left:0;right:0;background:var(--cream);border-bottom:1px solid var(--line);flex-direction:column;align-items:stretch;padding:14px;gap:2px}
  .links.open{display:flex}
  .links a{padding:14px 18px;border-radius:8px}
  .menu-toggle{display:inline-flex}
  nav{position:relative;gap:8px}
  .theme-toggle{width:36px;height:36px;display:grid;place-items:center}
  .lang-switcher{margin-right:0;gap:2px}
  .lang-btn{padding:4px 6px}
  .lang-label{display:none}
  .grid-2,.grid-3,.grid-4,.statute-list{grid-template-columns:1fr}
  .step{grid-template-columns:1fr;gap:8px;padding:20px}
  .poll-row,.seat-row{grid-template-columns:1.4fr 1.4fr 50px;gap:8px}
  .poll-row strong,.seat-row strong{font-size:11.5px}
  .social-grid{grid-template-columns:repeat(2,1fr)}
  .channel-group-head .cg-meta{display:none}
  .hero{padding:64px 0 56px}
  section{padding:64px 0}
  .quote{padding:36px 24px}
  .form-grid,.poll-controls{grid-template-columns:1fr}
  .topbar .doctrine{display:none}
  .bot-agent-float{right:14px;bottom:14px;width:calc(100% - 28px)}
}

/* ═══════════════════════════════════════════════════════════
   NATIONBUILDER + CIVICTECH + MORNING CONSULT INTEGRATION
   ═══════════════════════════════════════════════════════════ */

/* ─── CRM Dashboard ─── */
.crm-dashboard{background:var(--surface);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--shadow)}
.crm-header{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:20px}
.crm-filters{display:flex;gap:10px;flex-wrap:wrap}
.crm-filters input,.crm-filters select{padding:10px 14px;border-radius:10px;border:1.5px solid var(--line);background:var(--bg);font-family:var(--sans);font-size:13px}
.crm-table{width:100%;border-collapse:collapse;font-size:13.5px}
.crm-table th{background:var(--navy);color:var(--gold-soft);padding:12px 14px;text-align:left;font-weight:700;font-size:12px;letter-spacing:.5px;text-transform:uppercase}
.crm-table td{padding:12px 14px;border-bottom:1px solid var(--line-soft);color:var(--ink)}
.crm-table tr:hover td{background:rgba(212,173,74,.04)}
.crm-score{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700}
.crm-score.high{background:rgba(34,197,94,.12);color:#16a34a}
.crm-score.medium{background:rgba(251,191,36,.12);color:#ca8a04}
.crm-score.low{background:rgba(239,68,68,.12);color:#dc2626}
.crm-tag{display:inline-block;padding:3px 10px;border-radius:6px;font-size:10.5px;font-weight:700;background:var(--navy-soft);color:#fff;margin:2px}
.crm-export-btn{display:inline-flex;gap:8px;align-items:center;padding:10px 18px;border-radius:10px;background:var(--navy);color:var(--gold-soft);font-size:12.5px;font-weight:700;border:none;cursor:pointer}
.crm-export-btn:hover{background:var(--navy-mid)}

/* ─── Recruiting / Referral ─── */
.recruit-card{background:var(--surface);border-radius:var(--radius-lg);padding:32px;text-align:center;box-shadow:var(--shadow);border:1.5px solid var(--line)}
.recruit-link-box{background:var(--navy-deep);color:var(--gold-soft);padding:16px 20px;border-radius:12px;font-family:var(--mono);font-size:13px;margin:16px 0;position:relative}
.recruit-link-box button{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:var(--gold);color:var(--navy-deep);border:none;border-radius:6px;padding:6px 12px;font-size:11px;font-weight:700;cursor:pointer}
.recruit-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:20px}
.recruit-stat{background:var(--bg-soft);padding:18px;border-radius:12px}
.recruit-stat b{display:block;font-size:22px;color:var(--navy);font-family:var(--serif)}
.recruit-stat span{font-size:11.5px;color:var(--muted)}
.recruit-leaderboard{margin-top:24px}
.leader-row{display:flex;align-items:center;gap:14px;padding:12px 0;border-bottom:1px solid var(--line-soft)}
.leader-rank{width:28px;height:28px;border-radius:50%;background:var(--navy);color:var(--gold-soft);display:grid;place-items:center;font-size:11px;font-weight:800}
.leader-rank.gold{background:var(--gold);color:var(--navy-deep)}
.leader-rank.silver{background:#c0c0c0;color:var(--navy-deep)}
.leader-rank.bronze{background:#cd7f32;color:#fff}
.leader-name{flex:1;font-weight:600;font-size:13.5px}
.leader-points{font-family:var(--serif);color:var(--gold-deep);font-weight:700}

/* ─── Volunteer Task Hub ─── */
.task-hub{display:grid;grid-template-columns:280px 1fr;gap:24px}
.task-sidebar{background:var(--surface);border-radius:var(--radius);padding:20px;border:1.5px solid var(--line);height:fit-content;position:sticky;top:100px}
.task-sidebar h4{margin:0 0 14px;font-size:15px;color:var(--navy)}
.task-muni-list{list-style:none;padding:0;margin:0}
.task-muni-list li{padding:8px 12px;border-radius:8px;cursor:pointer;font-size:13px;display:flex;justify-content:space-between;align-items:center}
.task-muni-list li:hover{background:rgba(212,173,74,.08)}
.task-muni-list li.active{background:var(--navy);color:var(--gold-soft);font-weight:700}
.task-muni-list li .badge{font-size:10px;background:var(--gold);color:var(--navy-deep);padding:2px 8px;border-radius:999px;font-weight:700}
.task-card{background:var(--surface);border-radius:var(--radius);padding:20px;border:1.5px solid var(--line);margin-bottom:14px}
.task-card h5{margin:0 0 8px;font-size:15px;color:var(--navy)}
.task-meta{display:flex;gap:14px;flex-wrap:wrap;font-size:11.5px;color:var(--muted);margin-bottom:12px}
.task-card .actions{display:flex;gap:8px;margin-top:14px}
.task-photo-proof{width:100%;height:140px;border-radius:10px;border:2px dashed var(--line);display:grid;place-items:center;color:var(--muted);font-size:12px;cursor:pointer;background:var(--bg-soft);overflow:hidden}
.task-photo-proof.has-photo{border-style:solid;border-color:var(--gold);background:var(--bg)}
.task-photo-proof img{width:100%;height:100%;object-fit:cover}

/* ─── Events RSVP ─── */
.event-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:18px}
.event-card{background:var(--surface);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);border:1.5px solid var(--line);display:flex;flex-direction:column}
.event-header{background:linear-gradient(135deg,var(--navy),var(--navy-mid));color:#fff;padding:20px}
.event-date{display:inline-flex;align-items:center;gap:8px;font-size:12px;color:var(--gold-soft);margin-bottom:8px}
.event-header h4{margin:0;font-size:18px;font-family:var(--serif)}
.event-body{padding:20px;flex:1}
.event-body p{font-size:13px;color:var(--ink-soft);margin:0 0 12px}
.event-meta{display:flex;gap:12px;flex-wrap:wrap;font-size:11.5px;color:var(--muted);margin-bottom:14px}
.event-footer{padding:16px 20px;border-top:1px solid var(--line-soft);display:flex;justify-content:space-between;align-items:center;gap:10px}
.event-seats{font-size:12px;color:var(--muted)}
.event-seats b{color:var(--navy)}
.rsvp-btn{padding:10px 20px;border-radius:10px;font-size:12.5px;font-weight:700;border:none;cursor:pointer;transition:all .2s}
.rsvp-btn.open{background:var(--gold);color:var(--navy-deep)}
.rsvp-btn.open:hover{background:var(--gold-soft)}
.rsvp-btn.full{background:var(--line);color:var(--muted);cursor:not-allowed}
.qr-ticket{width:140px;height:140px;margin:0 auto;display:block}

/* ─── Petitions ─── */
.petition-hero{background:var(--navy);color:#fff;padding:48px 36px;border-radius:var(--radius-lg);text-align:center;margin-bottom:28px;position:relative;overflow:hidden}
.petition-hero::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(212,173,74,.15),transparent 50%)}
.petition-hero h3{position:relative;font-size:32px;margin:0 0 12px}
.petition-hero p{position:relative;color:rgba(255,255,255,.8);margin:0}
.petition-progress{height:18px;background:rgba(255,255,255,.15);border-radius:999px;overflow:hidden;margin:24px 0 12px;position:relative}
.petition-progress .bar{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-soft));border-radius:999px;transition:width 1s ease;position:relative}
.petition-progress .bar::after{content:"";position:absolute;right:0;top:0;bottom:0;width:3px;background:#fff;opacity:.5}
.petition-stats{display:flex;justify-content:center;gap:36px;flex-wrap:wrap;margin-top:16px;position:relative}
.petition-stat{text-align:center}
.petition-stat b{display:block;font-size:28px;font-family:var(--serif);color:var(--gold-soft)}
.petition-stat span{font-size:12px;color:rgba(255,255,255,.7)}
.petition-signers{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-top:20px}
.signer-card{background:var(--surface);padding:14px 18px;border-radius:10px;border:1.5px solid var(--line);display:flex;align-items:center;gap:12px}
.signer-avatar{width:40px;height:40px;border-radius:50%;background:var(--navy-soft);color:var(--gold-soft);display:grid;place-items:center;font-weight:700;font-size:14px}
.signer-info{flex:1}
.signer-info b{display:block;font-size:13px;color:var(--navy)}
.signer-info span{font-size:11px;color:var(--muted)}
.signer-time{font-size:10.5px;color:var(--muted-soft)}

/* ─── Email Campaign ─── */
.email-builder{background:var(--surface);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--shadow)}
.email-preview{background:var(--cream-soft);border:1.5px solid var(--line);border-radius:10px;padding:24px;max-width:600px;margin:20px auto;font-size:14px;line-height:1.7}
.email-preview-header{border-bottom:2px solid var(--navy);padding-bottom:12px;margin-bottom:16px}
.email-preview-header b{color:var(--navy);font-size:16px;display:block}
.email-preview-header span{color:var(--muted);font-size:11px}
.email-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:20px}
.email-stat-card{background:var(--bg-soft);padding:16px;border-radius:10px;text-align:center}
.email-stat-card b{display:block;font-size:22px;color:var(--navy);font-family:var(--serif)}
.email-stat-card span{font-size:11px;color:var(--muted)}

/* ─── Participatory Budgeting ─── */
.budget-container{display:grid;grid-template-columns:1fr 320px;gap:24px}
.budget-projects{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px}
.budget-project{background:var(--surface);border-radius:var(--radius);padding:20px;border:1.5px solid var(--line);cursor:pointer;transition:all .2s;position:relative}
.budget-project:hover{border-color:var(--gold);transform:translateY(-3px);box-shadow:var(--shadow-sm)}
.budget-project.selected{border-color:var(--gold);background:rgba(212,173,74,.04)}
.budget-project .price{font-family:var(--serif);font-size:20px;color:var(--gold-deep);font-weight:600}
.budget-project .votes{font-size:11px;color:var(--muted);margin-top:4px}
.budget-project h5{margin:8px 0 6px;font-size:14px;color:var(--navy)}
.budget-project p{font-size:12px;color:var(--ink-soft);margin:0}
.budget-sidebar{background:var(--surface);border-radius:var(--radius);padding:20px;border:1.5px solid var(--line);position:sticky;top:100px;height:fit-content}
.budget-pool{text-align:center;padding:16px;background:var(--navy);color:#fff;border-radius:10px;margin-bottom:16px}
.budget-pool b{display:block;font-size:26px;font-family:var(--serif);color:var(--gold-soft)}
.budget-pool span{font-size:11px;opacity:.8}
.budget-remaining{text-align:center;padding:12px;background:var(--bg-soft);border-radius:8px;margin-bottom:16px}
.budget-remaining b{color:var(--navy);font-size:18px}
.budget-remaining span{display:block;font-size:11px;color:var(--muted)}

/* ─── Anonymous Proposals ─── */
.anon-box{background:var(--surface);border-radius:var(--radius-lg);padding:32px;border:1.5px solid var(--line);box-shadow:var(--shadow-sm)}
.anon-header{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.anon-shield{width:44px;height:44px;border-radius:12px;background:var(--navy);color:var(--gold-soft);display:grid;place-items:center}
.anon-proposal{background:var(--bg-soft);border-radius:12px;padding:18px;margin-bottom:12px;border:1.5px solid var(--line-soft);position:relative}
.anon-proposal .badge{position:absolute;top:-8px;right:14px;background:var(--gold);color:var(--navy-deep);font-size:10px;font-weight:700;padding:3px 10px;border-radius:999px}
.anon-proposal p{margin:0 0 10px;font-size:13.5px;line-height:1.6}
.anon-proposal .meta{font-size:11px;color:var(--muted);display:flex;gap:14px}

/* ─── AI Sentiment & Topics ─── */
.sentiment-gauge{display:flex;align-items:center;gap:16px;background:var(--surface);padding:20px;border-radius:var(--radius);border:1.5px solid var(--line)}
.gauge-track{flex:1;height:24px;background:var(--bg-soft);border-radius:999px;overflow:hidden;display:flex}
.gauge-pos{background:rgba(34,197,94,.7);height:100%}
.gauge-neu{background:rgba(148,163,184,.5);height:100%}
.gauge-neg{background:rgba(239,68,68,.7);height:100%}
.gauge-labels{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-top:6px}
.sentiment-score{font-size:28px;font-family:var(--serif);font-weight:600;color:var(--navy);min-width:60px;text-align:center}
.topic-cloud{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px}
.topic-chip{padding:8px 14px;border-radius:999px;font-size:12px;font-weight:700;background:var(--bg-soft);border:1.5px solid var(--line);color:var(--ink-soft);cursor:pointer;transition:all .2s}
.topic-chip:hover{border-color:var(--gold);background:rgba(212,173,74,.08)}
.topic-chip.hot{background:var(--navy);color:var(--gold-soft);border-color:var(--navy)}

/* ─── Poll Archive ─── */
.archive-list{display:grid;gap:14px}
.archive-item{background:var(--surface);border-radius:var(--radius);padding:20px;border:1.5px solid var(--line);display:grid;grid-template-columns:1fr auto;gap:16px;align-items:center;cursor:pointer;transition:all .2s}
.archive-item:hover{border-color:var(--gold);box-shadow:var(--shadow-sm)}
.archive-item h5{margin:0 0 6px;font-size:15px;color:var(--navy)}
.archive-item .date{font-size:11.5px;color:var(--muted)}
.archive-result{display:flex;gap:10px;align-items:center}
.archive-bar{height:10px;width:120px;background:var(--bg-soft);border-radius:999px;overflow:hidden}
.archive-bar .fill{height:100%;background:var(--navy);border-radius:999px}
.archive-percent{font-size:14px;font-family:var(--serif);color:var(--navy);font-weight:600}

/* ─── Presentation Export ─── */
.slide-deck{background:var(--paper);border-radius:var(--radius-lg);padding:36px;box-shadow:var(--shadow);max-width:900px;margin:0 auto;border:1.5px solid var(--line)}
.slide-header{text-align:center;border-bottom:3px solid var(--navy);padding-bottom:20px;margin-bottom:24px}
.slide-header h2{color:var(--navy);font-size:28px;margin:0}
.slide-header p{color:var(--muted);font-size:13px;margin:6px 0 0}
.slide-chart{height:280px;background:var(--bg-soft);border-radius:10px;margin:20px 0;display:grid;place-items:center;font-size:13px;color:var(--muted)}
.slide-footer{display:flex;justify-content:space-between;align-items:center;margin-top:24px;padding-top:16px;border-top:1px solid var(--line)}
.slide-brand{font-size:12px;color:var(--navy);font-weight:700;letter-spacing:1px}
.slide-date{font-size:11px;color:var(--muted)}
.export-actions{display:flex;gap:10px;justify-content:center;margin-top:20px;flex-wrap:wrap}

/* ─── Admin Quick Bar ─── */
.admin-bar{background:var(--navy-deep);color:#fff;padding:10px 0;font-size:12px}
.admin-bar .inner{display:flex;gap:20px;align-items:center;flex-wrap:wrap}
.admin-bar a{color:var(--gold-soft);font-weight:700}
.admin-bar a:hover{color:#fff}

/* ─── Scroll-to-top ─── */
.scroll-top{position:fixed;bottom:24px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--navy);color:var(--gold-soft);border:none;cursor:pointer;display:grid;place-items:center;box-shadow:var(--shadow);z-index:90;opacity:0;transform:translateY(20px);transition:all .3s ease}
.scroll-top.visible{opacity:1;transform:translateY(0)}
.scroll-top:hover{background:var(--navy-mid);transform:translateY(-2px)}

/* ─── Page loader ─── */
.page-loader{position:fixed;inset:0;background:var(--cream);z-index:999;display:grid;place-items:center;transition:opacity .4s ease,visibility .4s ease}
.page-loader.hidden{opacity:0;visibility:hidden}
.loader-sigil{width:64px;height:64px;animation:pulse 1.2s ease-in-out infinite}

/* ─── Offline indicator ─── */
.offline-badge{position:fixed;top:80px;left:50%;transform:translateX(-50%);background:#dc2626;color:#fff;padding:8px 20px;border-radius:999px;font-size:12px;font-weight:700;z-index:100;box-shadow:0 4px 14px rgba(0,0,0,.2);display:none}
.offline-badge.visible{display:block}

/* ─── Typing indicator for bot ─── */
.typing-indicator{display:flex;gap:4px;padding:8px 12px}
.typing-indicator span{width:7px;height:7px;border-radius:50%;background:var(--muted);animation:typing 1.4s infinite ease-in-out both}
.typing-indicator span:nth-child(1){animation-delay:-.32s}
.typing-indicator span:nth-child(2){animation-delay:-.16s}
@keyframes typing{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}

/* ─── Member card photo area ─── */
.photo-upload{width:140px;height:180px;border-radius:8px;border:2px dashed var(--line);display:grid;place-items:center;cursor:pointer;overflow:hidden;background:var(--bg-soft);position:relative}
.photo-upload:hover{border-color:var(--gold);background:rgba(212,173,74,.04)}
.photo-upload.has-photo{border-style:solid;border-color:var(--gold);border-width:2px}
.photo-upload img{width:100%;height:100%;object-fit:cover}
.photo-upload .hint{font-size:11px;color:var(--muted);text-align:center;padding:8px}
.photo-upload input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer}

/* ─── Confetti canvas overlay ─── */
#confettiCanvas{position:fixed;inset:0;pointer-events:none;z-index:9999}

/* ─── Member card with QR repositioned ─── */
.member-card-v2{background:var(--paper);border-radius:14px;padding:24px;border:1.5px solid var(--line);display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:center;box-shadow:var(--shadow-sm);max-width:560px;margin:0 auto}
.member-photo-v2{width:100px;height:130px;border-radius:8px;object-fit:cover;border:2px solid var(--gold)}
.member-info-v2{flex:1}
.member-info-v2 h4{margin:0 0 4px;font-size:16px;color:var(--navy)}
.member-info-v2 .meta{font-size:11.5px;color:var(--muted);margin-bottom:8px}
.member-info-v2 .id{font-family:var(--mono);font-size:10.5px;background:var(--bg-soft);padding:4px 10px;border-radius:6px;display:inline-block;color:var(--navy)}
.member-qr-v2{width:90px;height:90px}

@media(max-width:920px){
  .task-hub{grid-template-columns:1fr}
  .task-sidebar{position:static}
  .budget-container{grid-template-columns:1fr}
  .recruit-stats{grid-template-columns:repeat(2,1fr)}
  .email-stats{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:520px){
  .brand-text b{font-size:14px}
  .brand-text span{font-size:10px}
  .brand-mark{width:40px;height:40px}
  .brand-mark svg{width:26px;height:26px}
  .hero h1{font-size:34px}
  .hero-kpi{grid-template-columns:1fr;gap:12px}
  .kpi-cell{border-bottom:1px solid rgba(212,173,74,.14)!important;padding:12px 0}
  .kpi-cell:last-child{border-bottom:none!important}
  .actions{flex-direction:column;align-items:stretch}
  .btn{width:100%}
  .member-card-preview{padding:18px 16px 14px;min-height:auto}
  .mc-brand{font-size:15px}
  .mc-brand small{font-size:8px;letter-spacing:1.5px}
  .mc-mark{width:32px;height:32px}
  .mc-body{gap:10px}
  .mc-body .member-photo-wrap{width:88px;height:114px}
  .mc-info p{font-size:11px}
  .mc-info strong{font-size:9px;min-width:50px}
  .mc-foot{padding-top:6px;margin-top:6px}
  .qr-real{width:52px;height:52px}
  .qr-fallback{width:52px;height:52px}
  .social-grid{grid-template-columns:1fr}
}

/* ─── Print ─── */
@media print{
  .topbar,header,.bot-agent-float,.scroll-progress,.actions,#bot-agent,#channels,#poll-tool,#membership,.menu-toggle{display:none!important}
  body{background:#fff;color:#000;font-size:11pt}
  .hero{background:#fff;color:#000;padding:20px 0;border:none}
  .hero h1,.hero p.lede,.hero-card h3,.hero-card ul li{color:#000}
  .accent{background:#fff;border:none}
  .quote{background:#fff;color:#000;border:2px solid #000;box-shadow:none}
  .quote h2,.quote p{color:#000}
  .card,.statute-item,.step{box-shadow:none;border:1px solid #ccc;break-inside:avoid;page-break-inside:avoid}
  section{padding:24px 0}
  .num{background:#000;color:#fff;border:none}
}

/* ─── Decorative background patterns ─── */
.section-divider{
  height:80px;display:flex;align-items:center;justify-content:center;
  position:relative;background:var(--cream);
}
.section-divider::before{
  content:"";position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
  width:100%;max-width:600px;height:1px;
  background:linear-gradient(90deg,transparent,var(--rule),transparent);
}
.section-divider .ornament{
  position:relative;background:var(--cream);padding:0 18px;
  font-family:var(--serif);font-size:22px;color:var(--gold-deep);
}


/* ════════════════════════════════════════════════════════
   v2.1 PLATINUM — 10/10 EDITION
   Mobile-first · PWA-ready · Performance-optimized
   ════════════════════════════════════════════════════════ */

/* ─── Reduced motion support ─── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* ─── Focus-visible for keyboard navigation ─── */
:focus-visible{
  outline: 2px solid var(--gold);
  outline-offset: 2px;
  border-radius: 4px;
}
button:focus-visible, a:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible{
  outline: 2px solid var(--gold);
  outline-offset: 2px;
}

/* ─── Scroll to top button ─── */
.scroll-top{
  position: fixed; right: 22px; bottom: 22px; z-index: 60;
  width: 46px; height: 46px; border-radius: 50%;
  background: var(--navy); color: var(--gold-soft);
  border: 1.5px solid var(--gold-soft);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; opacity: 0; transform: translateY(12px); pointer-events: none;
  transition: all .35s cubic-bezier(.4,0,.2,1);
  box-shadow: 0 6px 20px rgba(8,26,51,.35);
}
.scroll-top.show{ opacity: 1; transform: translateY(0); pointer-events: auto }
.scroll-top:hover{ background: var(--navy-mid); transform: translateY(-2px) }
.scroll-top svg{ width: 20px; height: 20px }

/* ─── Bot typing indicator ─── */
.typing-indicator{
  display: flex; align-items: center; gap: 6px;
  padding: 12px 16px !important;
  background: rgba(212,173,74,.08) !important;
  border-left-color: var(--gold-soft) !important;
  min-height: 48px;
}
.typing-indicator span{
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--gold-soft);
  animation: typingBounce 1.4s ease-in-out infinite;
  opacity: .6;
}
.typing-indicator span:nth-child(2){ animation-delay: .2s }
.typing-indicator span:nth-child(3){ animation-delay: .4s }
@keyframes typingBounce{
  0%, 60%, 100%{ transform: translateY(0) }
  30%{ transform: translateY(-6px) }
}

/* ─── Offline indicator ─── */
.offline-bar{
  position: fixed; top: 0; left: 0; right: 0; z-index: 300;
  background: #c0392b; color: #fff; text-align: center;
  font-size: 13px; font-weight: 600; padding: 10px;
  transform: translateY(-100%);
  transition: transform .35s ease;
}
.offline-bar.show{ transform: translateY(0) }

/* ─── Page loader ─── */
.page-loader{
  position: fixed; inset: 0; z-index: 500;
  background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  transition: opacity .5s ease, visibility .5s ease;
  animation: loaderAutoHide 2s ease forwards;
}
.page-loader.hidden{ opacity: 0; visibility: hidden; pointer-events: none; animation: none }
.page-loader-inner{ display: flex; flex-direction: column; align-items: center; gap: 8px }
@keyframes loaderAutoHide{
  0%, 70%{ opacity: 1; visibility: visible }
  100%{ opacity: 0; visibility: hidden; pointer-events: none }
}

/* ─── Button loading state ─── */
.btn.is-loading{
  position: relative; color: transparent !important;
  pointer-events: none;
}
.btn.is-loading::after{
  content: ""; position: absolute; left: 50%; top: 50%;
  width: 18px; height: 18px; margin: -9px 0 0 -9px;
  border: 2px solid rgba(255,255,255,.3);
  border-top-color: #fff; border-radius: 50%;
  animation: spin .8s linear infinite;
}
@keyframes spin{ to{ transform: rotate(360deg) } }

/* ─── Municipality tooltip ─── */
.muni-region{ position: relative; cursor: pointer }
.muni-region::after{
  content: attr(data-name) "\A" attr(data-coordinator);
  position: absolute; left: 50%; top: -20px; transform: translateX(-50%);
  background: var(--navy); color: #fff; font-size: 11px; font-weight: 600;
  padding: 6px 10px; border-radius: 8px; white-space: pre;
  opacity: 0; pointer-events: none; transition: opacity .25s ease;
  box-shadow: 0 4px 12px rgba(0,0,0,.25); z-index: 10;
  line-height: 1.4; text-align: center;
}
.muni-region:hover::after{ opacity: 1; top: -48px }

/* ─── Pie chart hover ─── */
#lpPieSlices path{ transition: opacity .2s ease, transform .2s ease; cursor: pointer }
#lpPieSlices path:hover{ opacity: .92; transform: scale(1.02); transform-origin: center }

/* ─── Mobile-first responsive improvements ─── */
@media (max-width: 768px) {
  .hero .grid{ grid-template-columns: 1fr !important; gap: 32px }
  .hero h1{ font-size: clamp(32px, 8vw, 52px) }
  .hero-kpi{ grid-template-columns: repeat(2, 1fr) }
  .kpi-cell:nth-child(2){ border-right: none }
  .kpi-cell:nth-child(1), .kpi-cell:nth-child(2){ border-bottom: 1px solid rgba(212,173,74,.14) }
  .grid-2, .grid-3, .grid-4{ grid-template-columns: 1fr }
  .step{ grid-template-columns: 1fr; gap: 12px }
  .step .day{ font-size: 18px }
  .principle{ grid-template-columns: 1fr }
  .principle .num{ margin: 0 auto }
  .tier-selector{ grid-template-columns: 1fr }
  .don-tiers{ grid-template-columns: repeat(2, 1fr) }
  .lp-main-grid{ grid-template-columns: 1fr !important }
  .ac-grid{ grid-template-columns: 1fr }
  .ac-scorecard{ grid-template-columns: 1fr }
  .muni-map-wrap{ grid-template-columns: 1fr }
  .member-card-preview{ position: relative; top: auto; margin-bottom: 24px }
  .inst-grid, .officina-grid, .junge-grid{ grid-template-columns: 1fr }
  .footer-grid{ grid-template-columns: 1fr }
  .scroll-top{ right: 12px; bottom: 12px; width: 42px; height: 42px }
}

@media (max-width: 480px) {
  .don-tiers{ grid-template-columns: 1fr }
  .hero{ padding: 70px 0 50px }
  section{ padding: 60px 0 }
  .container{ width: calc(100% - 24px) }
  .bot-panel{ width: calc(100vw - 24px); right: 12px; left: 12px }
}

/* ─── Touch feedback ─── */
@media (hover: none) {
  .card:hover{ transform: none }
  .card:active{ transform: scale(.98) }
  .btn:hover{ transform: none }
  .btn:active{ transform: scale(.96) }
}

/* ─── Lazy loading skeleton ─── */
.lazy-skeleton{
  background: linear-gradient(90deg, var(--cream-soft) 25%, var(--line-soft) 50%, var(--cream-soft) 75%);
  background-size: 200% 100%;
  animation: skeletonShimmer 1.5s infinite;
  border-radius: var(--radius);
}
@keyframes skeletonShimmer{
  0%{ background-position: 200% 0 }
  100%{ background-position: -200% 0 }
}

/* ─═══ Turnstile widget styling ═══─ */
.cf-turnstile{ margin: 12px 0 }

/* ═══════════════════════════════════════════════════════════
   v2.2 DIAMOND — SECURITY 10/10 · MOBILE 10/10
   ═══════════════════════════════════════════════════════════ */

/* ─── Touch action & tap highlight ─── */
*{
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  touch-action: manipulation;
}
input, textarea, select{
  touch-action: manipulation;
  -webkit-appearance: none;
  appearance: none;
}

/* ─── Prevent iOS input zoom ─── */
@media screen and (max-width: 768px){
  input[type="text"],
  input[type="email"],
  input[type="number"],
  input[type="tel"],
  input[type="url"],
  textarea,
  select{
    font-size: 16px !important;
  }
}

/* ─── Scroll snap for cards on mobile ─── */
@media (max-width: 768px){
  .officina-grid,
  .junge-grid,
  .inst-grid{
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding: 8px 0;
    scrollbar-width: none;
  }
  .officina-grid::-webkit-scrollbar,
  .junge-grid::-webkit-scrollbar,
  .inst-grid::-webkit-scrollbar{ display: none }
  .officina-grid > *,
  .junge-grid > *,
  .inst-grid > *{
    flex: 0 0 85%;
    scroll-snap-align: center;
  }
}

/* ─── Member card photo 35x45mm ─── */
.member-photo-wrap{
  width: 132px;
  height: 170px;
  border: 2px dashed var(--line);
  border-radius: 8px;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  cursor: pointer;
  transition: all .25s ease;
  flex-shrink: 0;
}
.member-photo-wrap:hover{
  border-color: var(--gold-soft);
  box-shadow: 0 0 0 4px rgba(212,173,74,.1);
}
.member-photo-wrap.has-photo{
  border-style: solid;
  border-color: var(--gold);
}
.member-photo-wrap img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}
.member-photo-placeholder{
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  color: var(--slate);
  font-size: 12px;
  font-weight: 600;
  text-align: center;
  padding: 12px;
}
.member-photo-placeholder svg{
  width: 32px;
  height: 32px;
  opacity: .5;
}
.member-photo-dim{
  font-size: 10px;
  color: var(--slate);
  opacity: .7;
  letter-spacing: 1px;
}
.member-photo-input{
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  z-index: 2;
}

/* ─═══ Safe area for notched phones ═══─ */
@supports (padding: max(0px)){
  .container{
    padding-left: max(16px, env(safe-area-inset-left));
    padding-right: max(16px, env(safe-area-inset-right));
  }
  .scroll-top{
    bottom: max(22px, env(safe-area-inset-bottom));
    right: max(22px, env(safe-area-inset-right));
  }
  .offline-bar{
    padding-top: max(10px, env(safe-area-inset-top));
  }
}

/* ─═══ Print styles ═══─ */
@media print{
  nav, .scroll-top, .offline-bar, .page-loader, .bot-panel, .bot-float{
    display: none !important;
  }
  section{ page-break-inside: avoid }
  body{ background: white; color: black }
  .card{ break-inside: avoid; box-shadow: none; border: 1px solid #ccc }
}


/* ═══════════════════════════════════════════════════════════
   TOAST NOTIFICATIONS · Share · Confetti · Sound
   Јаготка на тортата · v2.4 PLATINUM
   ═══════════════════════════════════════════════════════════ */

/* ─── Toast container ─── */
.toast-container{
  position:fixed;
  top:24px;
  right:24px;
  z-index:400;
  display:flex;
  flex-direction:column;
  gap:12px;
  max-width:380px;
  pointer-events:none;
}
.toast{
  background:var(--cream);
  border:1.5px solid var(--line);
  border-radius:var(--radius);
  padding:16px 20px;
  box-shadow:var(--shadow-lg);
  display:flex;
  align-items:center;
  gap:12px;
  font-size:14px;
  color:var(--navy);
  font-weight:500;
  transform:translateX(120%);
  opacity:0;
  transition:all .45s cubic-bezier(.4,0,.2,1);
  pointer-events:auto;
  position:relative;
  overflow:hidden;
}
.toast.show{
  transform:translateX(0);
  opacity:1;
}
.toast.toast-success{
  border-color:rgba(39,174,96,.4);
  background:linear-gradient(135deg,#fff,#f0fff4);
}
.toast.toast-error{
  border-color:rgba(192,57,43,.3);
  background:linear-gradient(135deg,#fff,#fdf2f2);
}
.toast.toast-info{
  border-color:rgba(52,152,219,.3);
  background:linear-gradient(135deg,#fff,#ebf5fb);
}
.toast.toast-gold{
  border-color:rgba(212,173,74,.4);
  background:linear-gradient(135deg,#fff,#fffaf0);
}
.toast-icon{
  font-size:20px;
  flex-shrink:0;
}
.toast-content{
  flex:1;
  line-height:1.45;
}
.toast-close{
  background:none;
  border:none;
  font-size:18px;
  color:var(--slate);
  cursor:pointer;
  padding:0;
  width:24px;
  height:24px;
  display:grid;
  place-items:center;
  border-radius:50%;
  transition:all .2s ease;
  flex-shrink:0;
}
.toast-close:hover{
  background:rgba(0,0,0,.08);
  color:var(--navy);
}
.toast-progress{
  position:absolute;
  bottom:0;
  left:0;
  height:3px;
  background:var(--gold);
  border-radius:0 0 0 var(--radius);
  animation:toastProgress 4s linear forwards;
}
@keyframes toastProgress{
  from{width:100%}
  to{width:0%}
}

/* ─── Share button (per section) ─── */
.section-share{
  position:absolute;
  top:20px;
  right:20px;
  z-index:10;
  opacity:0;
  transition:opacity .3s ease;
}
section:hover .section-share,
section:focus-within .section-share{
  opacity:1;
}
.share-btn{
  width:36px;
  height:36px;
  border-radius:50%;
  background:var(--cream);
  border:1.5px solid var(--line);
  color:var(--slate);
  display:grid;
  place-items:center;
  cursor:pointer;
  transition:all .25s ease;
  box-shadow:0 2px 8px rgba(0,0,0,.08);
}
.share-btn:hover{
  border-color:var(--gold-soft);
  color:var(--navy);
  transform:scale(1.1);
  box-shadow:0 4px 14px rgba(0,0,0,.12);
}
.share-btn svg{
  width:16px;
  height:16px;
}

/* ─── Confetti canvas ─── */
#confettiCanvas{
  position:fixed;
  inset:0;
  z-index:350;
  pointer-events:none;
  width:100%;
  height:100%;
}

/* ─── Mobile toast ─── */
@media (max-width: 768px){
  .toast-container{
    top:auto;
    bottom:24px;
    right:16px;
    left:16px;
    max-width:none;
  }
  .toast{
    transform:translateY(120%);
  }
  .toast.show{
    transform:translateY(0);
  }
  .section-share{
    opacity:1;
    top:12px;
    right:12px;
  }
  .share-btn{
    width:32px;
    height:32px;
  }
}



/* ═══ v17 FINAL POLISH ═══ */

/* Visual feedback when language switches */
@keyframes lang-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(212,173,74,.6); }
  70%  { box-shadow: 0 0 0 10px rgba(212,173,74,0); }
  100% { box-shadow: 0 0 0 0 rgba(212,173,74,0); }
}
.lang-btn.active {
  animation: lang-pulse 0.6s ease-out;
}
html.lang-changing main {
  animation: lang-fade 0.4s ease;
}
@keyframes lang-fade {
  0%   { opacity: 0.6; }
  100% { opacity: 1; }
}

/* QR card · final polish */
.mc-qr-col .qr-real,
.mc-qr-col .qr-fallback {
  transition: transform 0.3s ease;
}
.mc-qr-col:hover .qr-real,
.mc-qr-col:hover .qr-fallback {
  transform: scale(1.08);
}

/* "Powered by" footer hint */
.v17-footer-hint {
  text-align: center;
  font-size: 11px;
  color: var(--muted);
  padding: 16px 0;
  letter-spacing: 0.5px;
  opacity: 0.7;
  font-family: var(--mono);
}
.v17-footer-hint::before {
  content: "✦ ";
  color: var(--gold);
}

/* Better focus on form inputs */
input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--gold) !important;
  box-shadow: 0 0 0 3px rgba(212,173,74,.18);
}

/* ═══ v17 ADDITIONS · A11y, performance, polish ═══ */

/* visually-hidden helper for screen-reader-only labels */
.visually-hidden{
  position:absolute !important;
  width:1px;height:1px;
  padding:0;margin:-1px;
  overflow:hidden;clip:rect(0,0,0,0);
  white-space:nowrap;border:0;
}

/* Skip-link for keyboard users */
.skip-link{
  position:absolute;
  top:-100px;left:0;
  background:var(--navy);
  color:var(--gold-soft);
  padding:12px 20px;
  font-weight:700;
  text-decoration:none;
  z-index:9999;
  border-radius:0 0 8px 0;
  transition:top .2s ease;
}
.skip-link:focus{top:0;outline:2px solid var(--gold);outline-offset:-4px}

/* Stronger focus-visible rings */
*:focus-visible{
  outline:3px solid var(--gold);
  outline-offset:2px;
  border-radius:4px;
}
.btn:focus-visible,
.lang-btn:focus-visible,
.theme-toggle:focus-visible,
.menu-toggle:focus-visible{
  outline:3px solid var(--gold);
  outline-offset:3px;
  box-shadow:0 0 0 6px rgba(212,173,74,.25);
}

/* Reduced-motion support */
@media (prefers-reduced-motion: reduce){
  *,*::before,*::after{
    animation-duration:.01ms !important;
    animation-iteration-count:1 !important;
    transition-duration:.01ms !important;
    scroll-behavior:auto !important;
  }
  .reveal{opacity:1 !important;transform:none !important}
}

/* prefers-color-scheme: dark — but only auto-apply if user hasn't picked a theme */
@media (prefers-color-scheme: dark){
  html:not([data-theme]){
    color-scheme:dark;
  }
}

/* MOBILE MENU — improved overlay + transitions */
@media (max-width: 980px){
  .links{
    position:fixed;
    top:0;right:0;
    width:min(85vw, 360px);
    height:100dvh;
    background:var(--paper);
    border-left:1px solid var(--line);
    box-shadow:-12px 0 40px rgba(8,26,51,.25);
    flex-direction:column !important;
    align-items:stretch !important;
    gap:0 !important;
    padding:88px 24px 32px !important;
    overflow-y:auto;
    overscroll-behavior:contain;
    transform:translateX(100%);
    transition:transform .35s cubic-bezier(.2,.9,.3,1);
    z-index:1000;
  }
  .links.open{transform:translateX(0)}
  .links a{
    padding:14px 12px !important;
    border-bottom:1px solid var(--line-soft);
    border-radius:0 !important;
    font-size:15px;
    width:100%;
    text-align:left;
  }
  .links a:hover{background:var(--cream-soft)}
  body.menu-open{overflow:hidden}
  /* Backdrop */
  .menu-backdrop{
    position:fixed;inset:0;
    background:rgba(8,26,51,.45);
    backdrop-filter:blur(4px);
    opacity:0;
    pointer-events:none;
    transition:opacity .25s ease;
    z-index:999;
  }
  .menu-backdrop.show{opacity:1;pointer-events:auto}
}

/* Toast — improve a11y */
.toast{role:status}
.toast-container[aria-live]{position:fixed}

/* Loading shimmer for poll/Firebase */
.poll-loading{
  display:flex;align-items:center;justify-content:center;
  min-height:120px;color:var(--muted);
  gap:12px;
}
.poll-loading::before{
  content:"";
  width:18px;height:18px;
  border:2.5px solid var(--line);
  border-top-color:var(--gold);
  border-radius:50%;
  animation:poll-spin .8s linear infinite;
}
@keyframes poll-spin{to{transform:rotate(360deg)}}
.poll-error{
  background:#fef3f3;color:#9a2828;border:1px solid #f5c2c2;
  padding:14px 18px;border-radius:10px;
  font-size:14px;line-height:1.5;
}
[data-theme="dark"] .poll-error{background:#3a1a1a;color:#ffb6b6;border-color:#5a2929}
.poll-offline-banner{
  background:linear-gradient(135deg, var(--gold-soft), var(--gold));
  color:var(--navy-deep);
  padding:10px 16px;border-radius:10px;
  font-size:13px;font-weight:600;
  display:none;
}
.poll-offline-banner.show{display:block}

/* Lazy image fade-in */
img[loading="lazy"]{
  opacity:0;
  transition:opacity .35s ease;
}
img[loading="lazy"].loaded,
img[loading="lazy"][data-loaded="true"]{
  opacity:1;
}

/* Better dark-mode contrast on cards */
[data-theme="dark"] .newsletter-box{
  background:linear-gradient(135deg, var(--paper), var(--cream-soft));
  border-color:var(--line);
}
[data-theme="dark"] .newsletter-box h3{color:var(--ink)}
[data-theme="dark"] .newsletter-box p{color:var(--muted)}
[data-theme="dark"] .newsletter-form input[type=email]{
  background:var(--cream-soft);
  border-color:var(--line);
  color:var(--ink);
}
[data-theme="dark"] footer{background:var(--cream-soft);color:var(--muted)}
[data-theme="dark"] .footer-col h4{color:var(--ink)}
[data-theme="dark"] .footer-col a{color:var(--muted)}
[data-theme="dark"] .footer-col a:hover{color:var(--gold-soft)}

/* RTL prep (no current RTL langs but future-ready) */
html[dir="rtl"] .lang-switcher{margin-left:4px;margin-right:0}
html[dir="rtl"] .links{right:auto;left:0;border-left:none;border-right:1px solid var(--line)}
html[dir="rtl"] .links{transform:translateX(-100%)}
html[dir="rtl"] .links.open{transform:translateX(0)}

/* Print-friendly */
@media print{
  header,.lang-switcher,.theme-toggle,.menu-toggle,
  #botFloat,#scrollProgress,.toast-container,
  #newsletter,.poll-tool,.cm-form-grid{display:none !important}
  body{color:#000;background:#fff}
  a{color:#000;text-decoration:underline}
}


/* Party addresses (v17 phase 9) */
.wp-addr{
  font-size: 11px;
  color: var(--muted);
  margin-top: 8px;
  padding: 6px 8px;
  background: var(--cream-soft);
  border-radius: 6px;
  border-left: 2px solid var(--gold);
  line-height: 1.4;
  font-family: var(--mono);
  letter-spacing: 0.2px;
}
[data-theme="dark"] .wp-addr{
  background: var(--paper);
  color: var(--muted);
}
.wp-web{
  font-size: 11px;
  margin-top: 4px;
}
.wp-web a{
  color: var(--gold-deep);
  text-decoration: none;
  font-weight: 600;
}
.wp-web a:hover{
  text-decoration: underline;
}
[data-theme="dark"] .wp-web a{
  color: var(--gold-soft);
}


/* ═══ NETWORKING / PARTY PARTNERSHIP SYSTEM (v17 phase 10) ═══ */
.pn-section{padding:80px 0;background:linear-gradient(180deg,var(--cream-soft),var(--cream))}
[data-theme="dark"] .pn-section{background:linear-gradient(180deg,var(--paper),var(--cream-soft))}

.pn-intro{
  max-width:880px;margin:0 auto 36px;text-align:center;
}
.pn-intro p{color:var(--muted);font-size:15px;line-height:1.7;margin:12px 0 0}

/* Partnership type cards */
.pn-types{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;
  margin:0 0 36px;
}
.pn-type{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:18px 16px;
  cursor:pointer;
  transition:all .25s ease;
  display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;
  position:relative;
}
.pn-type:hover{
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:var(--shadow);
}
.pn-type.active{
  border-color:var(--gold);
  background:linear-gradient(135deg,var(--paper),rgba(212,173,74,.08));
  box-shadow:0 8px 24px rgba(212,173,74,.18);
}
.pn-type-icon{font-size:32px;line-height:1}
.pn-type-name{
  font-family:var(--serif);font-size:15px;font-weight:600;
  color:var(--navy);letter-spacing:.2px;
}
[data-theme="dark"] .pn-type-name{color:var(--ink)}
.pn-type-desc{font-size:11px;color:var(--muted);line-height:1.4}

/* Form & directory grid */
.pn-grid{
  display:grid;grid-template-columns:1fr 1.2fr;gap:24px;
  margin-top:24px;
}
@media (max-width:980px){
  .pn-grid{grid-template-columns:1fr}
}

.pn-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;
  padding:24px;
}
.pn-card h3{
  margin:0 0 16px;font-family:var(--serif);font-size:20px;color:var(--navy);
  display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .pn-card h3{color:var(--ink)}

/* Form */
.pn-form{display:flex;flex-direction:column;gap:14px}
.pn-form label{
  font-size:12px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.5px;font-weight:700;display:block;margin-bottom:4px;
}
.pn-form input, .pn-form select, .pn-form textarea{
  width:100%;padding:10px 12px;
  border:1.5px solid var(--line);border-radius:8px;
  background:var(--cream-soft);color:var(--ink);
  font-family:var(--sans);font-size:14px;
  transition:all .2s ease;
}
[data-theme="dark"] .pn-form input,
[data-theme="dark"] .pn-form select,
[data-theme="dark"] .pn-form textarea{background:var(--cream);color:var(--ink)}
.pn-form input:focus, .pn-form select:focus, .pn-form textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.pn-form textarea{min-height:90px;resize:vertical;font-family:var(--sans)}
.pn-target-display{
  background:linear-gradient(135deg,var(--cream-soft),rgba(212,173,74,.06));
  border:1.5px solid var(--gold-soft);
  border-radius:10px;
  padding:14px 16px;
  margin:6px 0;
  display:flex;align-items:center;gap:12px;
}
[data-theme="dark"] .pn-target-display{
  background:linear-gradient(135deg,var(--paper),rgba(212,173,74,.1));
}
.pn-target-flag{font-size:32px;flex-shrink:0}
.pn-target-info{flex:1;min-width:0}
.pn-target-name{
  font-family:var(--serif);font-size:16px;font-weight:600;
  color:var(--navy);margin:0;
}
[data-theme="dark"] .pn-target-name{color:var(--ink)}
.pn-target-country{font-size:12px;color:var(--muted);margin:2px 0 0}
.pn-target-block{
  font-size:10px;text-transform:uppercase;letter-spacing:1px;
  color:var(--gold-deep);font-weight:700;margin-top:4px;
}

/* Directory / searchable list */
.pn-search-wrap{position:relative;margin-bottom:14px}
.pn-search-wrap input{padding-left:36px !important}
.pn-search-wrap::before{
  content:"🔍";position:absolute;left:12px;top:50%;
  transform:translateY(-50%);font-size:14px;
  pointer-events:none;
}

.pn-filter-pills{
  display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;
}
.pn-pill{
  padding:5px 12px;border-radius:20px;
  border:1.5px solid var(--line);background:transparent;
  font-size:11px;font-weight:700;color:var(--muted);
  cursor:pointer;transition:all .2s ease;
  letter-spacing:.3px;
}
.pn-pill:hover{border-color:var(--gold-soft);color:var(--navy)}
[data-theme="dark"] .pn-pill:hover{color:var(--ink)}
.pn-pill.active{
  background:var(--navy);
  border-color:var(--navy);
  color:var(--gold-soft);
}

.pn-list{
  max-height:520px;overflow-y:auto;
  display:flex;flex-direction:column;gap:6px;
  padding:4px;margin:-4px;
}
.pn-list::-webkit-scrollbar{width:6px}
.pn-list::-webkit-scrollbar-track{background:transparent}
.pn-list::-webkit-scrollbar-thumb{background:var(--line);border-radius:3px}

.pn-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 12px;
  border:1.5px solid var(--line-soft);
  border-radius:8px;
  cursor:pointer;
  transition:all .15s ease;
  background:var(--cream-soft);
}
[data-theme="dark"] .pn-item{background:var(--cream);border-color:var(--line)}
.pn-item:hover{
  border-color:var(--gold-soft);
  transform:translateX(2px);
}
.pn-item.selected{
  border-color:var(--gold);
  background:linear-gradient(135deg,var(--cream-soft),rgba(212,173,74,.08));
  box-shadow:0 4px 12px rgba(212,173,74,.15);
}
[data-theme="dark"] .pn-item.selected{
  background:linear-gradient(135deg,var(--cream),rgba(212,173,74,.12));
}
.pn-item-flag{font-size:22px;line-height:1;flex-shrink:0}
.pn-item-info{flex:1;min-width:0;overflow:hidden}
.pn-item-name{
  font-family:var(--serif);font-size:14px;font-weight:600;
  color:var(--navy);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
[data-theme="dark"] .pn-item-name{color:var(--ink)}
.pn-item-meta{
  font-size:11px;color:var(--muted);margin-top:2px;
  display:flex;align-items:center;gap:8px;
}
.pn-item-block-dot{
  display:inline-block;width:8px;height:8px;border-radius:50%;
  flex-shrink:0;
}
.pn-item-block-dot.center-right{background:#3a76c2}
.pn-item-block-dot.center-left{background:#c2453a}
.pn-item-block-dot.liberal{background:#e0c14d}
.pn-item-block-dot.green{background:#5fa05c}
.pn-item-block-dot.conservative{background:#9b6fbb}
.pn-item-block-dot.meritocratic{background:var(--gold)}

/* Status tracker */
.pn-status-tracker{
  background:var(--paper);
  border-radius:14px;border:1.5px solid var(--line);
  padding:24px;margin-top:24px;
}
.pn-tracker-list{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:14px;margin-top:14px;
}
.pn-tracker-item{
  border:1.5px solid var(--line);border-radius:10px;
  padding:14px;background:var(--cream-soft);
  display:flex;flex-direction:column;gap:6px;
}
[data-theme="dark"] .pn-tracker-item{background:var(--cream);border-color:var(--line)}
.pn-tracker-head{
  display:flex;justify-content:space-between;align-items:center;gap:8px;
}
.pn-tracker-flag{font-size:20px;line-height:1}
.pn-tracker-name{
  font-family:var(--serif);font-size:13px;font-weight:600;color:var(--navy);
  flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
[data-theme="dark"] .pn-tracker-name{color:var(--ink)}
.pn-tracker-status{
  font-size:9px;text-transform:uppercase;letter-spacing:1px;
  font-weight:700;padding:3px 8px;border-radius:10px;
}
.pn-tracker-status.initiated{background:rgba(212,173,74,.18);color:var(--gold-deep)}
.pn-tracker-status.in-progress{background:rgba(58,167,93,.18);color:#2c7a4a}
.pn-tracker-status.active{background:rgba(95,206,126,.18);color:#1f7546}
.pn-tracker-status.concluded{background:var(--line);color:var(--muted)}
.pn-tracker-meta{font-size:11px;color:var(--muted);margin-top:4px;line-height:1.5}
.pn-tracker-actions{display:flex;gap:6px;margin-top:8px}
.pn-tracker-actions button{
  flex:1;padding:5px 8px;font-size:11px;
  border:1px solid var(--line);
  background:transparent;
  color:var(--ink);
  border-radius:6px;cursor:pointer;
  transition:all .15s ease;
}
.pn-tracker-actions button:hover{
  border-color:var(--gold);
  background:rgba(212,173,74,.08);
}
.pn-tracker-empty{
  grid-column:1/-1;text-align:center;padding:32px 16px;
  color:var(--muted);font-size:13px;font-style:italic;
}

/* Submit button */
.pn-submit{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:13px 24px;
  border:none;border-radius:10px;
  font-family:var(--sans);font-size:14px;font-weight:700;
  letter-spacing:.5px;text-transform:uppercase;
  cursor:pointer;
  transition:all .25s ease;
  box-shadow:0 8px 22px rgba(212,173,74,.3);
}
.pn-submit:hover:not(:disabled){
  transform:translateY(-2px);
  box-shadow:0 12px 30px rgba(212,173,74,.4);
}
.pn-submit:disabled{opacity:.5;cursor:not-allowed;box-shadow:none}

.pn-secondary-btn{
  background:transparent;
  border:1.5px solid var(--line);
  color:var(--ink);
  padding:10px 18px;border-radius:10px;
  font-family:var(--sans);font-size:13px;font-weight:600;
  cursor:pointer;transition:all .2s ease;
}
.pn-secondary-btn:hover{
  border-color:var(--gold);
  color:var(--gold-deep);
}

/* Stats strip */
.pn-stats{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:12px;margin:24px 0;
}
.pn-stat{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:10px;
  padding:14px;text-align:center;
}
.pn-stat-num{
  font-family:var(--serif);font-size:28px;font-weight:700;
  color:var(--gold-deep);line-height:1;
}
.pn-stat-label{
  font-size:11px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.5px;margin-top:6px;font-weight:700;
}


/* ═══ MUNICIPALITIES DETAILED DIRECTORY (v17 phase 11) ═══ */
.muni-directory{
  margin-top:32px;
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;
  padding:24px;
}
.muni-dir-head{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:16px;flex-wrap:wrap;gap:12px;
}
.muni-dir-head h3{
  margin:0;font-family:var(--serif);font-size:20px;color:var(--navy);
}
[data-theme="dark"] .muni-dir-head h3{color:var(--ink)}

.muni-stats-strip{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:10px;margin-bottom:18px;
}
.muni-stat{
  background:linear-gradient(135deg,var(--cream-soft),rgba(212,173,74,.05));
  border:1px solid var(--line);
  border-radius:10px;
  padding:12px 10px;text-align:center;
}
[data-theme="dark"] .muni-stat{
  background:linear-gradient(135deg,var(--cream),rgba(212,173,74,.05));
}
.muni-stat-num{
  font-family:var(--serif);font-size:22px;font-weight:700;
  color:var(--gold-deep);line-height:1;
}
.muni-stat-label{
  font-size:10px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.5px;margin-top:5px;font-weight:700;
}

.muni-toolbar{
  display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;
  align-items:center;
}
.muni-search-wrap{position:relative;flex:1;min-width:200px}
.muni-search-wrap::before{
  content:"🔍";position:absolute;left:12px;top:50%;
  transform:translateY(-50%);font-size:14px;pointer-events:none;
}
.muni-search-wrap input{
  width:100%;padding:9px 12px 9px 36px;
  border:1.5px solid var(--line);border-radius:8px;
  background:var(--cream-soft);color:var(--ink);
  font-family:var(--sans);font-size:14px;
  transition:all .2s ease;
}
[data-theme="dark"] .muni-search-wrap input{background:var(--cream)}
.muni-search-wrap input:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}

.muni-coord-filter{
  padding:9px 12px;border:1.5px solid var(--line);border-radius:8px;
  background:var(--cream-soft);color:var(--ink);font-size:13px;
  font-family:var(--sans);cursor:pointer;
}
[data-theme="dark"] .muni-coord-filter{background:var(--cream)}

.muni-region-pills{
  display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;
}
.muni-rpill{
  padding:5px 12px;border-radius:20px;
  border:1.5px solid var(--line);background:transparent;
  font-size:11px;font-weight:700;color:var(--muted);
  cursor:pointer;transition:all .2s ease;
  display:inline-flex;align-items:center;gap:5px;
}
.muni-rpill:hover{border-color:var(--gold-soft);color:var(--navy)}
[data-theme="dark"] .muni-rpill:hover{color:var(--ink)}
.muni-rpill.active{
  background:var(--navy);border-color:var(--navy);color:var(--gold-soft);
}

.muni-table-wrap{
  max-height:560px;overflow-y:auto;
  border:1px solid var(--line-soft);border-radius:8px;
}
.muni-table-wrap::-webkit-scrollbar{width:6px}
.muni-table-wrap::-webkit-scrollbar-thumb{background:var(--line);border-radius:3px}

.muni-table{
  width:100%;border-collapse:collapse;font-size:13px;
}
.muni-table thead{
  position:sticky;top:0;background:var(--cream-soft);z-index:2;
  border-bottom:1.5px solid var(--line);
}
[data-theme="dark"] .muni-table thead{background:var(--paper)}
.muni-table th{
  text-align:left;padding:10px 12px;font-weight:700;
  text-transform:uppercase;font-size:10px;letter-spacing:.5px;
  color:var(--muted);
}
.muni-table th.sortable{cursor:pointer;user-select:none}
.muni-table th.sortable:hover{color:var(--gold-deep)}
.muni-table th.sortable::after{content:" ⇅";opacity:.4;font-size:9px}
.muni-table th.sort-asc::after{content:" ↑";opacity:1;color:var(--gold-deep)}
.muni-table th.sort-desc::after{content:" ↓";opacity:1;color:var(--gold-deep)}
.muni-table td{
  padding:10px 12px;border-top:1px solid var(--line-soft);
  vertical-align:middle;
}
.muni-table tr{transition:background .15s ease}
.muni-table tr:hover{background:rgba(212,173,74,.06)}
[data-theme="dark"] .muni-table tr:hover{background:rgba(212,173,74,.08)}

.muni-row-name{
  font-family:var(--serif);font-weight:600;color:var(--navy);
  font-size:14px;
}
[data-theme="dark"] .muni-row-name{color:var(--ink)}
.muni-row-region{
  font-size:11px;color:var(--muted);
  display:flex;align-items:center;gap:4px;
}
.muni-row-pop{
  font-family:var(--mono);font-size:13px;color:var(--ink);
}
.muni-row-area{
  font-family:var(--mono);font-size:12px;color:var(--muted);
}
.muni-coord-badge{
  display:inline-block;padding:3px 10px;border-radius:12px;
  font-size:10px;font-weight:700;text-transform:uppercase;
  letter-spacing:.5px;
}
.muni-coord-badge.active{
  background:rgba(95,206,126,.18);color:#1f7546;
}
.muni-coord-badge.seeking{
  background:rgba(212,173,74,.18);color:var(--gold-deep);
}
[data-theme="dark"] .muni-coord-badge.active{
  background:rgba(95,206,126,.22);color:#5fce7e;
}
[data-theme="dark"] .muni-coord-badge.seeking{
  background:rgba(212,173,74,.22);color:var(--gold-soft);
}
.muni-row-action{
  font-size:11px;color:var(--gold-deep);text-decoration:none;font-weight:600;
}
.muni-row-action:hover{text-decoration:underline}
[data-theme="dark"] .muni-row-action{color:var(--gold-soft)}

/* Detail expansion row */
.muni-row-detail{display:none;background:var(--cream-soft) !important}
.muni-row-detail.show{display:table-row}
[data-theme="dark"] .muni-row-detail{background:var(--cream) !important}
.muni-detail-cell{padding:12px 16px !important}
.muni-detail-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:14px;
}
.muni-detail-item{
  display:flex;flex-direction:column;gap:2px;
}
.muni-detail-label{
  font-size:10px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.5px;font-weight:700;
}
.muni-detail-value{
  font-size:13px;color:var(--ink);font-weight:500;
}
.muni-detail-value a{color:var(--gold-deep);text-decoration:none}
.muni-detail-value a:hover{text-decoration:underline}
[data-theme="dark"] .muni-detail-value a{color:var(--gold-soft)}

.muni-detail-actions{
  display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;
  padding-top:10px;border-top:1px dashed var(--line);
}
.muni-detail-btn{
  padding:6px 12px;border:1.5px solid var(--line);border-radius:6px;
  background:transparent;color:var(--ink);font-size:11px;
  cursor:pointer;font-weight:600;text-decoration:none;
  display:inline-flex;align-items:center;gap:4px;
  transition:all .15s ease;
}
.muni-detail-btn:hover{border-color:var(--gold);color:var(--gold-deep)}
.muni-detail-btn.primary{
  background:var(--navy);color:var(--gold-soft);border-color:var(--navy);
}
.muni-detail-btn.primary:hover{
  background:var(--navy-mid);
}

.muni-empty{
  padding:32px;text-align:center;color:var(--muted);font-style:italic;
}


/* ═══ MAGAZINE V2 (v17 phase 12) ═══ */
.mag-v2-toolbar{
  display:flex;gap:10px;flex-wrap:wrap;align-items:center;
  margin-bottom:18px;
}
.mag-v2-search{
  flex:1;min-width:220px;position:relative;
}
.mag-v2-search::before{
  content:"🔍";position:absolute;left:12px;top:50%;
  transform:translateY(-50%);font-size:14px;pointer-events:none;
}
.mag-v2-search input{
  width:100%;padding:10px 14px 10px 38px;
  border:1.5px solid var(--line);border-radius:10px;
  background:var(--paper);color:var(--ink);
  font-family:var(--sans);font-size:14px;
}
[data-theme="dark"] .mag-v2-search input{background:var(--cream)}
.mag-v2-search input:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.mag-v2-pills{
  display:flex;gap:6px;flex-wrap:wrap;
}
.mag-v2-pill{
  padding:6px 14px;border-radius:20px;
  border:1.5px solid var(--line);background:transparent;
  font-size:11px;font-weight:700;color:var(--muted);
  cursor:pointer;transition:all .2s ease;letter-spacing:.3px;
}
.mag-v2-pill:hover{border-color:var(--gold-soft);color:var(--navy)}
[data-theme="dark"] .mag-v2-pill:hover{color:var(--ink)}
.mag-v2-pill.active{
  background:var(--navy);border-color:var(--navy);color:var(--gold-soft);
}

/* Daily highlight banner (rotates) */
.mag-daily-banner{
  background:linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 60%,rgba(212,173,74,.2) 100%);
  color:#fff;
  border-radius:14px;padding:24px 28px;
  margin:18px 0 24px;
  position:relative;overflow:hidden;
  cursor:pointer;
  transition:all .3s ease;
}
.mag-daily-banner:hover{
  transform:translateY(-2px);
  box-shadow:0 14px 36px rgba(8,26,51,.3);
}
.mag-daily-banner::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.mag-daily-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:4px 12px;border-radius:14px;
  font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  margin-bottom:10px;
}
.mag-daily-banner h3{
  font-family:var(--serif);font-size:22px;color:#fff;margin:0 0 8px;
  position:relative;z-index:2;line-height:1.3;
}
.mag-daily-banner p{
  color:rgba(255,255,255,.85);font-size:14px;line-height:1.6;
  margin:0;position:relative;z-index:2;
}
.mag-daily-meta{
  display:flex;gap:16px;flex-wrap:wrap;margin-top:12px;
  font-size:12px;color:rgba(255,255,255,.7);
  position:relative;z-index:2;
}

/* Card grid */
.mag-v2-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
  gap:18px;
}
.mag-v2-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:18px;
  cursor:pointer;
  transition:all .25s ease;
  display:flex;flex-direction:column;gap:10px;
  position:relative;
}
.mag-v2-card:hover{
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:0 12px 28px rgba(8,26,51,.12);
}
[data-theme="dark"] .mag-v2-card:hover{
  box-shadow:0 12px 28px rgba(0,0,0,.4);
}
.mag-v2-card-fav{
  position:absolute;top:12px;right:12px;
  background:none;border:none;cursor:pointer;
  font-size:18px;opacity:.4;transition:all .2s ease;
}
.mag-v2-card-fav:hover{opacity:1;transform:scale(1.15)}
.mag-v2-card-fav.fav{opacity:1;color:var(--gold-deep)}
.mag-v2-card-head{
  display:flex;align-items:center;gap:10px;
}
.mag-v2-card-flag{font-size:28px;line-height:1;flex-shrink:0}
.mag-v2-card-meta{flex:1;min-width:0}
.mag-v2-card-meta strong{
  font-family:var(--sans);font-size:13px;color:var(--navy);
  display:block;font-weight:700;
}
[data-theme="dark"] .mag-v2-card-meta strong{color:var(--ink)}
.mag-v2-card-meta span{
  font-size:11px;color:var(--muted);
  display:block;margin-top:2px;
}
.mag-v2-card h4{
  font-family:var(--serif);font-size:17px;color:var(--navy);
  margin:0;line-height:1.4;font-weight:700;
}
[data-theme="dark"] .mag-v2-card h4{color:var(--ink)}
.mag-v2-card p{
  font-size:13px;color:var(--muted);line-height:1.55;margin:0;
}
.mag-v2-card-foot{
  display:flex;justify-content:space-between;align-items:center;
  margin-top:auto;padding-top:10px;
  border-top:1px dashed var(--line);
  font-size:11px;
}
.mag-v2-card-src{color:var(--gold-deep);font-weight:600}
.mag-v2-card-date{color:var(--muted);font-family:var(--mono)}
.mag-v2-card-tags{
  display:flex;gap:5px;flex-wrap:wrap;
}
.mag-v2-tag{
  font-size:10px;background:var(--cream-soft);
  color:var(--navy);padding:2px 8px;border-radius:8px;
  font-weight:600;text-transform:uppercase;letter-spacing:.3px;
}
[data-theme="dark"] .mag-v2-tag{background:var(--cream);color:var(--ink)}

/* Modal */
.mag-modal{
  display:none;
  position:fixed;inset:0;
  background:rgba(8,26,51,.7);
  backdrop-filter:blur(6px);
  z-index:9999;
  align-items:center;justify-content:center;
  padding:20px;
  animation:mag-modal-in .2s ease;
}
@keyframes mag-modal-in{from{opacity:0}to{opacity:1}}
.mag-modal.show{display:flex}
.mag-modal-card{
  background:var(--paper);
  border-radius:16px;
  max-width:760px;width:100%;
  max-height:90vh;overflow-y:auto;
  position:relative;
  animation:mag-modal-up .25s cubic-bezier(.2,.9,.3,1);
}
@keyframes mag-modal-up{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.mag-modal-card::-webkit-scrollbar{width:8px}
.mag-modal-card::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px}
.mag-modal-close{
  position:absolute;top:14px;right:14px;
  width:36px;height:36px;
  background:var(--cream-soft);
  border:none;border-radius:50%;
  font-size:20px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  color:var(--ink);transition:all .2s ease;z-index:2;
}
[data-theme="dark"] .mag-modal-close{background:var(--cream)}
.mag-modal-close:hover{background:var(--gold);color:var(--navy-deep)}
.mag-modal-hero{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;padding:32px 32px 24px;
  border-radius:16px 16px 0 0;
  position:relative;overflow:hidden;
}
.mag-modal-hero::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.2),transparent 70%);
  pointer-events:none;
}
.mag-modal-hero-flag{
  font-size:64px;line-height:1;margin-bottom:10px;
  position:relative;z-index:2;
}
.mag-modal-hero h2{
  font-family:var(--serif);color:#fff;margin:0;
  font-size:26px;line-height:1.3;font-weight:700;
  position:relative;z-index:2;
}
.mag-modal-hero-meta{
  display:flex;gap:14px;flex-wrap:wrap;margin-top:14px;
  font-size:13px;color:rgba(255,255,255,.85);
  position:relative;z-index:2;
}
.mag-modal-hero-meta strong{color:var(--gold-soft);font-weight:700}
.mag-modal-body{padding:24px 32px 28px}
.mag-modal-body p.lede{
  font-size:16px;color:var(--ink);line-height:1.7;
  margin:0 0 16px;font-style:italic;
  border-left:3px solid var(--gold);padding-left:16px;
}
.mag-modal-body p.full{
  font-size:14px;color:var(--ink);line-height:1.75;
  margin:0 0 16px;
}
.mag-modal-tags{
  display:flex;gap:6px;flex-wrap:wrap;margin:16px 0;
}
.mag-modal-mk{
  background:linear-gradient(135deg,var(--cream-soft),rgba(212,173,74,.06));
  border:1.5px solid var(--gold-soft);border-radius:10px;
  padding:16px 18px;margin-top:16px;
}
[data-theme="dark"] .mag-modal-mk{
  background:linear-gradient(135deg,var(--cream),rgba(212,173,74,.08));
}
.mag-modal-mk strong{
  display:block;font-size:11px;color:var(--gold-deep);
  text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;
  font-weight:700;
}
.mag-modal-mk p{font-size:13px;color:var(--ink);line-height:1.6;margin:0}
.mag-modal-actions{
  display:flex;gap:10px;flex-wrap:wrap;margin-top:20px;
  padding-top:16px;border-top:1px dashed var(--line);
}
.mag-modal-btn{
  padding:9px 16px;border-radius:8px;
  font-family:var(--sans);font-size:13px;font-weight:600;
  text-decoration:none;cursor:pointer;border:1.5px solid var(--line);
  background:transparent;color:var(--ink);
  display:inline-flex;align-items:center;gap:5px;
  transition:all .2s ease;
}
.mag-modal-btn:hover{border-color:var(--gold);color:var(--gold-deep)}
.mag-modal-btn.primary{
  background:var(--navy);color:var(--gold-soft);border-color:var(--navy);
}
.mag-modal-btn.primary:hover{background:var(--navy-mid);color:var(--gold)}

/* Empty state */
.mag-v2-empty{
  text-align:center;padding:60px 20px;
  color:var(--muted);font-style:italic;
  grid-column:1/-1;
}

/* Counter pill */
.mag-v2-count{
  font-size:11px;color:var(--muted);
  display:inline-flex;align-items:center;gap:5px;
  margin-left:auto;
}
.mag-v2-count strong{color:var(--gold-deep);font-family:var(--mono)}


/* ═══ INDUSTRIAL CHAMPIONS (v17 phase 13) ═══ */
.ind-section{
  background:linear-gradient(180deg,var(--cream-soft) 0%,var(--cream) 100%);
  padding:80px 0;
}
[data-theme="dark"] .ind-section{
  background:linear-gradient(180deg,var(--paper) 0%,var(--cream-soft) 100%);
}

.ind-intro{
  max-width:920px;margin:0 auto 36px;text-align:center;
}
.ind-intro p{
  color:var(--muted);font-size:15px;line-height:1.7;margin:12px 0 0;
}
.ind-intro p strong{color:var(--gold-deep);font-weight:700}

.ind-vision-strip{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:14px;margin:32px 0;
}
.ind-vision-card{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:12px;padding:18px 16px;text-align:center;
  border:1px solid rgba(212,173,74,.3);
}
.ind-vision-num{
  font-family:var(--serif);font-size:32px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.ind-vision-label{
  font-size:11px;color:rgba(255,255,255,.75);
  text-transform:uppercase;letter-spacing:.5px;margin-top:6px;font-weight:700;
}

.ind-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));
  gap:22px;margin-top:24px;
}

.ind-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:16px;
  padding:0;
  overflow:hidden;
  transition:all .3s ease;
  display:flex;flex-direction:column;
  position:relative;
}
.ind-card:hover{
  transform:translateY(-4px);
  box-shadow:0 16px 40px rgba(8,26,51,.15);
  border-color:var(--gold);
}
[data-theme="dark"] .ind-card:hover{
  box-shadow:0 16px 40px rgba(0,0,0,.5);
}

.ind-card-banner{
  background:linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 50%,rgba(212,173,74,.15) 100%);
  padding:32px 24px 24px;
  position:relative;overflow:hidden;
  color:#fff;
}
.ind-card-banner::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:280px;height:280px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.ind-card-icon{
  font-size:54px;line-height:1;margin-bottom:10px;
  position:relative;z-index:2;display:inline-block;
}
.ind-card-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:3px 10px;border-radius:10px;
  font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:8px;
}
.ind-card-title{
  font-family:var(--serif);color:#fff;
  font-size:22px;line-height:1.25;margin:0;font-weight:700;
  position:relative;z-index:2;
}
.ind-card-subtitle{
  color:rgba(255,255,255,.85);font-size:12px;
  margin-top:6px;position:relative;z-index:2;letter-spacing:.3px;
}

.ind-card-body{
  padding:22px 24px 16px;flex:1;
}
.ind-card-body p{
  color:var(--muted);font-size:13px;line-height:1.7;margin:0 0 12px;
}
.ind-card-body p strong{color:var(--ink);font-weight:600}

.ind-features{
  margin:14px 0 0;
}
.ind-feature{
  display:flex;align-items:flex-start;gap:8px;
  padding:7px 0;border-top:1px dashed var(--line-soft);
  font-size:12px;line-height:1.55;
}
.ind-feature:first-child{border-top:none}
.ind-feat-icon{flex-shrink:0;font-size:14px;line-height:1.4}
.ind-feat-text{color:var(--ink)}
.ind-feat-text strong{color:var(--gold-deep);font-weight:700}

.ind-card-foot{
  background:var(--cream-soft);
  padding:12px 24px;
  border-top:1px solid var(--line);
  display:flex;justify-content:space-between;align-items:center;
  flex-wrap:wrap;gap:8px;
}
[data-theme="dark"] .ind-card-foot{background:var(--cream);border-color:var(--line)}
.ind-card-target{
  font-size:11px;color:var(--muted);
  display:flex;align-items:center;gap:5px;
}
.ind-card-target strong{
  color:var(--gold-deep);font-family:var(--mono);font-size:12px;
}
.ind-card-phase{
  font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;
  padding:3px 10px;border-radius:10px;
  background:rgba(212,173,74,.18);color:var(--gold-deep);
}

/* Multi-phase rollout (for SkyWorld) */
.ind-phases{
  margin-top:14px;
  display:flex;flex-direction:column;gap:8px;
}
.ind-phase{
  display:flex;gap:10px;align-items:flex-start;
  padding:10px 12px;
  background:var(--cream-soft);
  border-left:3px solid var(--gold);
  border-radius:6px;
  font-size:12px;
}
[data-theme="dark"] .ind-phase{background:var(--cream)}
.ind-phase-num{
  flex-shrink:0;width:24px;height:24px;
  background:var(--navy);color:var(--gold-soft);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:12px;font-family:var(--serif);
}
.ind-phase-text{
  flex:1;color:var(--ink);line-height:1.5;
}
.ind-phase-text strong{color:var(--gold-deep);font-weight:700}

@media (max-width:640px){
  .ind-grid{grid-template-columns:1fr}
  .ind-card-banner{padding:24px 18px 20px}
  .ind-card-icon{font-size:42px}
  .ind-card-title{font-size:19px}
}


/* ═══ DIASPORA ENGAGEMENT HUB (v17 phase 14) ═══ */
.dh-section{
  background:linear-gradient(180deg,var(--cream) 0%,var(--cream-soft) 100%);
  padding:80px 0;
}
[data-theme="dark"] .dh-section{
  background:linear-gradient(180deg,var(--cream-soft) 0%,var(--paper) 100%);
}

.dh-intro{
  max-width:880px;margin:0 auto 32px;text-align:center;
}
.dh-intro p{
  font-size:15px;line-height:1.7;color:var(--muted);margin:12px 0 0;
}
.dh-intro p strong{color:var(--gold-deep);font-weight:700}

/* Top stats banner */
.dh-stats-banner{
  background:linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 60%,rgba(212,173,74,.18) 100%);
  border-radius:16px;
  padding:28px 32px;
  margin:24px 0 36px;
  color:#fff;
  position:relative;overflow:hidden;
}
.dh-stats-banner::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:340px;height:340px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.dh-stats-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:14px;position:relative;z-index:2;
}
.dh-stat{text-align:center}
.dh-stat-num{
  font-family:var(--serif);font-size:32px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.dh-stat-label{
  font-size:11px;color:rgba(255,255,255,.8);
  text-transform:uppercase;letter-spacing:.5px;margin-top:6px;font-weight:700;
}

/* Module tabs */
.dh-modules{
  display:flex;gap:8px;flex-wrap:wrap;
  background:var(--paper);
  padding:10px;border-radius:14px;
  border:1.5px solid var(--line);
  margin-bottom:24px;
  overflow-x:auto;
}
.dh-module-btn{
  flex:1;min-width:140px;
  padding:14px 16px;
  background:transparent;
  border:1.5px solid transparent;
  border-radius:10px;
  cursor:pointer;
  font-family:var(--sans);font-size:13px;font-weight:600;
  color:var(--ink);
  display:flex;flex-direction:column;align-items:center;gap:5px;
  transition:all .2s ease;
  text-align:center;line-height:1.3;
}
.dh-module-btn:hover{
  background:var(--cream-soft);
  border-color:var(--line);
}
[data-theme="dark"] .dh-module-btn:hover{background:var(--cream)}
.dh-module-btn.active{
  background:linear-gradient(135deg,var(--navy),var(--navy-mid));
  color:var(--gold-soft);
  border-color:var(--navy);
  box-shadow:0 4px 14px rgba(8,26,51,.3);
}
.dh-module-icon{font-size:22px;line-height:1}
.dh-module-text{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px}

/* Module panel */
.dh-panel{
  display:none;
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:16px;
  padding:32px;
  animation:dh-fadein .25s ease;
}
.dh-panel.active{display:block}
@keyframes dh-fadein{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.dh-panel-head{
  display:flex;align-items:center;gap:14px;margin-bottom:20px;
  padding-bottom:18px;border-bottom:1.5px solid var(--line);
}
.dh-panel-icon{
  font-size:48px;line-height:1;
  background:linear-gradient(135deg,rgba(212,173,74,.15),rgba(212,173,74,.05));
  width:72px;height:72px;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.dh-panel-title{flex:1}
.dh-panel-title h3{
  font-family:var(--serif);font-size:24px;color:var(--navy);
  margin:0 0 4px;font-weight:700;
}
[data-theme="dark"] .dh-panel-title h3{color:var(--ink)}
.dh-panel-title p{
  font-size:13px;color:var(--muted);margin:0;line-height:1.5;
}

.dh-panel-body{
  display:grid;grid-template-columns:1fr 1fr;gap:24px;
  margin-top:18px;
}
@media (max-width:880px){
  .dh-panel-body{grid-template-columns:1fr}
}

.dh-panel-section{
  background:var(--cream-soft);
  padding:20px;border-radius:12px;
  border:1px solid var(--line-soft);
}
[data-theme="dark"] .dh-panel-section{background:var(--cream)}

.dh-panel-section h4{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 12px;font-weight:700;
  display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .dh-panel-section h4{color:var(--ink)}
.dh-panel-section ul{
  list-style:none;padding:0;margin:0 0 12px;
}
.dh-panel-section ul li{
  padding:6px 0;border-bottom:1px dashed var(--line-soft);
  font-size:13px;color:var(--ink);line-height:1.55;
  display:flex;align-items:flex-start;gap:6px;
}
.dh-panel-section ul li:last-child{border-bottom:none}
.dh-panel-section ul li::before{
  content:"✓";color:var(--gold-deep);font-weight:700;flex-shrink:0;
}
.dh-panel-section ul.cons li::before{content:"⚠";color:#c2453a}

/* Form styling */
.dh-form{display:flex;flex-direction:column;gap:14px}
.dh-form label{
  font-size:11px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.4px;font-weight:700;margin-bottom:4px;display:block;
}
.dh-form input, .dh-form select, .dh-form textarea{
  width:100%;padding:10px 12px;
  border:1.5px solid var(--line);border-radius:8px;
  background:var(--paper);color:var(--ink);
  font-family:var(--sans);font-size:14px;
  transition:all .2s ease;
}
[data-theme="dark"] .dh-form input,
[data-theme="dark"] .dh-form select,
[data-theme="dark"] .dh-form textarea{background:var(--cream-soft)}
.dh-form input:focus, .dh-form select:focus, .dh-form textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.dh-form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media (max-width:560px){.dh-form-row{grid-template-columns:1fr}}

.dh-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:13px 20px;
  border:none;border-radius:10px;
  font-family:var(--sans);font-size:13px;font-weight:700;
  letter-spacing:.4px;text-transform:uppercase;cursor:pointer;
  transition:all .25s ease;
  box-shadow:0 6px 18px rgba(212,173,74,.3);
}
.dh-btn:hover:not(:disabled){
  transform:translateY(-2px);
  box-shadow:0 10px 26px rgba(212,173,74,.4);
}
.dh-btn:disabled{opacity:.5;cursor:not-allowed;box-shadow:none}

.dh-btn-secondary{
  background:transparent;
  border:1.5px solid var(--line);
  color:var(--ink);
  padding:11px 18px;border-radius:10px;
  font-size:13px;font-weight:600;cursor:pointer;
  transition:all .2s ease;
  text-decoration:none;
  display:inline-flex;align-items:center;gap:5px;
}
.dh-btn-secondary:hover{border-color:var(--gold);color:var(--gold-deep)}

/* Calculator (used in 0% tax module) */
.dh-calc{
  background:linear-gradient(135deg,var(--cream-soft),rgba(212,173,74,.05));
  border-radius:10px;padding:18px;
  border:1.5px solid var(--gold-soft);margin-top:14px;
}
[data-theme="dark"] .dh-calc{
  background:linear-gradient(135deg,var(--cream),rgba(212,173,74,.06));
}
.dh-calc-result{
  display:flex;align-items:center;gap:14px;margin-top:14px;
  padding:14px;background:var(--paper);
  border-radius:8px;border:1px solid var(--line);
}
[data-theme="dark"] .dh-calc-result{background:var(--cream-soft)}
.dh-calc-num{
  font-family:var(--serif);font-size:28px;font-weight:700;
  color:var(--gold-deep);line-height:1;
}
.dh-calc-text{
  font-size:12px;color:var(--muted);line-height:1.5;
}

/* Comparison table */
.dh-comparison{
  width:100%;border-collapse:collapse;font-size:13px;
  margin-top:14px;
}
.dh-comparison th, .dh-comparison td{
  padding:10px;border-bottom:1px solid var(--line-soft);
  text-align:left;
}
.dh-comparison th{
  background:var(--cream-soft);font-size:11px;
  text-transform:uppercase;letter-spacing:.4px;font-weight:700;
  color:var(--muted);
}
[data-theme="dark"] .dh-comparison th{background:var(--cream)}
.dh-comparison td.highlight{
  background:rgba(212,173,74,.08);font-weight:700;color:var(--gold-deep);
}
[data-theme="dark"] .dh-comparison td.highlight{background:rgba(212,173,74,.12)}

/* Voting registry counter */
.dh-vote-meter{
  background:var(--cream-soft);
  border-radius:10px;padding:18px;margin-top:14px;
  border:1.5px solid var(--line);
}
[data-theme="dark"] .dh-vote-meter{background:var(--cream)}
.dh-vote-bar{
  width:100%;height:24px;background:var(--line);
  border-radius:12px;overflow:hidden;margin:10px 0;
  position:relative;
}
.dh-vote-fill{
  height:100%;
  background:linear-gradient(90deg,var(--gold),var(--gold-deep));
  border-radius:12px;
  transition:width 1s ease;
  display:flex;align-items:center;justify-content:flex-end;
  padding-right:10px;color:var(--navy-deep);
  font-size:11px;font-weight:700;
}
.dh-vote-stats{
  display:flex;justify-content:space-between;font-size:12px;color:var(--muted);
}

/* Country badges in returns module */
.dh-countries{
  display:flex;flex-wrap:wrap;gap:8px;margin:12px 0;
}
.dh-country{
  padding:5px 12px;border-radius:14px;
  background:var(--cream-soft);
  font-size:12px;font-weight:600;
  display:flex;align-items:center;gap:5px;
  border:1px solid var(--line);
}
[data-theme="dark"] .dh-country{background:var(--cream)}

/* Status pills */
.dh-status-pill{
  display:inline-block;padding:3px 10px;border-radius:10px;
  font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;
}
.dh-status-pill.success{background:rgba(95,206,126,.18);color:#1f7546}
.dh-status-pill.urgent{background:rgba(196,80,80,.18);color:#a13838}
.dh-status-pill.info{background:rgba(212,173,74,.18);color:var(--gold-deep)}
[data-theme="dark"] .dh-status-pill.success{color:#5fce7e}
[data-theme="dark"] .dh-status-pill.urgent{color:#e08484}
[data-theme="dark"] .dh-status-pill.info{color:var(--gold-soft)}

/* Skills grid */
.dh-skills-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:10px;margin-top:14px;
}
.dh-skill-card{
  padding:12px;border:1.5px solid var(--line);border-radius:10px;
  text-align:center;cursor:pointer;
  transition:all .2s ease;background:var(--paper);
}
.dh-skill-card:hover{
  border-color:var(--gold);
  transform:translateY(-2px);
}
[data-theme="dark"] .dh-skill-card{background:var(--cream-soft)}
.dh-skill-icon{font-size:28px;line-height:1;margin-bottom:6px}
.dh-skill-name{font-size:12px;font-weight:700;color:var(--navy)}
[data-theme="dark"] .dh-skill-name{color:var(--ink)}
.dh-skill-count{font-size:10px;color:var(--muted);margin-top:3px}

/* Pledged investors registry */
.dh-pledges-list{
  max-height:280px;overflow-y:auto;
  display:flex;flex-direction:column;gap:6px;
  margin-top:12px;padding:4px;
}
.dh-pledge-item{
  display:flex;align-items:center;gap:10px;
  padding:8px 12px;border-radius:8px;
  background:var(--paper);border:1px solid var(--line-soft);
  font-size:12px;
}
[data-theme="dark"] .dh-pledge-item{background:var(--cream-soft)}
.dh-pledge-flag{font-size:20px;flex-shrink:0}
.dh-pledge-info{flex:1;min-width:0}
.dh-pledge-name{font-weight:700;color:var(--ink)}
.dh-pledge-meta{font-size:11px;color:var(--muted);margin-top:1px}
.dh-pledge-amount{
  font-family:var(--mono);font-weight:700;color:var(--gold-deep);
  white-space:nowrap;
}


/* ═══ DIASPORA TOTAL INTEGRATION (v17 phase 14) ═══ */
.dia-hero{
  background:linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 50%,rgba(212,173,74,.15) 100%);
  border-radius:18px;padding:36px 32px;margin:0 0 32px;
  color:#fff;position:relative;overflow:hidden;
  border:1.5px solid rgba(212,173,74,.3);
}
.dia-hero::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:400px;height:400px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.dia-hero-flag-strip{
  display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;
  position:relative;z-index:2;
}
.dia-hero-flag{font-size:24px;line-height:1}
.dia-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 8px;font-weight:700;
  position:relative;z-index:2;
}
.dia-hero h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.dia-hero-lede{
  color:rgba(255,255,255,.9);font-size:16px;
  line-height:1.6;margin:0 0 22px;
  position:relative;z-index:2;max-width:760px;
}
.dia-hero-ctas{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:12px;position:relative;z-index:2;
}
.dia-hero-cta{
  background:rgba(255,255,255,.08);
  border:1.5px solid rgba(212,173,74,.3);
  border-radius:14px;
  padding:18px 16px;
  text-decoration:none;color:#fff;
  display:flex;flex-direction:column;gap:6px;
  cursor:pointer;
  transition:all .25s ease;
}
.dia-hero-cta:hover{
  background:rgba(212,173,74,.18);
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:0 14px 32px rgba(0,0,0,.25);
}
.dia-hero-cta-icon{font-size:32px;line-height:1}
.dia-hero-cta-title{
  font-family:var(--serif);font-size:16px;font-weight:700;
  color:#fff;margin:6px 0 2px;
}
.dia-hero-cta-desc{
  font-size:12px;color:rgba(255,255,255,.75);line-height:1.4;
}
.dia-hero-cta-arrow{
  margin-top:auto;color:var(--gold-soft);
  font-size:13px;font-weight:700;letter-spacing:.5px;
}

@media (max-width:640px){
  .dia-hero{padding:24px 20px}
  .dia-hero h2{font-size:24px}
  .dia-hero-lede{font-size:14px}
}

.dia-champ-section{
  background:linear-gradient(180deg,var(--cream-soft),var(--cream));
  padding:64px 0;
}
[data-theme="dark"] .dia-champ-section{
  background:linear-gradient(180deg,var(--paper),var(--cream-soft));
}
.dia-champ-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:18px;margin-top:24px;
}
.dia-champ-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;
  padding:22px;
  display:flex;flex-direction:column;gap:10px;
  transition:all .25s ease;
}
.dia-champ-card:hover{
  border-color:var(--gold);
  transform:translateY(-2px);
  box-shadow:0 10px 24px rgba(8,26,51,.1);
}
.dia-champ-head{
  display:flex;align-items:center;gap:12px;
}
.dia-champ-avatar{
  width:52px;height:52px;border-radius:50%;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-size:22px;font-weight:700;
  flex-shrink:0;border:2px solid var(--gold);
}
.dia-champ-name{
  font-family:var(--serif);font-size:16px;font-weight:700;
  color:var(--navy);margin:0;
}
[data-theme="dark"] .dia-champ-name{color:var(--ink)}
.dia-champ-loc{font-size:12px;color:var(--muted);margin:2px 0 0}
.dia-champ-quote{
  font-size:13px;color:var(--ink);line-height:1.6;
  font-style:italic;
  border-left:3px solid var(--gold);
  padding-left:14px;margin:6px 0;
}
.dia-champ-action{
  display:inline-flex;align-items:center;gap:5px;
  font-size:11px;font-weight:700;letter-spacing:.5px;
  color:var(--gold-deep);text-transform:uppercase;
  margin-top:auto;
}

.dia-float-cta{
  position:fixed;bottom:96px;left:20px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:14px;
  padding:14px 18px;
  border:1.5px solid var(--gold);
  box-shadow:0 18px 40px rgba(0,0,0,.25);
  z-index:1000;
  display:none;align-items:center;gap:14px;
  max-width:340px;
  animation:dia-float-in .35s cubic-bezier(.2,.9,.3,1);
}
@keyframes dia-float-in{
  from{transform:translateY(20px);opacity:0}
  to{transform:translateY(0);opacity:1}
}
.dia-float-cta.show{display:flex}
.dia-float-icon{font-size:28px;line-height:1;flex-shrink:0}
.dia-float-text{flex:1;min-width:0;font-size:13px;line-height:1.4}
.dia-float-text strong{color:var(--gold-soft);display:block;font-size:14px;margin-bottom:2px}
.dia-float-cta a{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:6px 12px;border-radius:8px;
  font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;
  text-decoration:none;flex-shrink:0;
  transition:transform .15s ease;
}
.dia-float-cta a:hover{transform:scale(1.05)}
.dia-float-close{
  position:absolute;top:6px;right:8px;
  background:none;border:none;color:rgba(255,255,255,.6);
  cursor:pointer;font-size:14px;
  width:18px;height:18px;
}
.dia-float-close:hover{color:#fff}

@media (max-width:560px){
  .dia-float-cta{left:12px;right:12px;bottom:88px;max-width:none}
}

.dh-cross-links{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:14px;margin-top:32px;
  padding-top:24px;border-top:1.5px dashed var(--line);
}
.dh-cross-link{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:18px;text-decoration:none;color:inherit;
  display:flex;flex-direction:column;gap:8px;
  transition:all .25s ease;
}
.dh-cross-link:hover{
  border-color:var(--gold);
  transform:translateY(-2px);
  box-shadow:0 10px 24px rgba(8,26,51,.1);
}
.dh-cross-link-icon{font-size:32px;line-height:1}
.dh-cross-link-title{
  font-family:var(--serif);font-size:15px;font-weight:700;
  color:var(--navy);margin:0;
}
[data-theme="dark"] .dh-cross-link-title{color:var(--ink)}
.dh-cross-link-desc{font-size:12px;color:var(--muted);line-height:1.5}
.dh-cross-link-cta{
  font-size:11px;color:var(--gold-deep);font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;
  margin-top:auto;
}

.dia-vote-urgency{
  background:linear-gradient(135deg,#c2453a 0%,#8b2a22 100%);
  color:#fff;border-radius:14px;padding:18px 22px;
  margin:18px 0;display:flex;align-items:center;gap:14px;
  border:1.5px solid rgba(255,255,255,.2);
}
.dia-vote-urgency-icon{font-size:32px;line-height:1;flex-shrink:0}
.dia-vote-urgency-text{flex:1;font-size:14px;line-height:1.5}
.dia-vote-urgency-text strong{font-size:16px;display:block;margin-bottom:4px}
.dia-vote-urgency a{
  background:rgba(255,255,255,.15);
  color:#fff;padding:8px 16px;
  border-radius:8px;text-decoration:none;
  font-weight:700;font-size:13px;
  border:1px solid rgba(255,255,255,.3);
  transition:all .2s ease;flex-shrink:0;
}
.dia-vote-urgency a:hover{
  background:rgba(255,255,255,.25);transform:translateY(-1px);
}


/* ═══ 1,000 MEMBERS DRIVE (v17 phase 15) ═══ */
.fd-section{
  background:linear-gradient(180deg,var(--cream-soft) 0%,var(--cream) 100%);
  padding:80px 0;position:relative;
}
[data-theme="dark"] .fd-section{
  background:linear-gradient(180deg,var(--paper),var(--cream-soft));
}
.fd-section::before{
  content:"";position:absolute;top:0;left:0;right:0;height:4px;
  background:linear-gradient(90deg,
    var(--gold) 0%, var(--gold-deep) 25%,
    #c2453a 50%, var(--gold-deep) 75%, var(--gold) 100%);
}

.fd-hero{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:0 0 32px;
  position:relative;overflow:hidden;
  border:2px solid var(--gold);
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.fd-hero::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(212,173,74,.22),transparent 70%);
  pointer-events:none;animation:fd-pulse 4s ease-in-out infinite;
}
@keyframes fd-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.1)}}
.fd-hero-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
}
.fd-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:36px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.fd-hero h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.fd-hero p{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0;
  position:relative;z-index:2;max-width:780px;
}

/* Live counter */
.fd-counter{
  background:rgba(0,0,0,.3);
  border:1.5px solid rgba(212,173,74,.4);
  border-radius:14px;padding:24px;
  margin-top:20px;position:relative;z-index:2;
  display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:center;
}
@media (max-width:680px){
  .fd-counter{grid-template-columns:1fr;gap:14px}
  .fd-hero h2{font-size:26px}
}
.fd-counter-num-wrap{text-align:center}
.fd-counter-num{
  font-family:var(--serif);font-size:72px;font-weight:700;
  color:var(--gold-soft);line-height:1;
  text-shadow:0 4px 16px rgba(212,173,74,.4);
  letter-spacing:-1px;
}
.fd-counter-target{
  font-family:var(--mono);font-size:18px;color:rgba(255,255,255,.7);
  margin-top:4px;letter-spacing:1px;
}
.fd-counter-target strong{color:#fff;font-size:22px}
.fd-progress-wrap{display:flex;flex-direction:column;gap:8px}
.fd-progress-label{
  display:flex;justify-content:space-between;align-items:center;
  font-size:12px;color:rgba(255,255,255,.85);
  text-transform:uppercase;letter-spacing:.8px;font-weight:700;
}
.fd-progress-label strong{color:var(--gold-soft);font-family:var(--mono)}
.fd-progress-bar{
  height:14px;background:rgba(255,255,255,.1);
  border-radius:7px;overflow:hidden;border:1px solid rgba(255,255,255,.15);
}
.fd-progress-fill{
  height:100%;
  background:linear-gradient(90deg,var(--gold) 0%,var(--gold-deep) 50%,var(--gold-soft) 100%);
  border-radius:6px;
  transition:width 1s cubic-bezier(.2,.9,.3,1);
  box-shadow:0 0 12px rgba(212,173,74,.6);
  position:relative;
}
.fd-progress-fill::after{
  content:"";position:absolute;top:0;left:0;right:0;bottom:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.3),transparent);
  animation:fd-shimmer 2s ease-in-out infinite;
}
@keyframes fd-shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
.fd-progress-stats{
  display:flex;gap:14px;flex-wrap:wrap;
  font-size:12px;color:rgba(255,255,255,.7);
}
.fd-progress-stats span strong{color:var(--gold-soft);font-family:var(--mono)}

/* Wave tracker — 10 waves of 100 */
.fd-waves{
  display:grid;grid-template-columns:repeat(10,1fr);
  gap:4px;margin-top:14px;
}
.fd-wave{
  height:8px;border-radius:3px;
  background:rgba(255,255,255,.1);
  position:relative;
  transition:all .4s ease;
}
.fd-wave.complete{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  box-shadow:0 0 8px rgba(212,173,74,.5);
}
.fd-wave.partial{
  background:linear-gradient(135deg,var(--gold-soft),var(--gold));
  opacity:.65;
}
.fd-wave.current{
  background:linear-gradient(135deg,var(--gold-soft),var(--gold));
  animation:fd-pulse-wave 1.5s ease-in-out infinite;
}
@keyframes fd-pulse-wave{0%,100%{opacity:.7}50%{opacity:1}}

/* 5-step process */
.fd-steps{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:14px;margin:32px 0;
}
.fd-step{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;padding:20px 18px;
  text-align:center;position:relative;
  transition:all .25s ease;
}
.fd-step:hover{
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:0 14px 28px rgba(8,26,51,.1);
}
.fd-step-num{
  position:absolute;top:-16px;left:50%;transform:translateX(-50%);
  width:32px;height:32px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-weight:700;font-size:14px;
  border:2px solid var(--paper);
}
.fd-step-icon{font-size:36px;line-height:1;margin:8px 0 10px}
.fd-step-title{
  font-family:var(--serif);font-size:14px;font-weight:700;
  color:var(--navy);margin:0 0 6px;
}
[data-theme="dark"] .fd-step-title{color:var(--ink)}
.fd-step-desc{
  font-size:11px;color:var(--muted);line-height:1.5;
}
.fd-step-time{
  font-size:10px;color:var(--gold-deep);font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;margin-top:8px;
}

/* Action panel */
.fd-actions{
  display:grid;grid-template-columns:1fr 1fr;gap:24px;
  margin-top:24px;
}
@media (max-width:880px){
  .fd-actions{grid-template-columns:1fr}
}
.fd-action-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:24px;
}
.fd-action-card h3{
  font-family:var(--serif);font-size:18px;color:var(--navy);
  margin:0 0 14px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .fd-action-card h3{color:var(--ink)}
.fd-form{display:flex;flex-direction:column;gap:12px}
.fd-form label{
  font-size:11px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.5px;font-weight:700;margin-bottom:3px;display:block;
}
.fd-form input, .fd-form select, .fd-form textarea{
  width:100%;padding:9px 12px;
  border:1.5px solid var(--line);border-radius:8px;
  background:var(--cream-soft);color:var(--ink);
  font-family:var(--sans);font-size:14px;
}
[data-theme="dark"] .fd-form input,
[data-theme="dark"] .fd-form select,
[data-theme="dark"] .fd-form textarea{background:var(--cream)}
.fd-form input:focus, .fd-form select:focus, .fd-form textarea:focus{
  outline:none;border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.18);
}
.fd-form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media (max-width:560px){.fd-form-row{grid-template-columns:1fr}}

.fd-btn-primary{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:14px 22px;border:none;border-radius:10px;
  font-family:var(--sans);font-size:14px;font-weight:700;
  letter-spacing:.5px;text-transform:uppercase;
  cursor:pointer;
  transition:all .25s ease;
  box-shadow:0 10px 25px rgba(212,173,74,.3);
  margin-top:6px;
}
.fd-btn-primary:hover{
  transform:translateY(-2px);
  box-shadow:0 14px 32px rgba(212,173,74,.4);
}

/* Notary directory */
.fd-notary-dir{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:24px;margin-top:20px;
}
.fd-notary-search{
  position:relative;margin-bottom:14px;
}
.fd-notary-search::before{
  content:"🔍";position:absolute;left:12px;top:50%;
  transform:translateY(-50%);font-size:14px;pointer-events:none;
}
.fd-notary-search input{
  width:100%;padding:10px 12px 10px 36px;
  border:1.5px solid var(--line);border-radius:8px;
  background:var(--cream-soft);color:var(--ink);font-size:14px;
}
[data-theme="dark"] .fd-notary-search input{background:var(--cream)}
.fd-notary-list{
  max-height:340px;overflow-y:auto;
  display:flex;flex-direction:column;gap:6px;
}
.fd-notary-list::-webkit-scrollbar{width:6px}
.fd-notary-list::-webkit-scrollbar-thumb{background:var(--line);border-radius:3px}
.fd-notary-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;
  border:1.5px solid var(--line-soft);
  border-radius:8px;
  background:var(--cream-soft);
  font-size:13px;
}
[data-theme="dark"] .fd-notary-item{background:var(--cream)}
.fd-notary-item-icon{font-size:18px;line-height:1;flex-shrink:0}
.fd-notary-item-info{flex:1;min-width:0}
.fd-notary-item-muni{
  font-weight:700;color:var(--navy);font-size:13px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
[data-theme="dark"] .fd-notary-item-muni{color:var(--ink)}
.fd-notary-item-meta{
  font-size:11px;color:var(--muted);
  display:flex;gap:10px;flex-wrap:wrap;margin-top:2px;
}
.fd-notary-item-action{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:6px 12px;border-radius:6px;
  font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;
  text-decoration:none;flex-shrink:0;
  transition:transform .15s ease;
}
.fd-notary-item-action:hover{transform:scale(1.05)}

/* Mass notary days */
.fd-mass-days{
  background:linear-gradient(135deg,rgba(212,173,74,.08),rgba(212,173,74,.03));
  border:1.5px solid var(--gold-soft);
  border-radius:14px;padding:24px;margin-top:24px;
}
[data-theme="dark"] .fd-mass-days{
  background:linear-gradient(135deg,rgba(212,173,74,.1),rgba(212,173,74,.05));
}
.fd-mass-days h3{
  font-family:var(--serif);font-size:20px;color:var(--navy);margin:0 0 6px;
  display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .fd-mass-days h3{color:var(--ink)}
.fd-mass-days-sub{
  font-size:13px;color:var(--muted);margin:0 0 16px;line-height:1.6;
}
.fd-mass-days-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:12px;
}
.fd-mass-day{
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:10px;padding:14px;
  display:flex;flex-direction:column;gap:4px;
}
.fd-mass-day-date{
  font-family:var(--mono);font-size:11px;color:var(--gold-deep);
  font-weight:700;letter-spacing:.5px;
}
.fd-mass-day-loc{
  font-family:var(--serif);font-size:14px;font-weight:700;
  color:var(--navy);
}
[data-theme="dark"] .fd-mass-day-loc{color:var(--ink)}
.fd-mass-day-spots{
  font-size:11px;color:var(--muted);margin-top:2px;
}
.fd-mass-day-spots strong{color:var(--gold-deep);font-family:var(--mono)}
.fd-mass-day-rsvp{
  margin-top:6px;
  display:inline-flex;align-items:center;gap:4px;
  font-size:11px;font-weight:700;color:var(--gold-deep);
  text-decoration:none;
}

/* Referral panel */
.fd-referral{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:14px;padding:24px;margin-top:24px;
  border:1.5px solid rgba(212,173,74,.3);
  position:relative;overflow:hidden;
}
.fd-referral::before{
  content:"";position:absolute;top:-30%;left:-15%;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.fd-referral h3{
  color:#fff;font-family:var(--serif);font-size:20px;margin:0 0 8px;
  position:relative;z-index:2;
}
.fd-referral p{
  color:rgba(255,255,255,.85);font-size:14px;line-height:1.6;margin:0 0 14px;
  position:relative;z-index:2;
}
.fd-referral-link-box{
  display:flex;gap:8px;align-items:center;
  background:rgba(0,0,0,.3);
  border:1px solid rgba(212,173,74,.3);
  border-radius:10px;padding:8px 12px;
  position:relative;z-index:2;
  flex-wrap:wrap;
}
.fd-referral-link{
  flex:1;min-width:220px;
  font-family:var(--mono);font-size:12px;
  color:var(--gold-soft);
  background:transparent;border:none;outline:none;
}
.fd-referral-share-btns{
  display:flex;gap:6px;flex-wrap:wrap;
  margin-top:12px;position:relative;z-index:2;
}
.fd-share-btn{
  padding:8px 14px;border-radius:8px;
  background:rgba(255,255,255,.1);
  color:#fff;text-decoration:none;
  font-size:12px;font-weight:700;
  border:1px solid rgba(255,255,255,.2);
  display:inline-flex;align-items:center;gap:5px;
  transition:all .2s ease;
}
.fd-share-btn:hover{
  background:rgba(212,173,74,.2);
  border-color:var(--gold);
  transform:translateY(-1px);
}
.fd-referral-stats{
  display:flex;gap:20px;flex-wrap:wrap;
  margin-top:14px;position:relative;z-index:2;
  font-size:12px;color:rgba(255,255,255,.75);
}
.fd-referral-stats strong{
  color:var(--gold-soft);font-family:var(--mono);font-size:16px;
  display:block;
}

/* PDF declaration preview */
.fd-pdf-preview{
  background:#fff;
  color:#1a1a1a;
  border:1px solid #ddd;
  border-radius:8px;padding:24px;
  margin-top:14px;
  font-family:var(--serif);
  font-size:13px;line-height:1.6;
  box-shadow:0 6px 20px rgba(0,0,0,.08);
  max-height:400px;overflow-y:auto;
  display:none;
}
.fd-pdf-preview.show{display:block}
.fd-pdf-preview h4{
  font-size:18px;text-align:center;margin:0 0 14px;
  color:#1a1a1a;font-weight:700;
}
.fd-pdf-preview .fd-pdf-data{
  background:#fffce8;
  padding:8px 12px;border-radius:4px;
  border-left:3px solid #d4ad4a;
  margin:10px 0;
}
.fd-pdf-preview .fd-pdf-sig{
  margin-top:24px;padding-top:14px;
  border-top:1px dashed #999;
  font-size:11px;color:#666;
  display:flex;justify-content:space-between;
}


/* ═══ DIGITAL NOTARY (v17 phase 16) ═══ */
.dn-block{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:32px 0;
  position:relative;overflow:hidden;
  border:2px solid var(--gold);
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.dn-block::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.dn-block::after{
  content:"";position:absolute;bottom:-30%;left:-15%;
  width:400px;height:400px;
  background:radial-gradient(circle,rgba(76,175,255,.12),transparent 70%);
  pointer-events:none;
}

.dn-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,#4caf50,#388e3c);
  color:#fff;
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
  box-shadow:0 4px 16px rgba(76,175,80,.3);
}
.dn-tag-pulse{
  width:8px;height:8px;border-radius:50%;
  background:#fff;
  animation:dn-pulse-dot 1.4s ease-in-out infinite;
}
@keyframes dn-pulse-dot{
  0%,100%{opacity:1;transform:scale(1)}
  50%{opacity:.5;transform:scale(1.3)}
}

.dn-block h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.dn-block h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.dn-block-lede{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0 0 24px;
  position:relative;z-index:2;max-width:780px;
}
.dn-block-lede strong{color:var(--gold-soft)}

/* Compliance badges */
.dn-badges{
  display:flex;gap:8px;flex-wrap:wrap;margin:18px 0;
  position:relative;z-index:2;
}
.dn-badge{
  background:rgba(255,255,255,.1);
  border:1px solid rgba(212,173,74,.4);
  color:#fff;
  padding:6px 12px;border-radius:8px;
  font-size:11px;font-weight:700;letter-spacing:.4px;
  display:inline-flex;align-items:center;gap:5px;
}
.dn-badge-icon{color:var(--gold-soft)}

/* Process timeline */
.dn-process{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:14px;margin:24px 0;position:relative;z-index:2;
}
.dn-step{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.25);
  border-radius:12px;
  padding:16px 14px;text-align:center;
  position:relative;
  transition:all .25s ease;
}
.dn-step:hover{
  background:rgba(255,255,255,.1);
  border-color:var(--gold);
  transform:translateY(-2px);
}
.dn-step-num{
  position:absolute;top:-14px;left:50%;transform:translateX(-50%);
  width:28px;height:28px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-weight:700;font-size:13px;
  border:2px solid var(--navy-deep);
}
.dn-step-icon{font-size:32px;line-height:1;margin:6px 0 8px}
.dn-step-title{
  font-family:var(--serif);font-size:13px;font-weight:700;
  color:#fff;margin:0 0 4px;
}
.dn-step-desc{
  font-size:11px;color:rgba(255,255,255,.7);line-height:1.4;
}
.dn-step-time{
  font-size:10px;color:var(--gold-soft);font-weight:700;
  margin-top:6px;
}

/* Live notary board */
.dn-live-board{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:24px;margin-top:24px;
  position:relative;z-index:2;
}
.dn-live-head{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:16px;flex-wrap:wrap;gap:10px;
}
.dn-live-head h3{
  font-family:var(--serif);font-size:18px;color:var(--navy);margin:0;
  display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .dn-live-head h3{color:var(--ink)}

.dn-live-stats{
  display:flex;gap:16px;flex-wrap:wrap;
  font-size:12px;
}
.dn-live-stat{
  display:flex;align-items:center;gap:5px;
  color:var(--muted);font-weight:600;
}
.dn-live-stat strong{color:var(--ink);font-family:var(--mono);font-size:14px}
.dn-live-stat.online strong{color:#4caf50}
.dn-live-stat.busy strong{color:#ff9800}

.dn-notary-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
  gap:12px;
}
.dn-notary{
  background:var(--cream-soft);
  border:1.5px solid var(--line);
  border-radius:10px;padding:14px;
  display:flex;flex-direction:column;gap:8px;
  transition:all .25s ease;
  position:relative;
}
[data-theme="dark"] .dn-notary{background:var(--cream)}
.dn-notary:hover{
  border-color:var(--gold);
  transform:translateY(-2px);
  box-shadow:0 8px 20px rgba(8,26,51,.1);
}
.dn-notary-status{
  position:absolute;top:10px;right:10px;
  display:flex;align-items:center;gap:5px;
  font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;
}
.dn-notary-dot{
  width:10px;height:10px;border-radius:50%;
}
.dn-notary-dot.online{
  background:#4caf50;
  box-shadow:0 0 8px rgba(76,175,80,.6);
  animation:dn-pulse-dot 1.4s ease-in-out infinite;
}
.dn-notary-dot.busy{background:#ff9800}
.dn-notary-dot.offline{background:#999}
.dn-notary-status.online{color:#4caf50}
.dn-notary-status.busy{color:#ff9800}
.dn-notary-status.offline{color:var(--muted)}
.dn-notary-head{
  display:flex;align-items:center;gap:10px;
  padding-right:80px;
}
.dn-notary-avatar{
  width:42px;height:42px;border-radius:50%;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-size:18px;font-weight:700;
  flex-shrink:0;
}
.dn-notary-name{
  font-family:var(--serif);font-size:14px;font-weight:700;
  color:var(--navy);margin:0;
}
[data-theme="dark"] .dn-notary-name{color:var(--ink)}
.dn-notary-loc{
  font-size:11px;color:var(--muted);margin:2px 0 0;
}
.dn-notary-meta{
  display:flex;justify-content:space-between;align-items:center;
  font-size:11px;color:var(--muted);
  padding-top:6px;
  border-top:1px dashed var(--line);
}
.dn-notary-meta strong{color:var(--gold-deep);font-family:var(--mono)}
.dn-notary-action{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:8px 14px;border-radius:8px;
  font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;
  text-decoration:none;text-align:center;
  border:none;cursor:pointer;
  transition:all .15s ease;
}
.dn-notary-action:hover:not(:disabled){
  transform:translateY(-1px);
  box-shadow:0 6px 16px rgba(212,173,74,.3);
}
.dn-notary-action:disabled{
  opacity:.5;cursor:not-allowed;
  background:var(--line);color:var(--muted);
}

/* Booking calendar */
.dn-cal{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:24px;margin-top:18px;
  position:relative;z-index:2;
}
.dn-cal h3{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 12px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .dn-cal h3{color:var(--ink)}
.dn-cal-days{
  display:grid;grid-template-columns:repeat(7,1fr);
  gap:8px;margin-bottom:12px;
}
.dn-cal-day{
  border:1.5px solid var(--line);background:transparent;
  border-radius:8px;padding:10px 6px;text-align:center;
  cursor:pointer;transition:all .15s ease;
  font-family:var(--sans);
}
.dn-cal-day:hover{
  border-color:var(--gold);
  background:rgba(212,173,74,.05);
}
.dn-cal-day.active{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  border-color:var(--gold-deep);
  color:var(--navy-deep);
}
.dn-cal-day-name{
  font-size:10px;color:var(--muted);
  text-transform:uppercase;letter-spacing:.5px;font-weight:700;
}
.dn-cal-day.active .dn-cal-day-name{color:var(--navy-deep)}
.dn-cal-day-num{
  font-family:var(--serif);font-size:18px;font-weight:700;
  color:var(--ink);margin-top:2px;
}
.dn-cal-day.active .dn-cal-day-num{color:var(--navy-deep)}
.dn-cal-day-slots{
  font-size:10px;color:var(--gold-deep);margin-top:2px;font-weight:700;
}
.dn-cal-day.active .dn-cal-day-slots{color:var(--navy-deep)}
.dn-cal-slots{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));
  gap:6px;
}
.dn-cal-slot{
  border:1.5px solid var(--line-soft);
  background:var(--cream-soft);
  color:var(--ink);
  padding:8px 4px;border-radius:6px;text-align:center;
  font-family:var(--mono);font-size:12px;font-weight:600;
  cursor:pointer;transition:all .15s ease;
}
[data-theme="dark"] .dn-cal-slot{background:var(--cream)}
.dn-cal-slot:hover:not(:disabled){
  border-color:var(--gold);
  background:rgba(212,173,74,.08);
}
.dn-cal-slot:disabled{
  opacity:.4;cursor:not-allowed;
  background:var(--line);
}
.dn-cal-slot.selected{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  border-color:var(--gold-deep);color:var(--navy-deep);
}

/* Video session UI */
.dn-session{
  display:none;
  position:fixed;inset:0;
  background:rgba(8,26,51,.92);
  backdrop-filter:blur(8px);
  z-index:9999;
  padding:20px;
  align-items:center;justify-content:center;
}
.dn-session.show{display:flex;animation:fd-fade-in .3s ease}
@keyframes fd-fade-in{from{opacity:0}to{opacity:1}}
.dn-session-card{
  background:var(--paper);
  border-radius:16px;
  max-width:760px;width:100%;
  max-height:92vh;overflow:hidden;
  display:flex;flex-direction:column;
}
.dn-session-head{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;padding:18px 22px;
  display:flex;justify-content:space-between;align-items:center;
}
.dn-session-head h3{
  margin:0;font-family:var(--serif);font-size:18px;color:#fff;
  display:flex;align-items:center;gap:8px;
}
.dn-session-close{
  background:rgba(255,255,255,.15);
  border:none;color:#fff;
  width:36px;height:36px;border-radius:50%;
  cursor:pointer;font-size:18px;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s ease;
}
.dn-session-close:hover{background:rgba(255,255,255,.25)}
.dn-session-body{
  padding:24px;overflow-y:auto;flex:1;
}
.dn-session-video{
  background:#000;
  aspect-ratio:16/9;
  border-radius:12px;
  margin-bottom:16px;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:12px;
  color:#fff;text-align:center;padding:20px;
  border:2px solid var(--gold);
  position:relative;
}
.dn-session-video-icon{
  font-size:56px;line-height:1;
  animation:dn-pulse-dot 1.5s ease-in-out infinite;
}
.dn-session-video-status{
  font-size:13px;color:var(--gold-soft);font-weight:700;
  text-transform:uppercase;letter-spacing:1px;
}
.dn-session-video-info{
  font-size:14px;color:rgba(255,255,255,.85);
  max-width:400px;line-height:1.5;
}
.dn-session-progress{
  display:flex;justify-content:space-between;
  margin:16px 0;
}
.dn-session-pstep{
  flex:1;text-align:center;
  position:relative;
  font-size:11px;color:var(--muted);
  text-transform:uppercase;letter-spacing:.4px;font-weight:700;
}
.dn-session-pstep::after{
  content:"";position:absolute;
  top:14px;left:50%;width:100%;height:2px;
  background:var(--line);z-index:0;
}
.dn-session-pstep:last-child::after{display:none}
.dn-session-pstep-dot{
  width:28px;height:28px;border-radius:50%;
  background:var(--cream-soft);
  border:2px solid var(--line);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 4px;font-size:13px;font-weight:700;
  color:var(--muted);
  position:relative;z-index:1;
}
.dn-session-pstep.done .dn-session-pstep-dot{
  background:#4caf50;border-color:#388e3c;color:#fff;
}
.dn-session-pstep.active .dn-session-pstep-dot{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  border-color:var(--gold-deep);color:var(--navy-deep);
  animation:dn-pulse-dot 1.5s ease-in-out infinite;
}
.dn-session-pstep.done{color:#4caf50}
.dn-session-pstep.active{color:var(--gold-deep)}
.dn-session-actions{
  display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;
  margin-top:16px;padding-top:16px;border-top:1px dashed var(--line);
}
.dn-session-btn{
  padding:10px 18px;border-radius:8px;
  font-family:var(--sans);font-size:13px;font-weight:700;
  cursor:pointer;transition:all .2s ease;
}
.dn-session-btn.primary{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);border:none;
}
.dn-session-btn.primary:hover{
  transform:translateY(-1px);
  box-shadow:0 6px 16px rgba(212,173,74,.3);
}
.dn-session-btn.secondary{
  background:transparent;
  color:var(--ink);
  border:1.5px solid var(--line);
}
.dn-session-btn.secondary:hover{
  border-color:var(--gold);color:var(--gold-deep);
}

/* FAQ */
.dn-faq{
  margin-top:24px;
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:20px 24px;
  position:relative;z-index:2;
}
.dn-faq h3{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 14px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .dn-faq h3{color:var(--ink)}
.dn-faq-item{
  border-top:1px solid var(--line);
  padding:14px 0;
}
.dn-faq-item:first-of-type{border-top:none;padding-top:0}
.dn-faq-q{
  font-family:var(--serif);font-size:14px;font-weight:700;
  color:var(--navy);cursor:pointer;
  display:flex;align-items:center;gap:8px;
  transition:color .15s ease;
}
[data-theme="dark"] .dn-faq-q{color:var(--ink)}
.dn-faq-q:hover{color:var(--gold-deep)}
.dn-faq-q::before{
  content:"+";font-size:20px;color:var(--gold-deep);
  width:18px;font-weight:300;transition:transform .25s ease;
}
.dn-faq-item.open .dn-faq-q::before{
  transform:rotate(45deg);
}
.dn-faq-a{
  font-size:13px;color:var(--muted);line-height:1.7;
  margin:8px 0 0 26px;display:none;
}
.dn-faq-item.open .dn-faq-a{display:block;animation:fd-fade-in .25s ease}


/* ═══ ROBOTIKA MACEDONIA (v17 phase 17) ═══ */
.rm-section{
  background:linear-gradient(180deg,var(--cream-soft) 0%,var(--cream) 100%);
  padding:80px 0;position:relative;
}
[data-theme="dark"] .rm-section{
  background:linear-gradient(180deg,var(--paper),var(--cream-soft));
}

.rm-hero{
  background:
    radial-gradient(circle at 20% 30%,rgba(212,173,74,.15),transparent 50%),
    linear-gradient(135deg,var(--navy-deep) 0%,var(--navy-mid) 100%);
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:0 0 32px;
  position:relative;overflow:hidden;
  border:2px solid var(--gold);
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.rm-hero::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(76,175,255,.15),transparent 70%);
  pointer-events:none;
}

.rm-hero-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,#2196f3,#1565c0);
  color:#fff;padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
  box-shadow:0 4px 16px rgba(33,150,243,.3);
}
.rm-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.rm-hero h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.rm-hero-lede{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0;
  position:relative;z-index:2;max-width:820px;
}
.rm-hero-lede strong{color:var(--gold-soft)}

/* Stats strip */
.rm-stats{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:14px;margin-top:22px;position:relative;z-index:2;
}
.rm-stat{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.3);
  border-radius:12px;
  padding:14px;text-align:center;
}
.rm-stat-num{
  font-family:var(--serif);font-size:28px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.rm-stat-label{
  font-size:11px;color:rgba(255,255,255,.7);
  text-transform:uppercase;letter-spacing:.5px;
  margin-top:6px;font-weight:700;
}

/* Partners grid (3 main partners) */
.rm-partners{
  margin-top:32px;
}
.rm-partners h3{
  font-family:var(--serif);font-size:22px;color:var(--navy);
  margin:0 0 6px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .rm-partners h3{color:var(--ink)}
.rm-partners-sub{
  font-size:13px;color:var(--muted);margin:0 0 22px;line-height:1.6;
}

.rm-partner-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:16px;
}
.rm-partner{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:24px;
  display:flex;flex-direction:column;gap:10px;
  transition:all .25s ease;
  position:relative;
}
.rm-partner:hover{
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:0 14px 30px rgba(8,26,51,.12);
}
[data-theme="dark"] .rm-partner:hover{
  box-shadow:0 14px 30px rgba(0,0,0,.4);
}
.rm-partner-flag{
  position:absolute;top:14px;right:14px;font-size:24px;line-height:1;
}
.rm-partner-icon{
  width:54px;height:54px;border-radius:12px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  display:flex;align-items:center;justify-content:center;
  font-size:28px;flex-shrink:0;
  border:2px solid var(--gold);
}
.rm-partner-name{
  font-family:var(--serif);font-size:18px;font-weight:700;
  color:var(--navy);margin:0;line-height:1.3;
}
[data-theme="dark"] .rm-partner-name{color:var(--ink)}
.rm-partner-role{
  font-size:11px;color:var(--gold-deep);font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;margin:0;
}
.rm-partner-desc{
  font-size:13px;color:var(--muted);line-height:1.6;margin:6px 0 0;
}
.rm-partner-meta{
  display:flex;flex-direction:column;gap:5px;
  margin-top:10px;padding-top:10px;
  border-top:1px dashed var(--line);
  font-size:12px;
}
.rm-partner-meta-row{
  display:flex;justify-content:space-between;
  color:var(--muted);
}
.rm-partner-meta-row strong{color:var(--ink);font-weight:600}
[data-theme="dark"] .rm-partner-meta-row strong{color:var(--ink)}

/* Chinese partners chip strip */
.rm-cn-partners{
  background:linear-gradient(135deg,rgba(212,173,74,.06),rgba(212,173,74,.02));
  border:1.5px solid var(--gold-soft);
  border-radius:14px;padding:20px 22px;margin-top:24px;
}
[data-theme="dark"] .rm-cn-partners{
  background:linear-gradient(135deg,rgba(212,173,74,.08),rgba(212,173,74,.04));
}
.rm-cn-partners h3{
  font-family:var(--serif);font-size:18px;color:var(--navy);
  margin:0 0 6px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .rm-cn-partners h3{color:var(--ink)}
.rm-cn-partners-sub{
  font-size:12px;color:var(--muted);margin:0 0 14px;line-height:1.5;
}
.rm-cn-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:10px;
}
.rm-cn-card{
  background:var(--paper);
  border:1px solid var(--line);
  border-radius:10px;padding:14px;
}
.rm-cn-card-head{
  display:flex;align-items:center;gap:8px;margin-bottom:6px;
}
.rm-cn-flag{font-size:18px;line-height:1}
.rm-cn-name{
  font-family:var(--serif);font-size:13px;font-weight:700;
  color:var(--navy);
}
[data-theme="dark"] .rm-cn-name{color:var(--ink)}
.rm-cn-spec{
  font-size:10px;color:var(--gold-deep);font-weight:700;
  text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;
}
.rm-cn-desc{
  font-size:11px;color:var(--muted);line-height:1.4;
}

/* Products grid (4 product categories) */
.rm-products{
  margin-top:32px;
}
.rm-products h3{
  font-family:var(--serif);font-size:22px;color:var(--navy);
  margin:0 0 6px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .rm-products h3{color:var(--ink)}
.rm-products-sub{
  font-size:13px;color:var(--muted);margin:0 0 22px;line-height:1.6;
}

.rm-prod-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:14px;
}
.rm-prod{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:20px 18px;
  position:relative;
  transition:all .25s ease;
}
.rm-prod:hover{
  border-color:var(--gold);
  transform:translateY(-2px);
}
.rm-prod-icon{
  width:48px;height:48px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:26px;
  margin-bottom:10px;
}
.rm-prod-icon.industrial{background:linear-gradient(135deg,#3a76c2,#1e4a85);color:#fff}
.rm-prod-icon.medical{background:linear-gradient(135deg,#c2453a,#8b2a22);color:#fff}
.rm-prod-icon.agro{background:linear-gradient(135deg,#5fa05c,#3a7037);color:#fff}
.rm-prod-icon.service{background:linear-gradient(135deg,var(--gold),var(--gold-deep));color:var(--navy-deep)}
.rm-prod-name{
  font-family:var(--serif);font-size:15px;font-weight:700;
  color:var(--navy);margin:0 0 6px;
}
[data-theme="dark"] .rm-prod-name{color:var(--ink)}
.rm-prod-desc{
  font-size:12px;color:var(--muted);line-height:1.5;margin:0 0 8px;
}
.rm-prod-list{
  list-style:none;padding:0;margin:8px 0 0;
  font-size:11px;color:var(--ink);line-height:1.6;
}
.rm-prod-list li{
  padding:3px 0;display:flex;align-items:flex-start;gap:6px;
}
.rm-prod-list li::before{
  content:"▸";color:var(--gold-deep);flex-shrink:0;font-size:12px;
}
.rm-prod-target{
  display:inline-block;
  background:rgba(212,173,74,.15);color:var(--gold-deep);
  padding:3px 10px;border-radius:8px;
  font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;
  margin-top:10px;
}

/* Ownership structure */
.rm-ownership{
  background:linear-gradient(135deg,var(--paper),rgba(212,173,74,.04));
  border:2px solid var(--gold);
  border-radius:14px;padding:26px;margin-top:32px;
}
[data-theme="dark"] .rm-ownership{
  background:linear-gradient(135deg,var(--cream),rgba(212,173,74,.06));
}
.rm-ownership h3{
  font-family:var(--serif);font-size:20px;color:var(--navy);
  margin:0 0 6px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .rm-ownership h3{color:var(--ink)}
.rm-ownership-sub{
  font-size:13px;color:var(--muted);margin:0 0 18px;line-height:1.6;
}

/* Stacked horizontal bar showing ownership */
.rm-own-bar{
  display:flex;height:48px;border-radius:10px;overflow:hidden;
  border:1.5px solid var(--line);
  margin-bottom:16px;
}
.rm-own-seg{
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;color:#fff;
  text-transform:uppercase;letter-spacing:.4px;
  position:relative;
  transition:all .25s ease;
}
.rm-own-seg:hover{filter:brightness(1.15)}
.rm-own-seg.mikrosam{background:linear-gradient(135deg,#3a76c2,#1e4a85);flex:18}
.rm-own-seg.mfskopje{background:linear-gradient(135deg,#5a4ec2,#3a2e85);flex:13}
.rm-own-seg.smes{background:linear-gradient(135deg,#5fa05c,#3a7037);flex:11}
.rm-own-seg.diaspora{background:linear-gradient(135deg,var(--gold),var(--gold-deep));color:var(--navy-deep);flex:9}
.rm-own-seg.cn{background:linear-gradient(135deg,#c2453a,#8b2a22);flex:35}
.rm-own-seg.eu{background:linear-gradient(135deg,#666,#333);flex:14}

.rm-own-legend{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:10px;
}
.rm-own-leg{
  display:flex;align-items:center;gap:10px;
  background:var(--cream-soft);
  border:1px solid var(--line);
  border-radius:8px;padding:10px 12px;
  font-size:12px;
}
[data-theme="dark"] .rm-own-leg{background:var(--cream)}
.rm-own-dot{
  width:14px;height:14px;border-radius:4px;flex-shrink:0;
}
.rm-own-dot.mikrosam{background:#3a76c2}
.rm-own-dot.mfskopje{background:#5a4ec2}
.rm-own-dot.smes{background:#5fa05c}
.rm-own-dot.diaspora{background:var(--gold)}
.rm-own-dot.cn{background:#c2453a}
.rm-own-dot.eu{background:#666}
.rm-own-leg-text{flex:1;min-width:0}
.rm-own-leg-name{
  font-weight:700;color:var(--ink);font-size:12px;
  display:block;
}
.rm-own-leg-pct{
  font-family:var(--mono);font-size:11px;color:var(--gold-deep);
  font-weight:700;margin-left:auto;
}

.rm-mk-total{
  display:flex;justify-content:space-between;align-items:center;
  padding:14px 18px;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  border-radius:10px;
  margin-top:14px;
  font-family:var(--serif);font-size:16px;font-weight:700;
}
.rm-mk-total strong{font-size:24px}


/* ═══ ROBOTIKA Phase 17.1 (timeline + workforce) ═══ */
.rm-roadmap{
  margin:36px 0 20px;
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;
  padding:24px 22px;
}
.rm-roadmap h3{
  font-family:var(--serif);font-size:18px;color:var(--navy);
  margin:0 0 6px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .rm-roadmap h3{color:var(--ink)}
.rm-roadmap-sub{
  font-size:13px;color:var(--muted);margin:0 0 18px;line-height:1.6;
}
.rm-timeline{
  position:relative;
  padding-left:24px;
}
.rm-timeline::before{
  content:"";position:absolute;left:8px;top:8px;bottom:8px;width:3px;
  background:linear-gradient(180deg,var(--gold),var(--gold-deep) 50%,var(--gold-soft));
  border-radius:2px;
}
.rm-tl-item{
  position:relative;margin-bottom:18px;
  padding:14px 16px;
  background:var(--cream-soft);
  border:1.5px solid var(--line);
  border-radius:10px;
  border-left:3px solid var(--gold);
}
[data-theme="dark"] .rm-tl-item{background:var(--cream)}
.rm-tl-item::before{
  content:"";position:absolute;
  left:-29px;top:18px;
  width:14px;height:14px;border-radius:50%;
  background:var(--gold);
  border:3px solid var(--paper);
  box-shadow:0 0 0 2px var(--gold);
}
.rm-tl-year{
  display:inline-block;
  font-family:var(--serif);font-weight:700;font-size:14px;
  color:var(--gold-deep);
  background:linear-gradient(135deg,rgba(212,173,74,.15),rgba(212,173,74,.05));
  padding:3px 10px;border-radius:8px;letter-spacing:.5px;
  margin-bottom:8px;
}
.rm-tl-title{
  font-family:var(--serif);font-size:15px;font-weight:700;
  color:var(--navy);margin:0 0 6px;
}
[data-theme="dark"] .rm-tl-title{color:var(--ink)}
.rm-tl-desc{
  font-size:13px;color:var(--muted);line-height:1.6;margin:0 0 8px;
}
.rm-tl-tags{
  display:flex;gap:6px;flex-wrap:wrap;
}
.rm-tl-tag{
  font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;
  background:rgba(212,173,74,.12);color:var(--gold-deep);
  padding:3px 9px;border-radius:8px;
}

/* Workforce panel */
.rm-workforce{
  margin-top:24px;
  display:grid;grid-template-columns:1fr 1fr;gap:18px;
}
@media (max-width:880px){
  .rm-workforce{grid-template-columns:1fr}
}
.rm-wf-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:22px;
}
.rm-wf-card h4{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 12px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .rm-wf-card h4{color:var(--ink)}
.rm-wf-list{
  list-style:none;padding:0;margin:0;
}
.rm-wf-list li{
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 0;border-bottom:1px dashed var(--line-soft);
  font-size:13px;color:var(--ink);line-height:1.5;
}
.rm-wf-list li:last-child{border-bottom:none}
.rm-wf-list li strong{
  color:var(--gold-deep);font-family:var(--mono);font-size:14px;
  flex-shrink:0;margin-left:14px;
}

.rm-cta-box{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:14px;
  padding:22px 24px;margin-top:24px;
  border:1.5px solid var(--gold);
  position:relative;overflow:hidden;
}
.rm-cta-box::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.rm-cta-box h4{
  color:#fff;font-family:var(--serif);font-size:18px;margin:0 0 8px;
  position:relative;z-index:2;
}
.rm-cta-box p{
  color:rgba(255,255,255,.85);font-size:13px;line-height:1.6;margin:0 0 14px;
  position:relative;z-index:2;
}
.rm-cta-box .rm-cta-btns{
  display:flex;gap:10px;flex-wrap:wrap;position:relative;z-index:2;
}
.rm-cta-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:10px 18px;border-radius:8px;
  font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;
  text-decoration:none;
  transition:transform .15s ease;
}
.rm-cta-btn:hover{transform:translateY(-1px)}
.rm-cta-btn-outline{
  background:transparent;
  color:#fff;
  border:1.5px solid rgba(255,255,255,.3);
}
.rm-cta-btn-outline:hover{
  border-color:var(--gold);color:var(--gold-soft);
}


/* ═══ STEP-BY-STEP GUIDE (v17 phase 18) ═══ */
.gd-section{
  background:linear-gradient(180deg,var(--cream),var(--cream-soft));
  padding:80px 0;
  position:relative;
}
[data-theme="dark"] .gd-section{
  background:linear-gradient(180deg,var(--cream-soft),var(--paper));
}

.gd-intro{
  max-width:880px;margin:0 auto 36px;text-align:center;
}
.gd-intro p{color:var(--muted);font-size:15px;line-height:1.7;margin:12px 0 0}

/* Path selector */
.gd-paths{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:18px;margin-bottom:36px;
}
.gd-path-btn{
  background:var(--paper);
  border:2px solid var(--line);
  border-radius:14px;
  padding:22px 18px;
  cursor:pointer;
  transition:all .25s ease;
  display:flex;flex-direction:column;align-items:center;gap:10px;
  text-align:center;
}
.gd-path-btn:hover{
  border-color:var(--gold);
  transform:translateY(-3px);
  box-shadow:0 14px 32px rgba(8,26,51,.12);
}
.gd-path-btn.active{
  border-color:var(--gold-deep);
  background:linear-gradient(135deg,var(--paper),rgba(212,173,74,.08));
  box-shadow:0 14px 32px rgba(212,173,74,.2);
}
.gd-path-flag{font-size:36px;line-height:1}
.gd-path-name{
  font-family:var(--serif);font-size:17px;font-weight:700;
  color:var(--navy);margin:0;
}
[data-theme="dark"] .gd-path-name{color:var(--ink)}
.gd-path-desc{
  font-size:12px;color:var(--muted);line-height:1.5;
}
.gd-path-time{
  font-size:11px;color:var(--gold-deep);font-weight:700;
  text-transform:uppercase;letter-spacing:.5px;
  background:rgba(212,173,74,.12);
  padding:4px 12px;border-radius:10px;
  margin-top:4px;
}

/* Path content */
.gd-path-content{
  display:none;
}
.gd-path-content.active{display:block;animation:gd-fade-in .35s ease}
@keyframes gd-fade-in{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* Summary card */
.gd-summary{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:16px;
  padding:24px 28px;margin-bottom:24px;
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:16px;
  border:1.5px solid rgba(212,173,74,.3);
  position:relative;overflow:hidden;
}
.gd-summary::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.15),transparent 70%);
  pointer-events:none;
}
.gd-sum-item{position:relative;z-index:2}
.gd-sum-num{
  font-family:var(--serif);font-size:28px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.gd-sum-label{
  font-size:11px;color:rgba(255,255,255,.75);
  text-transform:uppercase;letter-spacing:.5px;font-weight:700;
  margin-top:6px;
}

/* Steps */
.gd-steps{
  display:flex;flex-direction:column;gap:18px;
  position:relative;
  padding-left:42px;
}
.gd-steps::before{
  content:"";position:absolute;
  left:18px;top:18px;bottom:18px;width:3px;
  background:linear-gradient(180deg,var(--gold-deep),var(--gold),var(--gold-soft));
  border-radius:2px;
}

.gd-step{
  position:relative;
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:20px 22px;
  transition:all .2s ease;
}
.gd-step:hover{
  border-color:var(--gold-soft);
  box-shadow:0 8px 22px rgba(8,26,51,.08);
}
.gd-step::before{
  content:attr(data-step);
  position:absolute;
  left:-42px;top:18px;
  width:38px;height:38px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-weight:700;font-size:15px;
  border:3px solid var(--cream);
  z-index:1;
}
[data-theme="dark"] .gd-step::before{
  border-color:var(--cream-soft);
}

.gd-step-head{
  display:flex;justify-content:space-between;align-items:flex-start;
  gap:12px;flex-wrap:wrap;margin-bottom:10px;
}
.gd-step-title{
  font-family:var(--serif);font-size:17px;font-weight:700;
  color:var(--navy);margin:0;flex:1;
}
[data-theme="dark"] .gd-step-title{color:var(--ink)}
.gd-step-meta{
  display:flex;gap:8px;flex-wrap:wrap;
}
.gd-step-tag{
  padding:3px 10px;border-radius:10px;
  font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;
}
.gd-step-tag.time{background:rgba(76,175,80,.15);color:#2e7d32}
.gd-step-tag.cost{background:rgba(212,173,74,.15);color:var(--gold-deep)}
.gd-step-tag.optional{background:rgba(120,120,120,.12);color:var(--muted)}
.gd-step-tag.required{background:rgba(244,67,54,.12);color:#c62828}

[data-theme="dark"] .gd-step-tag.time{background:rgba(76,175,80,.2);color:#5fce7e}
[data-theme="dark"] .gd-step-tag.cost{background:rgba(212,173,74,.2);color:var(--gold-soft)}

.gd-step-desc{
  font-size:14px;color:var(--ink);line-height:1.7;margin:0 0 12px;
}
.gd-step-desc strong{color:var(--gold-deep);font-weight:700}

.gd-step-checklist{
  list-style:none;padding:0;margin:10px 0 0;
}
.gd-step-checklist li{
  display:flex;align-items:flex-start;gap:8px;
  padding:6px 0;
  font-size:13px;color:var(--muted);line-height:1.55;
}
.gd-step-checklist li::before{
  content:"✓";
  flex-shrink:0;
  width:20px;height:20px;border-radius:50%;
  background:rgba(76,175,80,.15);
  color:#2e7d32;
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:11px;
  margin-top:1px;
}

.gd-step-actions{
  display:flex;gap:8px;flex-wrap:wrap;
  margin-top:14px;padding-top:12px;
  border-top:1px dashed var(--line);
}
.gd-step-btn{
  padding:7px 14px;border-radius:7px;
  font-family:var(--sans);font-size:12px;font-weight:600;
  text-decoration:none;
  display:inline-flex;align-items:center;gap:5px;
  transition:all .15s ease;
}
.gd-step-btn.primary{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
}
.gd-step-btn.primary:hover{transform:translateY(-1px)}
.gd-step-btn.secondary{
  background:transparent;
  border:1.5px solid var(--line);
  color:var(--ink);
}
.gd-step-btn.secondary:hover{
  border-color:var(--gold);color:var(--gold-deep);
}

.gd-step-warn{
  background:rgba(255,152,0,.08);
  border-left:3px solid #ff9800;
  padding:10px 14px;border-radius:6px;
  margin-top:10px;
  font-size:12px;color:#e65100;line-height:1.6;
}
[data-theme="dark"] .gd-step-warn{
  background:rgba(255,152,0,.12);color:#ffb74d;
}

.gd-step-tip{
  background:rgba(33,150,243,.08);
  border-left:3px solid #2196f3;
  padding:10px 14px;border-radius:6px;
  margin-top:10px;
  font-size:12px;color:#0d47a1;line-height:1.6;
}
[data-theme="dark"] .gd-step-tip{
  background:rgba(33,150,243,.12);color:#64b5f6;
}

/* Final CTA */
.gd-final{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:16px;
  padding:32px;margin-top:32px;
  text-align:center;
  border:1.5px solid var(--gold);
}
.gd-final h3{
  color:var(--gold-soft);font-family:var(--serif);font-size:22px;
  margin:0 0 10px;
}
.gd-final p{
  color:rgba(255,255,255,.85);font-size:14px;line-height:1.6;
  margin:0 0 18px;
}
.gd-final-btns{
  display:flex;gap:10px;justify-content:center;flex-wrap:wrap;
}

/* Common FAQ */
.gd-common-faq{
  margin-top:32px;
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;
  padding:24px 26px;
}
.gd-common-faq h3{
  font-family:var(--serif);font-size:18px;color:var(--navy);
  margin:0 0 14px;
}
[data-theme="dark"] .gd-common-faq h3{color:var(--ink)}
.gd-faq-q{
  font-family:var(--serif);font-weight:700;color:var(--navy);
  font-size:14px;margin:14px 0 6px;
  cursor:pointer;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .gd-faq-q{color:var(--ink)}
.gd-faq-q::before{
  content:"Q.";color:var(--gold-deep);font-weight:700;
}
.gd-faq-a{
  font-size:13px;color:var(--muted);line-height:1.7;
  padding-left:24px;margin:0 0 4px;
}
.gd-faq-a strong{color:var(--ink);font-weight:600}

@media (max-width:640px){
  .gd-steps{padding-left:34px}
  .gd-steps::before{left:14px}
  .gd-step::before{
    left:-34px;width:30px;height:30px;font-size:13px;
  }
}


/* ═══ PARAGRAF AUTHORIZED PARTNER (v17 phase 21) ═══ */
.pgf-banner{
  background:linear-gradient(135deg,#fff7e0 0%,#fef3d4 50%,#fdf0c8 100%);
  border:2px solid var(--gold);
  border-radius:16px;
  padding:24px 28px;
  margin:24px 0;
  position:relative;
  overflow:hidden;
}
[data-theme="dark"] .pgf-banner{
  background:linear-gradient(135deg,#3d3520 0%,#4a4028 50%,#5a4d30 100%);
}
.pgf-banner::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:280px;height:280px;
  background:radial-gradient(circle,rgba(212,173,74,.25),transparent 70%);
  pointer-events:none;
}
.pgf-banner-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  margin-bottom:14px;
  position:relative;z-index:2;
}
.pgf-banner-tag::before{
  content:"⚖️";font-size:14px;
}
.pgf-banner-content{
  display:grid;grid-template-columns:1fr auto;gap:20px;align-items:center;
  position:relative;z-index:2;
}
@media (max-width:640px){
  .pgf-banner-content{grid-template-columns:1fr}
}
.pgf-banner-text h3{
  font-family:var(--serif);font-size:20px;color:var(--navy-deep);
  margin:0 0 8px;line-height:1.3;
}
[data-theme="dark"] .pgf-banner-text h3{color:var(--gold-soft)}
.pgf-banner-text h3 em{
  color:var(--gold-deep);font-style:normal;font-weight:700;
}
.pgf-banner-text p{
  color:var(--ink);font-size:13px;line-height:1.6;margin:0 0 14px;
}
[data-theme="dark"] .pgf-banner-text p{color:var(--cream)}
.pgf-banner-features{
  display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;
}
.pgf-feat{
  background:rgba(8,26,51,.08);
  color:var(--navy-deep);
  padding:4px 10px;border-radius:8px;
  font-size:11px;font-weight:600;
  display:inline-flex;align-items:center;gap:4px;
}
[data-theme="dark"] .pgf-feat{
  background:rgba(212,173,74,.15);color:var(--gold-soft);
}
.pgf-banner-cta{
  display:flex;flex-direction:column;gap:8px;align-items:flex-end;
}
@media (max-width:640px){
  .pgf-banner-cta{align-items:stretch}
}
.pgf-cta-btn{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;
  padding:12px 22px;border-radius:10px;
  font-size:13px;font-weight:700;
  text-decoration:none;
  text-transform:uppercase;letter-spacing:.5px;
  display:inline-flex;align-items:center;gap:6px;
  transition:all .2s ease;
  box-shadow:0 8px 22px rgba(8,26,51,.18);
  white-space:nowrap;
}
.pgf-cta-btn:hover{
  transform:translateY(-2px);
  box-shadow:0 12px 30px rgba(8,26,51,.25);
}
.pgf-cta-secondary{
  font-size:11px;color:var(--muted);
  text-align:right;
}
.pgf-cta-secondary a{
  color:var(--gold-deep);text-decoration:none;font-weight:600;
}
.pgf-cta-secondary a:hover{text-decoration:underline}

/* Authorized partners list in digital notary */
.pgf-partners-list{
  background:var(--paper);
  border:1.5px solid var(--gold-soft);
  border-radius:14px;
  padding:24px;margin-top:20px;
  position:relative;z-index:2;
}
.pgf-partners-list h4{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 14px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .pgf-partners-list h4{color:var(--ink)}
.pgf-partner-card{
  background:linear-gradient(135deg,rgba(212,173,74,.05),rgba(212,173,74,.02));
  border:2px solid var(--gold);
  border-radius:12px;padding:18px 20px;
  margin-bottom:12px;
  display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;
}
@media (max-width:640px){
  .pgf-partner-card{grid-template-columns:1fr;text-align:center}
}
.pgf-partner-logo{
  width:54px;height:54px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-size:24px;font-weight:700;
  flex-shrink:0;border:2px solid var(--gold);
}
.pgf-partner-info h5{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 4px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;
}
[data-theme="dark"] .pgf-partner-info h5{color:var(--ink)}
.pgf-partner-badge{
  background:linear-gradient(135deg,#4caf50,#388e3c);
  color:#fff;
  padding:2px 8px;border-radius:8px;
  font-size:9px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;
}
.pgf-partner-info p{
  font-size:12px;color:var(--muted);line-height:1.5;margin:0;
}
.pgf-partner-info p strong{color:var(--gold-deep)}
.pgf-partner-action{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:10px 18px;border-radius:8px;
  font-size:12px;font-weight:700;
  text-decoration:none;text-transform:uppercase;letter-spacing:.4px;
  flex-shrink:0;
  transition:transform .15s ease;
}
.pgf-partner-action:hover{transform:translateY(-1px)}


/* ═══ PARAGRAF AUTHORIZED PARTNER (v17 phase 21) ═══ */
.pg-banner{
  background:linear-gradient(135deg,#1a3868 0%,#0f2a52 50%,#0a1d3a 100%);
  color:#fff;border-radius:14px;
  padding:22px 24px;margin:24px 0;
  border:1.5px solid var(--gold);
  position:relative;overflow:hidden;
  display:flex;align-items:center;gap:18px;flex-wrap:wrap;
  box-shadow:0 14px 36px rgba(8,26,51,.18);
}
.pg-banner::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:300px;height:300px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.pg-banner-icon{
  width:64px;height:64px;border-radius:14px;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:flex;align-items:center;justify-content:center;
  font-size:32px;flex-shrink:0;
  border:2px solid #fff;
  position:relative;z-index:2;
}
.pg-banner-content{flex:1;min-width:240px;position:relative;z-index:2}
.pg-banner-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:3px 10px;border-radius:10px;
  font-size:10px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
  margin-bottom:8px;
}
.pg-banner h4{
  color:#fff;font-family:var(--serif);font-size:18px;
  margin:0 0 6px;font-weight:700;
}
.pg-banner h4 em{color:var(--gold-soft);font-style:normal}
.pg-banner p{
  color:rgba(255,255,255,.88);font-size:13px;line-height:1.6;margin:0;
}
.pg-banner p strong{color:var(--gold-soft)}
.pg-banner-link{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:10px 18px;border-radius:8px;
  font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;
  text-decoration:none;flex-shrink:0;
  position:relative;z-index:2;
  transition:transform .15s ease;
  display:inline-flex;align-items:center;gap:6px;
}
.pg-banner-link:hover{transform:translateY(-1px)}
.pg-seal{
  display:inline-flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,rgba(26,56,104,.12),rgba(212,173,74,.08));
  border:1px solid var(--gold-soft);
  padding:4px 10px;border-radius:8px;
  font-size:11px;font-weight:600;color:var(--navy);
  margin-left:6px;
}
[data-theme="dark"] .pg-seal{color:var(--ink)}
.pg-seal-icon{color:var(--gold-deep);font-size:13px;line-height:1}
.gd-step.pg-step{
  border-left:3px solid var(--gold);
  background:linear-gradient(90deg,rgba(212,173,74,.05),var(--paper) 30%);
}
.gd-step.pg-step::before{
  background:linear-gradient(135deg,#1a3868,#0a1d3a);
  color:var(--gold-soft);
}


/* ═══ Champions 8 & 9 (v17 phase 22) ═══ */

/* Free Financial Zone */
.ffz-section{
  background:linear-gradient(180deg,var(--cream-soft),var(--cream));
  padding:80px 0;
}
[data-theme="dark"] .ffz-section{
  background:linear-gradient(180deg,var(--paper),var(--cream-soft));
}
.ffz-hero{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:0 0 32px;
  position:relative;overflow:hidden;
  border:2px solid var(--gold);
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.ffz-hero::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.ffz-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
}
.ffz-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.ffz-hero h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.ffz-hero p{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0;
  position:relative;z-index:2;max-width:780px;
}

.ffz-stats{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:14px;margin-top:22px;position:relative;z-index:2;
}
.ffz-stat{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.3);
  border-radius:12px;padding:14px 16px;
  text-align:center;
}
.ffz-stat-num{
  font-family:var(--serif);font-size:28px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.ffz-stat-label{
  color:rgba(255,255,255,.85);font-size:11px;
  text-transform:uppercase;letter-spacing:.5px;font-weight:600;
  margin-top:6px;
}

.ffz-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:18px;
  margin-top:24px;
}
@media (max-width:880px){.ffz-grid{grid-template-columns:1fr}}

.ffz-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:22px;
}
.ffz-card h4{
  font-family:var(--serif);font-size:17px;color:var(--navy);
  margin:0 0 12px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .ffz-card h4{color:var(--ink)}
.ffz-card p{color:var(--muted);font-size:13px;line-height:1.6;margin:0 0 10px}
.ffz-card ul{list-style:none;padding:0;margin:8px 0 0}
.ffz-card li{
  padding:7px 0;border-top:1px dashed var(--line-soft);
  font-size:13px;line-height:1.5;color:var(--ink);
  display:flex;justify-content:space-between;gap:10px;
}
.ffz-card li:first-child{border-top:none}
.ffz-card li strong{color:var(--gold-deep);font-family:var(--mono);font-size:13px}

/* Win-win formula */
.ffz-formula{
  background:linear-gradient(135deg,rgba(212,173,74,.1),rgba(76,175,80,.1));
  border:2px solid var(--gold);
  border-radius:14px;padding:20px 24px;margin-top:18px;
  text-align:center;
}
.ffz-formula-eq{
  font-family:var(--serif);font-size:20px;font-weight:700;
  color:var(--navy);margin:0 0 6px;
  line-height:1.4;
}
[data-theme="dark"] .ffz-formula-eq{color:var(--ink)}
.ffz-formula-desc{
  font-size:13px;color:var(--muted);line-height:1.6;margin:0;
}
.ffz-formula-eq strong{color:var(--gold-deep)}

/* Mining section */
.mn-section{
  background:linear-gradient(180deg,var(--paper),var(--cream-soft));
  padding:80px 0;
}
[data-theme="dark"] .mn-section{
  background:linear-gradient(180deg,var(--cream),var(--paper));
}
.mn-hero{
  background:linear-gradient(135deg,#2d4a2c 0%,#1a3868 100%);
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:0 0 32px;
  position:relative;overflow:hidden;
  border:2px solid #5fce7e;
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.mn-hero::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(76,175,80,.18),transparent 70%);
  pointer-events:none;
}
.mn-tag{
  display:inline-block;
  background:linear-gradient(135deg,#5fce7e,#3fa75d);
  color:#fff;
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
}
.mn-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.mn-hero h2 em{color:#a9e6b8;font-style:normal;font-weight:700}
.mn-hero p{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0;
  position:relative;z-index:2;max-width:780px;
}

.mn-deposits{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:14px;margin-top:24px;
}
.mn-deposit{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;padding:16px 18px;
  position:relative;
  transition:all .25s ease;
  border-left:4px solid #5fce7e;
}
.mn-deposit:hover{
  transform:translateY(-3px);
  box-shadow:0 12px 28px rgba(8,26,51,.12);
  border-left-color:var(--gold);
}
.mn-deposit-head{
  display:flex;justify-content:space-between;align-items:flex-start;
  margin-bottom:8px;gap:10px;
}
.mn-deposit-name{
  font-family:var(--serif);font-size:15px;font-weight:700;
  color:var(--navy);margin:0;
}
[data-theme="dark"] .mn-deposit-name{color:var(--ink)}
.mn-deposit-loc{
  font-size:11px;color:var(--muted);margin:2px 0 0;
}
.mn-deposit-status{
  font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;
  padding:3px 8px;border-radius:8px;flex-shrink:0;
}
.mn-deposit-status.active{background:rgba(76,175,80,.15);color:#2e7d32}
.mn-deposit-status.planned{background:rgba(255,152,0,.15);color:#e65100}
.mn-deposit-status.unique{background:linear-gradient(135deg,var(--gold),var(--gold-deep));color:var(--navy-deep)}
[data-theme="dark"] .mn-deposit-status.active{background:rgba(76,175,80,.25);color:#5fce7e}
[data-theme="dark"] .mn-deposit-status.planned{background:rgba(255,152,0,.25);color:#ffa726}

.mn-deposit-desc{
  font-size:12px;color:var(--muted);line-height:1.55;margin:6px 0;
}
.mn-deposit-mins{
  display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;
}
.mn-mineral-tag{
  font-size:10px;font-weight:700;
  background:rgba(212,173,74,.12);color:var(--gold-deep);
  padding:2px 8px;border-radius:8px;
}

.mn-principles{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:14px;margin-top:32px;
}
.mn-principle{
  background:linear-gradient(135deg,rgba(76,175,80,.08),rgba(76,175,80,.02));
  border:1.5px solid #5fce7e;
  border-radius:12px;padding:18px 20px;
}
[data-theme="dark"] .mn-principle{
  background:linear-gradient(135deg,rgba(76,175,80,.12),rgba(76,175,80,.04));
}
.mn-principle-icon{font-size:30px;line-height:1;margin-bottom:8px}
.mn-principle h4{
  font-family:var(--serif);font-size:14px;color:var(--navy);
  margin:0 0 6px;
}
[data-theme="dark"] .mn-principle h4{color:var(--ink)}
.mn-principle p{
  font-size:12px;color:var(--muted);line-height:1.55;margin:0;
}


/* ═══ MK-DRONES (v17 phase 24) ═══ */
.dr-section{
  background:linear-gradient(180deg,var(--cream),var(--cream-soft));
  padding:80px 0;
}
[data-theme="dark"] .dr-section{
  background:linear-gradient(180deg,var(--cream-soft),var(--paper));
}
.dr-hero{
  background:linear-gradient(135deg,#1e3a5f 0%,#2d5fa0 50%,#0a1d3a 100%);
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:0 0 32px;
  position:relative;overflow:hidden;
  border:2px solid var(--gold);
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.dr-hero::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.dr-hero::after{
  content:"🛸";position:absolute;bottom:24px;right:30px;
  font-size:90px;opacity:.15;pointer-events:none;
  animation:dr-float 4s ease-in-out infinite;
}
@keyframes dr-float{
  0%,100%{transform:translateY(0) rotate(-5deg)}
  50%{transform:translateY(-12px) rotate(5deg)}
}
.dr-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
}
.dr-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.dr-hero h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.dr-hero p{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0;
  position:relative;z-index:2;max-width:780px;
}

.dr-stats{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
  gap:14px;margin-top:22px;position:relative;z-index:2;
}
.dr-stat{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.3);
  border-radius:12px;padding:14px 16px;
  text-align:center;
}
.dr-stat-num{
  font-family:var(--serif);font-size:26px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.dr-stat-label{
  color:rgba(255,255,255,.85);font-size:11px;
  text-transform:uppercase;letter-spacing:.5px;font-weight:600;
  margin-top:6px;
}

/* Sectors grid */
.dr-sectors{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:16px;margin-top:28px;
}
.dr-sector{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:22px 20px;
  transition:all .25s ease;
  border-left:4px solid var(--gold);
  position:relative;overflow:hidden;
}
.dr-sector:hover{
  transform:translateY(-3px);
  box-shadow:0 14px 32px rgba(8,26,51,.12);
  border-left-color:var(--navy);
}
.dr-sector-icon{
  font-size:38px;line-height:1;margin-bottom:10px;
  display:inline-block;
}
.dr-sector h4{
  font-family:var(--serif);font-size:17px;color:var(--navy);
  margin:0 0 8px;font-weight:700;
}
[data-theme="dark"] .dr-sector h4{color:var(--ink)}
.dr-sector-desc{
  font-size:13px;color:var(--muted);line-height:1.6;margin:0 0 12px;
}
.dr-sector ul{
  list-style:none;padding:0;margin:8px 0 0;
}
.dr-sector li{
  font-size:12px;color:var(--ink);
  padding:4px 0;
  padding-left:14px;position:relative;
  line-height:1.5;
}
.dr-sector li::before{
  content:"▸";position:absolute;left:0;
  color:var(--gold-deep);font-weight:700;
}
.dr-sector-target{
  display:inline-block;
  font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;
  background:rgba(212,173,74,.12);color:var(--gold-deep);
  padding:3px 10px;border-radius:8px;
  margin-top:10px;
}

/* Macedonian companies consortium */
.dr-consortium{
  background:linear-gradient(135deg,rgba(212,173,74,.08),rgba(76,175,80,.04));
  border:2px solid var(--gold-soft);
  border-radius:14px;
  padding:24px;margin-top:28px;
}
[data-theme="dark"] .dr-consortium{
  background:linear-gradient(135deg,rgba(212,173,74,.12),rgba(76,175,80,.06));
}
.dr-consortium h3{
  font-family:var(--serif);font-size:20px;color:var(--navy);
  margin:0 0 8px;display:flex;align-items:center;gap:8px;
}
[data-theme="dark"] .dr-consortium h3{color:var(--ink)}
.dr-consortium-sub{
  font-size:13px;color:var(--muted);margin:0 0 18px;line-height:1.6;
}
.dr-companies{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:10px;
}
.dr-company{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:10px;padding:12px 14px;
  display:flex;align-items:center;gap:10px;
}
[data-theme="dark"] .dr-company{background:var(--cream)}
.dr-company-icon{
  width:36px;height:36px;border-radius:8px;
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);font-weight:700;font-size:15px;
  flex-shrink:0;
}
.dr-company-name{
  font-family:var(--serif);font-size:13px;font-weight:700;
  color:var(--navy);line-height:1.3;
}
[data-theme="dark"] .dr-company-name{color:var(--ink)}
.dr-company-role{
  font-size:10px;color:var(--muted);margin-top:1px;
  text-transform:uppercase;letter-spacing:.4px;font-weight:600;
}

/* Synergy with Robotika */
.dr-synergy{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:14px;padding:22px;margin-top:18px;
  display:grid;grid-template-columns:auto 1fr;gap:18px;align-items:center;
}
.dr-synergy-icon{
  width:64px;height:64px;border-radius:14px;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  display:flex;align-items:center;justify-content:center;
  font-size:32px;
}
.dr-synergy h4{
  font-family:var(--serif);font-size:16px;color:var(--navy);
  margin:0 0 4px;
}
[data-theme="dark"] .dr-synergy h4{color:var(--ink)}
.dr-synergy p{
  font-size:13px;color:var(--muted);line-height:1.6;margin:0;
}
.dr-synergy strong{color:var(--gold-deep)}
@media (max-width:560px){
  .dr-synergy{grid-template-columns:1fr;text-align:center}
  .dr-synergy-icon{margin:0 auto}
}


/* ═══ CRM (Central Registry) — pending partner (v17 phase 25) ═══ */
.if-card.if-crm .if-card-head{
  border-left:5px solid #2e7d32;
}
.if-card.if-crm .if-icon{
  background:linear-gradient(135deg,#5fce7e,#2e7d32);
  color:#fff;
}
.if-pending-badge{
  display:inline-block;
  background:linear-gradient(135deg,rgba(76,175,80,.15),rgba(76,175,80,.08));
  color:#2e7d32;
  border:1px solid #5fce7e;
  padding:3px 10px;border-radius:10px;
  font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;
  margin-top:6px;
}
[data-theme="dark"] .if-pending-badge{
  background:rgba(76,175,80,.2);
  color:#5fce7e;
}

/* Municipalities CRM note */
.muni-crm-note{
  background:linear-gradient(135deg,rgba(76,175,80,.08),rgba(76,175,80,.02));
  border:1.5px solid #5fce7e;
  border-left:5px solid #2e7d32;
  border-radius:10px;
  padding:12px 16px;margin:14px 0;
  display:flex;align-items:center;gap:12px;
  font-size:13px;color:var(--ink);line-height:1.5;
}
.muni-crm-note .crm-icon{
  width:36px;height:36px;border-radius:8px;
  background:linear-gradient(135deg,#5fce7e,#2e7d32);
  color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.muni-crm-note strong{color:#2e7d32}
[data-theme="dark"] .muni-crm-note strong{color:#5fce7e}


/* ═══ MEDIA HUB (v17 phase 26) ═══ */
.mh-section{
  background:linear-gradient(180deg,var(--paper),var(--cream-soft));
  padding:80px 0;
}
[data-theme="dark"] .mh-section{
  background:linear-gradient(180deg,var(--cream),var(--paper));
}

/* Hero */
.mh-hero{
  background:linear-gradient(135deg,#1a1a2e 0%,#2d2d44 50%,#0a1d3a 100%);
  color:#fff;border-radius:18px;
  padding:36px 32px;margin:0 0 32px;
  position:relative;overflow:hidden;
  border:2px solid var(--gold);
  box-shadow:0 20px 50px rgba(8,26,51,.25);
}
.mh-hero::before{
  content:"";position:absolute;top:-30%;right:-15%;
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(212,173,74,.18),transparent 70%);
  pointer-events:none;
}
.mh-hero::after{
  content:"📡";position:absolute;bottom:24px;right:30px;
  font-size:90px;opacity:.12;pointer-events:none;
  animation:mh-pulse 3s ease-in-out infinite;
}
@keyframes mh-pulse{0%,100%{opacity:.12;transform:scale(1)}50%{opacity:.2;transform:scale(1.08)}}

.mh-tag{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:5px 14px;border-radius:14px;
  font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  position:relative;z-index:2;margin-bottom:14px;
}
.mh-hero h2{
  font-family:var(--serif);color:#fff;
  font-size:32px;line-height:1.2;margin:0 0 12px;font-weight:700;
  position:relative;z-index:2;
}
.mh-hero h2 em{color:var(--gold-soft);font-style:normal;font-weight:700}
.mh-hero p{
  color:rgba(255,255,255,.92);font-size:15px;line-height:1.7;margin:0;
  position:relative;z-index:2;max-width:780px;
}

/* Stats strip */
.mh-stats{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:14px;margin-top:22px;position:relative;z-index:2;
}
.mh-stat{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.3);
  border-radius:12px;padding:14px 16px;
  text-align:center;
}
.mh-stat-num{
  font-family:var(--serif);font-size:26px;font-weight:700;
  color:var(--gold-soft);line-height:1;
}
.mh-stat-label{
  color:rgba(255,255,255,.85);font-size:11px;
  text-transform:uppercase;letter-spacing:.5px;font-weight:600;
  margin-top:6px;
}

/* Category filter tabs */
.mh-filters{
  display:flex;flex-wrap:wrap;gap:8px;
  margin:24px 0 18px;
  justify-content:center;
}
.mh-filter-btn{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:10px;
  padding:10px 18px;
  font-family:var(--sans);font-size:13px;font-weight:600;
  color:var(--ink);cursor:pointer;
  transition:all .2s ease;
  display:inline-flex;align-items:center;gap:6px;
}
.mh-filter-btn:hover{
  border-color:var(--gold);transform:translateY(-1px);
}
.mh-filter-btn.active{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  color:var(--gold-soft);
  border-color:var(--gold);
  box-shadow:0 6px 18px rgba(8,26,51,.18);
}
.mh-filter-btn .count{
  background:rgba(212,173,74,.2);
  color:var(--gold-deep);
  padding:2px 8px;border-radius:8px;
  font-size:11px;font-weight:700;
  margin-left:4px;
}
.mh-filter-btn.active .count{
  background:rgba(212,173,74,.3);
  color:var(--gold-soft);
}

/* Search bar */
.mh-search{
  max-width:520px;margin:0 auto 20px;
  position:relative;
}
.mh-search input{
  width:100%;padding:12px 18px 12px 44px;
  border:1.5px solid var(--line);border-radius:12px;
  background:var(--paper);
  font-family:var(--sans);font-size:14px;color:var(--ink);
  transition:border-color .2s ease;
}
.mh-search input:focus{
  outline:none;
  border-color:var(--gold);
  box-shadow:0 0 0 3px rgba(212,173,74,.15);
}
.mh-search::before{
  content:"🔍";position:absolute;left:16px;top:50%;
  transform:translateY(-50%);font-size:16px;
  pointer-events:none;
}

/* Media grid */
.mh-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
  gap:14px;
}
.mh-card{
  background:var(--paper);
  border:1.5px solid var(--line);
  border-radius:12px;
  padding:18px 18px 16px;
  transition:all .25s ease;
  border-left:4px solid var(--gold);
  position:relative;
}
.mh-card:hover{
  transform:translateY(-3px);
  box-shadow:0 14px 30px rgba(8,26,51,.12);
  border-left-color:var(--navy);
}

/* Category-specific borders */
.mh-card[data-cat="tv"]{border-left-color:#d4ad4a}
.mh-card[data-cat="radio"]{border-left-color:#5fce7e}
.mh-card[data-cat="portal"]{border-left-color:#4a90c2}
.mh-card[data-cat="print"]{border-left-color:#a8842b}
.mh-card[data-cat="agency"]{border-left-color:#9c6ad9}
.mh-card[data-cat="diaspora"]{border-left-color:#e85d75}

.mh-card-head{
  display:flex;justify-content:space-between;align-items:flex-start;
  gap:10px;margin-bottom:8px;
}
.mh-card-name{
  font-family:var(--serif);font-size:16px;font-weight:700;
  color:var(--navy);margin:0;line-height:1.3;
}
[data-theme="dark"] .mh-card-name{color:var(--ink)}
.mh-card-cat{
  font-size:10px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;
  padding:3px 8px;border-radius:8px;flex-shrink:0;
}
.mh-card-cat.tv{background:rgba(212,173,74,.15);color:var(--gold-deep)}
.mh-card-cat.radio{background:rgba(76,175,80,.15);color:#2e7d32}
.mh-card-cat.portal{background:rgba(74,144,194,.15);color:#1e60a0}
.mh-card-cat.print{background:rgba(168,132,43,.15);color:var(--gold-deep)}
.mh-card-cat.agency{background:rgba(156,106,217,.15);color:#6d3eb5}
.mh-card-cat.diaspora{background:rgba(232,93,117,.15);color:#b03050}

[data-theme="dark"] .mh-card-cat.tv{background:rgba(212,173,74,.2);color:var(--gold-soft)}
[data-theme="dark"] .mh-card-cat.radio{background:rgba(76,175,80,.2);color:#5fce7e}
[data-theme="dark"] .mh-card-cat.portal{background:rgba(74,144,194,.2);color:#7ab3d8}
[data-theme="dark"] .mh-card-cat.agency{background:rgba(156,106,217,.2);color:#b388e0}

.mh-card-desc{
  font-size:12px;color:var(--muted);line-height:1.55;
  margin:0 0 10px;
}
.mh-card-meta{
  display:flex;flex-direction:column;gap:4px;
  font-size:11px;color:var(--muted);
  padding:8px 0;
  border-top:1px dashed var(--line-soft);
}
.mh-card-meta-row{
  display:flex;align-items:center;gap:6px;
  line-height:1.4;
}
.mh-card-meta-row strong{color:var(--ink);font-weight:600}
.mh-card-meta-row .icon{flex-shrink:0;font-size:13px}

.mh-card-actions{
  display:flex;flex-wrap:wrap;gap:6px;
  margin-top:10px;padding-top:10px;
  border-top:1px solid var(--line-soft);
}
.mh-card-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:6px 12px;border-radius:7px;
  font-size:11px;font-weight:700;
  text-decoration:none;text-transform:uppercase;letter-spacing:.3px;
  transition:transform .15s ease;
  display:inline-flex;align-items:center;gap:4px;
}
.mh-card-btn:hover{transform:translateY(-1px)}
.mh-card-btn.secondary{
  background:transparent;
  color:var(--gold-deep);
  border:1.5px solid var(--gold-soft);
}
.mh-card-btn.secondary:hover{
  background:rgba(212,173,74,.08);
}

/* Hidden state */
.mh-card.hidden{display:none}

/* Press release composer */
.mh-composer{
  background:linear-gradient(135deg,var(--navy-deep),var(--navy-mid));
  border-radius:16px;
  padding:28px;margin-top:32px;
  color:#fff;
  border:2px solid var(--gold);
  position:relative;overflow:hidden;
}
.mh-composer::before{
  content:"";position:absolute;top:-30%;right:-10%;
  width:400px;height:400px;
  background:radial-gradient(circle,rgba(212,173,74,.15),transparent 70%);
  pointer-events:none;
}
.mh-composer h3{
  font-family:var(--serif);font-size:22px;color:var(--gold-soft);
  margin:0 0 10px;position:relative;z-index:2;
}
.mh-composer-sub{
  color:rgba(255,255,255,.85);font-size:14px;line-height:1.6;
  margin:0 0 18px;position:relative;z-index:2;
}
.mh-composer-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:14px;position:relative;z-index:2;
}
.mh-composer-card{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(212,173,74,.3);
  border-radius:10px;padding:16px 18px;
}
.mh-composer-card h4{
  color:var(--gold-soft);font-family:var(--serif);font-size:14px;
  margin:0 0 6px;display:flex;align-items:center;gap:6px;
}
.mh-composer-card p{
  color:rgba(255,255,255,.85);font-size:12px;line-height:1.55;margin:0;
}
.mh-bulk-actions{
  display:flex;flex-wrap:wrap;gap:8px;
  margin-top:18px;position:relative;z-index:2;
}
.mh-bulk-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold-deep));
  color:var(--navy-deep);
  padding:10px 18px;border-radius:8px;
  font-size:12px;font-weight:700;text-decoration:none;
  text-transform:uppercase;letter-spacing:.4px;
  transition:transform .15s ease;
  display:inline-flex;align-items:center;gap:6px;
  border:none;cursor:pointer;font-family:inherit;
}
.mh-bulk-btn:hover{transform:translateY(-1px)}
.mh-bulk-btn.outline{
  background:transparent;
  color:var(--gold-soft);
  border:1.5px solid var(--gold-soft);
}

/* Press kit note */
.mh-press-kit{
  background:linear-gradient(135deg,rgba(76,175,80,.08),rgba(76,175,80,.02));
  border:1.5px solid #5fce7e;
  border-left:5px solid #2e7d32;
  border-radius:10px;padding:14px 18px;margin-top:18px;
  font-size:13px;color:var(--ink);line-height:1.55;
}
[data-theme="dark"] .mh-press-kit{
  background:linear-gradient(135deg,rgba(76,175,80,.12),rgba(76,175,80,.04));
}
.mh-press-kit strong{color:#2e7d32}
[data-theme="dark"] .mh-press-kit strong{color:#5fce7e}

@media (max-width:560px){
  .mh-filters{justify-content:flex-start;overflow-x:auto;flex-wrap:nowrap;padding-bottom:6px}
  .mh-filter-btn{white-space:nowrap;flex-shrink:0}
}

</style>

