   ════════════════════════════════════════════════════════════ */
(function(){
  'use strict';

  /* ════════════════════════════════════════════════════════════
     v17 SAFE CONSOLE SHIM
     Some sandboxed environments (about:srcdoc, certain WebViews)
     don't expose all console methods. Patch missing ones as no-ops
     to prevent "console.X is not a function" runtime errors.
     ════════════════════════════════════════════════════════════ */
  (function installSafeConsole(){
    try {
      if (typeof window.console === 'undefined' || window.console === null){
        window.console = {};
      }
      var noop = function(){};
      var methods = ['log','info','warn','error','debug','trace','dir','group',
                     'groupCollapsed','groupEnd','time','timeEnd','timeLog',
                     'count','countReset','assert','clear','table'];
      for (var i = 0; i < methods.length; i++){
        var m = methods[i];
        if (typeof window.console[m] !== 'function'){
          try { window.console[m] = noop; } catch(e){}
        }
      }
    } catch(e){
      // If even patching fails, create a fully fake console
      try {
        window.console = {
          log: function(){}, info: function(){}, warn: function(){},
          error: function(){}, debug: function(){}, trace: function(){},
          dir: function(){}, group: function(){}, groupCollapsed: function(){},
          groupEnd: function(){}, time: function(){}, timeEnd: function(){},
          timeLog: function(){}, count: function(){}, countReset: function(){},
          assert: function(){}, clear: function(){}, table: function(){}
        };
      } catch(e2){}
    }
  })();

  /* ════════════════════════════════════════════════════════════
     v17 SAFE STORAGE SHIM
     about:srcdoc / opaque origins / private mode block localStorage
     and throw SecurityError. We patch the global to fail silently
     so the rest of the code keeps working without 100 try/catch blocks.
     ════════════════════════════════════════════════════════════ */
  (function installSafeStorage(){
    let storageBroken = false;
    let realStorage = null;
    try {
      // Some environments throw when even ACCESSING window.localStorage
      realStorage = window.localStorage;
      const testKey = '__ms_storage_test__';
      realStorage.setItem(testKey, '1');
      realStorage.removeItem(testKey);
    } catch(e){
      storageBroken = true;
    }
    if (storageBroken){
      const memStore = Object.create(null);
      const safe = {
        getItem(k){ return Object.prototype.hasOwnProperty.call(memStore, k) ? memStore[k] : null; },
        setItem(k, v){ memStore[k] = String(v); },
        removeItem(k){ delete memStore[k]; },
        clear(){ for (const k in memStore) delete memStore[k]; },
        key(i){ return Object.keys(memStore)[i] || null; },
        get length(){ return Object.keys(memStore).length; },
      };
      // Try multiple strategies to install the shim
      let installed = false;
      try {
        Object.defineProperty(window, 'localStorage', {value: safe, configurable: true, writable: true});
        installed = true;
      } catch(e){}
      if (!installed){
        try { window.localStorage = safe; installed = true; } catch(e){}
      }
      if (!installed){
        // Worst case: expose as ms_safeStorage and pray nothing else needs it
        window.ms_safeStorage = safe;
      }
      try { console.info('[v17] localStorage unavailable; using in-memory fallback.'); } catch(e){}
    }
    // Also patch sessionStorage just in case
    try {
      window.sessionStorage.setItem('__t__','1');
      window.sessionStorage.removeItem('__t__');
    } catch(e){
      const memSS = Object.create(null);
      const safeSS = {
        getItem(k){ return Object.prototype.hasOwnProperty.call(memSS, k) ? memSS[k] : null; },
        setItem(k, v){ memSS[k] = String(v); },
        removeItem(k){ delete memSS[k]; },
        clear(){ for (const k in memSS) delete memSS[k]; },
        key(i){ return Object.keys(memSS)[i] || null; },
        get length(){ return Object.keys(memSS).length; },
      };
      try { Object.defineProperty(window, 'sessionStorage', {value: safeSS, configurable: true, writable: true}); }
      catch(e2){ try { window.sessionStorage = safeSS; } catch(e3){} }
    }
  })();

