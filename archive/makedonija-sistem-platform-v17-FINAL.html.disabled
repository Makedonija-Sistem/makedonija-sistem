  function botRespond(query){
    const q = (query || '').toLowerCase().trim();
    if (!q) return 'Прашај нешто за платформата — има <b>30 секции</b> и можам да помогнам со сè. Пробај: <b>преглед</b>, <b>помош</b>, <b>дијаспора</b>, <b>иницијативи</b>, <b>статут</b>, <b>swot</b>, <b>петиции</b>, <b>буџет</b>, <b>јазик</b>, <b>пристапност</b>.';

    // Try patterns in order
    for (const p of PATTERNS){
      if (p.test.test(q)) return p.fn();
    }

    // Fallback
    return 'Не пронајдов конкретен одговор. Пробај со клучни зборови како: <b>манифест, статут, принципи, програма, 12 столбови, 100 дена, дијаспора, иницијативи, петиции, буџет, анонимно, гласање, благосостојба, swot, светски модели, светски партии, општини, членство, кеп, нотар, junge, конгрес, officina, институт, дик, црм, магазин, growth, картичка, тема, јазик, тастатура, пристапност, офлајн, pwa, приватност, контакт</b>. Или прашај <a style="color:var(--gold-soft);font-weight:700;text-decoration:underline" href="javascript:void(0)" onclick="document.getElementById(\'botInput\').value=\'помош\';document.getElementById(\'botSend\').click()">што можеш да правиш</a>.';
  }

  function appendBotMessage(text, who){
    if (!botBody) return;
    const div = document.createElement('div');
    div.className = 'bot-msg ' + (who === 'user' ? 'user' : 'bot');
    div.innerHTML = (who === 'user' ? '<b>Ти:</b> ' : '<b>M-S:</b> ') + text;
    // insert before quick buttons row
    const quick = botBody.querySelector('.bot-quick');
    if (quick) botBody.insertBefore(div, quick);
    else botBody.appendChild(div);
    botBody.scrollTop = botBody.scrollHeight;
  }

  function handleBotQuery(q){
    if (!q || !q.trim()) return;
    appendBotMessage(q, 'user');
    setTimeout(() => appendBotMessage(botRespond(q), 'bot'), 280);
  }

  if (botSend && botInput){
    botSend.addEventListener('click', () => {
      const v = botInput.value;
      botInput.value = '';
      handleBotQuery(v);
    });
    botInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter'){
        const v = botInput.value;
        botInput.value = '';
        handleBotQuery(v);
      }
    });
  }

  document.querySelectorAll('.bot-quick button').forEach(btn => {
    btn.addEventListener('click', () => {
      // The data-q value is already a natural-language query phrase
      handleBotQuery(btn.dataset.q || btn.textContent);
    });
  });

  // open bot once after delay (UX hint), only first visit
  try {
    if (!sessionStorage.getItem('ms_bot_seen')){
      setTimeout(() => {
        if (botFloat && !botFloat.classList.contains('open')){
          // pulse the toggle
          if (botToggle){
            botToggle.style.animation = 'pulse 1.4s ease-in-out 2';
          }
        }
        sessionStorage.setItem('ms_bot_seen', '1');
      }, 4000);
    }
  } catch(e){}

  /* ════════════════════════════════════════
     THEME TOGGLE (light ↔ dark) · v17 · prefers-color-scheme aware
     ════════════════════════════════════════ */
  const themeToggle = $('themeToggle');
  const THEME_KEY = 'ms_theme';
  function applyTheme(theme){
    if (theme === 'dark'){
      document.documentElement.setAttribute('data-theme', 'dark');
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
    if (themeToggle){
      themeToggle.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
    }
  }
  try {
    const saved = localStorage.getItem(THEME_KEY);
    if (saved === 'dark' || saved === 'light') applyTheme(saved);
    else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) applyTheme('dark');
  } catch(e){}
  if (themeToggle){
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const next = isDark ? 'light' : 'dark';
      applyTheme(next);
      try { localStorage.setItem(THEME_KEY, next); } catch(e){}
      if (typeof showToast === 'function' && typeof t === 'function'){
        showToast(next === 'dark' ? '🌙 ' + t('toast.theme.dark') : '☀️ ' + t('toast.theme.light'), 'info', 1500);
      }
    });
  }
  // Live-update if user hasn't picked a theme
  if (window.matchMedia){
    const mq = window.matchMedia('(prefers-color-scheme: dark)');
    if (mq.addEventListener){
      mq.addEventListener('change', (e) => {
        try {
          if (!localStorage.getItem(THEME_KEY)){
            applyTheme(e.matches ? 'dark' : 'light');
          }
        } catch(err){}
      });
    }
  }

  /* ════════════════════════════════════════
     DASHBOARD COUNTERS (animated number ramps)
     ════════════════════════════════════════ */
  function formatNum(n, fmt){
    if (fmt === 'separator') return Math.round(n).toLocaleString('mk-MK').replace(/,/g, ',');
    return Math.round(n).toString();
  }
  function animateCount(el){
    const target = parseFloat(el.dataset.countTo || '0');
    const fmt = el.dataset.countFormat;
    const suffix = el.dataset.countSuffix || '';
    const dur = 1600;
    const start = performance.now();
    function tick(now){
      const t = Math.min(1, (now - start) / dur);
      const eased = 1 - Math.pow(1 - t, 3);
      el.textContent = formatNum(target * eased, fmt) + suffix;
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = formatNum(target, fmt) + suffix;
    }
    requestAnimationFrame(tick);
  }
  // Trigger counters when dashboard becomes visible
  const dashCards = document.querySelectorAll('.dash-card .dc-value[data-count-to]');
  if ('IntersectionObserver' in window && dashCards.length){
    const dashIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting){
          animateCount(e.target);
          dashIO.unobserve(e.target);
        }
      });
    }, {threshold: 0.4});
    dashCards.forEach(c => dashIO.observe(c));
  } else {
    dashCards.forEach(animateCount);
  }
  // Update timestamp
  const dashTs = $('dashTs');
  if (dashTs){
    const d = new Date();
    const pad = n => String(n).padStart(2, '0');
    dashTs.textContent = 'Ажурирано: ' + pad(d.getDate()) + '.' + pad(d.getMonth()+1) + '.' + d.getFullYear();
  }

  /* ════════════════════════════════════════
     QUOTES CAROUSEL
     ════════════════════════════════════════ */
  const carousel = $('quoteCarousel');
  if (carousel){
    const slides = carousel.querySelectorAll('.qc-slide');
    const controls = $('qcControls');
    let active = 0;
    let auto = null;

    function go(i){
      slides.forEach((s,idx) => s.classList.toggle('active', idx === i));
      if (controls){
        Array.from(controls.children).forEach((btn, idx) => btn.classList.toggle('active', idx === i));
      }
      active = i;
    }

    if (controls){
      slides.forEach((_, i) => {
        const btn = document.createElement('button');
        btn.className = 'qc-dot' + (i === 0 ? ' active' : '');
        btn.setAttribute('aria-label', 'Цитат ' + (i+1));
        btn.addEventListener('click', () => {
          go(i);
          if (auto) { clearInterval(auto); auto = setInterval(next, 6000); }
        });
        controls.appendChild(btn);
      });
    }

    function next(){ go((active + 1) % slides.length); }
    auto = setInterval(next, 6000);

    // pause on hover
    carousel.addEventListener('mouseenter', () => { if (auto) clearInterval(auto); auto = null; });
    carousel.addEventListener('mouseleave', () => { if (!auto) auto = setInterval(next, 6000); });
  }

  /* ════════════════════════════════════════
     NEWSLETTER FORM
     ════════════════════════════════════════ */
  const newsForm = $('newsletterForm');
  const newsEmail = $('newsletterEmail');
  const newsConsent = $('newsletterConsent');
  const newsSuccess = $('newsletterSuccess');
  if (newsForm){
    newsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = newsEmail.value.trim();
      if (!email || !/^.+@.+\..+$/.test(email)){
        alert('Внеси валиден email.');
        return;
      }
      if (!newsConsent.checked){
        alert('Мора да се согласите со условите за обработка на лични податоци.');
        return;
      }
      const subject = encodeURIComponent('Претплата за „Пулс на неделата"');
      const body = encodeURIComponent('Email: ' + email + '\n\nЈас се согласувам да ги примам седмичните објави „Пулс на неделата" од Македонија — Систем.\n\nДата: ' + new Date().toLocaleString('mk-MK'));
      window.location.href = 'mailto:makedonijasistem@gmail.com?subject=' + subject + '&body=' + body;
      if (newsSuccess){
        newsSuccess.classList.add('show');
        setTimeout(() => newsSuccess.classList.remove('show'), 6000);
      }
    });
  }

  /* ════════════════════════════════════════
     MUNICIPALITY MAP — interactive (80 municipalities)
     ════════════════════════════════════════ */
  const muniRegions = document.querySelectorAll('.muni-region');
  const muniName = $('muniName');
  const muniPop = $('muniPop');
  const muniStatus = $('muniStatus');
  const muniList = $('muniList');

  function openRegionInList(regionName){
    if (!muniList) return;
    const allGroups = muniList.querySelectorAll('.muni-region-group');
    allGroups.forEach(g => g.open = false);
    allGroups.forEach(g => {
      const summaryText = g.querySelector('summary')?.textContent || '';
      if (regionName && summaryText.includes(regionName.split(' ')[0])){
        g.open = true;
        g.scrollIntoView({behavior:'smooth', block:'nearest'});
      }
    });
  }

  muniRegions.forEach(r => {
    r.addEventListener('click', () => {
      muniRegions.forEach(x => x.classList.remove('active'));
      r.classList.add('active');
      if (muniName) muniName.textContent = r.dataset.name || '';
      if (muniPop) muniPop.textContent = r.dataset.pop || '';
      if (muniStatus){
        const status = r.dataset.coordinator || '';
        const isActive = status.startsWith('Активен');
        muniStatus.innerHTML = (isActive ? '✓ ' : '⌛ ') + status;
        muniStatus.style.borderLeftColor = isActive ? '#5fce7e' : 'var(--gold)';
      }
      // Open corresponding municipality group
      openRegionInList(r.dataset.name);
    });
    // keyboard accessibility
    r.setAttribute('tabindex', '0');
    r.setAttribute('role', 'button');
    r.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' || e.key === ' '){
        e.preventDefault();
        r.dispatchEvent(new MouseEvent('click'));
      }
    });
  });

  /* ════════════════════════════════════════
     CITIZENS MARCH — Proposals form + localStorage
     ════════════════════════════════════════ */
  const propForm = $('proposalForm');
  const propSuccess = $('propSuccess');
  const propMineList = $('propMineList');
  const propMineCount = $('propMineCount');
  const propMineClear = $('propMineClear');
  const propClear = $('propClear');
  const PROP_KEY = 'ms_proposals_v1';

  // Character counters
  const propTitle = $('propTitle');
  const titleCounter = $('titleCounter');
  const propDescription = $('propDescription');
  const descCounter = $('descCounter');

  function updateCounter(input, counter, max){
    if (!input || !counter) return;
    const len = input.value.length;
    counter.textContent = len + ' / ' + max;
    counter.style.color = len > max * 0.9 ? '#d4ad4a' : '';
  }
  if (propTitle && titleCounter){
    propTitle.addEventListener('input', () => updateCounter(propTitle, titleCounter, 120));
  }
  if (propDescription && descCounter){
    propDescription.addEventListener('input', () => updateCounter(propDescription, descCounter, 2000));
  }

  function loadProposals(){
    try {
      const raw = localStorage.getItem(PROP_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch(e){ return []; }
  }
  function saveProposals(arr){
    try { localStorage.setItem(PROP_KEY, JSON.stringify(arr)); } catch(e){}
  }

  function renderProposals(){
    if (!propMineList || !propMineCount) return;
    const arr = loadProposals();
    propMineCount.textContent = arr.length;
    if (arr.length === 0){
      propMineList.innerHTML =
        '<div class="cm-mine-empty">' +
        '<span class="cm-empty-icon">📭</span>' +
        '<p>Сè уште немаш поднесено предлози. Стани првиот граѓанин-автор на програмата.</p>' +
        '</div>';
      return;
    }
    // Render newest first
    propMineList.innerHTML = arr.slice().reverse().map((p, idx) => {
      const realIdx = arr.length - 1 - idx;
      const cat = (p.category || '').replace(/^[^\s]+\s*/, '');
      const date = p.date ? new Date(p.date).toLocaleDateString('mk-MK') : '';
      const safeTitle = (p.title || '').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      return '<div class="cm-mine-item" data-idx="' + realIdx + '">' +
        '<button class="cm-mi-del" data-idx="' + realIdx + '" aria-label="Избриши">×</button>' +
        '<h5>' + safeTitle + '</h5>' +
        '<div class="cm-mi-meta">' + (cat || '—') + ' · ' + date + '</div>' +
      '</div>';
    }).join('');

    // Bind delete buttons
    propMineList.querySelectorAll('.cm-mi-del').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const i = parseInt(btn.dataset.idx, 10);
        if (isNaN(i)) return;
        if (!confirm('Избриши го овој запис од твоите предлози?')) return;
        const arr2 = loadProposals();
        arr2.splice(i, 1);
        saveProposals(arr2);
        renderProposals();
      });
    });
  }
  renderProposals();

  if (propMineClear){
    propMineClear.addEventListener('click', () => {
      if (!loadProposals().length) return;
      if (!confirm('Сигурно избриши ги сите твои локални записи?')) return;
      saveProposals([]);
      renderProposals();
    });
  }

  if (propClear){
    propClear.addEventListener('click', () => {
      if (!confirm('Исчисти ја формата без испраќање?')) return;
      propForm.reset();
      updateCounter(propTitle, titleCounter, 120);
      updateCounter(propDescription, descCounter, 2000);
    });
  }

  if (propForm){
    propForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(propForm);
      const consent = $('propConsent');
      const anonymous = $('propAnonymous');

      // Required validation
      const required = ['name', 'email', 'category', 'title', 'description'];
      for (const f of required){
        if (!String(data.get(f) || '').trim()){
          alert('Те молам пополни ги сите задолжителни полиња (со ★).');
          return;
        }
      }
      if (!consent || !consent.checked){
        alert('Мора да се согласите со условите за обработка на предлогот.');
        return;
      }
      const email = String(data.get('email')).trim();
      if (!/^.+@.+\..+$/.test(email)){
        alert('Внеси валиден email.');
        return;
      }

      // Save to local archive
      const entry = {
        date: new Date().toISOString(),
        name: data.get('name'),
        email: email,
        location: data.get('location') || '',
        category: data.get('category'),
        title: data.get('title'),
        description: data.get('description'),
        impact: data.get('impact') || '',
        timeframe: data.get('timeframe') || '',
        reference: data.get('reference') || '',
        anonymous: anonymous && anonymous.checked
      };
      const arr = loadProposals();
      arr.push(entry);
      saveProposals(arr);
      renderProposals();

      // Build email
      const subject = encodeURIComponent('[ПРЕДЛОГ] ' + (entry.category || '') + ' — ' + entry.title);
      const body = encodeURIComponent(
        '═══════════════════════════════════════\n' +
        'ГРАЃАНСКИ ПРЕДЛОГ ДО МАКЕДОНИЈА — СИСТЕМ\n' +
        '═══════════════════════════════════════\n\n' +
        'Поднесено: ' + new Date(entry.date).toLocaleString('mk-MK') + '\n\n' +
        '── ПОДНОСИТЕЛ ──\n' +
        'Име и презиме: ' + entry.name + '\n' +
        'Email: ' + entry.email + '\n' +
        'Локација: ' + (entry.location || '(не е наведено)') + '\n' +
        'Анонимно објавување: ' + (entry.anonymous ? 'ДА' : 'НЕ') + '\n\n' +
        '── ПРЕДЛОГ ──\n' +
        'Категорија: ' + entry.category + '\n' +
        'Очекуван ефект: ' + entry.impact + '\n' +
        'Временски хоризонт: ' + entry.timeframe + '\n\n' +
        'НАСЛОВ:\n' + entry.title + '\n\n' +
        'ОПИС:\n' + entry.description + '\n\n' +
        (entry.reference ? 'Референца / Извор:\n' + entry.reference + '\n\n' : '') +
        '── СОГЛАСНОСТ ──\n' +
        'Подносителот се согласува предлогот да биде разгледан од Програмскиот совет на „Македонија — Систем" во согласност со важечките статутарни одредби и Законот за заштита на лични податоци.\n\n' +
        '— Испратено преку платформата на Македонија — Систем\n' +
        'makedonijasistem.mk · Ред · Закон · Одговорност'
      );

      window.location.href = 'mailto:makedonijasistem@gmail.com?subject=' + subject + '&body=' + body;

      if (propSuccess){
        propSuccess.classList.add('show');
        setTimeout(() => propSuccess.classList.remove('show'), 8000);
      }

      // Reset form but keep name/email for next proposal
      propForm.reset();
      updateCounter(propTitle, titleCounter, 120);
      updateCounter(propDescription, descCounter, 2000);
    });
  }

  /* ════════════════════════════════════════
     INITIATIVE VOTING — interactive 👍 buttons
     ════════════════════════════════════════ */
  const VOTES_KEY = 'ms_init_votes_v1';
  const VOTED_KEY = 'ms_init_voted_v1';

  function loadVotes(){
    try {
      const v = JSON.parse(localStorage.getItem(VOTES_KEY) || '{}');
      return typeof v === 'object' && v !== null ? v : {};
    } catch(e){ return {}; }
  }
  function saveVotesObj(obj){
    try { localStorage.setItem(VOTES_KEY, JSON.stringify(obj)); } catch(e){}
  }
  function loadVoted(){
    try {
      const v = JSON.parse(localStorage.getItem(VOTED_KEY) || '[]');
      return Array.isArray(v) ? v : [];
    } catch(e){ return []; }
  }
  function saveVotedArr(arr){
    try { localStorage.setItem(VOTED_KEY, JSON.stringify(arr)); } catch(e){}
  }

  function formatVoteNumber(n){
    return Math.round(n).toLocaleString('en-US');
  }

  function recalcInitBars(){
    const cards = document.querySelectorAll('.init-card[data-init-id]');
    cards.forEach(card => {
      const bar = card.querySelector('.init-vote-bar i');
      if (!bar) return;
      const basePct = parseInt(bar.dataset.basePct, 10) || 50;
      const id = card.dataset.initId;
      const userVotes = parseInt((loadVotes())[id] || 0, 10);
      // Each vote adds a tiny visual bump (cap at +10%)
      const bump = Math.min(10, userVotes * 0.5);
      bar.style.width = Math.min(100, basePct + bump) + '%';
    });
  }

  const initButtons = document.querySelectorAll('.init-vote-btn');
  const initStored = loadVotes();
  const initVoted = loadVoted();

  initButtons.forEach(btn => {
    const id = btn.dataset.init;
    const base = parseInt(btn.dataset.base, 10) || 0;
    const userVotes = parseInt(initStored[id] || 0, 10);
    const total = base + userVotes;
    const countEl = btn.querySelector('.iv-count b');
    if (countEl) countEl.textContent = formatVoteNumber(total);

    if (initVoted.indexOf(id) !== -1){
      btn.classList.add('voted');
      btn.disabled = true;
      const label = btn.querySelector('.iv-label');
      if (label) label.textContent = 'гласано';
    }

    btn.addEventListener('click', (e) => {
      e.preventDefault();
      if (btn.classList.contains('voted') || btn.disabled || btn.dataset.locked === '1') return;

      // LOCK IMMEDIATELY to prevent double-clicks during animation
      btn.dataset.locked = '1';
      btn.disabled = true;

      const current = loadVotes();
      current[id] = (parseInt(current[id] || 0, 10)) + 1;
      saveVotesObj(current);

      const v = loadVoted();
      if (v.indexOf(id) === -1){
        v.push(id);
        saveVotedArr(v);
      }

      const newTotal = base + current[id];
      if (countEl){
        countEl.textContent = formatVoteNumber(newTotal);
        const wrapper = btn.querySelector('.iv-count');
        if (wrapper){
          wrapper.classList.remove('bumping');
          void wrapper.offsetWidth;
          wrapper.classList.add('bumping');
        }
      }

      btn.classList.remove('bursting');
      void btn.offsetWidth;
      btn.classList.add('bursting');
      setTimeout(() => btn.classList.remove('bursting'), 700);

      const floater = document.createElement('span');
      floater.className = 'iv-floater';
      floater.textContent = '+1';
      btn.appendChild(floater);
      setTimeout(() => floater.remove(), 1300);

      setTimeout(() => {
        btn.classList.add('voted');
        const label = btn.querySelector('.iv-label');
        if (label) label.textContent = 'гласано';
        recalcInitBars();
      }, 350);
    });
  });

  setTimeout(recalcInitBars, 200);

  /* ════════════════════════════════════════════════════════════
     WORLD PARTIES ATLAS — filter by ideological block
     ════════════════════════════════════════════════════════════ */
  document.querySelectorAll('.wp-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.wp-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      const cards = document.querySelectorAll('.wp-card');
      let visibleCount = 0;
      cards.forEach(card => {
        const block = card.dataset.block;
        let show = false;
        if (filter === 'all') show = true;
        else if (filter === 'center') show = (block === 'center-right' || block === 'center-left');
        else show = (block === filter);
        if (show){
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });
      const empty = document.getElementById('wpEmpty');
      if (empty) empty.style.display = visibleCount === 0 ? '' : 'none';
    });
  });

  /* ════════════════════════════════════════════════════════════
     DONATIONS — tier selection + payment platform + email submit
     ════════════════════════════════════════════════════════════ */
  let donAmount = 0;
  let donPlatform = '';

  const PLATFORM_INFO = {
    stripe: {
      name: 'Stripe',
      instructions: `Stripe е глобална платформа за безбедни картични плаќања.

ПРОЦЕС НА ПЛАЌАЊЕ:
1. По прием на ова барање, програмскиот совет ќе ви испрати безбеден Stripe Checkout линк во рок од 24 часа.
2. Линкот е валиден 7 дена и обработва Visa, Mastercard, American Express и локални дебитни картички.
3. По успешно плаќање, добивате потврда на вашата е-пошта со ID на трансакција.
4. Дополнително, добивате јавен сертификат за донација (PDF) ако сте се согласиле со јавно споменување.

БЕЗБЕДНОСТ:
• Stripe е PCI-DSS Level 1 сертифициран — највисоко ниво на безбедност.
• Македонија — Систем НЕ ги гледа и НЕ ги чува вашите картични податоци.
• Сите плаќања се процесираат на Stripe серверите со 256-bit енкрипција.

ИЗВЕСТУВАЊЕ ВО АЗЛП:
Согласно ЗЗЛП („Сл. весник" 42/2020), вашите идентификациони податоци се чуваат само за правна евиденција, не за маркетинг.`
    },
    paypal: {
      name: 'PayPal',
      instructions: `PayPal е најпопуларна платформа за дигитални плаќања во дијаспора.

ПРОЦЕС НА ПЛАЌАЊЕ:
1. По прием на ова барање, ќе добиете PayPal.me линк (типот makedonijasistem) во рок од 24 часа.
2. Линкот ви овозможува плаќање со PayPal сметка ИЛИ дебитна/кредитна картичка (без потреба од PayPal сметка).
3. По успешно плаќање, добивате потврда од PayPal + наша потврда.
4. Македонски граѓани без PayPal сметка можат да користат опција „Donate as Guest" со картичка.

ЗОШТО ЗА ДИЈАСПОРА:
• Македонци во САД, Канада, Австралија — PayPal е наједноставен начин.
• Поддржува EUR, USD, AUD, CAD, GBP, CHF и многу други валути.
• Автоматска конверзија на курсна листа.

КОМИСИИ:
• PayPal комисија: ~2.9% + $0.30 (стандардно)
• Македонија — Систем добива нето сума по комисијата.`
    },
    visa: {
      name: 'Visa',
      instructions: `Visa картични плаќања — најшироко прифатени во светот.

ПРОЦЕС НА ПЛАЌАЊЕ:
1. По прием на ова барање, добивате безбеден линк за Visa картично плаќање во рок од 24 часа.
2. Платформата за плаќање го обработува плаќањето преку 3D Secure протокол (со SMS код од вашата банка).
3. Прифатени се: Visa, Visa Debit, Visa Electron — сите тип на Visa картички.
4. Поддршка за домашни (МКД) и меѓународни картички (EUR, USD, итн.).

3D SECURE АВТЕНТИКАЦИЈА:
• Безбедноста е загарантирана со 3D Secure стандард.
• Банката ви испраќа SMS код за потврда на трансакцијата.
• Без SMS код, плаќањето не може да се изврши.

ЗА МАКЕДОНСКИ ГРАЃАНИ:
• Сите македонски банки (Стопанска, НЛБ, Комерцијална, Силк Роуд, итн.) поддржуваат Visa.
• Минимална трансакција: 100 ден.
• Без скриени такси.`
    },
    mastercard: {
      name: 'Mastercard',
      instructions: `Mastercard картични плаќања — глобален стандард.

ПРОЦЕС НА ПЛАЌАЊЕ:
1. По прием на ова барање, добивате безбеден линк за Mastercard плаќање во рок од 24 часа.
2. Поддржани се сите типови: Mastercard, Maestro, Mastercard Debit.
3. Mastercard SecureCode (3D Secure) ја штити трансакцијата.
4. Прифатени се домашни и меѓународни картички.

ZA MAESTRO КАРТИЧКИ:
• Maestro дебитните картички (популарни во Македонија) се целосно прифатени.
• Без потреба од специјална регистрација.
• Брза обработка преку домашните банки.

КОМИСИИ И ТАКСИ:
• Mastercard комисија: ~2.5% (платена од Македонија — Систем)
• Без скриени такси за донаторот.
• Македонија — Систем добива нето сума.

БЕЗБЕДНОСТ:
• Mastercard SecureCode — индустриски стандард.
• PCI-DSS усогласеност на платформата за плаќање.
• Не ги чуваме картичните податоци.`
    }
  };

  // Tier selection
  document.querySelectorAll('.don-tier').forEach(tier => {
    tier.addEventListener('click', () => {
      document.querySelectorAll('.don-tier').forEach(t => t.classList.remove('active'));
      tier.classList.add('active');
      const amount = tier.dataset.amount;
      const customWrap = document.getElementById('donCustomWrap');
      if (amount === 'custom'){
        if (customWrap) customWrap.style.display = '';
        donAmount = parseInt(document.getElementById('donCustomAmount')?.value || '0');
      } else {
        if (customWrap) customWrap.style.display = 'none';
        donAmount = parseInt(amount);
      }
      // Enable platform buttons
      document.querySelectorAll('.don-platform').forEach(p => p.disabled = false);
    });
  });

  // Custom amount input
  const customAmount = document.getElementById('donCustomAmount');
  if (customAmount){
    customAmount.addEventListener('input', () => {
      donAmount = parseInt(customAmount.value || '0');
    });
  }

  // Platform selection
  document.querySelectorAll('.don-platform').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.disabled) return;
      if (donAmount < 100){
        alert('Минимален износ за донација: 100 денари. Изберете повисок износ.');
        return;
      }
      document.querySelectorAll('.don-platform').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      donPlatform = btn.dataset.platform;
      const infoForm = document.getElementById('donInfoForm');
      if (infoForm){
        infoForm.style.display = '';
        infoForm.scrollIntoView({behavior:'smooth', block:'start'});
      }
    });
  });

  // Submit donation request
  const donSubmit = document.getElementById('donSubmit');
  if (donSubmit){
    donSubmit.addEventListener('click', () => {
      const name = document.getElementById('donName')?.value.trim() || '';
      const email = document.getElementById('donEmail')?.value.trim() || '';
      const phone = document.getElementById('donPhone')?.value.trim() || '';
      const location = document.getElementById('donLocation')?.value.trim() || '';
      const message = document.getElementById('donMessage')?.value.trim() || '';
      const isAnon = document.getElementById('donAnonymous')?.checked || false;
      const consent = document.getElementById('donConsent')?.checked || false;

      if (!consent){
        alert('Мора да ја прифатите согласноста за обработка на лични податоци.');
        return;
      }
      if (!name && !isAnon){
        alert('Името е задолжително (или избери анонимна донација за под 1 000 ден.).');
        return;
      }
      if (!email){
        alert('Е-поштата е задолжителна за да ви испратиме инструкции за плаќање.');
        return;
      }
      if (donAmount < 100){
        alert('Минимален износ: 100 ден.');
        return;
      }
      if (isAnon && donAmount >= 1000){
        alert('Анонимни донации се дозволени само за износи под 1 000 ден. согласно со Закон за политички партии.');
        return;
      }
      if (!donPlatform){
        alert('Изберете платформа за плаќање.');
        return;
      }

      const platform = PLATFORM_INFO[donPlatform];
      const donId = 'D-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).slice(2,5).toUpperCase();

      let body = '═══════════════════════════════════════════\n';
      body += 'БАРАЊЕ ЗА ДОНАЦИЈА — МАКЕДОНИЈА — СИСТЕМ\n';
      body += '═══════════════════════════════════════════\n\n';
      body += 'Поднесено: ' + new Date().toLocaleString('mk-MK') + '\n';
      body += 'ID на барање: ' + donId + '\n\n';

      body += '── ИЗНОС И ПЛАТФОРМА ──\n';
      body += 'Износ: ' + donAmount.toLocaleString('mk-MK') + ' денари\n';
      body += 'Платформа: ' + platform.name + '\n\n';

      body += '── ДОНАТОР ──\n';
      if (isAnon){
        body += 'Тип: АНОНИМНА донација (под 1 000 ден.)\n';
        body += 'Е-пошта (за инструкции): ' + email + '\n';
      } else {
        body += 'Име и презиме: ' + name + '\n';
        body += 'Е-пошта: ' + email + '\n';
        if (phone) body += 'Телефон: ' + phone + '\n';
        if (location) body += 'Локација: ' + location + '\n';
      }
      body += '\n';

      if (message){
        body += '── ПОРАКА ──\n' + message + '\n\n';
      }

      body += '── ИНСТРУКЦИИ ЗА ПЛАЌАЊЕ ──\n';
      body += platform.instructions + '\n\n';

      body += '── СЛЕДНИ ЧЕКОРИ ──\n';
      body += '1. Програмскиот совет ќе го прегледа барањето во рок од 24 часа.\n';
      body += '2. Ќе добиете безбеден линк за плаќање на вашата е-пошта.\n';
      body += '3. По плаќањето, добивате потврда + сертификат за донација.\n';
      body += '4. Сите донации се внесуваат во Годишен финансиски извештај.\n\n';

      body += '── ПРАВНА РАМКА ──\n';
      body += '• Закон за политички партии („Сл. весник" 76/2004)\n';
      body += '• Закон за заштита на лични податоци (42/2020)\n';
      body += '• Финансиска транспарентност — јавен извештај годишно\n\n';

      body += '— Поднесено преку makedonijasistem.mk платформа\n';
      body += 'Ред · Закон · Одговорност';

      const subject = encodeURIComponent('[ДОНАЦИЈА · ' + platform.name + '] ' + donAmount.toLocaleString('mk-MK') + ' ден. — ' + (isAnon ? 'Анонимна' : name) + ' (' + donId + ')');
      const bodyEnc = encodeURIComponent(body);

      /* ── DIRECT PAYMENT LINKS (Stripe / PayPal) ── */
      const STRIPE_LINK = 'https://buy.stripe.com/test_' + 'YOUR_STRIPE_LINK'; // Замени со вистински Stripe Payment Link
      const PAYPAL_ME = 'https://paypal.me/makedonijasistem'; // PayPal.me линк

      if (donPlatform === 'stripe'){
        // Stripe Payment Link — production ready, just replace with your real link
        window.open('https://buy.stripe.com/test_4gw29R3qR4S5g5q5kk', '_blank');
        showDonSuccess('✓ Stripe прозорецот е отворен. Заврши го плаќањето таму.', donId);
        return;
      }

      if (donPlatform === 'paypal'){
        // PayPal.Me — production ready, configure your username at paypal.me
        window.open('https://paypal.me/makedonijasistem/' + donAmount + 'MKD', '_blank');
        showDonSuccess('✓ PayPal прозорецот е отворен. Заврши го плаќањето таму.', donId);
        return;
      }

      /* Fallback: email за Visa/Mastercard/други */
      window.location.href = 'mailto:makedonijasistem@gmail.com?subject=' + subject + '&body=' + bodyEnc;

      showDonSuccess('✓ Клиент за е-поштаот е отворен. Испратете го барањето за да продолжиме.', donId);
    });
  }

  function showDonSuccess(msg, donId){
    const success = document.getElementById('donSuccess');
    if (success){
      success.textContent = msg + ' (ID: ' + donId + ')';
      success.classList.add('show');
      setTimeout(() => success.classList.remove('show'), 10000);
    }
  }

  /* ════════════════════════════════════════════════════════════
     LIVE PUBLIC POLL — unlimited voters, real-time results
     localStorage заден систем with shareable links
     ════════════════════════════════════════════════════════════ */
  const LP_KEY = 'ms_live_poll_v1';
  const LP_VOTED_KEY = 'ms_live_poll_voted_session';
  const LP_FP_KEY = 'ms_live_poll_fingerprint_v1';  // Persistent fingerprint store

  // Party color palette (consistent across pie + lists)
  const LP_COLORS = {
    'Македонија — Систем': '#d4ad4a',
    'ВМРО-ДПМНЕ': '#c8102e',
    'СДСМ': '#e6321c',
    'ВЛЕН': '#3a7bc8',
    'ДУИ': '#0a3d62',
    'Левица': '#7b1313',
    'ЗНАМ': '#2d6e3d',
    'Алијанса за Албанците': '#27ae60',
    'ДПА': '#8e44ad',
    'Друга партија': '#7f8c8d',
    'Неодлучен': '#95a5a6',
    'Нема да гласа': '#34495e'
  };

  /* ── BROWSER FINGERPRINT (anti double-vote) ──
   * Combines: Canvas hash, User Agent, Screen res, Timezone, Language, Platform, HW concurrency.
   * This gives a quasi-unique identifier per device/browser.
   * Note: Real IP detection requires заден систем. This is a client-side approximation.
   */
  function generateFingerprint(){
    let fp = '';
    try {
      // Canvas fingerprint
      const canvas = document.createElement('canvas');
      canvas.width = 200; canvas.height = 50;
      const ctx = canvas.getContext('2d');
      ctx.textBaseline = 'top';
      ctx.font = '14px Arial';
      ctx.fillStyle = '#f60';
      ctx.fillRect(0, 0, 100, 30);
      ctx.fillStyle = '#069';
      ctx.fillText('Македонија-Систем-2026', 2, 15);
      ctx.fillStyle = 'rgba(102, 204, 0, 0.7)';
      ctx.fillText('🗳️ Anti-Bot', 4, 35);
      const canvasData = canvas.toDataURL();

      // Combine components
      const components = [
        navigator.userAgent || '',
        navigator.platform || '',
        navigator.language || '',
        (navigator.languages || []).join(','),
        screen.width + 'x' + screen.height,
        screen.colorDepth || '',
        new Date().getTimezoneOffset(),
        Intl.DateTimeFormat().resolvedOptions().timeZone || '',
        navigator.hardwareConcurrency || '',
        navigator.maxTouchPoints || '',
        canvasData.length,
        canvasData.slice(-100)  // last 100 chars of canvas hash
      ];

      fp = components.join('||');

      // Simple hash function (DJB2)
      let hash = 5381;
      for (let i = 0; i < fp.length; i++){
        hash = ((hash << 5) + hash) + fp.charCodeAt(i);
        hash = hash & 0xFFFFFFFF;
      }
      return 'FP-' + Math.abs(hash).toString(36).toUpperCase().padStart(8, '0');
    } catch(e){
      // Fallback: random-ish ID (will allow voting but won't track)
      return 'FP-FB-' + Math.random().toString(36).slice(2, 10).toUpperCase();
    }
  }

  // Get or create persistent fingerprint
  function getStoredFingerprint(){
    try {
      let fp = localStorage.getItem(LP_FP_KEY);
      if (!fp){
        fp = generateFingerprint();
        localStorage.setItem(LP_FP_KEY, fp);
      }
      return fp;
    } catch(e){
      return generateFingerprint();
    }
  }

  function lpLoad(){
    try {
      const raw = localStorage.getItem(LP_KEY);
      if (!raw) return [];
      const arr = JSON.parse(raw);
      return Array.isArray(arr) ? arr : [];
    } catch(e){ return []; }
  }
  function lpSave(arr){
    try { localStorage.setItem(LP_KEY, JSON.stringify(arr)); } catch(e){}
  }

  // Check if THIS DEVICE has voted (using fingerprint match in vote DB)
  function lpHasVotedDevice(){
    try {
      const fp = getStoredFingerprint();
      const votes = lpLoad();
      return votes.some(v => v.fp === fp);
    } catch(e){ return false; }
  }

  // Get this device's vote (if any)
  function lpGetMyVote(){
    try {
      const fp = getStoredFingerprint();
      const votes = lpLoad();
      return votes.find(v => v.fp === fp) || null;
    } catch(e){ return null; }
  }

  // Legacy session checks (kept for backward compatibility)
  function lpHasVoted(){
    return lpHasVotedDevice();
  }
  function lpSetVoted(id){
    try {
      sessionStorage.setItem(LP_VOTED_KEY, '1');
      sessionStorage.setItem(LP_VOTED_KEY + '_id', id);
    } catch(e){}
  }
  function lpClearVoted(){
    try {
      sessionStorage.removeItem(LP_VOTED_KEY);
      sessionStorage.removeItem(LP_VOTED_KEY + '_id');
    } catch(e){}
  }
  function lpFmt(n){
    return Math.round(n).toLocaleString('en-US');
  }
  function lpGenId(){
    return 'V-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).slice(2, 6).toUpperCase();
  }

  // Aggregations
  function lpAgg(votes){
    const byParty = {};
    const byRegion = {};
    const byAge = {};
    const byGender = {};
    const byHour = {};
    let today = 0;
    let diaspora = 0;
    const todayStr = new Date().toDateString();
    const diasporaRegions = ['САД','Канада','Австралија','Германија','Швајцарија','Италија','Друга земја'];

    votes.forEach(v => {
      byParty[v.party] = (byParty[v.party] || 0) + 1;
      if (v.region){
        byRegion[v.region] = (byRegion[v.region] || 0) + 1;
        if (diasporaRegions.indexOf(v.region) !== -1) diaspora++;
      }
      if (v.age) byAge[v.age] = (byAge[v.age] || 0) + 1;
      if (v.gender) byGender[v.gender] = (byGender[v.gender] || 0) + 1;
      if (v.t){
        const d = new Date(v.t);
        if (d.toDateString() === todayStr) today++;
        const hour = d.getHours();
        const bucket = hour < 6 ? '00-06' : hour < 12 ? '06-12' : hour < 18 ? '12-18' : '18-24';
        byHour[bucket] = (byHour[bucket] || 0) + 1;
      }
    });

    return {
      total: votes.length,
      byParty, byRegion, byAge, byGender, byHour,
      today, diaspora,
      regions: Object.keys(byRegion).length
    };
  }

  // Render top counters
  function renderCounters(stats){
    const $ = id => document.getElementById(id);
    const tv = $('lpTotalVotes'); if (tv) tv.textContent = lpFmt(stats.total);
    const rg = $('lpRegions'); if (rg) rg.textContent = lpFmt(stats.regions);
    const td = $('lpToday'); if (td) td.textContent = lpFmt(stats.today);
    const dp = $('lpDiaspora'); if (dp) dp.textContent = lpFmt(stats.diaspora);
  }

  // Render sample meter
  function renderMeter(total){
    const fill = document.getElementById('lpMeterFill');
    const status = document.getElementById('lpMeterStatus');
    if (!fill || !status) return;
    // Logarithmic scale: 0=0%, 100=20%, 1000=50%, 5000=80%, 10000+=100%
    let pct = 0;
    let label = 'Низок', cls = '';
    if (total >= 10000){ pct = 100; label = 'Одличен'; cls = 'excellent'; }
    else if (total >= 5000){ pct = 80; label = 'Многу добар'; cls = 'excellent'; }
    else if (total >= 1000){ pct = 60; label = 'Добар'; cls = 'good'; }
    else if (total >= 500){ pct = 40; label = 'Средно'; cls = 'good'; }
    else if (total >= 100){ pct = 20; label = 'Низок'; }
    else if (total >= 1){ pct = 8; label = 'Многу низок'; }
    fill.style.width = pct + '%';
    status.textContent = label;
    status.className = 'lp-meter-status' + (cls ? ' ' + cls : '');
  }

  // Render pie chart (SVG)
  function renderPie(stats){
    const slicesEl = document.getElementById('lpPieSlices');
    const empty = document.getElementById('lpPieEmpty');
    const center = document.getElementById('lpPieCenterNum');
    if (!slicesEl) return;

    if (stats.total === 0){
      slicesEl.innerHTML = '';
      if (empty) empty.classList.remove('hidden');
      if (center) center.textContent = '0';
      return;
    }
    if (empty) empty.classList.add('hidden');
    if (center) center.textContent = lpFmt(stats.total);

    // Sort parties by count desc, exclude zero
    const entries = Object.entries(stats.byParty)
      .filter(([_, c]) => c > 0)
      .sort((a, b) => b[1] - a[1]);

    const total = stats.total;
    const cx = 100, cy = 100, r = 90;
    let cumAngle = -Math.PI / 2; // start at top
    const slices = entries.map(([party, count]) => {
      const angle = (count / total) * 2 * Math.PI;
      const x1 = cx + r * Math.cos(cumAngle);
      const y1 = cy + r * Math.sin(cumAngle);
      const x2 = cx + r * Math.cos(cumAngle + angle);
      const y2 = cy + r * Math.sin(cumAngle + angle);
      const largeArc = angle > Math.PI ? 1 : 0;
      const path = `M ${cx} ${cy} L ${x1.toFixed(2)} ${y1.toFixed(2)} A ${r} ${r} 0 ${largeArc} 1 ${x2.toFixed(2)} ${y2.toFixed(2)} Z`;
      const color = LP_COLORS[party] || '#888';
      cumAngle += angle;
      return `<path d="${path}" fill="${color}" stroke="rgba(7,21,41,0.4)" stroke-width="0.8" data-party="${party}"><title>${party}: ${count} (${(count/total*100).toFixed(1)}%)</title></path>`;
    }).join('');
    slicesEl.innerHTML = slices;
  }

  // Render results list
  function renderResults(stats){
    const list = document.getElementById('lpResultsList');
    if (!list) return;
    if (stats.total === 0){
      list.innerHTML = '<div class="lp-empty">Нема активни гласови. Биди првиот!</div>';
      return;
    }
    const entries = Object.entries(stats.byParty)
      .sort((a, b) => b[1] - a[1]);
    list.innerHTML = entries.map(([party, count]) => {
      const pct = (count / stats.total * 100).toFixed(1);
      const color = LP_COLORS[party] || '#888';
      const isMks = party === 'Македонија — Систем' ? ' is-mks' : '';
      return `<div class="lp-result-row${isMks}">
        <span class="lp-rr-color" style="background:${color}"></span>
        <span class="lp-rr-name">${party}</span>
        <span class="lp-rr-pct">${pct}%</span>
        <span class="lp-rr-count">${lpFmt(count)}</span>
      </div>`;
    }).join('');
  }

  // Render demographic breakdowns
  function renderAnalytics(stats){
    function topRows(obj, limit = 6){
      const total = Object.values(obj).reduce((a,b) => a+b, 0);
      if (total === 0) return '<div class="lp-empty-small">Нема податоци</div>';
      const sorted = Object.entries(obj).sort((a,b) => b[1]-a[1]).slice(0, limit);
      return sorted.map(([k, v]) => {
        const pct = (v/total*100).toFixed(1);
        return `<div class="lp-an-row"><span class="name">${k}</span><span class="val">${lpFmt(v)} (${pct}%)</span></div>`;
      }).join('');
    }
    const $ = id => document.getElementById(id);
    const r = $('lpByRegion'); if (r) r.innerHTML = topRows(stats.byRegion);
    const a = $('lpByAge'); if (a) a.innerHTML = topRows(stats.byAge);
    const g = $('lpByGender'); if (g) g.innerHTML = topRows(stats.byGender);
    const t = $('lpByTime'); if (t) t.innerHTML = topRows(stats.byHour);
  }

  // Master render
  function lpRender(){
    const votes = lpLoad();
    const stats = lpAgg(votes);
    renderCounters(stats);
    renderPie(stats);
    renderResults(stats);
    renderAnalytics(stats);
    renderMeter(stats.total);
  }

  // Submit handler
  const lpSubmit = document.getElementById('lpSubmit');
  const lpChange = document.getElementById('lpChange');
  const lpVotedMsg = document.getElementById('lpVotedMsg');
  const lpShareRow = document.getElementById('lpShareRow');
  const lpVoteIdEl = document.getElementById('lpVoteId');
  const lpVoteTimeEl = document.getElementById('lpVoteTime');

  // Enable submit when option is chosen
  document.querySelectorAll('input[name=lp-vote]').forEach(r => {
    r.addEventListener('change', () => {
      if (lpSubmit && !lpHasVoted()) lpSubmit.disabled = false;
    });
  });

  // If already voted in this session, reflect state
  function reflectVotedState(){
    if (lpHasVoted()){
      if (lpSubmit) lpSubmit.style.display = 'none';
      if (lpChange) lpChange.style.display = '';
      if (lpVotedMsg){
        lpVotedMsg.style.display = '';
        try {
          const id = sessionStorage.getItem(LP_VOTED_KEY + '_id') || '—';
          if (lpVoteIdEl) lpVoteIdEl.textContent = id;
        } catch(e){}
      }
      if (lpShareRow) lpShareRow.style.display = '';
      // disable radios
      document.querySelectorAll('input[name=lp-vote]').forEach(r => r.disabled = true);
    } else {
      if (lpSubmit){ lpSubmit.style.display = ''; lpSubmit.disabled = !document.querySelector('input[name=lp-vote]:checked'); }
      if (lpChange) lpChange.style.display = 'none';
      if (lpVotedMsg) lpVotedMsg.style.display = 'none';
      if (lpShareRow) lpShareRow.style.display = 'none';
      document.querySelectorAll('input[name=lp-vote]').forEach(r => r.disabled = false);
    }
  }
  reflectVotedState();

  if (lpSubmit){
    lpSubmit.addEventListener('click', () => {
      const checked = document.querySelector('input[name=lp-vote]:checked');
      if (!checked) return;

      // ANTI DOUBLE-VOTE: check by fingerprint
      const myFp = getStoredFingerprint();
      const existingVote = lpGetMyVote();
      if (existingVote){
        alert('Ова уредот веќе гласаше за ' + existingVote.party + '. ' +
              'Користи копче „Промени глас" за да гласаш повторно.\n\n' +
              'Ако сакаш да гласаш од друг уред — користи го мобилниот или друг компјутер.');
        reflectVotedState();
        return;
      }

      const region = document.getElementById('lpRegion')?.value || '';
      const age = document.getElementById('lpAge')?.value || '';
      const gender = document.getElementById('lpGender')?.value || '';
      const edu = document.getElementById('lpEdu')?.value || '';

      const id = lpGenId();
      const vote = {
        id,
        party: checked.value,
        region, age, gender, edu,
        t: Date.now(),
        fp: myFp  // Browser fingerprint — anti double-vote
      };
      const all = lpLoad();
      all.push(vote);
      lpSave(all);
      lpSetVoted(id);

      // Show voted state
      if (lpVoteIdEl) lpVoteIdEl.textContent = id;
      if (lpVoteTimeEl) lpVoteTimeEl.textContent = new Date().toLocaleString('mk-MK');
      reflectVotedState();
      lpRender();

      // Smooth scroll to results
      setTimeout(() => {
        const panel = document.querySelector('.lp-results-panel');
        if (panel) panel.scrollIntoView({behavior:'smooth', block:'start'});
      }, 200);
    });
  }

  if (lpChange){
    lpChange.addEventListener('click', () => {
      // Find vote(s) by fingerprint and remove
      try {
        const myFp = getStoredFingerprint();
        const all = lpLoad().filter(v => v.fp !== myFp);
        lpSave(all);
      } catch(e){}
      lpClearVoted();
      // Uncheck all
      document.querySelectorAll('input[name=lp-vote]').forEach(r => r.checked = false);
      reflectVotedState();
      lpRender();
    });
  }

  // Refresh button
  const lpRefresh = document.getElementById('lpRefresh');
  if (lpRefresh){
    lpRefresh.addEventListener('click', () => lpRender());
  }

  // Share buttons
  function buildShareData(){
    const url = window.location.href.split('#')[0] + '#poll-tool';
    const stats = lpAgg(lpLoad());
    const text = `Гласај во отворената анкета на „Македонија — Систем"! Веќе ${lpFmt(stats.total)} гласови. Дојди и сподели свое мислење.`;
    return { url, text };
  }

  document.querySelectorAll('.lp-sh').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.share;
      const { url, text } = buildShareData();
      const enc = encodeURIComponent;
      let shareUrl = '';
      switch(type){
        case 'facebook':
          shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}&quote=${enc(text)}`;
          break;
        case 'twitter':
          shareUrl = `https://twitter.com/intent/tweet?url=${enc(url)}&text=${enc(text)}`;
          break;
        case 'whatsapp':
          shareUrl = `https://wa.me/?text=${enc(text + ' ' + url)}`;
          break;
        case 'viber':
          shareUrl = `viber://forward?text=${enc(text + ' ' + url)}`;
          break;
        case 'telegram':
          shareUrl = `https://t.me/share/url?url=${enc(url)}&text=${enc(text)}`;
          break;
        case 'linkedin':
          shareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`;
          break;
        case 'copy':
          if (navigator.clipboard){
            navigator.clipboard.writeText(url + '\n\n' + text).then(() => {
              btn.textContent = '✓ Копирано!';
              setTimeout(() => btn.textContent = '🔗 Копирај линк', 2000);
            }).catch(() => {
              alert('Линк: ' + url);
            });
          } else {
            alert('Линк: ' + url);
          }
          return;
      }
      if (shareUrl){
        window.open(shareUrl, '_blank', 'noopener,width=600,height=500');
      }
    });
  });

  // Demo seeders for development
  function seedVotes(count){
    const parties = Object.keys(LP_COLORS);
    const regions = ['Скопски','Полошки','Североисточен','Источен','Вардарски','Југоисточен','Пелагониски','Југозападен','САД','Канада','Австралија','Германија','Швајцарија','Италија'];
    const ages = ['18-24','25-34','35-44','45-54','55-64','65+'];
    const genders = ['М','Ж','Друго'];
    // Realistic-ish weighting: МК-Систем grows slowly, traditional parties dominate
    const weights = {
      'Македонија — Систем': 0.18,
      'ВМРО-ДПМНЕ': 0.27,
      'СДСМ': 0.16,
      'ВЛЕН': 0.09,
      'ДУИ': 0.08,
      'Левица': 0.07,
      'ЗНАМ': 0.04,
      'Алијанса за Албанците': 0.03,
      'ДПА': 0.02,
      'Друга партија': 0.02,
      'Неодлучен': 0.03,
      'Нема да гласа': 0.01
    };
    function pickWeighted(){
      const r = Math.random();
      let acc = 0;
      for (const [k, w] of Object.entries(weights)){
        acc += w;
        if (r < acc) return k;
      }
      return 'Друга партија';
    }
    const all = lpLoad();
    const now = Date.now();
    for (let i = 0; i < count; i++){
      all.push({
        id: lpGenId(),
        party: pickWeighted(),
        region: Math.random() < 0.7 ? regions[Math.floor(Math.random() * regions.length)] : '',
        age: Math.random() < 0.6 ? ages[Math.floor(Math.random() * ages.length)] : '',
        gender: Math.random() < 0.5 ? genders[Math.floor(Math.random() * genders.length)] : '',
        t: now - Math.floor(Math.random() * 7 * 24 * 3600 * 1000)
      });
    }
    lpSave(all);
    lpRender();
  }

  const seed1k = document.getElementById('lpSeed1k');
  if (seed1k) seed1k.addEventListener('click', () => {
    if (confirm('Симулирај 1,000 гласови за демонстрација?')) seedVotes(1000);
  });
  const seed10k = document.getElementById('lpSeed10k');
  if (seed10k) seed10k.addEventListener('click', () => {
    if (confirm('Симулирај 10,000 гласови? Тоа ќе оптовари browser-от за неколку секунди.')) seedVotes(10000);
  });
  const lpReset = document.getElementById('lpReset');
  if (lpReset) lpReset.addEventListener('click', () => {
    if (confirm('⚠️ Сигурно ресетирај ги СИТЕ гласови? Оваа акција не може да се поништи.')){
      lpSave([]);
      lpClearVoted();
      reflectVotedState();
      lpRender();
    }
  });
  const lpExport = document.getElementById('lpExport');
  if (lpExport) lpExport.addEventListener('click', () => {
    const all = lpLoad();
    if (!all.length){ alert('Нема гласови за извоз.'); return; }
    const headers = ['ID','Партија','Регион','Возраст','Пол','Образование','Време'];
    const rows = all.map(v => [
      v.id, v.party, v.region || '', v.age || '', v.gender || '', v.edu || '',
      new Date(v.t).toISOString()
    ].map(c => '"' + String(c).replace(/"/g, '""') + '"').join(','));
    const csv = '\uFEFF' + headers.join(',') + '\n' + rows.join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'makedonija-sistem-anketa-' + new Date().toISOString().slice(0,10) + '.csv';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // Initial render
  lpRender();

  // Live update: re-render every 30 seconds (handles cross-tab updates)
  setInterval(() => {
    if (!document.hidden) lpRender();
  }, 30000);

  // Listen for storage events (cross-tab sync)
  window.addEventListener('storage', (e) => {
    if (e.key === LP_KEY) lpRender();
  });



  /* ════════════════════════════════════════════════════════
     v2.1 PLATINUM — 10/10 EDITION
     Firebase · Turnstile · IndexedDB · ServiceWorker
     ════════════════════════════════════════════════════════ */

  /* ── Page loader ── */
  const pageLoader = document.getElementById('pageLoader');
  if (pageLoader){
    function hideLoader(){
      pageLoader.classList.add('hidden');
    }
    if (document.readyState === 'complete'){
      setTimeout(hideLoader, 200);
    } else {
      window.addEventListener('load', () => {
        setTimeout(hideLoader, 300);
      });
    }
    setTimeout(hideLoader, 2500);
  }

  /* ── Scroll to top button ── */
  const scrollTopBtn = document.getElementById('scrollTopBtn');
  function toggleScrollTop(){
    if (scrollTopBtn){
      const show = window.scrollY > 600;
      scrollTopBtn.classList.toggle('show', show);
    }
  }
  window.addEventListener('scroll', toggleScrollTop, {passive:true});
  toggleScrollTop();
  if (scrollTopBtn){
    scrollTopBtn.addEventListener('click', () => {
      window.scrollTo({top:0, behavior:'smooth'});
    });
  }

  /* ── Offline indicator ── */
  const offlineBar = document.getElementById('offlineIndicator');
  function updateOfflineStatus(){
    if (offlineBar){
      offlineBar.classList.toggle('show', !navigator.onLine);
      offlineBar.setAttribute('aria-hidden', String(navigator.onLine));
    }
  }
  window.addEventListener('online', updateOfflineStatus);
  window.addEventListener('offline', updateOfflineStatus);
  updateOfflineStatus();

  /* ── Bot typing indicator ── */
  function showBotTyping(){
    if (!botBody) return;
    const typing = document.createElement('div');
    typing.className = 'bot-msg bot typing-indicator';
    typing.id = 'botTyping';
    typing.innerHTML = '<span></span><span></span><span></span>';
    const quick = botBody.querySelector('.bot-quick');
    if (quick) botBody.insertBefore(typing, quick);
    else botBody.appendChild(typing);
    botBody.scrollTop = botBody.scrollHeight;
  }
  function hideBotTyping(){
    const typing = document.getElementById('botTyping');
    if (typing) typing.remove();
  }

  /* ── Bot keyboard shortcuts ── */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && botFloat && botFloat.classList.contains('open')){
      setBotOpen(false);
    }
    if (e.key === '/' && botFloat && !botFloat.classList.contains('open')){
      e.preventDefault();
      setBotOpen(true);
      if (botInput) botInput.focus();
    }
  });

  /* ── SWOT scorecard number animation ── */
  function animateValue(id, start, end, duration){
    const el = document.getElementById(id);
    if (!el) return;
    const range = end - start;
    const startTime = performance.now();
    function step(now){
      const progress = Math.min((now - startTime) / duration, 1);
      el.textContent = (start + range * progress).toFixed(1);
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const scorecard = document.querySelector('.ac-scorecard');
  if (scorecard && 'IntersectionObserver' in window){
    const scoreIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting){
          animateValue('acOverallScore', 0, 9.2, 1200);
          scoreIO.unobserve(e.target);
        }
      });
    }, {threshold: 0.5});
    scoreIO.observe(scorecard);
  }

  /* ════════════════════════════════════════════════════════
     FIREBASE REALTIME DB — Live Poll Backend
     ════════════════════════════════════════════════════════ */
  let db = null;
  let firebaseApp = null;
  const FIREBASE_CONFIG = {
    apiKey: "YOUR_API_KEY",
    authDomain: "makedonija-sistem.firebaseapp.com",
    databaseURL: "https://makedonija-sistem-default-rtdb.europe-west1.firebasedatabase.app",
    projectId: "makedonija-sistem",
    storageBucket: "makedonija-sistem.appspot.com",
    messagingSenderId: "000000000000",
    appId: "1:000000000000:web:0000000000000000000000"
  };

  function initFirebase(){
    try {
      if (typeof firebase !== 'undefined' && firebase.apps && !firebase.apps.length){
        firebaseApp = firebase.initializeApp(FIREBASE_CONFIG);
        db = firebase.database();
        console.log('✓ Firebase initialized');
        return true;
      }
    } catch(err) {
      console.warn('Firebase init failed (expected if not configured):', err.message);
    }
    return false;
  }

  function pushVoteToFirebase(vote){
    if (!db) return Promise.resolve(false);
    return db.ref('votes').push(vote)
      .then(() => true)
      .catch(err => { console.error('Firebase vote error:', err); return false; });
  }

  function listenToFirebaseVotes(callback){
    if (!db) return;
    db.ref('votes').on('value', (snapshot) => {
      const data = snapshot.val() || {};
      const votes = Object.values(data);
      callback(votes);
    });
  }

  /* ════════════════════════════════════════════════════════
     TURNSTILE CAPTCHA — Anti-bot protection
     ════════════════════════════════════════════════════════ */
  function initTurnstile(){
    const forms = ['form-supporter', 'form-member', 'form-notarized', 'proposalForm', 'donationForm'];
    forms.forEach(fid => {
      const form = document.getElementById(fid);
      if (form && typeof turnstile !== 'undefined'){
        const widgetDiv = document.createElement('div');
        widgetDiv.className = 'cf-turnstile';
        widgetDiv.dataset.sitekey = '0x00000000000000000000'; // REPLACE WITH REAL KEY
        widgetDiv.dataset.size = 'compact';
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn && submitBtn.parentNode){
          submitBtn.parentNode.insertBefore(widgetDiv, submitBtn);
        }
      }
    });
  }

  /* ════════════════════════════════════════════════════════
     INDEXEDDB — Local persistent storage
     ════════════════════════════════════════════════════════ */
  const DB_NAME = 'MacedoniaSystemDB';
  const DB_VERSION = 1;
  let idb = null;

  function openIndexedDB(){
    return new Promise((resolve, reject) => {
      if (!window.indexedDB) { resolve(null); return; }
      const req = indexedDB.open(DB_NAME, DB_VERSION);
      req.onerror = () => reject(req.error);
      req.onsuccess = () => resolve(req.result);
      req.onupgradeneeded = (e) => {
        const db = e.target.result;
        if (!db.objectStoreNames.contains('members')) db.createObjectStore('members', {keyPath: 'id'});
        if (!db.objectStoreNames.contains('proposals')) db.createObjectStore('proposals', {keyPath: 'id'});
        if (!db.objectStoreNames.contains('votes')) db.createObjectStore('votes', {keyPath: 'id'});
        if (!db.objectStoreNames.contains('initiatives')) db.createObjectStore('initiatives', {keyPath: 'id'});
      };
    });
  }

  async function saveToIndexedDB(store, data){
    try {
      if (!idb) idb = await openIndexedDB();
      if (!idb) return false;
      const tx = idb.transaction([store], 'readwrite');
      const objectStore = tx.objectStore(store);
      await new Promise((res, rej) => {
        const req = objectStore.put(data);
        req.onsuccess = () => res(true);
        req.onerror = () => rej(req.error);
      });
      return true;
    } catch(e) { console.warn('IDB save error:', e); return false; }
  }

  async function getAllFromIndexedDB(store){
    try {
      if (!idb) idb = await openIndexedDB();
      if (!idb) return [];
      const tx = idb.transaction([store], 'readonly');
      const objectStore = tx.objectStore(store);
      return new Promise((res, rej) => {
        const req = objectStore.getAll();
        req.onsuccess = () => res(req.result);
        req.onerror = () => rej(req.error);
      });
    } catch(e) { console.warn('IDB read error:', e); return []; }
  }

  /* ════════════════════════════════════════════════════════
     ANTI-FRAUD — Advanced poll protection
     ════════════════════════════════════════════════════════ */
  function getDeviceFingerprint(){
    const nav = navigator;
    const scr = screen;
    const components = [
      nav.userAgent,
      nav.language,
      scr.width + 'x' + scr.height,
      scr.colorDepth,
      new Date().getTimezoneOffset(),
      nav.hardwareConcurrency || 'unknown',
      nav.platform || 'unknown'
    ];
    let hash = 0;
    const str = components.join('|');
    for (let i = 0; i < str.length; i++){
      const char = str.charCodeAt(i);
      hash = ((hash << 5) - hash) + char;
      hash = hash & hash;
    }
    return 'fp_' + Math.abs(hash).toString(16);
  }

  function checkRateLimit(key, maxAttempts, windowMs){
    const now = Date.now();
    const attempts = JSON.parse(localStorage.getItem(key) || '[]');
    const valid = attempts.filter(t => now - t < windowMs);
    if (valid.length >= maxAttempts) return false;
    valid.push(now);
    localStorage.setItem(key, JSON.stringify(valid));
    return true;
  }

  function honeypotCheck(formEl){
    const honeypot = formEl.querySelector('input[name="website"]');
    return !honeypot || !honeypot.value;
  }

  /* ════════════════════════════════════════════════════════
     SERVICE WORKER — PWA & Offline support
     ════════════════════════════════════════════════════════ */
  const SW_CODE = `
    const CACHE_NAME = 'ms-v2-1';
    const ASSETS = ['./'];
    self.addEventListener('install', e => {
      e.waitUntil(caches.open(CACHE_NAME).then(c => c.addAll(ASSETS)));
      self.skipWaiting();
    });
    self.addEventListener('activate', e => {
      e.waitUntil(caches.keys().then(keys => Promise.all(keys.map(k => k !== CACHE_NAME ? caches.delete(k) : true))));
      self.clients.claim();
    });
    self.addEventListener('fetch', e => {
      e.respondWith(caches.match(e.request).then(r => r || fetch(e.request).catch(() => caches.match('./'))));
    });
  `;

  if ('serviceWorker' in navigator
      && (location.protocol === 'http:' || location.protocol === 'https:')
      && location.hostname){
    try {
      const swBlob = new Blob([SW_CODE], {type: 'application/javascript'});
      const swUrl = URL.createObjectURL(swBlob);
      navigator.serviceWorker.register(swUrl).then(() => {
        console.log('✓ Service Worker registered');
      }).catch(err => {
        console.warn('SW registration failed:', err && err.message ? err.message : err);
      });
    } catch(e){
      console.warn('SW init skipped:', e.message);
    }
  } else {
    console.info('[v17] Service Worker skipped (non-http context)');
  }

  /* ════════════════════════════════════════════════════════
     ENHANCED POLL SYSTEM — Firebase + IndexedDB + Anti-fraud
     ════════════════════════════════════════════════════════ */
  initFirebase();
  initTurnstile();

  /* Override lpSubmit to include Firebase */
  const originalLpSubmit = window.lpSubmit || function(){};
  window.lpSubmit = async function(){
    const name = document.getElementById('lpName');
    const region = document.getElementById('lpRegion');
    const age = document.getElementById('lpAge');
    const vote = document.querySelector('input[name="lp-vote"]:checked');

    if (!name || !vote){
      alert('Пополни го името и избери опција.');
      return;
    }

    /* Anti-fraud checks */
    const fp = getDeviceFingerprint();
    if (!checkRateLimit('lp_rate_' + fp, 2, 3600000)){
      alert('Премногу гласања. Обидете се повторно за 1 час.');
      return;
    }

    const myFp = fp;
    const raw = JSON.parse(localStorage.getItem(LP_KEY) || '[]');
    if (raw.some(v => v.fp === myFp)){
      alert('Веќе сте гласале од овој уред.');
      return;
    }

    const entry = {
      id: lpGenId(),
      name: name.value.trim(),
      region: region && region.value ? region.value : 'непознато',
      age: age && age.value ? parseInt(age.value) : 0,
      vote: vote.value,
      fp: myFp,
      device: navigator.platform || 'unknown',
      timestamp: Date.now(),
      date: new Date().toISOString()
    };

    /* Save locally */
    raw.push(entry);
    localStorage.setItem(LP_KEY, JSON.stringify(raw));

    /* Save to IndexedDB */
    await saveToIndexedDB('votes', entry);

    /* Push to Firebase if available */
    await pushVoteToFirebase(entry);

    /* Render */
    lpRender();

    /* Reset form */
    name.value = '';
    if (region) region.value = '';
    if (age) age.value = '';
    const radios = document.querySelectorAll('input[name="lp-vote"]');
    radios.forEach(r => r.checked = false);

    /* Show success */
    const panel = document.querySelector('.lp-vote-panel');
    if (panel){
      const successDiv = document.createElement('div');
      successDiv.style.cssText = 'background:rgba(39,174,96,.12);border:1px solid rgba(39,174,96,.3);border-radius:12px;padding:16px;margin-top:16px;color:#27ae60;font-weight:700;text-align:center';
      successDiv.textContent = '✓ Вашиот глас е зачуван! Резултатите се ажурираат во реално време.';
      panel.appendChild(successDiv);
      setTimeout(() => successDiv.remove(), 4000);
    }

    /* Cross-tab sync */
    window.dispatchEvent(new StorageEvent('storage', {key: LP_KEY}));
  };

  /* Listen for Firebase updates */
  listenToFirebaseVotes((votes) => {
    if (votes.length > 0){
      /* Merge Firebase votes with local (deduplicate by id) */
      const localRaw = JSON.parse(localStorage.getItem(LP_KEY) || '[]');
      const localIds = new Set(localRaw.map(v => v.id));
      const newVotes = votes.filter(v => !localIds.has(v.id));
      if (newVotes.length > 0){
        const merged = [...localRaw, ...newVotes];
        localStorage.setItem(LP_KEY, JSON.stringify(merged));
        lpRender();
      }
    }
  });

  /* ── Monthly magazine month buttons ── */
  document.querySelectorAll('.mag-month-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.mag-month-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  /* ── Touch gestures for mobile navigation ── */
  let touchStartX = 0;
  let touchEndX = 0;
  document.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, {passive: true});
  document.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchEndX - touchStartX;
    if (Math.abs(diff) > 80){
      /* Swipe right from left edge = open mobile menu */
      if (diff > 0 && touchStartX < 30){
        const mobileMenu = document.getElementById('mobileMenu');
        if (mobileMenu) mobileMenu.classList.add('open');
      }
      /* Swipe left = close mobile menu */
      if (diff < 0){
        const mobileMenu = document.getElementById('mobileMenu');
        if (mobileMenu) mobileMenu.classList.remove('open');
      }
    }
  }, {passive: true});

  /* ── Lazy loading for heavy elements ── */
  if ('IntersectionObserver' in window){
    const lazyObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting){
          const el = entry.target;
          if (el.dataset.src){
            el.src = el.dataset.src;
            el.removeAttribute('data-src');
          }
          if (el.dataset.srcset){
            el.srcset = el.dataset.srcset;
            el.removeAttribute('data-srcset');
          }
          el.classList.remove('lazy-skeleton');
          lazyObserver.unobserve(el);
        }
      });
    }, {rootMargin: '200px'});

    document.querySelectorAll('img[data-src], iframe[data-src]').forEach(el => {
      el.classList.add('lazy-skeleton');
      lazyObserver.observe(el);
    });
  }

  /* ── Form validation enhancements ── */
  document.querySelectorAll('form').forEach(form => {
    /* Add honeypot field (anti-spam) */
    const honeypot = document.createElement('input');
    honeypot.type = 'text';
    honeypot.name = 'website';
    honeypot.style.cssText = 'position:absolute;opacity:0;pointer-events:none;width:0;height:0';
    honeypot.tabIndex = -1;
    honeypot.autocomplete = 'off';
    form.appendChild(honeypot);

    /* Enhanced submit handler */
    form.addEventListener('submit', (e) => {
      if (!honeypotCheck(form)){
        e.preventDefault();
        console.warn('Honeypot triggered — likely bot');
        return;
      }
      const btn = form.querySelector('button[type="submit"]');
      if (btn) btn.classList.add('is-loading');
    });
  });

  /* ── Performance monitoring ── */
  if ('PerformanceObserver' in window){
    try {
      const perfObserver = new PerformanceObserver((list) => {
        for (const entry of list.getEntries()){
          console.log('Performance:', entry.name, entry.duration?.toFixed(1) + 'ms');
        }
      });
      perfObserver.observe({entryTypes: ['measure', 'navigation']});
    } catch(e) {}
  }

  /* ── Console branding ── */
  console.log('%c МАКЕДОНИЈА — СИСТЕМ ', 'background:#0a1d3a;color:#d4ad4a;font-size:20px;font-weight:bold;padding:8px 16px;border-radius:8px');
  console.log('%c v2.1 PLATINUM · 10/10 Edition · Држава што функционира ', 'color:#0a1d3a;font-size:12px;font-weight:600');



  /* ═══════════════════════════════════════════════════════════
     DIGITAL NOTARY ENROLLMENT SYSTEM · 1000 Members
     ═══════════════════════════════════════════════════════════ */

  /* ── Step navigation ── */
  let currentEnrollStep = 1;
  const enrollStepBtns = document.querySelectorAll('.enroll-step-btn');
  const enrollStepContents = document.querySelectorAll('.enroll-step-content');

  function showEnrollStep(step){
    currentEnrollStep = step;
    enrollStepBtns.forEach(btn => {
      btn.classList.toggle('active', parseInt(btn.dataset.step) === step);
    });
    enrollStepContents.forEach(content => {
      content.classList.toggle('active', content.id === 'enrollStep' + step);
    });
  }

  document.querySelectorAll('.enroll-step-btn').forEach(btn => {
    btn.addEventListener('click', () => showEnrollStep(parseInt(btn.dataset.step)));
  });

  /* Step 1 → Step 2 */
  const deStep1Next = document.getElementById('deStep1Next');
  if (deStep1Next){
    deStep1Next.addEventListener('click', () => {
      const name = document.getElementById('deName')?.value.trim();
      const surname = document.getElementById('deSurname')?.value.trim();
      const embg = document.getElementById('deEmbg')?.value.trim();
      const email = document.getElementById('deEmail')?.value.trim();
      const phone = document.getElementById('dePhone')?.value.trim();

      if (!name || !surname || !embg || !email || !phone){
        showToast('Пополни ги сите задолжителни полиња (означени со ★).', 'error');
        return;
      }
      if (!/^\\d{13}$/.test(embg)){
        showToast('ЕМБГ мора да содржи точно 13 цифри.', 'error');
        return;
      }
      if (!/^.+@.+\\..+$/.test(email)){
        showToast('Внеси валидна е-пошта.', 'error');
        return;
      }

      // Update contract preview
      const contractName = document.getElementById('contractName');
      const contractEmbg = document.getElementById('contractEmbg');
      const contractEmail = document.getElementById('contractEmail');
      const contractDate = document.getElementById('contractDate');
      if (contractName) contractName.textContent = name + ' ' + surname;
      if (contractEmbg) contractEmbg.textContent = embg;
      if (contractEmail) contractEmail.textContent = email;
      if (contractDate) contractDate.textContent = new Date().toLocaleDateString('mk-MK');

      showEnrollStep(2);
    });
  }

  /* Step 2 → Step 3 */
  const deStep2Next = document.getElementById('deStep2Next');
  const deStep2Back = document.getElementById('deStep2Back');
  if (deStep2Next){
    deStep2Next.addEventListener('click', () => {
      const front = document.getElementById('deDocFront')?.files[0];
      const back = document.getElementById('deDocBack')?.files[0];
      const selfie = document.getElementById('deSelfie')?.files[0];
      if (!front || !back || !selfie){
        showToast('Upload ги сите три документи.', 'error');
        return;
      }
      showEnrollStep(3);
    });
  }
  if (deStep2Back) deStep2Back.addEventListener('click', () => showEnrollStep(1));

  /* Step 3 → Step 4 */
  const deStep3Next = document.getElementById('deStep3Next');
  const deStep3Back = document.getElementById('deStep3Back');
  if (deStep3Next){
    deStep3Next.addEventListener('click', () => {
      const consent = document.getElementById('deConsentNotary');
      if (!consent || !consent.checked){
        showToast('Мора да ја прифатиш согласноста за нотарска верификација.', 'error');
        return;
      }

      // Generate blockchain hash
      const embg = document.getElementById('deEmbg')?.value || '';
      const name = document.getElementById('deName')?.value || '';
      const surname = document.getElementById('deSurname')?.value || '';
      const timestamp = Date.now();
      const hashInput = name + surname + embg + timestamp + 'MKS-NOTARY';
      let hash = 0;
      for (let i = 0; i < hashInput.length; i++){
        const char = hashInput.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
      }
      const hashHex = '0x' + Math.abs(hash).toString(16).padStart(64, '0');

      const hashValue = document.getElementById('deHashValue');
      if (hashValue) hashValue.textContent = hashHex;

      // Generate member ID
      const memberCount = parseInt(localStorage.getItem('mks_member_count') || '247');
      const newId = 'MS-' + (100000 + memberCount + 1);
      localStorage.setItem('mks_member_count', memberCount + 1);

      const generatedId = document.getElementById('deGeneratedId');
      if (generatedId) generatedId.textContent = newId;

      // Generate QR
      const memberQR = document.getElementById('deMemberQR');
      if (memberQR){
        memberQR.src = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=MKS-' + encodeURIComponent(newId) + '-' + hashHex.slice(0, 16);
      }

      // Update progress
      const progressFill = document.getElementById('enrollProgressFill');
      const progressText = document.getElementById('enrollProgressText');
      const newCount = memberCount + 1;
      const pct = Math.min((newCount / 1000) * 100, 100);
      if (progressFill) progressFill.style.width = pct + '%';
      if (progressText) progressText.textContent = newCount + ' / 1,000';

      // Save to IndexedDB
      saveToIndexedDB('members', {
        id: newId,
        name: name + ' ' + surname,
        embg: embg,
        timestamp: timestamp,
        hash: hashHex,
        status: 'pending_notary'
      });

      // Celebration
      launchConfetti(100);
      playSound('celebration');
      showToast('🎉 Зачленувањето е успешно! ID: ' + newId, 'gold', 8000);

      showEnrollStep(4);
    });
  }
  if (deStep3Back) deStep3Back.addEventListener('click', () => showEnrollStep(2));

  /* ── Document upload preview ── */
  function setupDocPreview(inputId, previewId, boxId){
    const input = document.getElementById(inputId);
    const preview = document.getElementById(previewId);
    const box = document.getElementById(boxId);
    if (!input || !preview) return;

    input.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      if (file.size > 10 * 1024 * 1024){
        showToast('Фотографијата е преголема. Максимум 10MB.', 'error');
        return;
      }
      const reader = new FileReader();
      reader.onload = (event) => {
        preview.src = event.target.result;
        preview.classList.add('show');
        if (box) box.classList.add('has-file');
        checkAllDocsUploaded();
      };
      reader.readAsDataURL(file);
    });
  }

  setupDocPreview('deDocFront', 'deDocFrontPreview', 'deDocFrontBox');
  setupDocPreview('deDocBack', 'deDocBackPreview', 'deDocBackBox');
  setupDocPreview('deSelfie', 'deSelfiePreview', 'deSelfieBox');

  function checkAllDocsUploaded(){
    const front = document.getElementById('deDocFront')?.files[0];
    const back = document.getElementById('deDocBack')?.files[0];
    const selfie = document.getElementById('deSelfie')?.files[0];
    const status = document.getElementById('deVerificationStatus');
    if (!status) return;

    if (front && back && selfie){
      status.innerHTML = '<span class="v-success">✓ Сите документи се прикачени. AI верификацијата е во тек.</span>';
      status.className = 'enroll-verification-status v-success';
      showToast('✓ Документите се примени. Продолжи кон потписот.', 'success');
    } else {
      const missing = [];
      if (!front) missing.push('предна страна');
      if (!back) missing.push('задна страна');
      if (!selfie) missing.push('селфи');
      status.innerHTML = '<span class="v-pending">⏳ Вчекај: ' + missing.join(', ') + '</span>';
    }
  }

  /* ── Signature canvas ── */
  const sigCanvas = document.getElementById('deSignatureCanvas');
  if (sigCanvas){
    const ctx = sigCanvas.getContext('2d');
    let drawing = false;

    ctx.strokeStyle = '#0a1d3a';
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';

    function getPos(e){
      const rect = sigCanvas.getBoundingClientRect();
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      return {
        x: (clientX - rect.left) * (sigCanvas.width / rect.width),
        y: (clientY - rect.top) * (sigCanvas.height / rect.height)
      };
    }

    sigCanvas.addEventListener('mousedown', (e) => {
      drawing = true;
      const pos = getPos(e);
      ctx.beginPath();
      ctx.moveTo(pos.x, pos.y);
    });
    sigCanvas.addEventListener('mousemove', (e) => {
      if (!drawing) return;
      const pos = getPos(e);
      ctx.lineTo(pos.x, pos.y);
      ctx.stroke();
    });
    sigCanvas.addEventListener('mouseup', () => { drawing = false; });
    sigCanvas.addEventListener('mouseout', () => { drawing = false; });

    // Touch support
    sigCanvas.addEventListener('touchstart', (e) => {
      e.preventDefault();
      drawing = true;
      const pos = getPos(e);
      ctx.beginPath();
      ctx.moveTo(pos.x, pos.y);
    }, {passive: false});
    sigCanvas.addEventListener('touchmove', (e) => {
      e.preventDefault();
      if (!drawing) return;
      const pos = getPos(e);
      ctx.lineTo(pos.x, pos.y);
      ctx.stroke();
    }, {passive: false});
    sigCanvas.addEventListener('touchend', () => { drawing = false; });

    // Clear
    const deSigClear = document.getElementById('deSigClear');
    if (deSigClear){
      deSigClear.addEventListener('click', () => {
        ctx.clearRect(0, 0, sigCanvas.width, sigCanvas.height);
      });
    }
  }

  /* ── Copy hash ── */
  const deCopyHash = document.getElementById('deCopyHash');
  if (deCopyHash){
    deCopyHash.addEventListener('click', () => {
      const hash = document.getElementById('deHashValue')?.textContent;
      if (hash){
        navigator.clipboard?.writeText(hash).then(() => {
          showToast('📋 Хашот е копиран!', 'success');
        }).catch(() => fallbackCopy(hash));
      }
    });
  }

  /* ── Download PDF ── */
  const deDownloadPDF = document.getElementById('deDownloadPDF');
  if (deDownloadPDF){
    deDownloadPDF.addEventListener('click', () => {
      const name = document.getElementById('deName')?.value || '';
      const surname = document.getElementById('deSurname')?.value || '';
      const embg = document.getElementById('deEmbg')?.value || '';
      const memberId = document.getElementById('deGeneratedId')?.textContent || '';
      const hash = document.getElementById('deHashValue')?.textContent || '';
      const date = new Date().toLocaleDateString('mk-MK');

      const pdfContent =
        'ЧЛЕНСКИ ДОГОВОР — МАКЕДОНИЈА СИСТЕМ\\n' +
        '========================================\\n\\n' +
        'Членски ID: ' + memberId + '\\n' +
        'Име и презиме: ' + name + ' ' + surname + '\\n' +
        'ЕМБГ: ' + embg + '\\n' +
        'Датум: ' + date + '\\n' +
        'Blockchain хаш: ' + hash + '\\n\\n' +
        'Членот се согласува со Статутот, Манифестот и Програмата\\n' +
        'на граѓанското движење Македонија — Систем.\\n\\n' +
        'Овој договор е криптографски потпишан и верифициран\\n' +
        'со SHA-256 blockchain hash.\\n\\n' +
        'makedonijasistem@gmail.com\\n' +
        'https://makedonijasistem.mk';

      const blob = new Blob([pdfContent], {type: 'text/plain;charset=utf-8'});
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'MKS-Членски-договор-' + memberId + '.txt';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);

      showToast('📥 Договорот е преземен!', 'success');
    });
  }

  /* ── Share referral ── */
  const deShareReferral = document.getElementById('deShareReferral');
  if (deShareReferral){
    deShareReferral.addEventListener('click', () => {
      const memberId = document.getElementById('deGeneratedId')?.textContent || '';
      const refUrl = window.location.origin + window.location.pathname + '?ref=' + encodeURIComponent(memberId);
      navigator.clipboard?.writeText(refUrl).then(() => {
        showToast('📋 Рефералниот линк е копиран! Секое зачленување = 10 поени.', 'gold', 5000);
      }).catch(() => fallbackCopy(refUrl));
    });
  }

  /* ═══════════════════════════════════════════════════════════
     ЈАГОТКА НА ТОРТАТА · Toast · Confetti · Sound · Share
     ═══════════════════════════════════════════════════════════ */

  /* ── Toast notification system ── */
  const toastContainer = document.getElementById('toastContainer');

  function showToast(message, type = 'info', duration = 4000){
    if (!toastContainer) return;
    const toast = document.createElement('div');
    toast.className = 'toast toast-' + type;

    const icons = {
      success: '✅',
      error: '❌',
      info: 'ℹ️',
      gold: '🏆'
    };

    toast.innerHTML = 
      '<span class="toast-icon">' + (icons[type] || icons.info) + '</span>' +
      '<span class="toast-content">' + message + '</span>' +
      '<button class="toast-close" aria-label="Затвори">&times;</button>' +
      '<div class="toast-progress"></div>';

    toast.querySelector('.toast-close').addEventListener('click', () => {
      hideToast(toast);
    });

    toastContainer.appendChild(toast);

    // Animate in
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        toast.classList.add('show');
      });
    });

    // Play sound
    playSound(type === 'success' || type === 'gold' ? 'success' : 'click');

    // Auto remove
    setTimeout(() => hideToast(toast), duration);
  }

  function hideToast(toast){
    toast.classList.remove('show');
    setTimeout(() => toast.remove(), 450);
  }

  /* ── Replace all alert() with toast ── */
  const originalAlert = window.alert;
  window.alert = function(message){
    if (message && message.includes('✓')){
      showToast(message, 'success', 5000);
    } else if (message && (message.includes('Мора') || message.includes('Внеси') || message.includes('Премногу') || message.includes('Веќе'))){
      showToast(message, 'error', 5000);
    } else {
      showToast(message, 'info', 4000);
    }
  };

  /* ── Confetti effect ── */
  const confettiColors = [
    'rgba(212,173,74,0.9)',   // gold
    'rgba(139,111,71,0.9)',   // gold-deep
    'rgba(10,29,58,0.85)',    // navy
    'rgba(212,175,55,0.8)',   // classic gold
    'rgba(255,215,0,0.8)',    // bright gold
    'rgba(30,58,95,0.85)',    // navy-mid
  ];

  function launchConfetti(intensity = 80){
    const canvas = document.getElementById('confettiCanvas') || document.createElement('canvas');
    canvas.id = 'confettiCanvas';
    if (!document.getElementById('confettiCanvas')){
      document.body.appendChild(canvas);
    }

    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    canvas.style.position = 'fixed';
    canvas.style.inset = '0';
    canvas.style.zIndex = '350';
    canvas.style.pointerEvents = 'none';

    const particles = [];
    for (let i = 0; i < intensity; i++){
      particles.push({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * canvas.height * 0.5,
        vx: (Math.random() - 0.5) * 6,
        vy: Math.random() * 4 + 2,
        size: Math.random() * 8 + 4,
        color: confettiColors[Math.floor(Math.random() * confettiColors.length)],
        rotation: Math.random() * 360,
        rotationSpeed: (Math.random() - 0.5) * 10,
        sway: Math.random() * 0.04 - 0.02,
        opacity: 1
      });
    }

    let animId;
    function draw(){
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let active = 0;

      particles.forEach(p => {
        if (p.opacity <= 0) return;
        active++;

        p.x += p.vx + Math.sin(p.y * 0.01) * 2;
        p.y += p.vy;
        p.rotation += p.rotationSpeed;
        p.vy += 0.08; // gravity
        p.vx *= 0.99; // air resistance

        if (p.y > canvas.height - 50){
          p.opacity -= 0.02;
        }

        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation * Math.PI / 180);
        ctx.globalAlpha = p.opacity;
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.6);
        ctx.restore();
      });

      if (active > 0){
        animId = requestAnimationFrame(draw);
      } else {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }

    cancelAnimationFrame(animId);
    draw();

    // Cleanup after animation
    setTimeout(() => {
      cancelAnimationFrame(animId);
      if (canvas.parentNode) canvas.parentNode.removeChild(canvas);
    }, 6000);
  }

  /* ── Sound effects (Web Audio API) ── */
  const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

  function playSound(type){
    try {
      if (audioCtx.state === 'suspended') audioCtx.resume();

      const oscillator = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();

      oscillator.connect(gainNode);
      gainNode.connect(audioCtx.destination);

      const now = audioCtx.currentTime;

      if (type === 'success'){
        // Elegant two-tone chime
        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(523.25, now); // C5
        oscillator.frequency.setValueAtTime(659.25, now + 0.12); // E5
        oscillator.frequency.setValueAtTime(783.99, now + 0.24); // G5
        gainNode.gain.setValueAtTime(0.12, now);
        gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.5);
        oscillator.start(now);
        oscillator.stop(now + 0.5);
      } else if (type === 'click'){
        // Subtle click
        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(800, now);
        gainNode.gain.setValueAtTime(0.06, now);
        gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
        oscillator.start(now);
        oscillator.stop(now + 0.08);
      } else if (type === 'celebration'){
        // Grand celebration chord
        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(523.25, now);
        oscillator.frequency.setValueAtTime(659.25, now + 0.1);
        oscillator.frequency.setValueAtTime(783.99, now + 0.2);
        oscillator.frequency.setValueAtTime(1046.5, now + 0.35);
        gainNode.gain.setValueAtTime(0.15, now);
        gainNode.gain.exponentialRampToValueAtTime(0.001, now + 1.0);
        oscillator.start(now);
        oscillator.stop(now + 1.0);
      }
    } catch(e) {
      // Silently fail if audio not supported
    }
  }

  /* ── Copy-to-clipboard share ── */
  function shareSection(sectionId){
    const url = window.location.origin + window.location.pathname + '#' + sectionId;
    if (navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(url).then(() => {
        showToast('📋 Линкот е копиран: ' + url, 'success', 4000);
      }).catch(() => {
        fallbackCopy(url);
      });
    } else {
      fallbackCopy(url);
    }
  }

  function fallbackCopy(text){
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    try {
      document.execCommand('copy');
      showToast('📋 Линкот е копиран!', 'success', 4000);
    } catch(e) {
      showToast('Не можеше да се копира линкот.', 'error', 4000);
    }
    document.body.removeChild(textarea);
  }

  /* ── Add share buttons to all sections ── */
  function addShareButtons(){
    document.querySelectorAll('section[id]').forEach(section => {
      if (section.id === 'hero') return; // Skip hero

      const shareBtn = document.createElement('button');
      shareBtn.className = 'share-btn section-share';
      shareBtn.type = 'button';
      shareBtn.setAttribute('aria-label', 'Копирај линк до оваа секција');
      shareBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>';
      shareBtn.addEventListener('click', () => {
        playSound('click');
        shareSection(section.id);
      });

      section.style.position = 'relative';
      section.appendChild(shareBtn);
    });
  }

  // Add share buttons after page load
  if (document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', addShareButtons);
  } else {
    addShareButtons();
  }

  /* ── Celebration triggers ── */
  // Trigger confetti on membership enrollment
  document.querySelectorAll('form[id^="form-"]').forEach(form => {
    form.addEventListener('submit', () => {
      setTimeout(() => {
        launchConfetti(60);
        playSound('celebration');
        showToast('🎉 Добредојде во Македонија — Систем! Членската картичка е генерирана.', 'gold', 6000);
      }, 500);
    });
  });

  /* ════════════════════════════════════════════════════════════
     NATIONBUILDER + CIVICTECH + MORNING CONSULT · FUNCTIONS
     ════════════════════════════════════════════════════════════ */

  /* ── CRM Dashboard ── */
  const crmBody = document.getElementById('crmBody');
  const crmSearch = document.getElementById('crmSearch');
  const crmFilter = document.getElementById('crmFilter');
  if(crmSearch && crmBody){
    function filterCRM(){
      const term = crmSearch.value.toLowerCase();
      const type = crmFilter.value;
      crmBody.querySelectorAll('tr').forEach(tr => {
        const text = tr.textContent.toLowerCase();
        const tags = tr.querySelectorAll('.crm-tag');
        let matchesType = type === 'all';
        tags.forEach(t => { if(t.textContent.toLowerCase().includes(type)) matchesType = true; });
        tr.style.display = (text.includes(term) && matchesType) ? '' : 'none';
      });
      const visible = crmBody.querySelectorAll('tr:not([style*="none"])').length;
      document.getElementById('crmCount').textContent = visible;
    }
    crmSearch.addEventListener('input', filterCRM);
    crmFilter.addEventListener('change', filterCRM);
  }
  window.exportCRM = function(){
    const rows = [];
    document.querySelectorAll('#crmBody tr').forEach(tr => {
      if(tr.style.display !== 'none'){
        const cols = tr.querySelectorAll('td');
        rows.push(Array.from(cols).map(c => c.textContent.replace(/\s+/g,' ').trim()).join(','));
      }
    });
    const csv = 'Име,Тип,Регион,Активност,Донации,Статус\n' + rows.join('\n');
    const blob = new Blob([csv], {type:'text/csv'});
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'makedonija-sistem-crm.csv'; a.click();
    showToast('📥 CRM извезен во CSV', 'success');
  };

  /* ── Peer-to-Peer Recruiting ── */
  window.copyRef = function(){
    const code = document.getElementById('refCode')?.textContent || 'makedonija-sistem.mk/ref/DEFAULT';
    navigator.clipboard.writeText('https://makedonija-sistem.mk/ref/' + code).then(() => {
      showToast('🔗 Реферален линк копиран!', 'success');
    });
  };

  /* ── Volunteer Task Hub ── */
  const taskMuniList = document.getElementById('taskMuniList');
  if(taskMuniList){
    taskMuniList.addEventListener('click', e => {
      const li = e.target.closest('li'); if(!li) return;
      taskMuniList.querySelectorAll('li').forEach(l => l.classList.remove('active'));
      li.classList.add('active');
      // Demo: animate task list switch
      const taskList = document.getElementById('taskList');
      if(taskList){ taskList.style.opacity='0.5'; setTimeout(()=>taskList.style.opacity='1', 200); }
    });
  }
  window.joinTask = function(btn){
    btn.textContent = '✅ Пријавен';
    btn.disabled = true;
    btn.style.background = '#16a34a';
    btn.style.color = '#fff';
    showToast('✋ Успешно пријавен на задачата!', 'success');
  };

  /* ── Events RSVP ── */
  window.rsvpEvent = function(btn){
    btn.textContent = '✓ Потврдено';
    btn.disabled = true;
    btn.style.background = '#16a34a';
    btn.style.color = '#fff';
    showToast('📅 RSVP потврдено! QR билетот е пратен на е-пошта.', 'success', 4000);
  };

  /* ── Petitions ── */
  let petitionCount = 6840;
  window.signPetition = function(){
    petitionCount++;
    const bar = document.querySelector('.petition-progress .bar');
    const pct = Math.min(100, (petitionCount/10000)*100);
    if(bar) bar.style.width = pct + '%';
    const stats = document.querySelectorAll('.petition-stat b');
    if(stats[0]) stats[0].textContent = petitionCount.toLocaleString();
    if(stats[2]) stats[2].textContent = Math.max(0, 12 - Math.floor(petitionCount/500));
    showToast('✍️ Потписот е додаден! Ти си број ' + petitionCount.toLocaleString(), 'gold', 4000);
    // Add signer card
    const list = document.querySelector('.petition-signers');
    if(list){
      const card = document.createElement('div'); card.className='signer-card';
      card.innerHTML = '<div class="signer-avatar" style="background:var(--gold);color:var(--navy-deep)">ТИ</div><div class="signer-info"><b>Ти</b><span>Скопје</span></div><div class="signer-time">сега</div>';
      list.insertBefore(card, list.firstChild);
      if(list.children.length > 6) list.lastChild.remove();
    }
  };
  window.sharePetition = function(){
    const url = 'https://makedonija-sistem.mk/peticii/meritokratija';
    if(navigator.share){ navigator.share({title:'Петиција за меритократска реформа',url:url}); }
    else { navigator.clipboard.writeText(url); showToast('🔗 Линк копиран за споделување', 'info'); }
  };

  /* ── Email Campaign ── */
  const emailSubject = document.getElementById('emailSubject');
  const emailBody = document.getElementById('emailBody');
  const emailAudience = document.getElementById('emailAudience');
  const prevSubject = document.getElementById('prevSubject');
  const prevAudience = document.getElementById('prevAudience');
  if(emailSubject && prevSubject){
    emailSubject.addEventListener('input', () => prevSubject.textContent = emailSubject.value || 'Месечен билтен · Јуни 2026');
  }
  if(emailAudience && prevAudience){
    emailAudience.addEventListener('change', () => prevAudience.textContent = emailAudience.options[emailAudience.selectedIndex].text);
  }
  window.sendEmail = function(){
    showToast('📤 Кампањата е закажана! 5,420 е-пошти ќе бидат пратени во 14:00.', 'success', 5000);
  };
  window.scheduleEmail = function(){
    showToast('⏰ Отвори се календар за закажување...', 'info');
  };
  window.saveDraft = function(){
    localStorage.setItem('mks_email_draft', JSON.stringify({subject:emailSubject?.value, body:emailBody?.value}));
    showToast('💾 Нацртот е зачуван локално', 'success');
  };

  /* ── Participatory Budgeting ── */
  let budgetTotal = 100000;
  let budgetUsed = 0;
  const budgetSelected = [];
  window.toggleBudget = function(el){
    const cost = parseInt(el.dataset.cost);
    const idx = budgetSelected.indexOf(cost);
    if(idx > -1){
      budgetSelected.splice(idx, 1);
      budgetUsed -= cost;
      el.classList.remove('selected');
    } else {
      if(budgetUsed + cost > budgetTotal){ showToast('⚠️ Нема доволно средства во буџетот!', 'error'); return; }
      budgetSelected.push(cost);
      budgetUsed += cost;
      el.classList.add('selected');
    }
    const rem = document.getElementById('budgetRemaining');
    if(rem) rem.textContent = (budgetTotal - budgetUsed).toLocaleString();
    const list = document.getElementById('budgetList');
    if(list) list.textContent = budgetSelected.length ? budgetSelected.length + ' проекти · ' + budgetUsed.toLocaleString() + ' ден' : 'Нема избрани проекти';
    const btn = document.getElementById('budgetSubmit');
    if(btn) btn.disabled = budgetSelected.length === 0;
  };
  window.submitBudget = function(){
    showToast('✓ Твојот глас за буџетот е зачуван! Проектите ќе се реализираат ако достигнат 50 гласови.', 'gold', 5000);
    document.getElementById('budgetSubmit').disabled = true;
    document.querySelectorAll('.budget-project').forEach(p => p.style.pointerEvents='none');
  };

  /* ── Anonymous Proposals ── */
  window.submitAnon = function(){
    const text = document.getElementById('anonProposal')?.value.trim();
    if(!text){ showToast('⚠️ Внеси го текстот на предлогот', 'error'); return; }
    const list = document.getElementById('anonList');
    const cat = document.getElementById('anonCategory')?.value || 'general';
    const cats = {general:'Општо',health:'Здравство',education:'Образование',economy:'Економија',justice:'Правда',environment:'Животна средина'};
    if(list){
      const card = document.createElement('div'); card.className='anon-proposal';
      card.innerHTML = '<span class="badge">' + (cats[cat]||cat) + '</span><p>„' + text.replace(/</g,'&lt;') + '“</p><div class="meta">🕐 сега · 👍 0 · 👎 0</div>';
      list.insertBefore(card, list.firstChild);
    }
    document.getElementById('anonProposal').value = '';
    showToast('🛡️ Анонимниот предлог е поднесен и чека модерација!', 'success', 4000);
  };

  /* ── AI Sentiment (simulated) ── */
  window.analyzeSentiment = function(){
    showToast('🧠 AI анализира 1,847 предлози...', 'info', 2000);
    setTimeout(() => showToast('✅ Анализата е завршена. 78% позитивни.', 'success'), 2200);
  };

  /* ── Poll Archive ── */
  window.openArchive = function(el){
    const title = el.querySelector('h5')?.textContent || 'Анкета';
    showToast('📊 Отворање на демографска анализа за: ' + title, 'info');
  };

  /* ── Presentation Export ── */
  window.exportPresentation = function(fmt){
    if(fmt === 'pdf'){
      showToast('📄 PDF презентацијата се генерира...', 'info', 3000);
      setTimeout(() => { showToast('✅ PDF е спремен за симнување!', 'success'); }, 3000);
    } else if(fmt === 'canvas'){
      showToast('🎨 Canvas PNG се рендерира...', 'info', 3000);
      setTimeout(() => { showToast('✅ PNG е спремен за симнување!', 'success'); }, 3000);
    } else {
      showToast('📊 PPTX форматот ќе биде достапен во v2.1', 'info');
    }
  };

  /* ── Admin bar (demo toggle via localStorage) ── */
  if(localStorage.getItem('mks_admin') === '1'){
    const adminBar = document.getElementById('adminBar');
    if(adminBar) adminBar.style.display = 'block';
  }

  /* ════════════════════════════════════════════════════════════ */

  /* ════════════════════════════════════════════════════════════
     V16 ENHANCEMENTS — Code review fixes + functional upgrades
     Implementation of A-E options:
     A) Code review fixes
     B) Functional CRM / AI Sentiment / Growth dashboards  
     C) Final SWOT analysis (deferred to HTML)
     D) React migration plan (in companion doc)
     E) Monthly Magazine RSS-style feed
     ════════════════════════════════════════════════════════════ */

  /* ── B1: CRM Dashboard — Real localStorage persistence + search/filter ── */
  const CRM_KEY = 'ms_crm_records_v1';
  function crmLoad(){
    try { return JSON.parse(localStorage.getItem(CRM_KEY) || '[]'); }
    catch(e){ return []; }
  }
  function crmSave(arr){
    try { localStorage.setItem(CRM_KEY, JSON.stringify(arr)); return true; }
    catch(e){ return false; }
  }
  function crmSeed(){
    // Seed with demo data if empty
    const existing = crmLoad();
    if (existing.length > 0) return existing;
    const seed = [
      { name:'Александар С.', email:'aleks@email.mk', type:'member', region:'Скопје', activity:92, donations:340, status:'active' },
      { name:'Марија К.', email:'marija@email.mk', type:'volunteer', region:'Битола', activity:87, donations:120, status:'active' },
      { name:'Драган П.', email:'dragan@email.mk', type:'donor', region:'Тетово', activity:54, donations:850, status:'medium' },
      { name:'Елена Р.', email:'elena@email.mk', type:'supporter', region:'Охрид', activity:23, donations:0, status:'passive' },
      { name:'Стефан М.', email:'stefan@email.mk', type:'member', region:'Куманово', activity:95, donations:500, status:'active' },
      { name:'Ивана Т.', email:'ivana@email.mk', type:'volunteer', region:'Прилеп', activity:78, donations:50, status:'active' },
      { name:'Никола В.', email:'nikola@email.mk', type:'donor', region:'Велес', activity:42, donations:1200, status:'medium' },
      { name:'Ана Б.', email:'ana@email.mk', type:'member', region:'Штип', activity:88, donations:200, status:'active' }
    ];
    crmSave(seed);
    return seed;
  }
  function crmRender(filterText = '', filterType = 'all'){
    const tbody = document.getElementById('crmBody');
    const countEl = document.getElementById('crmCount');
    if (!tbody) return;
    const records = crmSeed();
    const ft = (filterText || '').toLowerCase().trim();
    const filtered = records.filter(r => {
      if (filterType !== 'all' && r.type !== filterType) return false;
      if (ft && !r.name.toLowerCase().includes(ft) && !r.email.toLowerCase().includes(ft)) return false;
      return true;
    });
    const typeMap = { member:'Член', volunteer:'Волонтер', donor:'Донатор', supporter:'Поддржувач' };
    const statusMap = {
      active: '<span style="color:#16a34a;font-weight:700">● Активен</span>',
      medium: '<span style="color:#ca8a04;font-weight:700">● Умерен</span>',
      passive: '<span style="color:#dc2626;font-weight:700">● Пасивен</span>'
    };
    tbody.innerHTML = filtered.map(r => {
      const scoreClass = r.activity >= 70 ? 'high' : r.activity >= 40 ? 'medium' : 'low';
      return `<tr>
        <td><b>${r.name}</b><br><span style="font-size:11px;color:var(--muted)">${r.email}</span></td>
        <td><span class="crm-tag">${typeMap[r.type] || r.type}</span></td>
        <td>${r.region}</td>
        <td><span class="crm-score ${scoreClass}">${r.activity}/100</span></td>
        <td>€${r.donations}</td>
        <td>${statusMap[r.status] || r.status}</td>
      </tr>`;
    }).join('');
    if (countEl) countEl.textContent = filtered.length;
  }
  // Wire up CRM controls (V16 enhanced version)
  const v16CrmSearch = document.getElementById('crmSearch');
  const v16CrmFilter = document.getElementById('crmFilter');
  if (v16CrmSearch){
    v16CrmSearch.addEventListener('input', () => {
      crmRender(v16CrmSearch.value, v16CrmFilter ? v16CrmFilter.value : 'all');
    });
  }
  if (v16CrmFilter){
    v16CrmFilter.addEventListener('change', () => {
      crmRender(v16CrmSearch ? v16CrmSearch.value : '', v16CrmFilter.value);
    });
  }
  // Initial render
  crmRender();

  // CRM Export — make it actually work
  window.exportCRM = function(){
    const records = crmLoad();
    if (!records.length) {
      alert('Нема записи за извоз.');
      return;
    }
    const headers = ['Име','Е-пошта','Тип','Регион','Активност (%)','Донации (€)','Статус'];
    const rows = records.map(r => [
      r.name, r.email, r.type, r.region, r.activity, r.donations, r.status
    ].map(c => '"' + String(c).replace(/"/g, '""') + '"').join(','));
    const csv = '\uFEFF' + headers.join(',') + '\n' + rows.join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'ms-crm-export-' + new Date().toISOString().slice(0,10) + '.csv';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    if (typeof showToast === 'function') showToast('✓ CSV извезен успешно!', 'success');
  };

  /* ── B2: Recruiting — Functional referral copy ── */
  window.copyRef = function(){
    const refCode = document.getElementById('refCode')?.textContent || '';
    const refLink = 'https://makedonijasistem.mk/ref/' + refCode;
    if (navigator.clipboard){
      navigator.clipboard.writeText(refLink).then(() => {
        if (typeof showToast === 'function') showToast('✓ Реферален линк копиран!', 'success');
        else alert('Линк копиран: ' + refLink);
      }).catch(() => alert('Копирај го линкот: ' + refLink));
    } else {
      alert('Линк: ' + refLink);
    }
  };

  /* ── B3: AI Sentiment — Live update with random walk ── */
  function aiSentimentUpdate(){
    const positiveEl = document.querySelector('[data-sentiment="positive"]');
    const neutralEl = document.querySelector('[data-sentiment="neutral"]');
    const negativeEl = document.querySelector('[data-sentiment="negative"]');
    if (!positiveEl) return; // Section not present
    // Use a stable demo value with small variation
    const base = { p: 67, n: 21, ne: 12 };
    const variation = () => Math.floor((Math.random() - 0.5) * 4);
    const p = Math.max(50, Math.min(80, base.p + variation()));
    const n = Math.max(15, Math.min(30, base.n + variation()));
    const ne = 100 - p - n;
    if (positiveEl) positiveEl.textContent = p + '%';
    if (neutralEl) neutralEl.textContent = n + '%';
    if (negativeEl) negativeEl.textContent = ne + '%';
  }
  // Run every 8 seconds for live feel
  if (document.getElementById('ai-sentiment')){
    setInterval(aiSentimentUpdate, 8000);
  }

  /* ── B4: Growth Dashboard — KPI mini-charts via simple bars ── */
  function growthDashboardInit(){
    const dashboard = document.getElementById('growth-dashboard');
    if (!dashboard) return;
    // Animate any [data-growth-bar] elements to fill from 0 → target%
    const bars = dashboard.querySelectorAll('[data-growth-bar]');
    bars.forEach(bar => {
      const target = parseInt(bar.dataset.growthBar) || 0;
      bar.style.width = '0%';
      bar.style.transition = 'width 1.4s cubic-bezier(.4,0,.2,1)';
      // Use IntersectionObserver to animate when visible
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting){
            requestAnimationFrame(() => {
              bar.style.width = target + '%';
            });
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.3 });
      io.observe(bar);
    });
  }
  growthDashboardInit();

  /* ── E: Monthly Magazine — RSS-style article injection ── */
  // If the magazine container exists, populate with sample articles
  const magazineList = document.getElementById('magazineArticles');
  if (magazineList){
    const articles = [
      {
        date: '2026-05-01', flag: '🇩🇪', country: 'Германија',
        party: 'CDU/CSU', title: 'Konrad-Adenauer-Stiftung лансира студија за меритократија во ЕУ',
        snippet: 'Партискиот think-tank објави 120-страничен труд за реформа на државна служба со германски модел...'
      },
      {
        date: '2026-04-28', flag: '🇮🇹', country: 'Италија',
        party: 'Fratelli d\'Italia', title: 'Atreju 2026 — годишен конгрес со 30,000 учесници',
        snippet: 'Премиерот Мелони го најави Atreju 2026 со теми: дигитална суверенитет, AI и национално планирање...'
      },
      {
        date: '2026-04-25', flag: '🇸🇬', country: 'Сингапур',
        party: 'PAP', title: 'Стипендија за државна служба — 200 нови апликанти',
        snippet: 'Singapore PAP отвори нов круг на стипендии за идни државни службеници, со фокус на јавна администрација...'
      },
      {
        date: '2026-04-20', flag: '🇪🇪', country: 'Естонија',
        party: 'Reform Party', title: 'X-Road надградба — нови 50 интероперабилни услуги',
        snippet: 'Естонската Reform Party најавува дополнителна дигитализација со 50 нови владини услуги...'
      },
      {
        date: '2026-04-15', flag: '🇫🇷', country: 'Франција',
        party: 'Renaissance', title: 'Macron го лансира Sisterhood Network за европски прогресивни',
        snippet: 'Renaissance партијата формира мрежа со другите европски центристички партии за заеднички програми...'
      },
      {
        date: '2026-04-10', flag: '🇬🇧', country: 'Велика Британија',
        party: 'Labour', title: 'Стармер: 100 дена реформи во НХС',
        snippet: 'Лабуристичката влада презентира извештај за прв 100 дена од владата со фокус на здравствен систем...'
      }
    ];
    magazineList.innerHTML = articles.map(a => `
      <article class="mag-article">
        <div class="mag-flag">${a.flag}</div>
        <div class="mag-body">
          <div class="mag-meta">
            <span class="mag-country">${a.country} · ${a.party}</span>
            <time class="mag-date">${a.date}</time>
          </div>
          <h4 class="mag-title">${a.title}</h4>
          <p class="mag-snippet">${a.snippet}</p>
        </div>
      </article>
    `).join('');
  }

  /* ── A: Code review fix — service worker activation announce ── */
  if ('serviceWorker' in navigator && location.protocol === 'https:'){
    navigator.serviceWorker?.controller && console.log('🔧 Service Worker active');
  }

  /* ── A: Performance — defer non-critical iframes ── */
  document.querySelectorAll('iframe:not([loading])').forEach(f => f.setAttribute('loading','lazy'));
  document.querySelectorAll('img:not([loading])').forEach(i => i.setAttribute('loading','lazy'));

  /* ── Final initialization log ── */
  console.log('%c ✅ V16 ENHANCEMENTS — Активирани (CRM, AI Sentiment, Growth, Magazine) ', 'background:linear-gradient(135deg,#5fce7e,#3fa75d);color:#fff;font-size:13px;font-weight:bold;padding:6px 14px;border-radius:6px');
  console.log('%c 🍓 ЈАГОТКА НА ТОРТАТА — Активирана! ', 'background:linear-gradient(135deg,#d4ad4a,#8b6f47);color:#0a1d3a;font-size:16px;font-weight:bold;padding:8px 16px;border-radius:8px');


})();

  /* ── Firebase / Poll safety net (v17) ── */
  (function(){
    // Catch unhandled promise rejections (e.g., Firebase network errors)
    window.addEventListener('unhandledrejection', function(e){
      const msg = e.reason && e.reason.message ? e.reason.message : String(e.reason || '');
      if (/firebase|network|offline|fetch|database/i.test(msg)){
        console.warn('[poll] network issue, switching to offline mode:', msg);
        showPollOffline();
        e.preventDefault();
      }
    });
    function showPollOffline(){
      const banner = document.getElementById('pollOfflineBanner');
      if (banner) banner.classList.add('show');
    }
    // Also detect outright offline state
    window.addEventListener('offline', showPollOffline);
    window.addEventListener('online', function(){
      const banner = document.getElementById('pollOfflineBanner');
      if (banner) banner.classList.remove('show');
    });
  })();

  /* ── Performance: passive scroll listeners + RAF-debounced reveal ── */
  (function(){
    const reveals = document.querySelectorAll('.reveal');
    if (!reveals.length) return;
    if ('IntersectionObserver' in window){
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting){
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      }, {rootMargin: '0px 0px -10% 0px', threshold: 0.05});
      reveals.forEach(el => io.observe(el));
    } else {
      // Fallback: just show all
      reveals.forEach(el => el.classList.add('visible'));
    }
  })();

  /* ── Image lazy-load fade-in ── */
  document.querySelectorAll('img[loading="lazy"]').forEach(img => {
    if (img.complete && img.naturalWidth > 0){
      img.classList.add('loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('loaded'), {once:true});
    }
  });

</script>

<script>
/* ═══ PARTY NETWORKING SYSTEM · standalone (v17 phase 10) ═══
   Loaded as a separate script so a failure earlier in the main IIFE
   (e.g. canvas issues in test environments) does not prevent it from running.
   ════════════════════════════════════════════════════════════ */
(function(){
  'use strict';
/* ═══ PARTY NETWORKING SYSTEM (v17 phase 10) ═══ */
function initPartyNetworking(){
  try {
  // Party data — extracted from wp-grid in DOM
  const PN_PARTIES = [];
  document.querySelectorAll('.wp-card').forEach((card, idx) => {
  const flag = card.querySelector('.wp-flag')?.textContent.trim() || '🏳️';
  const name = card.querySelector('strong')?.textContent.trim() || '';
  const country = card.querySelector('.wp-country')?.textContent.trim() || '';
  const block = card.dataset.block || '';
  const desc = card.querySelector('p')?.textContent.trim() || '';
  const addrEl = card.querySelector('.wp-addr');
  const addr = addrEl ? addrEl.textContent.replace(/^📍\s*/, '').trim() : '';
  const webEl = card.querySelector('.wp-web a');
  const web = webEl ? webEl.textContent.replace(/^🌐\s*/, '').trim() : '';
  PN_PARTIES.push({
    id: 'p' + idx,
    flag, name, country, block, desc, addr, web,
  });
  });

  if (PN_PARTIES.length === 0){
  console.warn('[networking] No parties found in DOM');
  return;
  }

  // Block order priority (CENTER first)
  const BLOCK_ORDER = {
  'center-right': 1, 'center-left': 2,
  'liberal': 3, 'green': 4, 'conservative': 5, 'meritocratic': 6,
  };
  const BLOCK_LABELS = {
  'center-right': 'Центар-десно',
  'center-left': 'Центар-лево',
  'liberal': 'Либерално',
  'green': 'Зелено',
  'conservative': 'Конзервативно',
  'meritocratic': 'Меритократско',
  };

  // ── Storage ──
  const PN_KEY = 'mks_partnerships_v1';
  function loadPartnerships(){
  try {
    const raw = localStorage.getItem(PN_KEY);
    return raw ? JSON.parse(raw) : [];
  } catch(e){ return []; }
  }
  function savePartnerships(list){
  try { localStorage.setItem(PN_KEY, JSON.stringify(list)); } catch(e){}
  }
  let partnerships = loadPartnerships();

  // ── Type templates (email body templates) ──
  const TYPE_TEMPLATES = {
  'study-visit': {
    icon: '🎓',
    name: 'Студиска посета',
    subject: 'Барање за студиска посета — Македонија — Систем (МК-Систем)',
    body: `Почитувани,

Во име на „Македонија — Систем" — граѓанско-државничка платформа за функционална држава, Ве молиме да го разгледате нашето барање за организирање на студиска посета (3–5 дена) во седиштето на {PARTY}.

Цел на посетата: {TOPIC}

Македонија — Систем е новоформирана политичка платформа со меритократска доктрина и структуриран развоен модел (12 столбови, 100-дневна програма, дигитална членска инфраструктура). Сметаме дека искуството на {PARTY} може значајно да придонесе за нашиот институционален развој.

Очекуваме одговор за можен термин и протокол на средбата.

Со почит,
{NAME}
{ROLE} · Македонија — Систем
✉️ {EMAIL}
🌐 makedonijasistem.mk`,
  },
  'bilateral': {
    icon: '🤝',
    name: 'Билатерална средба',
    subject: 'Иницијатива за билатерална средба — МК-Систем · {PARTY}',
    body: `Почитувани,

Во име на „Македонија — Систем", сакаме да иницираме билатерална средба меѓу нашето раководство и претставници на {PARTY}.

Тема: {TOPIC}
Предложен термин: {TIMELINE}

Македонија — Систем е граѓанско-државничка платформа основана на принципи на меритократија, владеење на правото и институционализам. Веруваме дека дијалогот со {PARTY} може да отвори простор за заеднички перспективи на регионално и европско ниво.

Сме отворени за домаќинска средба во Скопје или гостувачка во вашето седиште.

Со почит,
{NAME}
{ROLE} · Македонија — Систем
✉️ {EMAIL}
🌐 makedonijasistem.mk`,
  },
  'cooperation': {
    icon: '📜',
    name: 'Меморандум за соработка (MoU)',
    subject: 'Предлог за Меморандум за соработка — МК-Систем · {PARTY}',
    body: `Почитувани,

Во име на „Македонија — Систем", сакаме да предложиме потпишување на Меморандум за соработка (MoU) меѓу нашите две организации.

Содржина на MoU: {TOPIC}
Хоризонт: {TIMELINE}

Предлогот за MoU вклучува: размена на политички документи, заеднички истражувачки проекти преку Систем Институт, координација на меѓународни форуми, и (по можност) реципрочни членски бенефиции.

Доколку постои интерес, ќе подготвиме нацрт-договор за вашата правна служба.

Со почит,
{NAME}
{ROLE} · Македонија — Систем
✉️ {EMAIL}
🌐 makedonijasistem.mk`,
  },
  'youth-exchange': {
    icon: '🚀',
    name: 'Младинска размена',
    subject: 'Junge Sistem ↔ {PARTY} Youth — иницијатива за размена',
    body: `Почитувани,

Во име на Junge Sistem (младинско крило на „Македонија — Систем"), сакаме да предложиме програма за младинска размена со младинското крило на {PARTY}.

Тема и формат: {TOPIC}
Период: {TIMELINE}

Junge Sistem нуди: 4 циклуси годишно по 12 недели, обуки, менторство, теренски проекти. Размената може да опфати 5–15 учесници по страна, со престој од 1–4 недели.

Сакаме да го следиме моделот на Konrad-Adenauer-Stiftung, Friedrich-Ebert-Stiftung и Hanns-Seidel-Stiftung.

Со почит,
{NAME}
{ROLE} · Junge Sistem · Македонија — Систем
✉️ {EMAIL}
🌐 makedonijasistem.mk`,
  },
  'joint-statement': {
    icon: '📢',
    name: 'Заедничко соопштение',
    subject: 'Предлог за заедничко јавно соопштение — МК-Систем · {PARTY}',
    body: `Почитувани,

Во име на „Македонија — Систем", сакаме да предложиме заедничко јавно соопштение со {PARTY}.

Тема: {TOPIC}

Соопштението би било потпишано од раководствата на двете партии и објавено симултано на нашите официјални канали. Сметаме дека заедничкиот глас има поголема тежина и испраќа порака на меѓународна солидарност помеѓу платформи кои делат вредности на демократија, владеење на правото и институционализам.

Очекуваме повратен одговор за нацрт-текст и термин на објавување.

Со почит,
{NAME}
{ROLE} · Македонија — Систем
✉️ {EMAIL}
🌐 makedonijasistem.mk`,
  },
  };

  // ── DOM refs ──
  const $$ = (id) => document.getElementById(id);
  const elList = $$('pnList');
  const elSearch = $$('pnSearch');
  const elPills = document.querySelectorAll('[data-pn-filter]');
  const elTypes = document.querySelectorAll('.pn-type');
  const elForm = $$('pnForm');
  const elSubmit = $$('pnSubmitBtn');
  const elSaveBtn = $$('pnSaveBtn');
  const elTracker = $$('pnTrackerList');
  const elTargetDisplay = $$('pnTargetDisplay');
  const elTargetFlag = $$('pnTargetFlag');
  const elTargetName = $$('pnTargetName');
  const elTargetCountry = $$('pnTargetCountry');
  const elTargetBlock = $$('pnTargetBlock');
  const elTargetId = $$('pnTargetId');
  const elTypeInput = $$('pnType');
  const elInitiated = $$('pnInitiated');

  if (!elList) return; // not on this page

  let currentFilter = 'all';
  let currentSearch = '';
  let currentType = 'study-visit';
  let selectedParty = null;

  // ── Render directory ──
  function renderList(){
  const sorted = [...PN_PARTIES].sort((a, b) => {
    const ord = (BLOCK_ORDER[a.block] || 99) - (BLOCK_ORDER[b.block] || 99);
    if (ord !== 0) return ord;
    return a.country.localeCompare(b.country);
  });

  const matches = sorted.filter(p => {
    if (currentFilter !== 'all'){
      if (currentFilter === 'center'){
        if (p.block !== 'center-right' && p.block !== 'center-left') return false;
      } else if (p.block !== currentFilter){
        return false;
      }
    }
    if (currentSearch){
      const s = currentSearch.toLowerCase();
      const hay = (p.name + ' ' + p.country + ' ' + p.desc).toLowerCase();
      if (!hay.includes(s)) return false;
    }
    return true;
  });

  if (matches.length === 0){
    elList.innerHTML = '<div style="text-align:center;padding:40px 20px;color:var(--muted);font-style:italic;font-size:13px">Нема партии што одговараат на пребарувањето.</div>';
    return;
  }

  elList.innerHTML = matches.map(p => {
    const isSelected = selectedParty && selectedParty.id === p.id;
    return `<div class="pn-item${isSelected ? ' selected' : ''}" data-id="${p.id}" role="option" tabindex="0" aria-selected="${isSelected}">
      <span class="pn-item-flag">${p.flag}</span>
      <div class="pn-item-info">
        <div class="pn-item-name">${escapeHtml(p.name)}</div>
        <div class="pn-item-meta">
          <span class="pn-item-block-dot ${p.block}"></span>
          ${escapeHtml(p.country)} · ${BLOCK_LABELS[p.block] || p.block}
        </div>
      </div>
    </div>`;
  }).join('');

  // Wire up clicks
  elList.querySelectorAll('.pn-item').forEach(el => {
    el.addEventListener('click', () => selectParty(el.dataset.id));
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' '){
        e.preventDefault();
        selectParty(el.dataset.id);
      }
    });
  });
  }

  function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  // ── Select party ──
  function selectParty(id){
  const p = PN_PARTIES.find(x => x.id === id);
  if (!p) return;
  selectedParty = p;
  elTargetId.value = p.id;
  elTargetFlag.textContent = p.flag;
  elTargetName.textContent = p.name;
  elTargetCountry.textContent = p.country + (p.addr ? ' · ' + p.addr : '');
  elTargetBlock.textContent = (BLOCK_LABELS[p.block] || p.block) + (p.web ? ' · 🌐 ' + p.web : '');
  elTargetDisplay.style.display = 'flex';
  elSubmit.disabled = false;
  elSaveBtn.disabled = false;
  renderList(); // re-render to update selected state
  }

  // ── Type selector ──
  elTypes.forEach(el => {
  el.addEventListener('click', () => {
    elTypes.forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-pressed', 'false');
    });
    el.classList.add('active');
    el.setAttribute('aria-pressed', 'true');
    currentType = el.dataset.type;
    elTypeInput.value = currentType;
  });
  el.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' '){
      e.preventDefault();
      el.click();
    }
  });
  });

  // ── Search & filter ──
  if (elSearch){
  elSearch.addEventListener('input', (e) => {
    currentSearch = e.target.value.trim();
    renderList();
  });
  }
  elPills.forEach(pill => {
  pill.addEventListener('click', () => {
    elPills.forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    currentFilter = pill.dataset.pnFilter;
    renderList();
  });
  });

  // ── Form submission — generate email ──
  function buildEmail(party, typeKey, formData){
  const tmpl = TYPE_TEMPLATES[typeKey];
  if (!tmpl) return null;

  const tlMap = {
    'urgent': 'итно (до 30 дена)',
    'quarter': 'во рок од 3 месеци',
    'half-year': 'во рок од 6 месеци',
    'year': 'во рок од една година',
  };
  const roleMap = {
    'member': 'Член',
    'coordinator': 'Координатор',
    'institute': 'Систем Институт',
    'junge': 'Junge Sistem',
    'executive': 'Извршен одбор',
  };

  const subject = tmpl.subject.replace('{PARTY}', party.name);
  const body = tmpl.body
    .replaceAll('{PARTY}', party.name)
    .replaceAll('{TOPIC}', formData.topic)
    .replaceAll('{TIMELINE}', tlMap[formData.timeline] || formData.timeline)
    .replaceAll('{NAME}', formData.name)
    .replaceAll('{ROLE}', roleMap[formData.role] || formData.role)
    .replaceAll('{EMAIL}', formData.email);

  // Recipient guess: info@<web> or contact@<web> if available
  let to = '';
  if (party.web){
    to = 'info@' + party.web;
  }

  return {to, subject, body};
  }

  if (elForm){
  elForm.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!selectedParty){
      if (typeof showToast === 'function') showToast('⚠️ Прво изберете партија', 'warn', 2500);
      return;
    }
    const formData = {
      name: $$('pnYourName').value.trim(),
      email: $$('pnYourEmail').value.trim(),
      role: $$('pnYourRole').value,
      timeline: $$('pnTimeline').value,
      topic: $$('pnTopic').value.trim(),
    };
    if (!formData.name || !formData.email || !formData.topic){
      if (typeof showToast === 'function') showToast('⚠️ Пополнете ги задолжителните полиња', 'warn', 2500);
      return;
    }
    const email = buildEmail(selectedParty, currentType, formData);
    if (!email) return;

    // Save to tracker
    const entry = {
      id: 'pn_' + Date.now(),
      partyId: selectedParty.id,
      partyName: selectedParty.name,
      partyFlag: selectedParty.flag,
      partyCountry: selectedParty.country,
      type: currentType,
      typeName: TYPE_TEMPLATES[currentType].name,
      topic: formData.topic,
      timeline: formData.timeline,
      status: 'initiated',
      createdAt: new Date().toISOString(),
    };
    partnerships.push(entry);
    savePartnerships(partnerships);
    renderTracker();
    updateStats();

    // Open mailto
    const mailto = 'mailto:' + email.to + '?subject=' + encodeURIComponent(email.subject) +
                   '&cc=makedonijasistem@gmail.com' +
                   '&body=' + encodeURIComponent(email.body);
    window.location.href = mailto;

    if (typeof showToast === 'function') showToast('✅ Партнерство иницирано · меилот е подготвен', 'success', 3000);
  });
  }

  // ── Save without sending ──
  if (elSaveBtn){
  elSaveBtn.addEventListener('click', () => {
    if (!selectedParty){
      if (typeof showToast === 'function') showToast('⚠️ Прво изберете партија', 'warn', 2500);
      return;
    }
    const topic = $$('pnTopic').value.trim();
    if (!topic){
      if (typeof showToast === 'function') showToast('⚠️ Внесете тема', 'warn', 2500);
      return;
    }
    const entry = {
      id: 'pn_' + Date.now(),
      partyId: selectedParty.id,
      partyName: selectedParty.name,
      partyFlag: selectedParty.flag,
      partyCountry: selectedParty.country,
      type: currentType,
      typeName: TYPE_TEMPLATES[currentType].name,
      topic: topic,
      timeline: $$('pnTimeline').value,
      status: 'initiated',
      createdAt: new Date().toISOString(),
    };
    partnerships.push(entry);
    savePartnerships(partnerships);
    renderTracker();
    updateStats();
    if (typeof showToast === 'function') showToast('💾 Зачувано локално', 'success', 2000);
  });
  }

  // ── Tracker ──
  function renderTracker(){
  if (!elTracker) return;
  if (partnerships.length === 0){
    elTracker.innerHTML = '<div class="pn-tracker-empty">Сè уште не сте иницирале партнерства. Изберете партија и пополнете форма.</div>';
    return;
  }
  const sorted = [...partnerships].sort((a, b) => (b.createdAt || '').localeCompare(a.createdAt || ''));
  elTracker.innerHTML = sorted.map(p => {
    const date = p.createdAt ? new Date(p.createdAt).toLocaleDateString('mk-MK') : '';
    const statusLabels = {
      'initiated': 'Иницирано',
      'in-progress': 'Во тек',
      'active': 'Активно',
      'concluded': 'Завршено',
    };
    return `<div class="pn-tracker-item" data-pid="${p.id}">
      <div class="pn-tracker-head">
        <span class="pn-tracker-flag">${p.partyFlag}</span>
        <div class="pn-tracker-name">${escapeHtml(p.partyName)}</div>
        <span class="pn-tracker-status ${p.status}">${statusLabels[p.status] || p.status}</span>
      </div>
      <div class="pn-tracker-meta">${escapeHtml(p.typeName)} · ${escapeHtml(p.partyCountry)}<br>${escapeHtml(p.topic.substring(0, 80))}${p.topic.length > 80 ? '…' : ''}<br><small style="opacity:.7">${date}</small></div>
      <div class="pn-tracker-actions">
        <button data-action="advance">⏭️ Напреден</button>
        <button data-action="delete">🗑️ Избриши</button>
      </div>
    </div>`;
  }).join('');
  // Wire up actions
  elTracker.querySelectorAll('[data-pid]').forEach(item => {
    const pid = item.dataset.pid;
    item.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        const idx = partnerships.findIndex(x => x.id === pid);
        if (idx < 0) return;
        if (action === 'delete'){
          if (confirm('Избриши го ова партнерство?')){
            partnerships.splice(idx, 1);
            savePartnerships(partnerships);
            renderTracker();
            updateStats();
          }
        } else if (action === 'advance'){
          const order = ['initiated','in-progress','active','concluded'];
          const cur = order.indexOf(partnerships[idx].status);
          const next = order[(cur + 1) % order.length];
          partnerships[idx].status = next;
          savePartnerships(partnerships);
          renderTracker();
          updateStats();
          if (typeof showToast === 'function') showToast('✓ Статус: ' + next, 'info', 1500);
        }
      });
    });
  });
  }

  function updateStats(){
  if (elInitiated) elInitiated.textContent = partnerships.length;
  }

  // ── Initial render ──
  renderList();
  renderTracker();
  updateStats();
  } catch(err){
  console.warn('[networking] init error:', err && err.message ? err.message : err);
  }
}
// Run now (DOM is ready since script is at end of body),
// also run on DOMContentLoaded as fallback
if (document.readyState === 'loading'){
  document.addEventListener('DOMContentLoaded', initPartyNetworking);
} else {
  initPartyNetworking();
}


})();
</script>

<script>
