    {name:'Куманово', region:'northeast', center:'Куманово', pop:98104, area:509.5, coord:'active', mayor:'Максим Димитриевски', web:'kumanovo.gov.mk'},
    {name:'Кратово', region:'northeast', center:'Кратово', pop:6924, area:375.4, coord:'seeking', mayor:'Љупчо Бошкоски', web:'kratovo.gov.mk'},
    {name:'Крива Паланка', region:'northeast', center:'Крива Паланка', pop:17855, area:480.8, coord:'seeking', mayor:'Сашко Митовски', web:'krivapalanka.gov.mk'},
