    <!-- Position of MS in spectrum -->
    <div class="wp-position reveal">
      <h3>📍 Позиција на „Македонија — Систем" во глобалниот политички спектар</h3>
      <p class="wp-position-lede">Македонија — Систем не е лево, не е десно. Тоа е <strong>компетенциско-меритократска</strong> позиција — структурна, не идеолошка. Најблизу до неа се меѓународно: Сингапурската PAP (по меритократија), Естонската Reform Party (по дигитализација), и Германските Volkspartei модели (по институционална стабилност). Но никоја од нив не ги поврзува сите три во еден систем.</p>

      <div class="wp-spectrum">
        <div class="wp-spec-axis">
          <div class="wp-spec-label left">🔴 Лево</div>
          <div class="wp-spec-line">
            <div class="wp-spec-marker mks" style="left:50%">
              <span>⭐ МК-Систем</span>
            </div>
            <div class="wp-spec-marker traditional" style="left:25%">СДСМ</div>
            <div class="wp-spec-marker traditional" style="left:75%">ВМРО</div>
          </div>
          <div class="wp-spec-label right">🔵 Десно</div>
        </div>
        <p class="wp-spec-note">Хоризонтална оска: лево-десно. <strong>Македонија — Систем</strong> избегнува да се позиционира на оваа оска. Наместо тоа, се позиционира <strong>вертикално</strong> — повисоко на оската на компетентност vs. некомпетентност.</p>
      </div>
    </div>

  </div>
</section>

<!-- ═══ PARTY NETWORKING / PARTNERSHIP SYSTEM ═══ -->
<section id="party-networking" class="pn-section">
  <div class="container">
    <div class="section-head reveal" style="text-align:center">
      <span class="label" data-i18n="pn.label">Меѓупартиско вмрежување · Networking</span>
      <h2 data-i18n="pn.title">Вмрежи се со <em>61 партија</em> ширум светот.</h2>
    </div>

    <div class="pn-intro reveal">
      <p data-i18n="pn.intro">Македонија — Систем гради меѓународни партнерства преку 5 формати: студиски посети, билатерални средби, меморандуми за соработка, размени за младинско крило и заеднички јавни соопштенија. Изберете тип, изберете партија, генерирајте професионален меил со дипломатски протокол.</p>
    </div>

    <!-- Stats -->
    <div class="pn-stats reveal">
      <div class="pn-stat">
        <div class="pn-stat-num">61</div>
        <div class="pn-stat-label" data-i18n="pn.stat.parties">Партии</div>
      </div>
      <div class="pn-stat">
        <div class="pn-stat-num">6</div>
        <div class="pn-stat-label" data-i18n="pn.stat.continents">Континенти</div>
      </div>
      <div class="pn-stat">
        <div class="pn-stat-num">5</div>
        <div class="pn-stat-label" data-i18n="pn.stat.formats">Формати</div>
      </div>
      <div class="pn-stat">
        <div class="pn-stat-num" id="pnInitiated">0</div>
        <div class="pn-stat-label" data-i18n="pn.stat.initiated">Иницирани</div>
      </div>
    </div>

    <!-- Type selector -->
    <h3 style="font-family:var(--serif);font-size:18px;color:var(--navy);margin:24px 0 14px" data-i18n="pn.types_h">Изберете формат на партнерство:</h3>
    <div class="pn-types reveal">
      <div class="pn-type active" data-type="study-visit" tabindex="0" role="button" aria-pressed="true">
        <div class="pn-type-icon">🎓</div>
        <div class="pn-type-name" data-i18n="pn.t.study">Студиска посета</div>
        <div class="pn-type-desc" data-i18n="pn.t.study.d">3–5 дена · обука и аналитика</div>
      </div>
      <div class="pn-type" data-type="bilateral" tabindex="0" role="button" aria-pressed="false">
        <div class="pn-type-icon">🤝</div>
        <div class="pn-type-name" data-i18n="pn.t.bilat">Билатерална средба</div>
        <div class="pn-type-desc" data-i18n="pn.t.bilat.d">Лидер со лидер · 1 ден</div>
      </div>
      <div class="pn-type" data-type="cooperation" tabindex="0" role="button" aria-pressed="false">
        <div class="pn-type-icon">📜</div>
        <div class="pn-type-name" data-i18n="pn.t.coop">Меморандум за соработка</div>
        <div class="pn-type-desc" data-i18n="pn.t.coop.d">Долгорочен MoU</div>
      </div>
      <div class="pn-type" data-type="youth-exchange" tabindex="0" role="button" aria-pressed="false">
        <div class="pn-type-icon">🚀</div>
        <div class="pn-type-name" data-i18n="pn.t.youth">Младинска размена</div>
        <div class="pn-type-desc" data-i18n="pn.t.youth.d">Junge Sistem ↔ Twin youth</div>
      </div>
      <div class="pn-type" data-type="joint-statement" tabindex="0" role="button" aria-pressed="false">
        <div class="pn-type-icon">📢</div>
        <div class="pn-type-name" data-i18n="pn.t.joint">Заедничко соопштение</div>
        <div class="pn-type-desc" data-i18n="pn.t.joint.d">Глобален принцип</div>
      </div>
    </div>

    <!-- Form + Directory grid -->
    <div class="pn-grid reveal">
      <!-- LEFT: Form -->
      <div class="pn-card">
        <h3>📝 <span data-i18n="pn.form_h">Иницирање партнерство</span></h3>

        <div id="pnTargetDisplay" class="pn-target-display" style="display:none">
          <div class="pn-target-flag" id="pnTargetFlag">🇲🇰</div>
          <div class="pn-target-info">
            <p class="pn-target-name" id="pnTargetName">—</p>
            <p class="pn-target-country" id="pnTargetCountry">—</p>
            <p class="pn-target-block" id="pnTargetBlock">—</p>
          </div>
        </div>

        <form id="pnForm" class="pn-form" novalidate>
          <input type="hidden" id="pnTargetId" value="">
          <input type="hidden" id="pnType" value="study-visit">

          <div>
            <label for="pnYourName" data-i18n="pn.f.name">Вашето име</label>
            <input type="text" id="pnYourName" required autocomplete="name" placeholder="Име Презиме">
          </div>

          <div>
            <label for="pnYourEmail" data-i18n="pn.f.email">Е-пошта за повратен контакт</label>
            <input type="email" id="pnYourEmail" required autocomplete="email" placeholder="email@domen.mk">
          </div>

          <div>
            <label for="pnYourRole" data-i18n="pn.f.role">Улога во Македонија — Систем</label>
            <select id="pnYourRole">
              <option value="member" data-i18n="pn.f.role.member">Член</option>
              <option value="coordinator" data-i18n="pn.f.role.coord">Координатор</option>
              <option value="institute" data-i18n="pn.f.role.inst">Институт</option>
              <option value="junge" data-i18n="pn.f.role.junge">Junge Sistem</option>
              <option value="executive" data-i18n="pn.f.role.exec">Извршен одбор</option>
            </select>
          </div>

          <div>
            <label for="pnTimeline" data-i18n="pn.f.timeline">Временски рок</label>
            <select id="pnTimeline">
              <option value="urgent" data-i18n="pn.f.tl.urgent">Итно (до 30 дена)</option>
              <option value="quarter" selected data-i18n="pn.f.tl.q">Квартал (3 месеци)</option>
              <option value="half-year" data-i18n="pn.f.tl.half">Половина година</option>
              <option value="year" data-i18n="pn.f.tl.year">Една година</option>
            </select>
          </div>

          <div>
            <label for="pnTopic" data-i18n="pn.f.topic">Тема / Цел на партнерството</label>
            <textarea id="pnTopic" required placeholder="На пр.: Размена на искуства за дигитализација на државна служба; Заедничко соопштение за европски ЕУ интеграции; Студиска посета на Junge Union…"></textarea>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:6px">
            <button type="submit" class="pn-submit" id="pnSubmitBtn" disabled data-i18n="pn.btn.submit">📨 Генерирај меил →</button>
            <button type="button" class="pn-secondary-btn" id="pnSaveBtn" disabled data-i18n="pn.btn.save">💾 Зачувај локално</button>
          </div>
          <p style="font-size:11px;color:var(--muted);margin:4px 0 0;line-height:1.5" data-i18n="pn.f.privacy">📍 Изберете партија од листата десно за да активирате форма. Сите податоци остануваат во вашиот прелистувач, не на сервер.</p>
        </form>
      </div>

      <!-- RIGHT: Directory -->
      <div class="pn-card">
        <h3>🌍 <span data-i18n="pn.dir_h">Каталог на 61 партија</span></h3>

        <div class="pn-search-wrap">
          <input type="text" id="pnSearch" placeholder="Пребарувај по име, земја…" data-i18n-placeholder="pn.dir.search">
        </div>

        <div class="pn-filter-pills" role="tablist">
          <button class="pn-pill active" data-pn-filter="all" data-i18n="pn.f.all">🌍 Сите</button>
          <button class="pn-pill" data-pn-filter="center" data-i18n="pn.f.center">⚪ Центар</button>
          <button class="pn-pill" data-pn-filter="center-right" data-i18n="pn.f.cr">🔵 Ц-десни</button>
          <button class="pn-pill" data-pn-filter="center-left" data-i18n="pn.f.cl">🔴 Ц-леви</button>
          <button class="pn-pill" data-pn-filter="liberal" data-i18n="pn.f.lib">🟡 Либ.</button>
          <button class="pn-pill" data-pn-filter="green" data-i18n="pn.f.grn">🟢 Зел.</button>
          <button class="pn-pill" data-pn-filter="conservative" data-i18n="pn.f.con">🟣 Конз.</button>
          <button class="pn-pill" data-pn-filter="meritocratic" data-i18n="pn.f.mer">⭐ Мерит.</button>
        </div>

        <div class="pn-list" id="pnList" role="listbox" aria-label="Партии">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>

    <!-- Status Tracker -->
    <div class="pn-status-tracker reveal">
      <h3 style="margin:0 0 6px;font-family:var(--serif);font-size:18px;color:var(--navy)">
        📊 <span data-i18n="pn.tracker_h">Статус на партнерства</span>
      </h3>
      <p style="font-size:13px;color:var(--muted);margin:0" data-i18n="pn.tracker_d">Иницираните партнерства се чуваат локално. Можете да го промените статусот или да ги избришете.</p>
      <div class="pn-tracker-list" id="pnTrackerList">
        <!-- Populated by JS -->
      </div>
    </div>
  </div>
</section>

