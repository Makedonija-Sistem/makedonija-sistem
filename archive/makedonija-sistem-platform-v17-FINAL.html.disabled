                  <option value="10000" selected>€10,000 — €50,000</option>
                  <option value="50000">€50,000 — €100,000</option>
                  <option value="100000">€100,000 — €500,000</option>
                  <option value="500000">€500,000 — €1M</option>
                  <option value="1000000">€1M+</option>
                </select>
              </div>
              <div>
                <label data-i18n="dh.fund.fcountry">Земја</label>
                <input type="text" id="dhFundCountry" placeholder="Germany / USA / Switzerland…">
              </div>
            </div>
            <div>
              <label data-i18n="dh.fund.fpriority">Сектор приоритет</label>
              <select id="dhFundPriority">
                <option value="diversified" data-i18n="dh.fund.s.div">🔄 Диверзифицирано (сите сектори)</option>
                <option value="auto" data-i18n="dh.fund.s.auto">🚗 Vardar H₂ (водороден автомобил)</option>
                <option value="phone" data-i18n="dh.fund.s.phone">📱 MK-Phone</option>
                <option value="vision" data-i18n="dh.fund.s.vision">👓 MK-Vision</option>
                <option value="chips" data-i18n="dh.fund.s.chips">💎 МК Чипови</option>
                <option value="skyworld" data-i18n="dh.fund.s.sky">🚊 SkyWorld</option>
                <option value="agro" data-i18n="dh.fund.s.agro">🌾 Агро</option>
                <option value="energy" data-i18n="dh.fund.s.energy">⚡ Енергија</option>
                <option value="tech" data-i18n="dh.fund.s.tech">💻 IT / Софтвер</option>
              </select>
            </div>
            <div>
              <label data-i18n="dh.fund.femail">Е-пошта</label>
              <input type="email" id="dhFundEmail" placeholder="ime@email.com">
            </div>
            <button type="submit" class="dh-btn" data-i18n="dh.fund.submit">🏦 Регистрирај предупог</button>
          </form>

          <div class="dh-vote-meter" style="margin-top:14px">
