<!-- ═══ MACEDONIA SISTEM · OFFICIAL SIGIL · v2.0 ═══
     5 institutional pillars forming letter "М",
     16-ray sun crown (Macedonian flag tribute, abstracted),
     foundation rule (rule of law),
     concentric rings (institutional containment).
     Designed inline as SVG symbol — used everywhere via <use>. -->
<svg width="0" height="0" style="position:absolute;pointer-events:none" aria-hidden="true">
  <defs>
    <!-- ── Primary sigil (gold on navy circle) ── -->
    <symbol id="ms-sigil" viewBox="0 0 200 200">
      <circle cx="100" cy="100" r="96" fill="#0a1d3a"/>
      <circle cx="100" cy="100" r="92" fill="none" stroke="#d4ad4a" stroke-width="1.4" opacity="0.95"/>
      <circle cx="100" cy="100" r="84" fill="none" stroke="#d4ad4a" stroke-width="0.6" opacity="0.5"/>
      <!-- 16 sun rays — short marks on inner ring -->
      <g stroke="#d4ad4a" stroke-width="1.2" opacity="0.85" stroke-linecap="round">
        <line x1="100" y1="14" x2="100" y2="22"/>
        <line x1="100" y1="178" x2="100" y2="186"/>
        <line x1="14" y1="100" x2="22" y2="100"/>
        <line x1="178" y1="100" x2="186" y2="100"/>
        <line x1="40.8" y1="40.8" x2="46.4" y2="46.4"/>
        <line x1="153.6" y1="153.6" x2="159.2" y2="159.2"/>
        <line x1="40.8" y1="159.2" x2="46.4" y2="153.6"/>
        <line x1="153.6" y1="46.4" x2="159.2" y2="40.8"/>
        <line x1="68.4" y1="20.4" x2="71.6" y2="27.6"/>
        <line x1="131.6" y1="20.4" x2="128.4" y2="27.6"/>
        <line x1="20.4" y1="68.4" x2="27.6" y2="71.6"/>
        <line x1="20.4" y1="131.6" x2="27.6" y2="128.4"/>
        <line x1="172.4" y1="68.4" x2="179.6" y2="71.6"/>
        <line x1="172.4" y1="131.6" x2="179.6" y2="128.4"/>
        <line x1="68.4" y1="179.6" x2="71.6" y2="172.4"/>
        <line x1="131.6" y1="179.6" x2="128.4" y2="172.4"/>
      </g>
      <!-- 5 institutional pillars forming "M" silhouette -->
      <g fill="#d4ad4a">
        <rect x="60" y="68" width="8" height="64" rx="1"/>
        <rect x="76" y="68" width="8" height="44" rx="1"/>
        <rect x="92" y="68" width="8" height="32" rx="1"/>
        <rect x="108" y="68" width="8" height="44" rx="1"/>
        <rect x="124" y="68" width="8" height="64" rx="1"/>
      </g>
      <!-- Crown bar above pillars -->
      <rect x="56" y="62" width="80" height="3" fill="#d4ad4a"/>
      <!-- Foundation bar (rule of law) -->
      <rect x="56" y="135" width="80" height="3" fill="#d4ad4a"/>
      <!-- SISTEM lettering -->
      <text x="100" y="156" text-anchor="middle" fill="#d4ad4a" font-family="Georgia,'PT Serif','Playfair Display',serif" font-size="11" font-weight="600" letter-spacing="3.5">СИСТЕМ</text>
    </symbol>

    <!-- ── Compact sigil for member card (no outer ring) ── -->
    <symbol id="ms-sigil-card" viewBox="0 0 200 200">
      <rect width="200" height="200" rx="22" fill="url(#ms-card-bg)"/>
      <circle cx="100" cy="100" r="78" fill="none" stroke="#d4ad4a" stroke-width="1.2" opacity="0.7"/>
      <g stroke="#d4ad4a" stroke-width="1.2" opacity="0.85" stroke-linecap="round">
        <line x1="100" y1="22" x2="100" y2="30"/>
        <line x1="100" y1="170" x2="100" y2="178"/>
        <line x1="22" y1="100" x2="30" y2="100"/>
        <line x1="170" y1="100" x2="178" y2="100"/>
        <line x1="46" y1="46" x2="51.6" y2="51.6"/>
        <line x1="148.4" y1="148.4" x2="154" y2="154"/>
        <line x1="46" y1="154" x2="51.6" y2="148.4"/>
        <line x1="148.4" y1="51.6" x2="154" y2="46"/>
      </g>
      <g fill="#d4ad4a">
        <rect x="60" y="68" width="8" height="64" rx="1"/>
        <rect x="76" y="68" width="8" height="44" rx="1"/>
        <rect x="92" y="68" width="8" height="32" rx="1"/>
        <rect x="108" y="68" width="8" height="44" rx="1"/>
        <rect x="124" y="68" width="8" height="64" rx="1"/>
      </g>
      <rect x="56" y="62" width="80" height="3" fill="#d4ad4a"/>
      <rect x="56" y="135" width="80" height="3" fill="#d4ad4a"/>
      <text x="100" y="156" text-anchor="middle" fill="#d4ad4a" font-family="Georgia,serif" font-size="11" font-weight="600" letter-spacing="3.5">СИСТЕМ</text>
    </symbol>

    <linearGradient id="ms-card-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a1d3a"/>
      <stop offset="100%" stop-color="#1e3a66"/>
    </linearGradient>

    <!-- ── Pillar-only mark (icon size) ── -->
    <symbol id="ms-mark" viewBox="0 0 200 200">
      <g fill="currentColor">
        <rect x="60" y="68" width="8" height="64" rx="1"/>
        <rect x="76" y="68" width="8" height="44" rx="1"/>
        <rect x="92" y="68" width="8" height="32" rx="1"/>
        <rect x="108" y="68" width="8" height="44" rx="1"/>
        <rect x="124" y="68" width="8" height="64" rx="1"/>
      </g>
      <rect x="56" y="62" width="80" height="3" fill="currentColor"/>
      <rect x="56" y="135" width="80" height="3" fill="currentColor"/>
    </symbol>
  </defs>
</svg>
