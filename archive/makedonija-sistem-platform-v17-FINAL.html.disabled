    'Контакти': {en:'Contacts', al:'Kontaktet', sr:'Контакти', de:'Kontakte'},
    'Социјални мрежи': {en:'Social networks', al:'Rrjetet sociale', sr:'Друштвене мреже', de:'Soziale Netzwerke'},
  };

  // For each ORIGINAL Macedonian text we need to remember the original
  // so we can translate back. We tag elements on first run with their MK text.
  function snapshotOriginals(root){
    root = root || document.body;
    if (!root) return;
    const all = root.querySelectorAll(
      'h1, h2, h3, h4, h5, h6, p, span, button, a, label, li, strong, em, b, i, td, th, summary, figcaption, cite, small'
    );
    all.forEach(el => {
      // skip elements with data-i18n (already handled)
      if (el.hasAttribute('data-i18n')) return;
      // skip elements with children (we only handle leaf text)
      if (el.children.length > 0) return;
      // skip elements inside .lang-switcher (the buttons themselves)
      if (el.closest && el.closest('.lang-switcher')) return;
      const text = (el.textContent || '').trim();
      if (!text || text.length > 80) return;
      if (COMMON_PHRASES[text] && !el.hasAttribute('data-mk-orig')){
        el.setAttribute('data-mk-orig', text);
      }
    });
  }
  function applyCommonPhrases(lang){
    if (lang === 'mk'){
      // restore originals
      document.querySelectorAll('[data-mk-orig]').forEach(el => {
        el.textContent = el.getAttribute('data-mk-orig');
      });
      return;
    }
    document.querySelectorAll('[data-mk-orig]').forEach(el => {
      const orig = el.getAttribute('data-mk-orig');
      const tx = COMMON_PHRASES[orig];
      if (tx && tx[lang]){
        el.textContent = tx[lang];
      }
    });
  }
  // First snapshot, then apply current language
  snapshotOriginals();
  applyCommonPhrases(currentLang);

  // Re-apply on language change
  window.addEventListener('langchange', (e) => {
    applyCommonPhrases(e.detail.lang);
  });

  // Watch for dynamically added content
  if (typeof MutationObserver !== 'undefined'){
    const mo = new MutationObserver((muts) => {
      muts.forEach(m => {
        m.addedNodes.forEach(n => {
          if (n.nodeType === 1){
            snapshotOriginals(n);
            applyCommonPhrases(currentLang);
          }
        });
      });
    });
    try { mo.observe(document.body, {childList:true, subtree:true}); } catch(e){}
  }


  /* ── Scroll progress ── */
  const progress = document.getElementById('scrollProgress');
  const header = document.getElementById('siteHeader');
  function onScroll(){
    const h = document.documentElement;
    const scrolled = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
    if (progress) progress.style.width = scrolled + '%';
    if (header) header.classList.toggle('scrolled', h.scrollTop > 8);
  }
  window.addEventListener('scroll', onScroll, {passive:true});
  onScroll();

  /* ── Mobile menu (v17 — robust, accessible) ── */
  const menuToggle = document.getElementById('menuToggle');
  const navLinks = document.getElementById('navLinks');

  // Inject backdrop element if missing
  let menuBackdrop = document.getElementById('menuBackdrop');
  if (!menuBackdrop && navLinks){
    menuBackdrop = document.createElement('div');
    menuBackdrop.id = 'menuBackdrop';
    menuBackdrop.className = 'menu-backdrop';
    menuBackdrop.setAttribute('aria-hidden', 'true');
    document.body.appendChild(menuBackdrop);
  }

  function setMenuOpen(open){
    if (!navLinks || !menuToggle) return;
    navLinks.classList.toggle('open', open);
    if (menuBackdrop) menuBackdrop.classList.toggle('show', open);
    document.body.classList.toggle('menu-open', open);
    menuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    menuToggle.setAttribute('aria-label', open
      ? (typeof t === 'function' ? t('a11y.menu_close') : 'Close menu')
      : (typeof t === 'function' ? t('a11y.menu_open') : 'Open menu'));
    if (open){
      // focus first link for keyboard users
      const firstLink = navLinks.querySelector('a');
      if (firstLink) setTimeout(() => firstLink.focus(), 100);
    } else {
      menuToggle.focus();
    }
  }

  if (menuToggle && navLinks){
    menuToggle.addEventListener('click', () => {
      setMenuOpen(!navLinks.classList.contains('open'));
    });
    if (menuBackdrop){
      menuBackdrop.addEventListener('click', () => setMenuOpen(false));
    }
    // Close on link click (so the page scrolls)
    navLinks.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        if (window.matchMedia('(max-width: 980px)').matches){
          setMenuOpen(false);
        }
      });
    });
    // ESC closes menu
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && navLinks.classList.contains('open')){
        setMenuOpen(false);
      }
    });
    // Close menu when resizing up to desktop
    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        if (window.innerWidth > 980 && navLinks.classList.contains('open')){
          setMenuOpen(false);
        }
      }, 150);
    });
  }
  // Keep legacy variable references if any other code uses them
  if (menuToggle && navLinks){
    menuToggle.addEventListener('click', () => {
      const open = navLinks.classList.toggle('open');
      menuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    navLinks.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        navLinks.classList.remove('open');
        menuToggle.setAttribute('aria-expanded', 'false');
      });
    });
  }

  /* ── Active nav link on scroll ── */
  const sections = Array.from(document.querySelectorAll('main section[id]'));
  const navAs = Array.from(document.querySelectorAll('.links a'));
  function setActive(){
    let current = '';
    const y = window.scrollY + 120;
    sections.forEach(s => {
      if (y >= s.offsetTop && y < s.offsetTop + s.offsetHeight) current = s.id;
    });
    navAs.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + current));
  }
  window.addEventListener('scroll', setActive, {passive:true});

  /* ── Reveal on scroll ── */
  if ('IntersectionObserver' in window){
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting){
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, {threshold: 0.12, rootMargin: '0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
  }

  /* ── Membership: 3-tier enrollment system ── */
  const $ = id => document.getElementById(id);
  const cName = $('cardName'), cAddress = $('cardAddress'),
        cMunicipality = $('cardMunicipality'), cStatus = $('cardStatus'),
        cTier = $('cardTier'), cId = $('cardId'), qr = $('cardQR');

  function makeId(name){
    const seed = (name || '').split('').reduce((a,c) => a + c.charCodeAt(0), 0);
    return 'MS-' + String(Math.abs(seed) + 100001).slice(0, 6);
  }

  // Map tab → tier label
  const TIER_LABELS = {
    'form-supporter': { rank: 'Ниво 1', status: 'Поддржувач' },
    'form-member': { rank: 'Ниво 2 · КЕП', status: 'Член (КЕП)' },
    'form-notarized': { rank: 'Ниво 3 · Заверен', status: 'Заверен член' }
  };

  let activeFormId = 'form-supporter';

  function updateCardFrom(formEl){
    if (!formEl) return;
    const data = new FormData(formEl);
    const name = (data.get('name') || '').trim();
    const id = name ? makeId(name) : 'MS-100001';
    const tier = TIER_LABELS[formEl.id] || TIER_LABELS['form-supporter'];

    if (cName) cName.textContent = name || 'Име Презиме';
    if (cAddress) cAddress.textContent = (data.get('address') || '').trim() || 'Адреса';
    if (cMunicipality) cMunicipality.textContent = (data.get('municipality') || '').trim() || 'Општина';
    if (cStatus) cStatus.textContent = tier.status;
    if (cTier) cTier.textContent = tier.rank;
    if (cId) cId.textContent = id;
    if (qr && qr.tagName === 'IMG'){
      const qrData = encodeURIComponent('Makedonija-Sistem|' + id + '|' + (name || 'Member') + '|' + tier.status);
      qr.src = 'https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=' + qrData;
    }
  }

  function switchTab(formId){
    activeFormId = formId;
    document.querySelectorAll('.enroll-tab').forEach(t => {
      const isActive = t.dataset.form === formId;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    document.querySelectorAll('.enroll-form').forEach(f => {
      f.classList.toggle('active', f.id === formId);
    });
    const form = document.getElementById(formId);
    if (form) updateCardFrom(form);
  }

  // Tab buttons
  document.querySelectorAll('.enroll-tab').forEach(btn => {
    btn.addEventListener('click', () => switchTab(btn.dataset.form));
  });

  // Tier card jump-to-form buttons
  document.querySelectorAll('[data-go]').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.go;
      switchTab(target);
      // Smooth scroll to form
      const formBox = document.querySelector('.enroll-form-box');
      if (formBox){
        formBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Live update card preview as user types in active form
  document.querySelectorAll('.enroll-form input, .enroll-form select, .enroll-form textarea').forEach(el => {
    const formEl = el.closest('.enroll-form');
    el.addEventListener('input', () => {
      if (formEl && formEl.id === activeFormId) updateCardFrom(formEl);
    });
    if (el.tagName === 'SELECT'){
      el.addEventListener('change', () => {
        if (formEl && formEl.id === activeFormId) updateCardFrom(formEl);
      });
    }
  });

  /* ═══════════════════════════════════════════════════════════
     XSS PROTECTION — Input sanitization
     ═══════════════════════════════════════════════════════════ */
  function sanitizeInput(str){
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
  function stripTags(str){
    return str.replace(/<[^>]*>/g, '');
  }

  /* ── Member photo upload (35x45mm passport style) ── */
  const memberPhotoInput = document.getElementById('memberPhotoInput');
  const memberPhotoWrap = document.getElementById('memberPhotoWrap');
  const memberPhotoImg = document.getElementById('memberPhotoImg');
  const memberPhotoPlaceholder = document.getElementById('memberPhotoPlaceholder');

  if (memberPhotoInput){
    memberPhotoInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      // Validate file type
      const allowedTypes = ['image/jpeg', 'image/png', 'image/jpg'];
      if (!allowedTypes.includes(file.type)){
        alert('Само JPG и PNG фотографии се дозволени.');
        return;
      }
      // Validate file size (max 5MB)
      if (file.size > 5 * 1024 * 1024){
        alert('Фотографијата е преголема. Максимум 5MB.');
        return;
      }
      // Validate image dimensions (aspect ratio ~1:1.29 for 35x45mm)
      const reader = new FileReader();
      reader.onload = (event) => {
        const img = new Image();
        img.onload = () => {
          const ratio = img.height / img.width;
          if (ratio < 1.1 || ratio > 1.5){
            alert('Несоодветен формат. Препорачано: пасош фотографија 35×45mm (околу 1:1.29 сооднос).');
            return;
          }
          // Save to localStorage for persistence
          try {
            localStorage.setItem('memberPhotoData', event.target.result);
          } catch(err){
            console.warn('Photo too large for localStorage');
          }
          // Show photo
          memberPhotoImg.src = event.target.result;
          memberPhotoImg.style.display = 'block';
          if (memberPhotoPlaceholder) memberPhotoPlaceholder.style.display = 'none';
          memberPhotoWrap.classList.add('has-photo');
        };
        img.src = event.target.result;
      };
      reader.readAsDataURL(file);
    });

    // Load saved photo on page load
    const savedPhoto = localStorage.getItem('memberPhotoData');
    if (savedPhoto){
      memberPhotoImg.src = savedPhoto;
      memberPhotoImg.style.display = 'block';
      if (memberPhotoPlaceholder) memberPhotoPlaceholder.style.display = 'none';
      memberPhotoWrap.classList.add('has-photo');
    }
  }

  // Form submission handlers
  function handleEnrollSubmit(formEl, tierLabel, emailSubject, extraBody){
    formEl.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(formEl);
      const name = stripTags((data.get('name') || '').trim());
      const email = stripTags((data.get('email') || '').trim());

      if (!name || !email){
        alert('Името и е-поштата се задолжителни.');
        return;
      }
      if (!/^.+@.+\..+$/.test(email)){
        alert('Внеси валиден формат на е-пошта.');
        return;
      }
      // Check ALL required checkboxes in this form
      const requiredCBs = formEl.querySelectorAll('input[type=checkbox][required]');
      for (const cb of requiredCBs){
        if (!cb.checked){
          alert('Мора да ги прифатиш сите задолжителни согласности (означени со ★).');
          return;
        }
      }
      // Validate ЕМБГ if present
      const embg = data.get('embg');
      if (embg && !/^\d{13}$/.test(embg.trim())){
        alert('ЕМБГ мора да биде точно 13 цифри.');
        return;
      }
      // XSS sanitize all text inputs
      formEl.querySelectorAll('input[type="text"], textarea').forEach(input => {
        if (input.value) input.value = stripTags(input.value);
      });

      const id = makeId(name);
      const tier = TIER_LABELS[formEl.id];

      // Build email body
      let body = '═══════════════════════════════════════════\n';
      body += 'ДИГИТАЛНО ЗАЧЛЕНУВАЊЕ ВО МАКЕДОНИЈА — СИСТЕМ\n';
      body += '═══════════════════════════════════════════\n\n';
      body += 'Поднесено: ' + new Date().toLocaleString('mk-MK') + '\n';
      body += 'Членски ID (нацрт): ' + id + '\n';
      body += 'Ниво: ' + tier.rank + '\n\n';

      body += '── ПОДНОСИТЕЛ ──\n';
      body += 'Име и презиме: ' + name + '\n';
      body += 'Е-пошта: ' + email + '\n';
      if (data.get('embg')) body += 'ЕМБГ: ' + data.get('embg') + '\n';
      if (data.get('phone')) body += 'Телефон: ' + data.get('phone') + '\n';
      if (data.get('address')) body += 'Адреса: ' + data.get('address') + '\n';
      if (data.get('municipality')) body += 'Општина: ' + data.get('municipality') + '\n';
      body += '\n';

      body += extraBody(data) || '';

      body += '── СОГЛАСНОСТИ ──\n';
      body += 'Подносителот дал согласност за обработка на лични податоци\n';
      body += 'согласно со Закон за заштита на лични податоци (РСМ 42/2020).\n\n';

      body += '— Испратено преку платформата makedonijasistem.mk\n';
      body += 'Ред · Закон · Одговорност';

      const subject = encodeURIComponent(emailSubject + ' — ' + name + ' (' + id + ')');
      const bodyEnc = encodeURIComponent(body);

      window.location.href = 'mailto:makedonijasistem@gmail.com?subject=' + subject + '&body=' + bodyEnc;

      const successDiv = formEl.querySelector('[data-success]');
      if (successDiv){
        successDiv.classList.add('show');
        setTimeout(() => successDiv.classList.remove('show'), 8000);
      }
    });
  }

  // Wire up the 3 forms
  const supporterForm = document.getElementById('form-supporter');
  if (supporterForm){
    handleEnrollSubmit(supporterForm, 'Поддржувач', '[ПОДДРЖУВАЧ]', (data) => {
      let extra = '── ВИД НА ЗАЧЛЕНУВАЊЕ ──\n';
      extra += 'Ниво 1 — Поддржувач (без правна обврзаност)\n\n';
      if (data.get('message')){
        extra += '── ПОРАКА ──\n' + data.get('message') + '\n\n';
      }
      return extra;
    });
  }

  const memberForm = document.getElementById('form-member');
  if (memberForm){
    handleEnrollSubmit(memberForm, 'Поддржувач', '[ЧЛЕН-КЕП]', (data) => {
      let extra = '── ВИД НА ЗАЧЛЕНУВАЊЕ ──\n';
      extra += 'Ниво 2 — Член со квалификуван електронски потпис\n';
      extra += 'Правна основа: ЗЕДЕИДУ („Сл. весник на РСМ" бр. 101/2019)\n\n';
      extra += '── ПОДАТОЦИ ЗА КЕП ──\n';
      extra += 'Давател на КЕП: ' + (data.get('kep_provider') || '') + '\n';
      if (data.get('cert_serial')){
        extra += 'Сериски број на сертификат: ' + data.get('cert_serial') + '\n';
      }
      extra += '\n── СЛЕДНИ ЧЕКОРИ ──\n';
      extra += '1. Програмскиот совет ќе подготви PDF документ за пристапна изјава\n';
      extra += '2. PDF ќе биде испратен на е-поштата за потпишување со КЕП\n';
      extra += '3. Подносителот го враќа потпишаниот PDF\n';
      extra += '4. Верификација во рок од 3 работни дена\n\n';
      return extra;
    });
  }

  const notarizedForm = document.getElementById('form-notarized');
  if (notarizedForm){
    handleEnrollSubmit(notarizedForm, 'Поддржувач', '[ЗАВЕРЕН-ЧЛЕН]', (data) => {
      let extra = '── ВИД НА ЗАЧЛЕНУВАЊЕ ──\n';
      extra += 'Ниво 3 — Заверен член (полна правна обврзаност)\n';
      extra += 'Тип на заверка: ' + (data.get('notary_type') || '') + '\n';
      extra += 'Правна основа: Закон за нотаријатот / Закон за адвокатура\n\n';
      extra += '── ПОДАТОЦИ ЗА ЗАВЕРКА ──\n';
      extra += 'Нотар / адвокат / служба: ' + (data.get('notary_name') || '') + '\n';
      if (data.get('act_number')){
        extra += 'Број на акт: ' + data.get('act_number') + '\n';
      }
      if (data.get('notary_date')){
        extra += 'Датум на заверка: ' + data.get('notary_date') + '\n';
      }
      extra += '\n── СЛЕДНИ ЧЕКОРИ ──\n';
      extra += '1. Подготовка на изјава за членство во PDF (преписки А/Б)\n';
      extra += '2. Подносителот посетува нотар/адвокат/конзуларна служба\n';
      extra += '3. Извршување на солемизација или заверка\n';
      extra += '4. Достава на заверен документ (скениран PDF + оригинал по препорачана пошта)\n';
      extra += '5. Верификација од Етичка комисија во рок од 5 работни дена\n\n';
      return extra;
    });
  }

  // Initial card update
  if (supporterForm) updateCardFrom(supporterForm);

  /* ════════════════════════════════════════
     POLL TOOL — single source of truth
     ════════════════════════════════════════ */
  const POLL_KEY = 'ms_poll_v2';
  const PARTIES = [
    'Македонија — Систем','ВМРО-ДПМНЕ','СДСМ','ДУИ','ВЛЕН','Левица','ЗНАМ',
    'Алијанса за Албанците','ДПА','ГРОМ','ЛДП','ДОМ','Демократски сојуз',
    'Интегра','ТМРО','Друга партија / независна листа','Неодлучни','Нема да гласаат'
  ];

  const poll = (function loadPoll(){
    try {
      const saved = localStorage.getItem(POLL_KEY);
      if (saved){
        const obj = JSON.parse(saved);
        const fresh = {};
        PARTIES.forEach(p => fresh[p] = Number(obj[p] || 0));
        return fresh;
      }
    } catch(e){}
    const fresh = {};
    PARTIES.forEach(p => fresh[p] = 0);
    return fresh;
  })();

  function savePoll(){
    try { localStorage.setItem(POLL_KEY, JSON.stringify(poll)); } catch(e){}
  }

  let model = 'dhondt';
  const results = $('pollResults');
  const seatsBox = $('seatResults');

  function eligibleEntries(){
    const total = Object.values(poll).reduce((a,b) => a + Number(b||0), 0) || 1;
    const threshold = Number($('thresholdPct')?.value || 0);
    return Object.entries(poll).filter(([name, v]) => {
      if (name === 'Неодлучни' || name === 'Нема да гласаат') return false;
      return (Number(v||0)/total*100) >= threshold && Number(v||0) > 0;
    });
  }

  function allocateDhondt(entries, seats, sainte){
    const out = Object.fromEntries(entries.map(([n]) => [n, 0]));
    const quot = [];
    entries.forEach(([n,v]) => {
      for (let i = 0; i < seats; i++){
        const div = sainte ? (2*i + 1) : (i + 1);
        quot.push([n, Number(v)/div]);
      }
    });
    quot.sort((a,b) => b[1] - a[1]);
    quot.slice(0, seats).forEach(([n]) => out[n]++);
    return out;
  }

  function allocateLargest(entries, seats){
    const total = entries.reduce((a, [,v]) => a + Number(v), 0) || 1;
    const out = {}; const rem = [];
    entries.forEach(([n,v]) => {
      const exact = Number(v)/total * seats;
      out[n] = Math.floor(exact);
      rem.push([n, exact - out[n]]);
    });
    let used = Object.values(out).reduce((a,b) => a+b, 0);
    rem.sort((a,b) => b[1] - a[1]);
    let i = 0;
    while (used < seats && rem.length > 0){
      out[rem[i % rem.length][0]]++;
      used++;
      i++;
    }
    return out;
  }

  function renderPoll(){
    if (!results) return;
    const total = Object.values(poll).reduce((a,b) => a + Number(b||0), 0) || 1;
    const sorted = Object.entries(poll).sort((a,b) => Number(b[1]) - Number(a[1]));
    const maxV = Math.max(...sorted.map(([,v]) => Number(v||0)), 1);
    results.innerHTML = sorted.map(([name,v]) => {
      const pct = Math.round((Number(v||0)/total)*1000)/10;
      const isLead = Number(v||0) > 0 && Number(v||0) === maxV;
      return '<div class="poll-row' + (isLead ? ' lead' : '') + '"><strong>' + name + '</strong>' +
             '<div class="bar"><i style="width:' + Math.min(pct,100) + '%"></i></div>' +
             '<span>' + pct + '%</span></div>';
    }).join('');
    renderSeats();
  }

  function renderSeats(){
    if (!seatsBox) return;
    const seats = Math.max(1, Number($('totalSeats')?.value || 120));
    const entries = eligibleEntries();
    let alloc = {};
    if (entries.length){
      if (model === 'dhondt') alloc = allocateDhondt(entries, seats, false);
      else if (model === 'sainte') alloc = allocateDhondt(entries, seats, true);
      else alloc = allocateLargest(entries, seats);
    }
    const sorted = Object.entries(alloc).sort((a,b) => b[1] - a[1]);
    if (!sorted.length){
      seatsBox.innerHTML = '<p class="form-note">Внеси податоци за партии за да се пресмета распределба на мандати.</p>';
      return;
    }
    seatsBox.innerHTML = sorted.map(([n,s]) =>
      '<div class="seat-row"><strong>' + n + '</strong>' +
      '<div class="bar"><i style="width:' + (s/seats*100) + '%"></i></div>' +
      '<span>' + s + '</span></div>'
    ).join('');
  }

  document.querySelectorAll('.model-tabs button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.model-tabs button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      model = btn.dataset.model;
      renderSeats();
    });
  });

  const addBtn = $('addPoll');
  if (addBtn){
    addBtn.addEventListener('click', () => {
      const party = $('pollParty').value;
      const votes = Math.max(0, Number($('pollVotes').value || 0));
      poll[party] = votes;
      savePoll();
      renderPoll();
    });
  }

  const resetBtn = $('resetPoll');
  if (resetBtn){
    resetBtn.addEventListener('click', () => {
      if (!confirm('Сигурно ресетирај ги сите анкетни податоци?')) return;
      Object.keys(poll).forEach(k => poll[k] = 0);
      savePoll();
      renderPoll();
    });
  }

  ['totalSeats','thresholdPct'].forEach(id => {
    const el = $(id);
    if (el) el.addEventListener('input', renderSeats);
  });

  renderPoll();

  /* ════════════════════════════════════════
     BOT AGENT — local heuristic responder
     ════════════════════════════════════════ */
  const botFloat = $('botFloat');
  const botHead = $('botHead');
  const botToggle = $('botToggle');
  const botBody = $('botBody');
  const botInput = $('botInput');
  const botSend = $('botSend');

  function setBotOpen(open){
    if (!botFloat) return;
    botFloat.classList.toggle('open', open);
    if (botToggle) botToggle.textContent = open ? 'Затвори' : 'Отвори';
  }

  if (botHead && botToggle){
    botToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      setBotOpen(!botFloat.classList.contains('open'));
    });
    botHead.addEventListener('click', (e) => {
      if (e.target === botToggle) return;
      setBotOpen(!botFloat.classList.contains('open'));
    });
  }

  // ════════════════════════════════════════════════════════
  //   BOT-AGENT KNOWLEDGE BASE — full coverage of platform
  // ════════════════════════════════════════════════════════
  const link = (href, text) => `<a href="${href}" style="color:var(--gold-soft);text-decoration:underline;font-weight:700">${text} →</a>`;

  const KB = {
    intro: `<b>МАКЕДОНИЈА — СИСТЕМ</b> е граѓанско-државничка платформа за функционална држава со ред, закон и одговорност. Не партија како другите — туку <em>систем</em> заснован на меритократија, институционализам и достоинство. Доктрина: <em>„Не реваншизам — систем. Не партиска книшка — компетентност. Не хаос — ред, закон и одговорност."</em><br><br>${link('#manifest', 'Прочитај го манифестот')}`,

    pulse: `На <b>почетниот пулс-табла</b> се следат пет клучни индикатори во реално време:<br>• 12,847 поддржувачи<br>• 68 општини активни<br>• 34 земји во дијаспора<br>• 23 активни иницијативи<br>• 74% доверба на членовите<br><br>${link('#dashboard', 'Види го пулс-таблата')}`,

    principi: `Имаме <b>10 темелни принципи</b>:<br>1. Правда со интегритет<br>2. Здравство што навистина лекува<br>3. Образование од корен<br>4. Економија на AI, идеи и алатки<br>5. Администрација што служи<br>6. Безбедност со координација<br>7. Дипломатија од кариера<br>8. Млади со иднина дома<br>9. Дијаспора како национална сила<br>10. Локална власт што решава<br><br>${link('#principles', 'Види ги сите 10 принципи')}`,

    program: `<b>Програмата за 100 дена</b> има 4 фази:<br>• <b>Ден 1–15:</b> Институционална мапа — јавен преглед на состојбата без партиска боја<br>• <b>Ден 15–30:</b> Кодекс за интегритет — правила за јавни функции<br>• <b>Ден 30–60:</b> Први пилоти со алатки со вештачка интелигенција и Македонија Пулс<br>• <b>Ден 60–100:</b> Пакет закони и мерки со мерливи KPI<br><br>${link('#programme', 'Види ја програмата')}`,

    statut: `<b>Статутот</b> има <b>9 главни членови:</b><br>1. Име, седиште и симбол на организацијата<br>2. Карактер и вредности<br>3. Членство<br>4. Слобода на влез и излез<br>5. Членарина (не се наплаќа)<br>6. Претседател — макс. 2 мандата по 5 години<br>7. Забрани (без говор на омраза, реваншизам)<br>8. Органи (Собрание, Извршен одбор, Етичка комисија...)<br>9. Транспарентност (јавни финансии и одлуки)<br><br>${link('#statute', 'Прочитај го целиот статут')}`,

    simbol: `<b>Сигилот</b> на Македонија — Систем е официјален симбол со 5 институционални столбови што формираат буква „М". Цветови: navy #0a1d3a (авторитет) + злато #d4ad4a (достоинство). Симболи во дизајнот: 5 темели (правда, извршна, законодавна, локална самоуправа, граѓанско општество), 16 сончеви зраци (отвореност), линии горе/долу (ред + закон). Симболот е заштитен со авторски права согласно Член 1 од Статутот.<br><br>${link('#statute', 'Види го Член 1 за симболот')}`,

    economy: `<b>Економија:</b> Домашен капитал прво. Вештачка интелигенција Македонија (идеи → HTML алатки → клиенти → приход). Фер странски инвестиции — добредојдени ако носат знаење, плати, локални добавувачи и долгорочна вредност.<br><br>${link('#economy', 'Види ја економската стратегија')}`,

    agro: `<b>Земјоделство и храна:</b> Субвенции за реален принос (не за празни ниви). Државна земја за активни производители. Договорно производство, гарантиран пласман и поддршка за семејни фарми.<br><br>${link('#agro', 'Види ја стратегијата')}`,

    energy: `<b>Енергија и инфраструктура:</b> Хидро-каскада по Вардар (таму каде што е оправдано). Сончеви концентратори за топла вода и оранжерии. Термални акумулатори за училишта, болници и индустрија.<br><br>${link('#energy', 'Види ја енергетската стратегија')}`,

    society: `<b>Општествен ред:</b> Финансиска правда (банки и извршители како сервис, не товар). Регулација на кладилници и казина (200м од училишта). Здрава Македонија (намалување пушење, борба против дрога). Отпад како суровина (рециклирање како индустрија).<br><br>${link('#society', 'Види ги политиките')}`,

    pulse2: `<b>Македонија Пулс — AI Опсерваторија:</b> Етички систем со вештачка интелигенција за јавни анкети, медиумски трендови, локални проблеми и приоритети. Цел: политики базирани на податоци, не на наратив. Месечен извештај „Пулс на Македонија".<br><br>${link('#pulse', 'Види ја опсерваторијата')}`,

    bestpractices: `<b>Светски модели</b> — 12 земји со најдобри практики применливи за Македонија:<br>🇪🇪 Естонија (Х-Роуд · дигитална држава)<br>🇸🇬 Сингапур (анти-корупција)<br>🇫🇮 Финска (учители како елита)<br>🇳🇿 Нов Зеланд (Буџет за благосостојба)<br>🇩🇰 Данска (е-картон)<br>🇨🇭 Швајцарија (граѓански референдуми)<br>🇰🇷 Јужна Кореја (К-стартап)<br>🇮🇪 Ирска (Глобална ирска мрежа)<br>🇨🇦 Канада (Multiculturalism)<br>🇩🇪 Германија (дуални школи)<br>🇮🇸 Исланд (јавни даноци)<br>🇸🇪 Шведска (480 дена родителски одмор)<br><br>${link('#bestpractices', 'Види ги сите модели')}`,

    wellbeing: `<b>Македонски индекс на благосостојба</b> — мери 5 области (по новозеландски модел):<br>🏥 Здравство: 58/100<br>🛡️ Безбедност: 71/100<br>🎓 Образование: 49/100<br>🚗 Мобилност: 55/100<br>⚖️ Доверба во институции: 38/100<br><br>Вкупен индекс: <b>54.2/100</b> (−13.8 поени под ЕУ просек)<br><br>${link('#wellbeing', 'Види ги деталите')}`,

    march: `<b>Граѓански марш · Предлози</b> — секој граѓанин може да поднесе свој предлог за програмата. Процес: <br>1. Поднеси предлог (форма со 15 категории)<br>2. Преглед од Програмскиот совет<br>3. Јавно гласање меѓу членовите<br>4. Топ предлозите влегуваат во програмата<br><br>Предлозите се испраќаат на е-пошта и се чуваат локално во „Мои предлози".<br><br>${link('#citizens-march', 'Поднеси свој предлог')}`,

    initiatives: `<b>Иницијативи</b> — 6 активни предлози со јавно гласање:<br>• Дигитална лична карта (2,341 поддршка)<br>• Закон за дијаспорско гласање (4,872 поддршка)<br>• Субвенции за AI стартапи (1,608 поддршка)<br>• Регулација на кладилници (3,455 поддршка)<br>• Хидро-електрана на Вардар (1,924 поддршка)<br>• Прегледи за пензионери (5,127 поддршка)<br><br>👍 Кликни на копчето „поддршка" за да гласаш. Гласаш само еднаш по иницијатива.<br><br>${link('#initiatives', 'Гласај сега')}`,

    voting: `<b>Како функционира гласањето:</b> Кликнеш на копчето „👍 поддршка" под секоја иницијатива. Бројот се зголемува за 1, копчето станува златно со ✓, и се чува локално во браузерот. Заштита: не може двапати по иста иницијатива. Сите гласови се транспарентни и видливи.<br><br>${link('#initiatives', 'Гласај сега')}`,

    municipalities: `<b>🏛️ Целосна Карта на Општини · 80 + 1 Град Скопје</b><br><br>Во карта на општини сега има <b>детална база</b> со:<br>• <b>Население</b> (Попис 2021)<br>• <b>Површина</b> (km²)<br>• <b>Густина на население</b> (жит/km²)<br>• <b>Седиште / центар-град</b><br>• <b>Градоначалник</b><br>• <b>Официјален сајт</b><br>• <b>Координатор</b> за МК-Систем (активен / бара се)<br><br><b>8 региони:</b><br>🏛️ Скопје: 17 општини · 641K жители<br>🏔️ Полог: 9 општини · 320K<br>🌾 Североисток: 6 општини · 173K<br>☀️ Исток: 11 општини · 178K<br>🍇 Вардар: 9 општини · 153K<br>🌶️ Југоисток: 10 општини · 172K<br>🍎 Пелагонија: 9 општини · 222K<br>🏞️ Југозапад: 9 општини · 218K<br><br><b>Можете да:</b><br>• Пребарувате по име, седиште, градоначалник<br>• Филтрирате по регион и статус на координатор<br>• Сортирате по име, население, површина<br>• Кликнете „Детали" за целосни информации<br>• Кликнете „Биди координатор" за конкретна општина<br>• Кликнете на регион на картата → автоматски се филтрира<br><br>${link('#municipalities', 'Истражи ги сите 81 општини')}`,


    diaspora: `<b>Дијаспора</b> — Македонија нема граници, има домаќини. Платформата има посебни координатори во <b>12 земји:</b><br>🇺🇸 САД (~250,000)<br>🇨🇦 Канада (~120,000)<br>🇦🇺 Австралија (~180,000)<br>🇳🇿 Нов Зеланд (~12,000)<br>🇩🇪 Германија (~100,000)<br>🇨🇭 Швајцарија (~70,000)<br>🇮🇹 Италија (~80,000)<br>🇦🇹 Австрија (~25,000)<br>🇸🇪 Шведска (~6,500)<br>🇬🇧 Велика Британија (~12,000)<br>🇳🇱 Холандија (~10,000)<br>и други...<br><br>${link('#diaspora', 'Зачлени се од дијаспора')}`,

    code: `<b>Кодекс на вредности:</b> Компетентност · Интегритет · Јавна одговорност · Транспарентност · Мерливи резултати · Законитост · Достоинство · Меритократија · Институционализам.<br><br>${link('#code', 'Види го кодексот')}`,

    membership: `<b>Тристепено дигитално зачленување:</b><br><br><b>🪪 Ниво 1 · Поддржувач</b> — 2 минути, без правна обврзаност. За симпатизери и поддржувачи. Пристап до иницијативи, гласање и newsletter.<br><br><b>🔐 Ниво 2 · Член (со КЕП)</b> — 10–15 минути, со <b>квалификуван електронски потпис</b> согласно ЗЕДЕИДУ. Право на статутарни одлуки и кандидатура. Прифатени даватели: КИБС-Трст, МК Телеком, А1, ЦАОС, EU eIDAS.<br><br><b>⚖️ Ниво 3 · Заверен член</b> — 30–60 минути, со <b>нотарска солемизација</b> или <b>адвокатска заверка</b>. Полна правна обврзаност. Препорачано за функции во органи и за дијаспора со прекугранични импликации.<br><br>${link('#membership', 'Избери ниво и зачлени се')}`,

    kep: `<b>Квалификуван електронски потпис (КЕП)</b> е дигитален потпис со правна тежина еднаква на своерачен потпис, согласно <b>Законот за електронски документи, електронска идентификација и доверливи услуги (ЗЕДЕИДУ)</b>, „Сл. весник на РСМ" бр. 101/2019.<br><br><b>Прифатени даватели во РСМ:</b><br>• КИБС-Трст (КИБС АД Скопје)<br>• Македонски Телеком — Trust Services<br>• А1 Македонија — Trust Services<br>• ЦАОС (Централно Авторизационо)<br>• EU eIDAS квалификувани сертификати (за дијаспора)<br><br>Цена: ~1,500–3 000 ден. за физичко лице. Важност: 1–3 години.<br><br>${link('#membership', 'Зачлени се со КЕП')}`,

    notary: `<b>Нотарска солемизација</b> е законска постапка каде нотарот ја заверува твојата изјава и потпис согласно <b>Законот за нотаријатот</b>. Полна правна тежина. Цена: ~600–1,200 ден.<br><br><b>Адвокатска заверка</b> е алтернатива согласно <b>Законот за адвокатура</b> — адвокат заверува потпис и идентитет.<br><br><b>За дијаспора:</b> Конзуларна заверка преку најблиска амбасада или конзулат на РСМ.<br><br>Заверката е препорачана за лица кои сакаат функции во органи на „Македонија — Систем".<br><br>${link('#membership', 'Зачлени се со заверка')}`,

    poll: `<b>📊 Жива анкета — отворена за сите!</b><br><br>Секој посетител на платформата може да гласа од било која социјална мрежа или месинџер. Без ограничување — сите гласови се запишуваат и резултатите се прикажуваат во живо со pie chart, демографска анализа (по регион, возраст, пол, време), и реални проценти.<br><br>Карактеристики:<br>• <b>Неограничен примерок</b> (1,000, 10,000, 20,000+)<br>• <b>Кружен дијаграм</b> со живи резултати<br>• <b>Споделување</b> на Facebook, X, WhatsApp, Viber, Telegram, LinkedIn<br>• <b>Демографска анализа</b> по регион, возраст, пол, време<br>• <b>CSV извоз</b> за подлабока анализа<br>• <b>Анонимност</b> (без лични податоци)<br><br>Дополнително — симулатор на распределба на мандати (D'Hondt, Sainte-Laguë, Largest Remainder).<br><br>${link('#poll-tool', 'Гласај сега')}`,

    dik: `<b>🏛️ Изборен контекст · Официјални податоци од ДИК</b><br><br>Македонија — Систем работи во рамка на постоечкиот изборен систем. Официјалните податоци доаѓаат од <b>Државната изборна комисија (sec.mk)</b>:<br><br>📊 <b>Реални бројки (01.02.2026):</b><br>• 1,819,341 вкупно избирачи<br>• 80 општини + Град Скопје<br>• 3,480 избирачки места<br>• 120 парламентарни мандати (6 изборни единици × 20)<br><br>📐 <b>Праг за освојување мандат:</b><br>• Прв мандат: ~91,000 гласови (~5% по изборна единица)<br>• Парламентарна група (10 мандати): 150,000–180,000 гласови<br>• Коалициски партнер (20+): 270,000+ гласови<br><br>🔗 <b>Официјални алатки:</b><br>• <a href="https://www.sec.mk" style="color:var(--gold-soft);font-weight:700">sec.mk</a> — главен портал<br>• <a href="https://izbirackispisok.gov.mk" style="color:var(--gold-soft);font-weight:700">izbirackispisok.gov.mk</a> — Избирачки список<br>• <a href="https://dijaspora.sec.mk" style="color:var(--gold-soft);font-weight:700">dijaspora.sec.mk</a> — Регистрација за дијаспора<br>• <a href="https://eregistar.sec.mk" style="color:var(--gold-soft);font-weight:700">eregistar.sec.mk</a> — Е-регистар на акти<br><br>${link('#election-context', 'Види ги сите ДИК податоци')}`,

    institutions: `<b>🏛️ Институционална рамка · Регулаторни партнери</b><br><br>Платформата работи во согласност со <b>4 клучни институции</b> во РСМ:<br><br>🛡️ <b>АЗЛП</b> — Агенција за заштита на личните податоци (<a href="https://azlp.mk" style="color:var(--gold-soft);font-weight:700">azlp.mk</a>)<br>Нашиот „надзирач" за лични податоци. Согласно ЗЗЛП 42/2020. Контакт: info@privacy.mk · +389 2 3230 635<br><br>⚖️ <b>НКРМ</b> — Нотарска комора (<a href="https://www.nkrm.org.mk" style="color:var(--gold-soft);font-weight:700">nkrm.org.mk</a>)<br>За „Заверен член" Ниво 3 — нотарска солемизација. Согласно со Закон за нотаријатот 72/2016. Цена: 600–1,200 ден.<br><br>🏛️ <b>АКРСМ</b> — Адвокатска комора (<a href="https://www.mba.org.mk" style="color:var(--gold-soft);font-weight:700">mba.org.mk</a>)<br>Алтернатива на нотарска заверка. Согласно со Закон за адвокатура 59/2002.<br><br>📋 <b>ЦРМ</b> — Централен регистар на РСМ (<a href="https://www.crm.com.mk/" style="color:#5fce7e;font-weight:700">crm.com.mk</a>) <span style="color:#5fce7e">🟢 во процес</span><br>Клучна институција за регистрација на политичка партија согласно член 14. <b>Сè уште без потпишан договор</b>.<br><br>🌍 <b>МНР</b> — Министерство за надворешни работи (<a href="https://mfa.gov.mk" style="color:var(--gold-soft);font-weight:700">mfa.gov.mk</a>)<br>За дијаспора — конзуларни услуги, нотарски услуги во конзулати, <a href="https://mfa.gov.mk/mk-MK/kontakt/anketa-dijaspora" style="color:var(--gold-soft);font-weight:700">анкета за дијаспора</a>.<br><br>${link('#institutional-framework', 'Види ги сите институции')}`,

    azlp: `<b>🛡️ АЗЛП · Агенција за заштита на личните податоци</b><br><br>Независно регулаторно тело за заштита на лични податоци во РСМ, согласно <b>Законот за заштита на лични податоци</b> („Сл. весник на РСМ" бр. 42/2020).<br><br><b>Македонија — Систем</b> е „контролор" во правна смисла:<br>• НЕ собира лични податоци на сервер без согласност<br>• Чува податоци локално (localStorage) или со е-пошта<br>• Поднесува известувања до АЗЛП за чувствителна обработка<br>• Назначува офицер за заштита кога има потреба<br><br><b>Право на граѓанинот:</b><br>• Барање за утврдување повреда на права<br>• Известување за нарушување на безбедност<br>• Пристап, корекција, бришење, преносливост<br><br>📞 +389 2 3230 635 · 📧 info@privacy.mk<br><br>${link('https://azlp.mk', 'Посети azlp.mk')} · ${link('https://e-ucilnica.azlp.mk', 'Е-училница')}`,

    mfa_diaspora: `<b>🌍 Дијаспорски услуги преку МНР</b><br><br>Министерството за надворешни работи и надворешна трговија (<a href="https://mfa.gov.mk" style="color:var(--gold-soft);font-weight:700">mfa.gov.mk</a>) спроведува конзуларни услуги за македонските граѓани во дијаспора.<br><br>Корисни линкови за дијаспора:<br>• <a href="https://mfa.gov.mk/mk-MK/konzularni-uslugi/notarski-uslugi" style="color:var(--gold-soft);font-weight:700">Нотарски услуги во конзулати</a> — алтернатива за „Заверен член"<br>• <a href="https://mfa.gov.mk/mk-MK/konzularni-uslugi/maticni-knigi" style="color:var(--gold-soft);font-weight:700">Матични книги</a><br>• <a href="https://mfa.gov.mk/mk-MK/konzularni-uslugi/patni-ispravi" style="color:var(--gold-soft);font-weight:700">Патни исправи</a><br>• <a href="https://mfa.gov.mk/mk-MK/konzularni-uslugi/drzavjanstvo" style="color:var(--gold-soft);font-weight:700">Државјанство</a><br>• <a href="https://mfa.gov.mk/mk-MK/kontakt/anketa-dijaspora" style="color:var(--gold-soft);font-weight:700">📊 Анкета за дијаспора</a> (јавно мислење)<br><br>${link('#institutional-framework', 'Види повеќе во институции')}`,

    uslugi: `<b>💻 Uslugi.gov.mk · Национален портал за е-услуги</b><br><br>Министерството за дигитална трансформација (МДТ) управува со националниот портал за е-Влада, со <b>над 800 онлајн услуги</b>.<br><br>📋 <b>Категории услуги:</b><br>• <b>Лични документи:</b> 13 за лични карти · 10 патни исправи · 10 возачки дозволи<br>• <b>Здравство:</b> 17 превентивни · 17 специјалистички · 18 за лекови · 4 здравствено осигурување<br>• <b>Образование:</b> 26 високо образование · 24 стипендии · 12 обуки · 11 школски<br>• <b>Социјална помош:</b> 24 парична помош · 11 детска заштита · 5 институционална<br>• <b>Имот:</b> 33 изградба · 41 реални акти · 24 земјиште и води<br>• <b>Семејство:</b> 18 матични книги · 5 деца и старателство<br>• <b>Транспорт и животна средина:</b> 37 заштита на средина · 9 превоз<br><br>🔐 <b>Најава</b> со е-ID за пристап до сите услуги.<br><br><b>Македонија — Систем</b> го промовира uslugi.gov.mk како клучен ресурс. Граѓаните треба да го знаат и користат.<br><br>${link('https://uslugi.gov.mk', 'Посети uslugi.gov.mk')} · ${link('#institutional-framework', 'Види во институции')}`,

    donations: `<b>💰 Донации · Поддршка за платформата</b><br><br>Македонија — Систем работи независно. Не примаме државни средства, не примаме помош од странски политички фондации. <b>Граѓанските донации</b> се клучни за развој, хостинг, правна помош и кампањи.<br><br><b>4 платформи за плаќање:</b><br>• <b>Stripe</b> — глобален стандард, PCI-DSS Level 1 безбедност<br>• <b>PayPal</b> — за дијаспора (САД, Канада, Австралија)<br>• <b>Visa</b> — сите домашни и меѓународни картички<br>• <b>Mastercard</b> — вкл. Maestro дебитни<br><br><b>Износи:</b><br>• 500 ден. — Симболична поддршка<br>• 1 000 ден. — Граѓанска донација (препорачано)<br>• 3 000 ден. — Институционална<br>• Друг износ — мин. 100 ден.<br><br><b>Транспарентност:</b><br>• Годишен финансиски извештај<br>• Согласно со Закон за политички партии (76/2004)<br>• Без анонимни преку 1 000 ден.<br>• Без странски средства<br><br>${link('#donations', 'Донирај сега')}`,

    analytics: `<b>📊 Аналитички центар · SWOT анализа</b><br><br>Платформата има <b>севкупна оценка 9.2/10</b> (Q2 2026). Во овој дел се анализираат сите системи на „Македонија — Систем" — јаки, слаби, можности, закани.<br><br><b>SWOT матрица:</b><br>• 💪 <b>Strengths (Јаки):</b> 9 системи — доктринарна јасност, правна рамка, тристепено зачленување, транспарентност, итн.<br>• ⚠️ <b>Weaknesses (Слаби):</b> 6 системи — без заден систем, без CAPTCHA, без реална мапа, итн.<br>• 🚀 <b>Opportunities (Можности):</b> 8 — дијаспорски капитал, незадоволство од традиционални партии, ЕУ интеграција<br>• ⚡ <b>Threats (Закани):</b> 7 — доминација на ВМРО/СДСМ, демографски пад, поларизирани медиуми, хибридни закани<br><br><b>10 системи мониторирани:</b> доктрина (10/10), програма (10/10), зачленување (9.5/10), анкета (8.5/10), бот (9/10), дијаспора (9/10), институции (10/10), партиска инфраструктура (9/10), донации (8/10), мапа (7/10).<br><br><b>8 стратешки препораки</b> со приоритети и временски рамки.<br><br>${link('#analytical-center', 'Прочитај ја SWOT анализата')}`,

    world_parties: `<b>🌍 Глобален партиски атлас</b><br><br>Атласот ги покажува <b>60+ главни политички партии</b> од 6 континенти, групирани по идеолошки блокови:<br><br>• 🔵 <b>Центар-десни</b> (CDU, FdI, Conservative, ВМРО-ДПМНЕ)<br>• 🔴 <b>Центар-леви</b> (SPD, Labour, Democratic Party, СДСМ)<br>• 🟡 <b>Либерали</b> (Renaissance, FDP, Reform Party)<br>• 🟢 <b>Зелени</b> (Bündnis 90/Die Grünen, Greens)<br>• 🟣 <b>Конзервативни</b> (Republican Party, Likud, BJP)<br>• ⭐ <b>Меритократски</b> (Singapore PAP, Македонија — Систем)<br><br><b>Каде стои Македонија — Систем?</b><br>Не лево, не десно. Меритократско-компетенциска позиција. Најблизу: Сингапурска PAP (меритократија), Естонска Reform Party (дигитализација), Германски Volkspartei модели (стабилност). Но <b>никоја не ги поврзува сите три во еден систем</b>.<br><br>Континенти: 27 ЕУ · 11 Америка · 14 Азија-Пасифик · 6 Африка · 4 Океанија · 1 Македонија.<br><br>${link('#world-parties', 'Истражи ги сите партии')}`,

    botagent: `<b>M-S агент</b> е оперативниот AI асистент на платформата. Покрива: стратегија и документи, оперативна поддршка, планови, чек-листи, e-пошта обрасци, организациски совети. Сите одговори се во рамка на демократски, транспарентен и институционален пристап.<br><br>${link('#bot-agent', 'Види ги функциите')}`,

    channels: `<b>Канали:</b> Платформата ги има сите главни социјални мрежи (Facebook, Instagram, X, TikTok, YouTube, LinkedIn, Truth Social, Rumble), гласници (Viber, WhatsApp, Signal, Telegram, SMS, е-пошта), и платформи за состаноци (Google Meet, Zoom, Webex, MS Teams). Кликни и веднаш отвораш канал.<br><br>${link('#channels', 'Види ги сите канали')}`,

    newsletter: `<b>Пулс на неделата</b> — седмичен е-преглед на иницијативи, состојби и доктринарни осврти. Без спам. Без таргетирани реклами. Само сериозен пулс на државата. Претплати се со е-пошта.<br><br>${link('#newsletter', 'Претплати се')}`,

    contact: `<b>Контакт:</b><br>📧 Е-пошта: <a href="mailto:makedonijasistem@gmail.com" style="color:var(--gold-soft);font-weight:700">makedonijasistem@gmail.com</a><br>🌍 Локација: Скопје, Република Македонија<br>📨 M-S агент задачи: <a href="mailto:makedonijasistem@gmail.com?subject=M-S агент%20task" style="color:var(--gold-soft);font-weight:700">испрати задача</a>`,

    theme: `Платформата има <b>светла и темна тема</b>. Кликни на копчето ☀/🌙 во навигацијата (горе десно) за да менуваш. Изборот се чува автоматски.`,

    privacy: `<b>Приватност:</b> Платформата НЕ собира приватни податоци на сервер. Сè работи локално во твојот браузер (localStorage). Кога поднесуваш предлог или апликација, се отвара твоја е-пошта со подготвен текст — ти ја контролираш испраќањето.`,

    structure: `Платформата има <b>19 главни секции:</b><br>1. Пулс (dashboard)<br>2. Манифест<br>3. 10 принципи<br>4. <b>Програма · Генерален Рестарт</b><br>5. Програма 100 дена<br>6. Светски модели<br>7. Македонски индекс на благосостојба<br>8. Граѓански марш (предлози)<br>9. Иницијативи (со гласање)<br>10. Општини (карта)<br>11. Дијаспора (12 земји)<br>12. Систем — Институт<br>13. Junge Sistem (млади)<br>14. Годишен Конгрес<br>15. Officina работилници<br>16. Членство (3 нивоа)<br>17. Жива анкета<br>18. Статут (9 члена)<br>19. Канали и контакт`,

    program_restart: `<b>⚡ ПРОГРАМА · ГЕНЕРАЛЕН РЕСТАРТ</b><br><br>Не реформа — <b>генерален рестарт</b>. Кога Македонија — Систем ќе ја освои власта, нема да ги дели луѓето на партии. <b>Сите компетентни Македонци</b> ќе си го добијат своето место — без оглед на политичка ориентација. Партиските вработувања престануваат. Меритократијата ја заменува партиската книшка.<br><br><b>4 правила на рестартот:</b><br>1. Не реваншизам<br>2. Транспарентен процес<br>3. Без амнестија за корупција<br>4. Постепен ритам (10 години, 2 мандата)<br><br><b>12 столбови:</b> Меритократски систем · Дигитализација · Економија на знаење · Образование · Здравство · Правда · Безбедност · Дијаспора · Локална самоуправа · Зелена енергија · Демографска обнова · Меѓународна позиција<br><br><b>20 мерливи показатели:</b> Од 60% партиски вработувања на &lt;5%. PISA од 402 на 480+. Време до доктор: 14 → 5 дена. Дијаспорски гласови: 20k → 200k+. И уште 16.<br><br><b>7 уникатни карактеристики</b> — никоја партија во светот не ги прави сите заедно.<br><br>${link('#program-restart', 'Прочитај ја целата програма')}`,

    twelve_pillars: `<b>12-те столбови на Генералниот Рестарт:</b><br><br><b>01.</b> ⚖️ Меритократски државен систем (60% → &lt;5% партиски вработувања)<br><b>02.</b> 💻 Дигитализација на сè (Х-Роуд модел, 30% → 90% услуги онлајн)<br><b>03.</b> 🤖 Економија на знаење и AI (3% → 8%+ од БДП)<br><b>04.</b> 🎓 Образование од корен (PISA 402 → 480+)<br><b>05.</b> 🏥 Здравство кое лекува (14 → 5 дена до доктор)<br><b>06.</b> ⚖️ Правда (18 → 9 месеци процеси)<br><b>07.</b> 🛡️ Безбедност (доверба полиција 54% → 70%)<br><b>08.</b> 🌍 Дијаспора (20k → 200k+ гласови)<br><b>09.</b> 🏛️ Локална самоуправа (25% → 50% сопствени приходи)<br><b>10.</b> 🌱 Зелена и енергетска независност (25% → 50%+ обновлива)<br><b>11.</b> 👨‍👩‍👧‍👦 Демографска обнова (наталитет 1.4 → 1.7+)<br><b>12.</b> 🌐 Меѓународна позиција со достоинство<br><br>${link('#program-restart', 'Види детали по столб')}`,

    unique_features: `<b>Што е уникатно во Македонија — Систем</b> (никоја партија во светот не го прави):<br><br><b>1.</b> Доктринарна тријада („Ред · Закон · Одговорност") + Меритократски устав на државна служба<br><b>2.</b> Тристепено дигитално зачленување (Поддржувач / КЕП / Заверен)<br><b>3.</b> Жива анкета без ограничување<br><b>4.</b> Институт + Junge Sistem + Officina + Annual Congress (4-во-1 модел)<br><b>5.</b> Дијаспора како институционална сила (не симболична)<br><b>6.</b> Тристепен правен рестарт (4 правила интегрирани)<br><b>7.</b> Доктрина: <em>не лево, не десно — компетенциско-меритократска</em><br><br>CDU има Volkspartei. FdI има Atreju. Singaporean PAP има меритократија. Estonian Reform има дигитализација. Но <b>никоја не ги поврзува сите овие во еден систем</b>. Македонија — Систем го прави.<br><br>${link('#program-restart', 'Види ја уникатноста')}`,

    institute: `<b>Систем — Институт за јавни политики</b> е партиски think-tank инспириран од германските модели (Konrad-Adenauer-Stiftung на CDU, Friedrich-Ebert-Stiftung на SPD). Независен Институт со <b>6 експерти</b> по области:<br>⚖️ Правда (д-р А. П.)<br>🏥 Здравство (д-р Б. Т.)<br>💼 Економија и AI (проф. С. К.)<br>🎓 Образование (проф. М. Р.)<br>🛡️ Безбедност и дипломатија (амб. Н. В.)<br>🌳 Енергија (д-р Т. М.)<br><br>Институтот продуцира студии, бели трудови и законски предлози. Експертската работа доаѓа пред политичкото одлучување.<br><br>${link('#institute', 'Види го Институтот')}`,

    junge: `<b>Junge Sistem</b> е младинско крило за луѓе под 30 години. Инспирирано од германските модели (Junge Union на CDU, Jusos на SPD). Не симболична организација — туку реална школа за идни лидери. Има 6 програми:<br>🎓 10 стипендии годишно<br>🤝 12-месечно менторство<br>📚 Систем Академија (7 модули + сертификат)<br>🌐 Меѓународна размена (до 20 годишно)<br>💼 Стажирање (3-6 месеци)<br>🏛️ Шадоу-Кабинет (8 позиции)<br><br>${link('#junge', 'Зачлени се во Junge Sistem')}`,

    congress: `<b>Македонија — Систем · Конгрес 2027</b> е првиот годишен flagship настан, инспириран од италијанскиот „Atreju" модел на Fratelli d'Italia. <b>15 Септември 2027</b> — 3 дена, 40+ предавачи од 15+ земји, 5,000 учесници.<br><br>Програма:<br>• <b>Ден 1:</b> Институции и доктрина<br>• <b>Ден 2:</b> Економија, AI и дијаспора<br>• <b>Ден 3:</b> Граѓани, општини и иднина<br><br>Не партиски митинг — туку државнички фестивал на идеи.<br><br>${link('#congress', 'Регистрирај се за Конгрес 2027')}`,

    officina: `<b>Officina</b> се <b>8 тематски работилници</b> по сектори, инспирирани од италијанскиот „Officina per l'Italia" модел. Секоја работилница има свој координатор, месечни средби и годишен бел труд:<br>⚖️ Officina · Правда (14 членови)<br>🏥 Officina · Здравство (22 членови)<br>🎓 Officina · Образование (17 членови)<br>💼 Officina · Економија (28 членови)<br>🌾 Officina · Земјоделство (11 членови)<br>⚡ Officina · Енергија (9 членови)<br>🛡️ Officina · Безбедност (13 членови)<br>🌐 Officina · Дипломатија (15 членови)<br><br>Експертската работа се случува тука, пред да дојде до политичка одлука.<br><br>${link('#officina', 'Пријави се за Officina')}`,

    help: `Можам да одговарам на прашања за <b>сè на платформата</b>. Прашај ме слободно за: манифест, принципи, програма, статут, симбол, иницијативи, гласање, дијаспора, благосостојба, светски модели, општини, членство, предлози, Институт, Junge Sistem, Конгрес, Officina работилници, контакт, или било каква друга тема. Користи природен јазик — јас разбирам.`,
    // ═══ v17 EXPANDED KB ENTRIES ═══

    crm: `<b>📊 Supporter CRM</b> е целосна база на членови, донатори и волонтери. Ги следи: имиња, региони, активност, донации, статус. Поддржува филтри (Сите/Членови/Донатори/Волонтери), пребарување по име/е-пошта и извоз во CSV формат за надворешна анализа. Видливост ограничена на овластени лица согласно ЗЗЛП.<br><br>${link('#crm-dashboard', 'Отвори CRM')}`,

    recruit: `<b>🤝 Peer-to-Peer Регрутирање</b> — секој член може да биде амбасадор. Систем со реферални линкови:<br>• Уникатен линк за секој член<br>• Бодови за секој привлечен нов член<br>• Табела на лидери (топ амбасадори)<br>• Статистики: Поканети / Придружиле / Бодови / Ранг<br><br>Цел: 12-те столбови на регрутирањето — секој месец нов кохорт.<br><br>${link('#recruit-hub', 'Земи го твојот линк')}`,

    volunteer: `<b>🛠️ Волонтерски Центар</b> — теренски задачи за 80-те општини:<br>• Координација на локални предлози<br>• Теренска документација (фото-докази)<br>• Организација на јавни форуми<br>• Дистрибуција на печатени материјали<br>• Помош на изборни денови<br><br>Секоја задача има: локација, рок, потребен број луѓе, координатор.<br><br>${link('#volunteer-hub', 'Пријави се за задача')}`,

    events: `<b>📅 Настани и RSVP</b> — јавни настани со резервација место:<br>• Конгреси (300 места)<br>• Officina работилници (50–100 места)<br>• Општински форуми (по 80-те општини)<br>• Дијаспорски состаноци (онлајн + во живо)<br><br>RSVP систем: пријавиш се → добиваш QR-код → скенираш на влез. Слободни/полни места во реално време.<br><br>${link('#events', 'Види ги настаните')}`,

    petitions: `<b>✍️ Петиции</b> — граѓански иницијативи за уставни и законски измени:<br>• <b>Меритократска Реформа на Уставот</b> — 6,840 / 10,000 потписи<br>• Цел: да се воведе меритократија во државна служба<br>• Преостанати 12 дена за прибирање потписи<br><br>Секоја петиција има: цел, опис, потпис-копче, споделување, статус (активна/отворена/завршена).<br><br>${link('#petitions', 'Потпиши петиција')}`,

    email_camp: `<b>📧 Масовна Е-пошта</b> — сегментирано испраќање со A/B тестирање:<br>• Сегменти: членови, донатори, волонтери, дијаспора, по општина<br>• A/B тест на наслов и содржина<br>• Закажување (immediate / scheduled)<br>• Зачувување нацрти<br>• Метрики: отворени / кликнати / отписи<br><br>${link('#email-campaign', 'Создади кампања')}`,

    budget: `<b>💰 Партиципативен Буџет</b> — гласај каде да оди јавниот денар. Систем по бразилски и португалски модел:<br>• 4 проекти на гласање (инфраструктура, образование, здравство, дигитализација)<br>• Секој граѓанин има 1 глас<br>• Буџетски лимит: % од општински буџет<br>• Резултатите обврзувачки за локалната власт<br><br>${link('#participatory-budget', 'Гласај за буџет')}`,

    anon_proposals: `<b>🛡️ Анонимни Предлози / Жвиждукачки канал</b> — заштитен канал за пријава на корупција, неправилности и предлози без откривање идентитет:<br>• Криптирана форма<br>• Без IP логирање<br>• Преглед од Етичка комисија<br>• Заштита согласно <b>Закон за заштита на укажувачи</b> (ЗЗУ)<br>• Тип: корупција / неправилност / предлог / други<br><br>${link('#anon-proposals', 'Поднеси анонимно')}`,

    ai_sentiment: `<b>🧠 AI Анализа на Граѓански Предлози</b> — автоматска обработка:<br>• Групирање на слични предлози<br>• Приоритизирање според популарност и итност<br>• Сумирање на долги предлози<br>• Sentiment анализа (позитивно / неутрално / негативно)<br>• Откривање на тренд-теми<br><br>Технологија: GPT-style модел со македонски корпус. Етичка контрола од Програмскиот совет.<br><br>${link('#ai-sentiment', 'Види ја анализата')}`,

    archive: `<b>🗂️ Архива на Анкети · Демографска Анализа</b> — сите минати анкети со пресек по:<br>• Возраст (18–25, 26–35, 36–45, 46–60, 60+)<br>• Пол (М / Ж / Не сака да каже)<br>• Регион (8 региони)<br>• Образование, професија<br><br>Графикони, споредби, тренд линии. Извоз во CSV / JSON за истражувачи.<br><br>${link('#poll-archive', 'Отвори ја архивата')}`,

    presentation: `<b>📊 Презентација за Медиуми</b> — едно-кликни PDF/PPTX извоз со:<br>• Slide 1: Манифест и доктрина<br>• Slide 2: 10 принципи<br>• Slide 3: 12 столбови<br>• Slide 4: Програма за 100 дена<br>• Slide 5: Бројки и пулс<br>• Slide 6: Контакт<br><br>За новинари, аналитичари, инвеститори, партнери. На 5 јазици.<br><br>${link('#presentation', 'Преземи презентација')}`,

    growth: `<b>📈 Growth Dashboard</b> — статистика за раст на платформата во реално време:<br>• Нови членови по ден / недела / месец<br>• Конверзија (поддржувач → член → заверен член)<br>• Регионален раст<br>• Дијаспорски раст<br>• Извор на регрутирање (P2P / директно / соц. мрежи)<br>• Cohort анализа (задржување на членови)<br><br>${link('#growth-dashboard', 'Види го dashboard-от')}`,

    junge: `<b>🚀 Junge Sistem · Школа за Идни Лидери</b> — младинско крило:<br>• Возраст: 16–30<br>• Програма: Обуки, менторство, теренски проекти<br>• Размени со партнерски фондации (Konrad-Adenauer, Friedrich-Ebert, Hanns-Seidel модели)<br>• Годишно: 4 циклуси по 12 недели<br>• По завршувањето: членство во Институт или активна функција<br><br>${link('#junge', 'Зачлени се во Junge')}`,

    institute: `<b>📚 Систем Институт · Партиски Think-Tank</b> — по германски модел (Konrad-Adenauer-Stiftung, Friedrich-Ebert-Stiftung):<br>• Истражувања и политики<br>• Анализи без идеолошки филтри<br>• Книги и публикации<br>• Конференции и панели<br>• Меѓународни партнерства<br><br>Цел: квалитетни политики базирани на докази.<br><br>${link('#institute', 'Види ги истражувањата')}`,

    congress: `<b>🎪 Конгрес 2027 · Годишно Собрание</b> — највисокото тело на платформата:<br>• Извештаи за работа<br>• Нов курс и приоритети<br>• Избор на тело (Извршен одбор, Етичка комисија, Претседател)<br>• Отворен граѓански панел<br>• Усвојување буџет за наредна година<br>• Транспарентен — преноси во живо<br><br>Се одржува секоја година во последниот викенд од октомври.<br><br>${link('#congress', 'Види детали за Конгрес 2027')}`,

    officina: `<b>🔧 Officina · Работилници по Сектори</b> — експертски работилници:<br>• 🏥 Здравство<br>• ⚡ Енергетика<br>• 🌾 Агро<br>• 💻 Дигитално<br>• 🛡️ Безбедност<br>• 🎓 Образование<br>• 💰 Финансии<br>• 🌍 Дипломатија<br><br>Секоја работилница: 8–12 експерти + програмски совет. Резултат: бели книги (white papers) што влегуваат во програмата.<br><br>${link('#officina', 'Види ги работилниците')}`,

    worldparties: `<b>🌍 Атлас на Светски Партии</b> — споредба со партии и движења ширум светот:<br>• Идеолошки спектар (лево-центар-десно)<br>• Метод (популизам / технократија / меритократија)<br>• Земја и регион<br>• Слични вредности (зелена, либерална, социјал-демократска, конзервативна)<br><br>Цел: лоцирање на „Македонија — Систем" во меѓународен контекст. Не сме изолирани — има слични модели во светот.<br><br>${link('#world-parties', 'Истражи го атласот')}`,

    magazine: `<b>📰 Месечен Магазин · Светски Политички Настани</b> — преглед на:<br>• 🇪🇺 Европа: ЕУ, Брисел, Москва, Берлин, Париз<br>• 🇺🇸 Америка: САД, Канада, Латинска Америка<br>• 🇨🇳 Азија: Кина, Индија, Јапонија, Кореа<br>• 🇿🇦 Африка: Европа на Африка, Кенија, Нигерија<br>• 🇲🇰 Балкан: соседи, регионални иницијативи<br>• Анализа: што значи за Македонија<br><br>Излегува на 1-ви секој месец. Бесплатно за членови.<br><br>${link('#monthly-magazine', 'Прочитај го магазинот')}`,

    swot: `<b>📊 SWOT Анализа · Аналитички Центар</b> — без шминка:<br><br><b>S · Предности</b>: јасна доктрина, технолошка платформа, дигитално зачленување, дијаспорски капитал, меритократска филозофија<br><br><b>W · Слабости</b>: ново име на сцена, мал тим, ограничен почетен буџет, без парламентарна група<br><br><b>O · Можности</b>: ЕУ интеграција, дигитализација, разочарани од стари партии, дијаспорски глас<br><br><b>T · Закани</b>: партиски мрежи против, дезинформации, регулаторни пречки, економска криза<br><br>${link('#analytical-center', 'Види ја целата SWOT')}`,

    channels: `<b>📡 Канали и Социјални Мрежи</b> — официјални присуства:<br>• 🌐 Веб: makedonijasistem.mk<br>• 📧 Е-пошта: makedonijasistem@gmail.com<br>• 📘 Facebook: @makedonijasistem<br>• 📷 Instagram: @makedonijasistem<br>• 🐦 Twitter / X: @makedonijasistem<br>• 📺 YouTube: Македонија — Систем<br>• 💬 Viber заедница: за членови<br>• 📨 Telegram канал: за вести<br><br>Без анонимни профили. Без сенки. Сè јавно.<br><br>${link('#channels', 'Поврзи се')}`,

    newsletter: `<b>📨 Newsletter · Пулс на неделата</b> — седмичен преглед:<br>• Иницијативи во тек<br>• Состојби и доктринарни осврти<br>• Закажани настани<br>• Топ предлози од граѓаните<br>• Меѓународни новости<br><br>Без спам. Без таргетирани реклами. Согласност согласно <b>ЗЗЛП</b>. Можеш да отпишеш во секое време.<br><br>${link('#newsletter', 'Претплати се')}`,

    theme: `<b>🌙 Темна / Светла тема</b> — кликни го копчето ☀️/🌙 во горниот десен агол. Платформата:<br>• Памти твој избор во localStorage<br>• Поддржува <code>prefers-color-scheme</code> (системска тема)<br>• Live ажурирање ако промениш системска тема (без избран твој)<br>• Затоплени бои за читливост<br><br>Тастатура: TAB до копчето → Enter за префрлање.`,

    privacy: `<b>🔒 Приватност и заштита на податоци</b> — согласно ЗЗЛП и GDPR:<br>• <b>Сите податоци локално</b> во твојот прелистувач (localStorage)<br>• <b>НЕ собираме</b> на сервер без согласност<br>• <b>Cookies</b> само за функционалност (тема, јазик)<br>• <b>Аналитика</b>: ако ја имаме, само анонимна и аггрегирана<br>• <b>Кога поднесуваш предлог</b>: твоја е-пошта се отвара со подготвен текст — ти контролираш<br>• <b>Право на брисење</b>: Кликни „🗑️ Исчисти ги моите записи"<br><br>Контролор: Македонија — Систем. Контакт за заштита: makedonijasistem@gmail.com<br><br>${link('#anon-proposals', 'Користи анонимен канал')}`,

    languages: `<b>🌍 Преведувач · 5 јазици</b>:<br>• 🇲🇰 Македонски (стандард, Правопис 2017)<br>• 🇬🇧 English<br>• 🇦🇱 Shqip<br>• 🇷🇸 Српски<br>• 🇩🇪 Deutsch<br><br>Кликни ги знамињата горе-десно или притисни <b>Alt+1 до Alt+5</b> за брза промена. URL: добави <b>?lang=de</b> за директен линк на одреден јазик. 439 преведени клучеви + рантајм-преведувач за чести фрази.`,

    keyboard: `<b>⌨️ Тастатурни кратенки</b>:<br>• <b>Alt+1</b> → Македонски<br>• <b>Alt+2</b> → English<br>• <b>Alt+3</b> → Shqip<br>• <b>Alt+4</b> → Српски<br>• <b>Alt+5</b> → Deutsch<br>• <b>/</b> → отвори бот-агент<br>• <b>Esc</b> → затвори мени / бот / dialog<br>• <b>Tab</b> → навигација помеѓу елементи<br>• <b>Enter</b> → активирај копче<br><br>Целосна поддршка за читачи на екран (NVDA, JAWS, VoiceOver).`,

    a11y: `<b>♿ Пристапност (a11y)</b> — Македонија Систем е пристапна за сите:<br>• <b>Skip-link</b> на врвот за тастатурни корисници<br>• <b>Силни focus прстени</b> (3px злато) за TAB-навигација<br>• <b>aria-pressed</b>, <b>aria-live</b>, <b>aria-label</b> на сите интерактивни<br>• <b>prefers-reduced-motion</b>: без анимации ако корисникот ги исклучил<br>• <b>Семантички HTML</b>: правилна употреба на h1-h6, nav, main<br>• <b>Контраст</b>: WCAG AA на сите текстови<br>• <b>Скрин-ридер</b>: тестирано со NVDA<br><br>Доколку забележиш a11y проблем — пиши на makedonijasistem@gmail.com.`,

    performance: `<b>⚡ Перформанси</b> — оптимизирано за брзина:<br>• <b>Lazy loading</b>: слики се вчитуваат само кога се видливи<br>• <b>IntersectionObserver</b>: scroll-trigger без блокирање<br>• <b>Debounced</b> scroll listeners<br>• <b>Compressed</b> CSS и JS (single file)<br>• <b>Service Worker</b>: офлајн кеш на главните страници<br>• <b>Print stylesheet</b>: чисто за печатење<br>• <b>RAF</b> (requestAnimationFrame) за анимации<br><br>Тарget: Lighthouse 90+ на сите 4 категории.`,

    offline: `<b>📡 Офлајн режим</b> — платформата работи и без интернет:<br>• <b>Service Worker</b> кеширан на главната страница<br>• <b>localStorage</b> за гласови и предлози (in-memory fallback за приватни моди)<br>• <b>Офлајн банер</b> на анкетата кога нема врска<br>• <b>Auto-resync</b> на гласови кога ќе се поврзеш<br>• <b>Online/offline events</b> со toast пораки<br><br>Анкетата ги задржува гласовите локално и ги испраќа во Firebase кога ќе се поврзеш.`,

    firebase: `<b>🔥 Firebase Realtime Database</b> — за анкета во живо:<br>• Анкетата чува гласови во <b>Firebase Realtime DB</b><br>• Сметка со <b>анти-фрод</b>: rate limiting + Cloudflare Turnstile CAPTCHA<br>• Резултатите се ажурираат во реално време за сите гледачи<br>• Конфигурацијата на Firebase се чита од метатагови<br>• <b>safety-net</b>: ако Firebase падне, гласовите се чуваат локално и се синхронизираат подоцна<br><br>Без личени податоци во гласовите — само анонимен ID.`,

    turnstile: `<b>🛡️ Cloudflare Turnstile · CAPTCHA</b> — заштита од ботови:<br>• Невидлив CAPTCHA (без challenges)<br>• Верификација на гласови во анкета<br>• Заштита на форми за зачленување<br>• Заштита на петиции и анонимни предлози<br>• Алтернатива на Google reCAPTCHA (без таргетирани реклами)<br><br>Cloudflare има GDPR-комплијантна имплементација.`,

    pwa: `<b>📱 PWA · Прогресивна Веб Апликација</b>:<br>• Можеш да ја <b>инсталираш</b> на телефон / десктоп<br>• Работи <b>офлајн</b> по првото вчитување<br>• Има свој <b>icon</b> на почетниот екран<br>• Service Worker за брзо вчитување<br>• Manifest со целосни метаподатоци<br><br>Како да инсталираш: На Chrome / Edge → менито (3 точки) → „Инсталирај Македонија — Систем". На Safari iOS → Сподели → „Додај на почетен екран".`,

    digital_card: `<b>🪪 Дигитална Членска Картичка</b> — после зачленување добиваш:<br>• Уникатен ID (MS-100001 формат)<br>• QR-код за скенирање<br>• Пасош фото (35×45 mm)<br>• Име, адреса, општина, статус, ниво<br>• Дизајн: navy (#0a1d3a) + злато (#d4ad4a)<br>• Аспект ratio 95:65 mm (стандардна банкарска картичка)<br>• Може да се принта или да се покаже на телефон<br><br>QR-кодот линкува на твојот јавен профил (само ако сакаш да биде јавен).`,

    bot_about: `Јас сум <b>M-S</b> (агент на Македонија — Систем) — оперативен асистент на „Македонија — Систем". Знам сè што е во платформата:<br>• 14 главни секции (манифест, принципи, програма…)<br>• 12 столбови на рестартот<br>• 10 темелни принципи<br>• 80+ општини и координатори<br>• 12 земји со дијаспора<br>• 12 светски модели<br>• 9 членови на Статутот<br><br>Прашај ме на македонски, англиски, албански, српски или германски — ќе одговорам. Ако не знам нешто, ќе ти кажам каде да гледаш.<br><br>Тип: <b>помош</b> за листа на сите команди.`,

    help: `<b>📚 Што можам да правам:</b><br><br><b>Информации за платформата:</b><br>• <b>што е</b> · <b>манифест</b> · <b>10 принципи</b><br>• <b>генерален рестарт</b> · <b>12 столбови</b><br>• <b>статут</b> · <b>симбол</b> · <b>кодекс</b><br><br><b>Програмски области:</b><br>• <b>економија</b> · <b>агро</b> · <b>енергија</b><br>• <b>општество</b> · <b>дијаспора</b><br>• <b>меритократија</b> · <b>Macedonia Pulse</b><br><br><b>Дигитални алатки:</b><br>• <b>зачленување</b> · <b>КЕП</b> · <b>нотар</b><br>• <b>иницијативи</b> · <b>предлог</b> · <b>гласање</b><br>• <b>петиции</b> · <b>буџет</b> · <b>анонимно</b><br><br><b>Институционални:</b><br>• <b>конгрес</b> · <b>институт</b> · <b>junge</b><br>• <b>officina</b> · <b>статут</b> · <b>дик</b><br><br><b>Анализи:</b><br>• <b>swot</b> · <b>светски партии</b> · <b>магазин</b><br>• <b>благосостојба</b> · <b>светски модели</b><br><br><b>Технички:</b><br>• <b>тема</b> · <b>јазик</b> · <b>тастатура</b><br>• <b>пристапност</b> · <b>офлајн</b> · <b>pwa</b><br>• <b>приватност</b><br><br>Прашај ме со свои зборови — разбирам природен јазик.`,

    overview: `<b>📋 Преглед на Платформата</b> — 30 секции:<br><br><b>I. Доктрина</b> (1–4):<br>1. Манифест 2. 10 принципи 3. Кодекс 4. Статут<br><br><b>II. Програма</b> (5–10):<br>5. Генерален рестарт 6. 100 дена 7. Економија 8. Агро 9. Енергија 10. Општество<br><br><b>III. Алатки</b> (11–15):<br>11. AI Pulse 12. Светски модели 13. Благосостојба 14. SWOT 15. Светски партии<br><br><b>IV. Учество</b> (16–22):<br>16. Иницијативи 17. Граѓански марш 18. Петиции 19. Буџет 20. Анонимни предлози 21. AI sentiment 22. Архива<br><br><b>V. Организација</b> (23–28):<br>23. Зачленување 24. Конгрес 25. Институт 26. Junge 27. Officina 28. Општини<br><br><b>VI. Поддршка</b> (29–30):<br>29. Дијаспора 30. Донации<br><br>${link('#top', 'Оди на врв')}`,
    networking: `<b>🤝 Меѓупартиско Вмрежување</b> — систем за партнерства со <b>61 светски партии</b>:<br><br>• <b>5 формати</b>: студиска посета, билатерална средба, MoU, младинска размена, заедничко соопштение<br>• <b>Каталог на сите 61 партии</b> со адреси и веб-сајтови<br>• <b>Форма за иницирање</b> со автоматски meil со дипломатски протокол<br>• <b>Статус-тракер</b>: Иницирано → Во тек → Активно → Завршено<br>• <b>Локално зачувување</b> — сите партнерства во твојот прелистувач<br><br>Партии со определба <b>ЦЕНТАР</b> се прикажани прво (41 од 61):<br>🔵 22 Центар-десни (CDU/CSU, FdI, ВМРО-ДПМНЕ, New Democracy…)<br>🔴 19 Центар-леви (SPD, Labour, СДСМ, Democratic Party…)<br><br>${link('#party-networking', 'Вмрежи се сега')}`,
    industrial: `<b>🏭 Технолошки Шампиони · Индустрија 2030</b><br><br>Македонија како <b>технолошки лидер на Балканот и пошироко</b>. 6 стратешки производи, €8 милијарди инвестиции, 45,000 високотехнолошки работни места до 2030.<br><br><b>6 шампиони:</b><br>🚗 <b>Vardar H₂</b> — водороден автомобил (ТИРЗ Скопје 2)<br>📱 <b>MK-Phone</b> — мобилни телефони со транзиција кон „hand-display"<br>👓 <b>MK-Vision</b> — дигитални очила со AR, превод, медицинска дијагностика<br>💎 <b>МК Чипови</b> — Тајван 2.0 · 7nm 2027 → 3nm 2030<br>🚊 <b>SkyWorld</b> — надземна жичница · 3 фази (Скопје → 80 општини → Балкан)<br>🏗️ <b>15 ТИРЗ</b> — здружени македонски профити (≥51% домашно)<br><br>Сите производи се со <b>здружен македонски капитал</b> и партнерства со светски лидери (Toyota, BMW, ASML, TSMC, Anatoliy Yunitskiy).<br><br>${link('#industrial-champions', 'Истражи ги шампионите')}`,

    hydrogen: `<b>🚗 Vardar H₂ · Водороден автомобил</b><br><br>Производство на македонски водороден автомобил во ТИРЗ Скопје 2 + Тетово.<br><br>• <b>Опсег:</b> 700 km со едно полнење<br>• <b>Полнење:</b> 3–5 минути<br>• <b>Емисии:</b> 0 g/km (само вода)<br>• <b>Партнерства:</b> Toyota Mirai, BMW iX5 Hydrogen<br>• <b>Прв прототип:</b> 2028<br><br>${link('#industrial-champions', 'Види ги детали')}`,

    mk_phone: `<b>📱 MK-Phone · Македонски мобилни</b><br><br>Македонски мобилни телефони со open-source софтвер и врвна приватност. Во иднина (2028+): „<b>hand-display</b>" — холографски телефон без физички екран.<br><br>• Без backdoors, без telemetry<br>• Македонски Linux-базиран OS<br>• 7-дневна батерија (graphene)<br>• ТИРЗ Скопје 1<br>• Прв MK-Phone: 2027<br><br>${link('#industrial-champions', 'Види детали')}`,

    mk_vision: `<b>👓 MK-Vision · Дигитални очила</b><br><br>Сите функции предвидени до 2030:<br>• AR проекција<br>• Превод во реално време (100+ јазици)<br>• Медицинска дијагностика без вадење крв<br>• AI асистент (M-S интеграција)<br>• AR гејминг и едукација<br><br>ТИРЗ Битола + Прилеп. Целосни функции до 2030.<br><br>${link('#industrial-champions', 'Види детали')}`,

    chips: `<b>💎 Македонски Чипови · Тајван 2.0</b><br><br>Стратешка цел: <b>Македонија наместо Тајван</b> како светски лидер во производство на чипови.<br><br>• Прва фабрика: 7nm чипови до 2027<br>• Втора фабрика: 3nm чипови до 2030<br>• EU Chips Act: €2 милијарди субвенции<br>• Партнерства: ASML, TSMC<br>• Безбеден производ за Европа (без зависност од Кина)<br><br>ТИРЗ Скопје 2 + Штип.<br><br>${link('#industrial-champions', 'Види детали')}`,

    skyworld: `<b>🚊 SkyWorld · Надземна жичница</b><br><br>По белорускиот модел (Anatoliy Yunitskiy) — брз, екологичен, евтин транспорт без сообраќаен метеж.<br><br><b>Фаза 1 (2026–2027):</b> Скопје · 4 линии · 65 km · аеродром<br><b>Фаза 2 (2028–2030):</b> Сите 80 + 1 општини · 2,400 km<br><b>Фаза 3 (2030–2032):</b> Балкан и Европа · Скопје–Софија–Атина–Будимпешта<br><br>${link('#industrial-champions', 'Види детали')}`,

    tirz: `<b>🏗️ 15 ТИРЗ · Здружен македонски капитал</b><br><br>Преструктуирање на 15-те Технолошки индустриски развојни зони за <b>здружени македонски профити</b>.<br><br>• <b>≥51% домашно сопствеништво</b><br>• Дијаспора како главен инвеститор (2.5M Македонци · €5B потенцијал)<br>• Меритократски менаџмент (не партиски)<br>• Локации: Скопје 1, 2, Тетово, Кичево, Битола, Прилеп, Штип, Куманово, Гевгелија, Струмица, Велес, Кавадарци, Охрид, Гостивар, Кочани<br><br>${link('#industrial-champions', 'Види детали')}`,
    diaspora_hub: `<b>🌍 Дијаспора-Систем · Целосно вмрежување</b><br><br>Македонија има <b>2.5 милиони во дијаспора</b> — највозможниот неискористен капитал. 5 интегрирани модули:<br><br><b>1. 💎 0% Данок инвестиции</b><br>• 0% корпоративен данок 10 години во ТИРЗ<br>• Бесплатно земјиште, едношалтерски систем<br>• Дијаспорски бонус: +5% субвенции<br>• Брз пасош: 2 години<br><br><b>2. 🏠 Враќање во Македонија</b><br>• Релокациски грант €5–15K<br>• Гарантирана работа во ТИРЗ<br>• 0% камата за домување<br>• Резервирани училишта за деца<br><br><b>3. 🗳️ Дијаспорско гласање</b><br>• Цел: 600,000 регистрирани до 2027<br>• Помош преку М-С координатор<br>• Поддршка за ДИК регистрација (dijaspora.sec.mk)<br><br><b>4. 🏦 Инвестициски фонд €5B</b><br>• Минимум €1,000 / Максимум €5M<br>• Принос: 12–18% годишно<br>• ≥51% домашно сопствеништво<br><br><b>5. 🎓 Skills Bridge</b><br>• Дигитален ментор / експертски совет<br>• Без преселба — придонес од каде што си<br>• 8 главни области (AI, биотех, медицина, итн.)<br><br>${link('#diaspora-hub', 'Истражи го хабот')}`,

    diaspora_invest: `<b>💎 0% Корпоративен данок · ТИРЗ за дијаспора</b><br><br>Најповолни инвестициски услови во Европа специјално за дијаспората:<br><br>• <b>0%</b> корпоративен данок 10 години<br>• <b>0% ДДВ</b> на машини и опрема<br>• <b>Бесплатно земјиште</b> 99-годишен закуп<br>• <b>4 часа</b> регистрирање компанија<br>• <b>€5–10K</b> субвенции по работно место<br>• <b>+5%</b> дијаспорски бонус<br>• <b>2 години</b> до македонски пасош (наспроти 8)<br><br>Споредба: Македонија 0% vs Кипар 12.5% vs Германија 30%.<br><br>${link('#diaspora-hub', 'Калкулирај заштеда')}`,

    diaspora_return: `<b>🏠 Враќање во Македонија · Програма</b><br><br>Сè на едно место за враќање:<br><br>• <b>Релокациски грант</b> €5–15K (по семеен состав)<br>• <b>0% царина</b> за домашни добра + автомобил<br>• <b>Гарантирана работа</b> во ТИРЗ<br>• <b>Резервирано место</b> во топ училишта<br>• <b>Бесплатно здравство</b> прва година<br>• <b>5%</b> данок на доход (наспроти 10%) прв 5 години<br>• <b>0% камата</b> за купување домување<br>• <b>М-С координатор</b> за сите 25 чекори<br><br>Приоритет: инженери, лекари, IT, семеjства со деца, претприемачи.<br><br>${link('#diaspora-hub', 'Регистрирај интерес')}`,

    diaspora_vote: `<b>🗳️ Дијаспорско гласање за МК-Систем</b><br><br>Цел: <b>600,000 регистрирани</b> дијаспорски гласачи до изборите 2027.<br><br>Моментален статус: 42,847 регистрирани (7.1%).<br><br><b>Топ земји:</b><br>🇩🇪 Германија: 8,742<br>🇮🇹 Италија: 5,634<br>🇨🇭 Швајцарија: 4,891<br>🇺🇸 САД: 4,562<br>🇦🇺 Австралија: 3,924<br>🇨🇦 Канада: 3,128<br><br>Регистрацијата за избори се прави преку <b>dijaspora.sec.mk</b> (ДИК). Платформата на МК-Систем те поврзува со координатор за помош.<br><br>${link('#diaspora-hub', 'Регистрирај интерес')}`,

    diaspora_fund: `<b>🏦 Дијаспорски Инвестициски Фонд · €5B</b><br><br>Здружен капитал на 2.5M Македонци за ≥51% домашно сопствеништво на стратешки индустрии.<br><br><b>Услови:</b><br>• Минимум: <b>€1,000</b> по член<br>• Максимум: <b>€5M</b> по член<br>• Pro-rata удел во профитот<br>• Меритократски одбор (без партиски)<br>• Очекуван принос: <b>12–18%</b> годишно<br>• 5-годишен хоризонт<br><br><b>Заштита:</b><br>• Регулиран од МСС<br>• Big 4 аудит<br>• EU MiFID II compliant<br>• Повлекување после 24 месеци<br><br>Pre-launch предупоги: €127M (2.5% од целта).<br><br>${link('#diaspora-hub', 'Регистрирај предупог')}`,

    diaspora_skills: `<b>🎓 Skills Bridge · Знаење → Македонија</b><br><br>Не мораш да се вратиш физички. Придонеси преку знаење:<br><br><b>Тип на ангажман:</b><br>• Дигитален ментор (1–2 ч / неделно)<br>• Експертски совет (ad-hoc)<br>• Тех. инспектор (ревизии)<br>• Локален амбасадор<br>• Виртуелен предавач (Junge Sistem)<br>• Networker (МК ↔ глобален пазар)<br><br><b>Главни области:</b><br>🤖 AI / ML (142 потреби)<br>💼 VC / Финансии (76)<br>🔬 Полупроводници (89)<br>🏥 Медицина (124)<br>📚 Едукација (98)<br>⚡ Hydrogen Tech (56)<br>🎨 UI / UX дизајн (45)<br>🧪 Биотехнологија (38)<br><br>${link('#diaspora-hub', 'Понуди знаење')}`,
    diaspora_hero: `<b>🇲🇰 Дијаспора · 2.5M Македонци</b><br><br>Македонија има 2.5 милиони граѓани во дијаспората — една третина од сите Македонци. Преку Македонија — Систем, имаш <b>3 моќни алатки</b>:<br><br>💎 <b>Инвестирај</b> со 0% данок 10 години во ТИРЗ<br>🏠 <b>Врати се</b> со €5–15K грант + 0% царина<br>🗳️ <b>Гласај</b> од странство — 600,000 регистрирани = 30 пратеници<br><br>${link('#diaspora', 'Истражи ги алатките')}`,

    diaspora_invest: `<b>💎 Дијаспорски инвестиции · 0% данок</b><br><br>Македонија нуди најповолни услови во Европа:<br>• <b>0% корпоративен данок</b> 10 години во ТИРЗ<br>• <b>0% ДДВ</b> на увоз на машини и опрема<br>• <b>Бесплатно земјиште</b> со 99-годишен закуп<br>• <b>Едношалтерски систем</b> — регистрација за 4 часа<br>• <b>Дијаспорски бонус</b>: +5% субвенции за инвеститори со македонско потекло<br>• <b>Брз пасош</b>: државјанство за 2 години<br><br>Споредба:<br>🇲🇰 МК (ТИРЗ): 0% · 4 часа<br>🇨🇾 Кипар: 12.5% · 5 дена<br>🇩🇪 Германија: 30% · 14 дена<br><br>${link('#diaspora-hub', 'Калкулатор')}`,

    diaspora_return: `<b>🏠 Враќање во Македонија</b><br><br>Поддршка за дијаспорци кои се враќаат:<br>• <b>€5–15K грант</b> за пресел<br>• <b>0% царина</b> на личен имот<br>• <b>Гарантирана работа</b> во ТИРЗ компании или јавна служба<br>• <b>Бесплатно школско место</b> за деца<br>• <b>0% камата кредит</b> за стан/куќа (5 години)<br>• <b>25-чекор асистенција</b> од М-С координатор<br><br>${link('#diaspora-hub', 'Пријави интерес')}`,

    diaspora_vote: `<b>🗳️ Дијаспорско гласање</b><br><br><b>⚠️ Важно:</b> Имаме само 18 месеци до изборите 2027. Цел: 600,000 регистрирани дијаспорци = 30 пратеници во Собранието.<br><br>Како да гласаш од странство:<br>1. Регистрирај се на <b>dijaspora.sec.mk</b> (Државна изборна комисија)<br>2. Потребно: македонски пасош + адреса во странство<br>3. Опции: гласање во конзулат · е-гласач со eIDAS<br>4. Гласаш за 30 пратеници на дијаспората + национална листа<br><br>Топ 5 земји: 🇩🇪 8,742 · 🇮🇹 5,634 · 🇨🇭 4,891 · 🇺🇸 4,562 · 🇦🇺 3,924<br><br>Денеска регистрирани: ~42,847 (7.1% од целта).<br><br>${link('#diaspora-hub', 'Регистрирај се сега')}`,

    diaspora_fund: `<b>🏦 Дијаспорски Инвестициски Фонд (МК-ДИФ)</b><br><br>Прв македонски колективен фонд за дијаспорски капитал:<br>• <b>Минимална инвестиција:</b> €1,000<br>• <b>Максимум:</b> €5M по член<br>• <b>Поделба профити:</b> Pro-rata според удел<br>• <b>Управа:</b> Меритократски одбор<br>• <b>Цел капитал:</b> €5 милијарди до 2030<br>• <b>Очекуван повраток:</b> 12–18% годишно<br><br>${link('#diaspora-hub', 'Зачлени се')}`,

    diaspora_skills: `<b>🎓 Skills Bridge · Знаење без враќање</b><br><br>За дијаспорци кои не сакаат физички да се вратат, но сакаат да придонесат:<br>• <b>Дигитален менторски програм</b><br>• <b>Експерти-консултанти</b><br>• <b>Дијаспорски амбасадори</b><br>• <b>Виртуелни предавачи</b><br>• <b>Networking конектори</b><br><br>Потребно: експертиза + 2 часа неделно.<br><br>${link('#diaspora-hub', 'Пријави се')}`,

    diaspora_champions: `<b>🏆 Дијаспорски шампиони</b><br><br>Реални приказни:<br>👨‍💼 <b>Климент М.</b> (🇩🇪 Минхен → ТИРЗ Скопје): €350K, 28 вработени<br>👩‍⚕️ <b>Ана П.</b> (🇨🇦 Торонто → Битола): €12K грант<br>🗳️ <b>Стефан Д.</b> (🇺🇸 Чикаго): 2 циклуси гласа со eIDAS<br>💻 <b>Билјана Т.</b> (🇨🇭 Цирих): Skills Bridge ментор<br>🌾 <b>Илија Г.</b> (🇦🇺 Сиднеј → Прилеп): Тутун-погон<br>💎 <b>Елена К.</b> (🇮🇹 Милано): €1,000 во МК-ДИФ<br><br>${link('#diaspora-champions', 'Прочитај ги')}`,

    diaspora_taxes: `<b>📊 Дијаспорски даночни бенефити</b><br><br>🇲🇰 <b>Македонија (ТИРЗ):</b> 0% корп. данок · 4 часа регистрација · +5% дијаспорски бонус<br><br>🇨🇾 Кипар: 12.5% · 🇮🇪 Ирска: 12.5% · 🇧🇬 Бугарија: 10% · 🇲🇪 Црна Гора: 15% · 🇩🇪 Германија: 30%<br><br>${link('#diaspora-hub', 'Калкулатор')}`,
    founders_drive: `<b>⚡ 1,000 Основачи Drive · Magic Algorithm</b><br><br>За регистрација на политичка партија во РСМ, согласно <b>Законот за политички партии (член 13)</b>, потребни се <b>минимум 1,000 основачи со нотарски заверени изјави</b>.<br><br><b>5-чекорен процес:</b><br>1. 📝 Пополни форма (3 мин)<br>2. 📄 Преземи PDF изјава со пред-пополнети податоци (1 мин)<br>3. ⚖️ Кај нотар — потпиши и завери (15 мин · 100–250 ден.)<br>4. 📤 Прати скен (2 мин)<br>5. 🎉 Добиваш сертификат како основач #X<br><br><b>Magic Multiplier:</b> 334 поддржувачи × 3 пријатели = 1,000+ основачи. Linked WhatsApp/Viber/Facebook share.<br><br><b>Mass Notary Days:</b> Координирани викенди во 8 градови со 50% попуст од нотари.<br><br>${link('#founders-drive', 'Стани основач сега')}`,

    notary: `<b>⚖️ Нотарска заверка за изјава</b><br><br>За правна тежина, изјавата за основач мора да биде <b>солемизирана од нотар</b>.<br><br><b>Што ти треба:</b><br>• Лична карта<br>• Изјавата (PDF преземен од платформата)<br>• 100–250 денари такса<br>• Таксена марка 50 ден.<br><br><b>Време:</b> 15 минути кај нотар<br><br><b>Каде?</b> Платформата има директорија на нотари во сите 81 општини. Барај по град/општина.<br><br><b>Mass Notary Days:</b> М-С организира координирани денови во 8 градови со попуст 50%. Викенди!<br><br>${link('#founders-drive', 'Најди нотар')}`,

    mass_notary: `<b>🎯 Денови на масовно нотарско заверување</b><br><br>М-С координира викенди со <b>50% попуст</b> од нотари за нашите основачи.<br><br><b>8 локации:</b><br>🏛️ Скопје Центар · 🏔️ Тетово · 🍎 Битола · 🌶️ Струмица · ☀️ Штип · 🍇 Велес · 🏞️ Охрид · 🌾 Куманово<br><br>Резервирај термин преку email — само 30 минути секоја сабота. Цел: 80–100 заверки по локација = 800 за 1 ден!<br><br>${link('#founders-drive', 'Резервирај термин')}`,

    referral: `<b>🚀 Magic Multiplier · Referral Систем</b><br><br>Преземи го твојот линк со ref-код. Прати на 3+ пријатели. Колку повеќе се регистрираат — толку повисок ранг:<br>• 🥉 Стартер (1+ регистрирани преку тебе)<br>• 🥈 Активен (5+ регистрирани)<br>• 🥇 Top 10% (10+ регистрирани)<br><br><b>Каде да испратиш линк?</b><br>💬 WhatsApp · 📱 Viber · 📘 Facebook · 🐦 X · ✈️ Telegram · 📧 Email<br><br>Сè локално зачувано во прелистувач — нема трекинг.<br><br>${link('#founders-drive', 'Земи го твојот линк')}`,

    party_law: `<b>📜 Закон за политички партии (РСМ)</b><br><br>Сл. весник на РСМ бр. 76/2004 и измени:<br><br><b>Член 13:</b> За регистрација на партија потребни се:<br>• Минимум <b>1,000 основачи</b><br>• <b>Нотарски заверени изјави</b> за пристапување<br>• Усвоен <b>Статут</b> и <b>Програма</b><br>• Адреса на седиштето<br>• Управни тела<br><br><b>Член 14:</b> Регистрација пред Централниот регистар на РСМ. Решение во рок од 30 дена.<br><br>МК-Систем е во активна фаза на собирање основачи за регистрација.<br><br>${link('#founders-drive', 'Биди основач')}`,
    digital_notary: `<b>🎥 Дигитална Нотарска Заверка · во реално време</b><br><br>Поврзи се со <b>сертифициран македонски нотар</b> преку видео-врска и заврши целата солемизација <b>за 15 минути</b> — без да излезеш од дома.<br><br><b>5-чекорен процес:</b><br>1. 🔐 КЕП логин (2 мин)<br>2. 📅 Резервирај термин (1 мин)<br>3. 🎥 Видео-врска со нотар (8 мин)<br>4. ✍️ е-Потпис со КЕП + Qualified Seal (3 мин)<br>5. 📜 Готов електронски документ (1 мин)<br><br><b>Тековно онлајн:</b> 12 нотари · ~7 мин просечно чекање<br><br><b>Правна основа:</b><br>• ЗЕДЕИДУ (Закон за електронски документи)<br>• eIDAS Регулатива ЕУ 910/2014 (член 25, 35)<br>• Закон за нотарите · член 53б<br>• Полна правна тежина = хартиен документ<br><br><b>Цена:</b> Иста како физички — 100–250 ден. + 50 ден. таксена марка<br><br>${link('#digital-notary', 'Поврзи се со нотар')}`,

    e_signature: `<b>✍️ Квалификуван Електронски Потпис (КЕП)</b><br><br>За дигитална нотарска заверка потребен е КЕП согласно ЗЕДЕИДУ.<br><br><b>Прифатени даватели во РСМ:</b><br>• <b>КИБС-Трст</b> (КИБС АД Скопје)<br>• <b>Македонски Телеком — Trust Services</b><br>• <b>А1 Македонија — Trust Services</b><br>• <b>ЦАОС</b> (Централно Авторизационо Опслужно Средство)<br>• <b>EU eIDAS</b> квалификувани сертификати (преку интероперабилност)<br><br><b>Цена:</b> 1,500–3,000 ден. за физичко лице (валидност 1–3 години)<br><br><b>За дијаспора:</b> Можеш да користиш национален дигитален ID на ЕУ земјата каде живееш (Personalausweis DE, Public Services Card IE, итн.)<br><br>${link('#digital-notary', 'Започни со КЕП')}`,

    eidas: `<b>🇪🇺 eIDAS · меѓународна правна тежина</b><br><br><b>Регулатива ЕУ 910/2014 за electronic IDentification, Authentication and trust Services</b>:<br><br>• <b>Член 25 (QES):</b> Qualified Electronic Signature има иста правна тежина како своерачен потпис во сите 27 ЕУ земји + ЕЕА<br>• <b>Член 35 (QSeal):</b> Qualified Electronic Seal за правни лица (нотари)<br>• <b>Член 42 (QTSP):</b> Qualified Trust Service Providers — листи на прифатени даватели<br>• <b>Член 47 (QTimestamp):</b> Кvалификуван временски печат (RFC 3161)<br><br>Македонија е <b>имплементирана</b> преку ЗЕДЕИДУ. Сите наши КЕП сертификати се прифатени во ЕУ.<br><br>${link('#digital-notary', 'Дигитална заверка')}`,

    notary_law: `<b>📜 Закон за нотарите · Член 53б</b><br><br>Член 53б (воведен со измените 2019) ги регулира <b>електронските нотарски акти</b>:<br><br>• Нотарот може да солемизира електронски документ ако странките имаат <b>квалификуван електронски потпис</b><br>• Идентификација: <b>видео-врска во живо</b> + проверка на ЛК + проверка на КЕП сертификат<br>• Соларизацијата се прави со <b>Qualified Electronic Seal</b> на нотарот<br>• Документот се чува во <b>централна електронска архива на нотарите</b> 7 години<br>• Полна правна тежина согласно член 53а<br><br>Тековно <b>87 од 167 активни нотари</b> се регистрирани за е-услуги (52%). Цел М-С: 100% до Q3 2026.<br><br>${link('#digital-notary', 'Користи го системот')}`,

    video_session: `<b>🎥 Видео-сесија со нотар · што се случува</b><br><br>Кога ќе клика "Поврзи се", се отвара дигитална сесија:<br><br><b>1. Чекање (~5–10 мин):</b> Нотарот завршува претходен случај<br><br><b>2. Видео-врска:</b> WebRTC peer-to-peer (encrypted end-to-end). Ти и нотарот се гледате во живо.<br><br><b>3. Идентификација (1–2 мин):</b> Држи ја ЛК пред камера. Нотарот визуелно ја споредува со твоето лице.<br><br><b>4. Потпишување:</b> Ти потпишуваш со КЕП (USB токен PIN или мобилна апликација).<br><br><b>5. Солемизација:</b> Нотарот потпишува со Qualified Electronic Seal (QSeal).<br><br><b>6. Временски печат:</b> RFC 3161 compliant timestamp се додава автоматски.<br><br><b>7. Документ:</b> Испратен на твоја е-пошта + архива во encrypted vault.<br><br>${link('#digital-notary', 'Стартувај сесија')}`,
    robotika: `<b>🤖 Роботика Македонија · 7-ми индустриски шампион</b><br><br>Производство на индустриски, медицински, агро и сервисни роботи во ТИРЗ зоните на <b>Прилеп, Скопје 2 и Битола</b>.<br><br><b>Главни партнери:</b><br>🏭 <b>Микросам АД Прилеп</b> (18%) — светски лидер во композити<br>🎓 <b>Машински факултет УКИМ Скопје</b> (13%) — академски стожер<br>🏢 <b>30+ македонски МСП</b> (11%) — повеќеделен удел<br>🌍 <b>Дијаспора преку МК-ДИФ</b> (9%) — здружен капитал<br>🇨🇳 <b>4 кинески партнери</b> (35%) — know-how, малцински<br>🇪🇺 <b>ЕУ Horizon</b> (14%) — европски фондови<br><br><b>Вкупен македонски удел: 51%</b> (без доминантен сопственик)<br><br><b>4 категории:</b><br>🏭 Индустриски роботи (2027 · ТИРЗ Прилеп)<br>🏥 Медицински роботи (2028 · ТИРЗ Скопје 2)<br>🌾 Агро-ботови (2028 · ТИРЗ Битола)<br>🤖 Сервисни AI ботови (2029 · сите 3)<br><br>€450M инвестиции · 5,500 високотехнолошки работни места до 2030.<br><br>${link('#robotika-macedonia', 'Истражи ја Robotika Macedonia')}`,

    mikrosam: `<b>🏭 Микросам АД Прилеп · Технолошки стожер</b> · <a href="https://mikrosam.com/" target="_blank" style="color:var(--gold-soft)">mikrosam.com</a><br><br>Македонски <b>светски лидер во автоматизација на композитни материјали</b> — со <b>35 години работа</b> (од 1990).<br><br>📊 Глобална присутност:<br>• <b>45+ земји</b> — клиенти ширум светот<br>• <b>370+ производни линии</b> инсталирани<br>• Клиенти: <b>GKN Aerospace · Syensqo · NIAR</b> и многу други<br><br>🎯 Технолошки експертизи:<br>• <b>Filament Winding</b> (FW) машини<br>• <b>Automated Fiber & Tape Placement</b> (AFP/ATL)<br>• <b>Prepreg</b> производна опрема<br>• <b>CNG/Hydrogen/LPG резервоари</b> — директна синергија со <b>Vardar H₂!</b><br>• <b>Slitting & Conversion</b> за prepregs<br>• Софтвер: WindingExpert, MikroPlace, QCS<br><br>🏛️ <b>IACR — Институт за напредни композити и роботика</b><br>• Основан <b>2009</b> (16 години постоечки)<br>• Веќе во роботика! Не градиме од нула.<br>• Mikrosam Academy за обука на инженери<br><br>🏆 Награди:<br>• <b>3-ти Ноември 2025</b> (Општина Прилеп)<br>• Многу industry-firsts и patenти<br><br><b>Улога во Роботика Македонија:</b><br>• <b>18% удел</b> во проектот (лидер на JV)<br>• Носи 35-годишно know-how + IACR<br>• Прв индустриски робот: 2027 во ТИРЗ Прилеп<br>• Кадри од Mikrosam Academy + Careers<br><br>${link('#robotika-macedonia', 'Види ја улогата во проектот')}`,

    mf_skopje: `<b>🎓 Машински факултет — УКИМ Скопје</b><br><br>Машинскиот факултет на Универзитет „Св. Кирил и Методиј" има <b>50+ години експертиза</b> во:<br>• Механотроника и мехатроника<br>• Индустриски системи и автоматизација<br>• CAD/CAM, 3D печатење<br>• AI/ML за инженерство<br>• Над 200 професори и истражувачи<br><br><b>Улога во Роботика Македонија:</b><br>• 13% удел во проектот<br>• <b>Robotika Lab</b> — централен R&D хаб (отворање 2026)<br>• Обука на нови роботички инженери<br>• Тестирање и сертификација<br>• Партнерства со ETH Zurich, MIT, Tsinghua<br><br>${link('#robotika-macedonia', 'Види детали')}`,

    chinese_partners: `<b>🇨🇳 Кинески партнери · know-how трансфер</b><br><br>Кина е <b>светски лидер во производство на роботи</b> (45% од глобалниот капацитет). Robotika Macedonia има партнерство со 4 водечки кинески компании, <b>сите со малцински удел</b> (без контрола):<br><br>1. <b>UBTECH Robotics</b> — хуманоидни и едукативни роботи (Walker X модел)<br>2. <b>Geek+ (极智嘉)</b> — логистички AGV/AMR (DHL, GAP, Walmart)<br>3. <b>JAKA Robotics</b> — cobots (топ 3 во светот за колаборативни роботи)<br>4. <b>Estun Automation</b> — компоненти (Tesla, BYD партнер)<br><br><b>Принцип:</b> Кинеските партнери донесуваат know-how, ние одржуваме сопствеништво и брендирање. <b>Сите производи се македонски бренд.</b><br><br>${link('#robotika-macedonia', 'Види партнерства')}`,
    robotika_roadmap: `<b>🗺️ Robotika Macedonia · Roadmap 2026–2030</b><br><br><b>Q3 2026:</b> JV регистрација "Robotika Macedonia DOOEL" во ТИРЗ Прилеп<br><b>Q1–Q2 2027:</b> Прв R&D центар + 100 инженери<br><b>Q4 2027:</b> Прв македонски робот „Vardar-1" (заварувачки, 6-axis, €55K)<br><b>2028:</b> Втора фабрика Скопје 2 (медицински) + трета Битола (агро). ЕУ извоз<br><b>2029:</b> Сервисни роботи + AI · 3,000 вработени · Балкан пазар<br><b>2030:</b> Топ 5 во ЕУ · 5,500 места · €450M инвестиција · 8,000 роботи годишно<br><br>${link('#robotika-macedonia', 'Види детален план')}`,

    robotika_workforce: `<b>👥 5,500 работни места во Robotika · Распределба</b><br><br><b>По функција:</b><br>• 🔧 1,800 инженери<br>• 🏭 2,200 техничари/оператори<br>• 🎓 500 R&D истражувачи<br>• 🛠️ 400 сервис<br>• 📊 350 менаџмент<br>• 🚚 250 логистика<br><br><b>Откаде:</b><br>• 1,200 МФ Скопје нови дипломирани<br>• 800 други мак. универзитети<br>• 1,500 дијаспорски инженери (враќање!)<br>• 1,200 reskilling (текстил → робот)<br>• 300 странски експерти<br>• 500 млади со 6-мес. обука<br><br>${link('#robotika-macedonia', 'Аплицирај за работа')}`,
    guide_steps: `<b>📋 Упатство по чекори · 3 патишта</b><br><br>Имаш <b>3 различни патишта</b> зависно каде се наоѓаш:<br><br>🇲🇰 <b>Македонија</b> — 30 мин · 150 ден. · 5 чекори<br>1. Подготви документи (ЛК, ЕМБГ)<br>2. Пополни форма<br>3. Преземи PDF изјава<br>4. Кај нотар (физички или дигитален)<br>5. Прати скен<br><br>🇪🇺 <b>ЕУ дијаспора</b> — 25 мин · €30 · 6 чекори<br>1. Провери го твојот еИД (Personalausweis, SPID, BankID, итн.)<br>2. Пополни форма<br>3. Резервирај дигитален нотар<br>4. Видео-сесија (15 мин)<br>5. Преземи документ<br>6. Готово!<br><br>🌍 <b>Прекуокеан дијаспора</b> (САД, Канада, Австралија) — 1–2 недели · ~$80 · 7 чекори<br>• Опција А: Македонска амбасада<br>• Опција Б: Локален нотар + Hague апостил<br><br>${link('#guide', 'Види детално упатство')}`,
    paragraf: `<b>⚖️ Paragraf.mk · Правен AI партнер</b> · <a href="https://paragraf.mk" target="_blank" style="color:var(--gold-soft)">paragraf.mk</a><br><br>Стратешки правен партнер на М-С — водечка македонска LexAI платформа.<br><br>📊 Што нудат:<br>• <b>LexAI</b> — AI правен асистент обучен на македонско право<br>• <b>Генератор на документи</b> — договори, поднесоци, обрасци<br>• <b>Предвидувач на исход и ризик</b> — ML модели на судска пракса<br>• <b>5 јазици</b> · GDPR · EU хостинг<br><br>🤝 Улога во М-С:<br>• <b>Адв. Стоjанкиќ</b> — основачки правен консултант<br>• Целосна правна инфраструктура за партнерства<br>• 24-часовен правен преглед за инвеститори (наспроти 2-4 недели традиционално)<br>• 60% побрз due diligence за странски партнери<br>• Compliance dashboard за сите 7 шампиони<br><br>📍 ул. Фрањо Клуз 3, Скопје<br>📞 (+389) 77 883 533<br>📧 info@paragraf.mk<br><br><i>„Странските инвеститори имаат именуван правен партнер од прв ден — не анонимна канцеларија."</i><br><br>${link('#party-networking', 'Контактирај правен тим')}`,
    paragraf_member: `<b>⚖️ Заверка на изјава преку Paragraf.mk</b><br><br>М-С има <b>стратешко партнерство</b> со <a href="https://paragraf.mk" target="_blank" style="color:var(--gold-soft)">Paragraf.mk</a> — водечка македонска LexAI правна платформа.<br><br><b>Адв. Стојанкиќ</b> е именуван овластен правен партнер за заверка на изјави за основачи.<br><br>📋 Како функционира:<br>1. Оди на <b>paragraf.mk</b> и регистрирај се (бесплатна основна регистрација)<br>2. Внеси ги твоите податоци (ЕМБГ, ЛК, адреса)<br>3. LexAI ја генерира изјавата за основач со <b>пред-валидирани правни клаузули</b><br>4. Видео-сесија со Адв. Стојанкиќ или назначен нотар (15 мин)<br>5. Електронски потпис со полна правна валидност (ЗЕДЕИДУ + eIDAS)<br>6. PDF се испраќа на твоjа е-пошта и автоматски на М-С<br><br>✅ Предности:<br>• <b>15 минути</b> вкупно (наспроти 1-2 недели традиционално)<br>• <b>Од било каде во светот</b> (за дијаспора особено важно)<br>• <b>5 јазици</b> (мк, ен, ал, ср, де)<br>• <b>GDPR · EU хостинг</b><br>• <b>LexAI верификација</b> на сите правни клаузули<br>• <b>Полна правна валидност</b> согласно член 53б Закон за нотарите<br><br>📍 ул. Фрањо Клуз 3, Скопје<br>📞 (+389) 77 883 533<br>📧 info@paragraf.mk<br>📧 legal@makedonijasistem.mk (за М-С прашања)<br><br>${link('#founders-drive', 'Започни регистрација')}`,
    financial_hub: `<b>✈️ Скопје Глобален Финансиски Хаб · Шампион #8</b><br><br>Стратешка визија: <b>50+ светски финансиски магнати</b> се сместуваат во <b>бесцаринската зона на Меѓународниот аеродром Скопје</b>.<br><br>📊 Win-win формула:<br>• <b>0% корпоративен данок</b> за нив<br>• <b>1% од приходите</b> за Македонија<br>• Цел: €500M+ годишен приход за РСМ<br><br>💼 Што добиваат магнатите:<br>• 0% корп. данок · 0% ДДВ<br>• Аеродром 24/7 на 100m<br>• EU/CEFTA пристап<br>• 4-часовна регистрација<br>• Луксузни канцеларии и хотел<br><br>🇲🇰 Што добива Македонија:<br>• <b>€500M+ годишно</b> (1% revenue share)<br>• 5,000+ високотехнолошки места<br>• Глобален бренд: „Дубаи на Балкан"<br>• €40M имотни приходи годишно<br>• €80M услуги бизнис<br><br>🌐 Споредба:<br>• 🇦🇪 Дубаи DIFC: 0% (50 год.)<br>• 🇸🇬 Сингапур: 17%<br>• 🇲🇺 Мауритиус: 3%<br>• 🇲🇰 <b>Скопје: 0% + 1% revenue share</b> (единствено!)<br><br>${link('#financial-hub', 'Види детали')}`,
    
    mining_resources: `<b>⛏️ Македонски Рудни Богатства · Шампион #9</b><br><br>Македонија има <b>светски значајни рудни наоѓалишта</b>. До сега експлоатирани со само 0.2% од GDP за нас. Со нашиот модел: <b>4-6% од GDP!</b><br><br>🎯 4 темелни принципи:<br>1. 🇲🇰 <b>≥51% домашно сопствеништво</b> — здружување на македонски компании<br>2. 🌿 <b>EBRD еколошки стандарди</b> + Equator Principles<br>3. 🏥 <b>30-год здравствена гаранција</b> за локалните жители<br>4. 💧 <b>24/7 хидрогеолошки мониторинг</b><br><br>📍 8 стратешки наоѓалишта:<br>• <b>Алшар</b> (Кавадарци) — УНИКАТ во светот: Tl-As-Sb-Au<br>• <b>Илoвица-Штука</b> (Струмица) — Cu-Au, NPV $513M, 30-год концесија<br>• <b>Кр. Паланка</b> — Sb-Au-Ag, US-backed €5M<br>• <b>Бучим</b> (Радовиш) — активен Cu-Au<br>• <b>Саса</b> (Мак. Каменица) — активен Pb-Zn-Ag<br>• <b>Тoраница</b> — Pb-Zn реактивирање<br>• <b>Злетово</b> (Пробиштип) — активен Pb-Zn<br>• <b>Боров Дол</b> (Радовиш) — Cu развој 2029<br><br>🤝 <b>Општествен договор:</b> Никој рудник без локален референдум >50% „за". Ако „против" — нема рудник. Така нема протести.<br><br>${link('#mining-resources', 'Види ги наоѓалиштата')}`,
    
    allchar: `<b>💎 Алшар (Allchar) · единствено наоѓалиште во светот</b><br><br>📍 Кавадарци · Ржaново<br><br>Алшар е <b>уникатно наоѓалиште</b> на:<br>• <b>Tl</b> талиум<br>• <b>As</b> арсен<br>• <b>Sb</b> антимон<br>• <b>Au</b> злато<br><br>🔬 Стратешко значење:<br>• Минералот <b>лорандит</b> (TlAsS₂) се користи за <b>детекција на неутрина</b> од сонцето<br>• Само наоѓалиште во светот за научни истражувања на овој комплекс<br>• Стратешко за NASA, CERN, и неутрино физика<br><br>🌿 М-С пристап:<br>• Не масовна експлоатација (ризик за уникатноста)<br>• Селективна еколошка експлоатација<br>• Партнерство со меѓународни истражувачки центри<br>• Локална вработеност + здравствена гаранција<br><br>${link('#mining-resources', 'Види детали')}`,
    
    ilovica: `<b>⛏️ Илoвица-Штука · Cu-Au наоѓалиште</b><br><br>📍 Струмица · 20 km<br><br>📊 Клучни параметри:<br>• <b>NPV $513 милиони</b> (по даноци)<br>• <b>IRR 19.8%</b><br>• <b>30-годишна концесија</b> за експлоатација<br>• 10 Mtpa bulk-mining<br>• Бакар + злато<br><br>⚖️ Правен статус:<br>• Одобрен EIA (Environmental Impact Assessment)<br>• EBRD Performance Requirements<br>• Equator Principle compliance<br><br>🌿 М-С пристап:<br>• ≥51% домашно сопствеништво<br>• Hidrogeolошки мониторинг 24/7<br>• Реставрација на земјиштето во план<br>• Здравствена гаранција за 80,000 земјоделци во регионот<br>• <b>ЛОКАЛЕН РЕФЕРЕНДУМ</b> пред почеток<br><br>${link('#mining-resources', 'Види детали')}`,
    mk_drones: `<b>🛸 MK-Drones · Македонски Дронови · Шампион #10</b><br><br>Повеќенамечно производство на <b>беспилотни летала</b> за 5+ клучни сектори.<br><br>📊 Клучни бројки:<br>• <b>€1.2B</b> инвестиции<br>• <b>3,500</b> работни места<br>• <b>15,000 дронови/година</b> до 2030<br>• <b>≥51%</b> македонско сопствеништво<br><br>🎯 6 модели за 6 сектори:<br>• 🌾 <b>Берач</b> (аграр) — RTK GPS, NDVI, спрејер<br>• 📦 <b>Курир</b> (логистика) — 10kg, 60km, cold-chain<br>• 📺 <b>Камера</b> (TV) — 8K, gimbal, live 5G<br>• 🏗️ <b>Инспектор</b> (инфра) — Thermal, LiDAR<br>• 🚨 <b>Стража</b> (безбедност) — night vision, AED<br>• 📐 <b>Мапер</b> (геодезија) — photogrammetry, 3D<br><br>🤝 Здружен МК конзорциум:<br>• Микросам Прилеп — композитни шасии<br>• МФ УКИМ Скопје — R&D, автоконтрола<br>• ЗИМ Холдинг — метални компоненти<br>• Конти Хидропласт — пластика<br>• EVN — електроника, батерии<br>• Тиквеш + АРМ — тест полиго н<br>• 25+ МСП — делови, сервис<br>• Дијаспора — капитал, пазари<br><br>🤖 <b>Синергија со Robotika Macedonia:</b> иста АИ платформа, контрола, батерии = 50% помала R&D цена.<br><br>${link('#drones-macedonia', 'Види детали')}`,
    crm: `<b>📋 ЦРМ · Централен регистар на РСМ</b> · <a href="https://www.crm.com.mk/" target="_blank" style="color:#5fce7e;font-weight:700">crm.com.mk</a><br><br><span style="color:#5fce7e">🟢 Институција во процес на пристап — без потпишан договор сè уште</span><br><br>📊 Што е ЦРМ:<br>Централниот регистар е клучната институција за <b>регистрација на правни субјекти во Македонија</b>:<br>• Политички партии (член 14 од Закон за политички партии)<br>• Трговски друштва (за индустриските шампиони)<br>• Здруженија и фондации<br>• Регистар на општини и буџетски корисници<br><br>🎯 Зошто е важна за М-С:<br>• По собирање на <b>1,000 заверени основачи</b>, поднесокот за регистрација на партија се поднесува тука<br>• Сите 80+1 општини се регистрирани тука<br>• Сите 10 индустриски шампиони ќе бидат регистрирани тука како ДООЕЛ<br><br>📌 Сегашен статус:<br>Македонија — Систем е во <b>процес на пристап</b> до ЦРМ. <b>Договор за соработка не е сè уште потпишан</b> — затоа иконата е зелена (статус: pending).<br><br>📞 Контакт: види <a href="https://www.crm.com.mk/" target="_blank" style="color:#5fce7e;font-weight:700">crm.com.mk</a><br><br>${link('#institutional-framework', 'Види институционална рамка')}`,
    media_hub: `<b>📡 Медиумски Хаб · Press &amp; PR</b><br><br>База на сите <b>42+ македонски медиуми</b> за идна соработка и испраќање соопштенија.<br><br>📊 Категории:<br>• 📺 <b>10 ТВ</b>: МРТ, Sitel, Канал 5, Телма, Алсат, Алфа, 24Vesti, Sky, A1on, Klan<br>• 📻 <b>7 Радио</b>: МРА 1/2/3, Antenna 5, Канал 77, Metropolis, City Radio<br>• 💻 <b>14 Портали</b>: Republika, Slobodenpecat, Vecer, Faktor, Plusinfo, Kurir, A1on, DW, RFE/RL и др.<br>• 📰 <b>5 Печат</b>: Vest, Слободен Печат, Нова Македонија, Лице в Лице, Koha<br>• 📡 <b>3 Агенции</b>: МИА (државна), Meta.mk, BalkanInsight (BIRN)<br>• 🌍 <b>3 Дијаспора</b>: САД, Австралија, Канада<br><br>🎯 Функции:<br>• <b>Еден клик</b> до соопштение за цела категорија (BCC)<br>• Индивидуално контактирање секој медиум<br>• Филтрирање по категорија<br>• Барање по име<br>• Копирање сите email адреси<br><br>⚠️ <b>Сегашен статус:</b> Базата е <b>подготвена за идна употреба</b>. Сите контакти се <b>јавно достапни</b>. М-С ќе започне директна комуникација по официјална регистрација.<br><br>${link('#media-hub', 'Види ја цела база')}`,
















  };

  // Pattern matcher with priority order
  const PATTERNS = [

