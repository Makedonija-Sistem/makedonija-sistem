<!-- ═══ POLL TOOL ═══ -->
<section id="poll-tool">
  <div class="container">
    <div class="section-head reveal">
      <span class="label">📊 Жива анкета за јавно мислење</span>
      <h2 data-i18n="poll.title">Гласај <em>сега</em> — резултатите се менуваат во <em>реално време.</em></h2>
      <div id="pollOfflineBanner" class="poll-offline-banner" role="status" aria-live="polite">📡 Офлајн режим — гласовите ќе се испратат кога ќе се поврзете повторно.</div>
      <p>Секој посетител на платформата може да гласа од било која социјална мрежа или месинџер. Без ограничување на број на испитаници — сите гласови се запишуваат веднаш и резултатите се прикажуваат во живо. Анализа по партии, региони, демографија и време. Споделете со пријатели — повеќе гласови = поточна реалност.</p>
    </div>

    <!-- ═══ LIVE COUNTERS ═══ -->
    <div class="lp-stats reveal">
      <div class="lp-stat">
        <span class="lp-stat-icon">🗳️</span>
        <div class="lp-stat-num" id="lpTotalVotes">0</div>
        <span class="lp-stat-label">Вкупно гласови</span>
      </div>
      <div class="lp-stat">
        <span class="lp-stat-icon">📍</span>
        <div class="lp-stat-num" id="lpRegions">0</div>
        <span class="lp-stat-label">Региони покриени</span>
      </div>
      <div class="lp-stat">
        <span class="lp-stat-icon">⚡</span>
        <div class="lp-stat-num" id="lpToday">0</div>
        <span class="lp-stat-label">Гласови денес</span>
      </div>
      <div class="lp-stat">
        <span class="lp-stat-icon">🌐</span>
        <div class="lp-stat-num" id="lpDiaspora">0</div>
        <span class="lp-stat-label">Дијаспора</span>
      </div>
    </div>

    <!-- ═══ MAIN VOTING UI ═══ -->
    <div class="lp-main-grid">
      <!-- LEFT: Vote panel -->
      <div class="lp-vote-panel reveal">
        <div class="lp-vote-head">
          <span class="lp-badge">🟢 ОТВОРЕНА АНКЕТА</span>
          <h3>За која партија / опција би гласал/а на следните парламентарни избори?</h3>
          <p class="lp-vote-sublede">Изборот е анонимен. <strong>Може да гласаш само еднаш по уред</strong> — заштитата работи преку browser fingerprint (комбинација од твојот browser, екран, временска зона и системски подесувања). Ако сакаш да го промениш гласот — кликни „Промени глас". За гласање од друг уред, отвори ја платформата на мобилниот или друг компјутер.</p>
        </div>

        <!-- Party radio grid -->
        <div class="lp-options" id="lpOptions">
          <label class="lp-option" data-party="Македонија — Систем">
            <input type="radio" name="lp-vote" value="Македонија — Систем">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text">
              <strong>Македонија — Систем</strong>
              <small>Ред · Закон · Одговорност</small>
            </span>
          </label>
          <label class="lp-option" data-party="ВМРО-ДПМНЕ">
            <input type="radio" name="lp-vote" value="ВМРО-ДПМНЕ">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text"><strong>ВМРО-ДПМНЕ</strong></span>
          </label>
          <label class="lp-option" data-party="СДСМ">
            <input type="radio" name="lp-vote" value="СДСМ">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text"><strong>СДСМ</strong></span>
          </label>
          <label class="lp-option" data-party="ВЛЕН">
            <input type="radio" name="lp-vote" value="ВЛЕН">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text"><strong>ВЛЕН</strong></span>
          </label>
          <label class="lp-option" data-party="ДУИ">
            <input type="radio" name="lp-vote" value="ДУИ">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text"><strong>ДУИ</strong></span>
          </label>
          <label class="lp-option" data-party="Левица">
            <input type="radio" name="lp-vote" value="Левица">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text"><strong>Левица</strong></span>
          </label>
          <label class="lp-option" data-party="ЗНАМ">
            <input type="radio" name="lp-vote" value="ЗНАМ">
            <span class="lp-opt-mark"></span>
            <span class="lp-opt-text"><strong>ЗНАМ</strong></span>
          </label>
          <label class="lp-option" data-party="Алијанса за Албанците">
            <input type="radio" name="lp-vote" value="Алијанса за Албанците">
            <span class="lp-opt-mark"></span>
