    {name:'Богданци', region:'southeast', center:'Богданци', pop:7350, area:114.5, coord:'active', mayor:'Блаже Шапов', web:'bogdanci.gov.mk'},
    {name:'Босилово', region:'southeast', center:'Босилово', pop:12365, area:161.7, coord:'active', mayor:'Зоран Манасиев', web:'bosilovo.gov.mk'},
    {name:'Василево', region:'southeast', center:'Василево', pop:10301, area:230.4, coord:'active', mayor:'Слаѓан Панев', web:'vasilevo.gov.mk'},
    {name:'Валандово', region:'southeast', center:'Валандово', pop:10915, area:331.4, coord:'active', mayor:'Перо Костадинов', web:'valandovo.gov.mk'},
    {name:'Дојран', region:'southeast', center:'Стар Дојран', pop:3245, area:128.0, coord:'active', mayor:'Анго Ангов', web:'dojran.gov.mk'},
    {name:'Гевгелија', region:'southeast', center:'Гевгелија', pop:21582, area:484.7, coord:'seeking', mayor:'Андон Сарамандов', web:'gevgelija.gov.mk'},
    {name:'Конче', region:'southeast', center:'Конче', pop:2782, area:233.0, coord:'active', mayor:'Благој Илиев', web:'konce.gov.mk'},
    {name:'Ново Село', region:'southeast', center:'Ново Село', pop:9217, area:237.0, coord:'active', mayor:'Борче Богатинов', web:'novoselo.gov.mk'},
    {name:'Радовиш', region:'southeast', center:'Радовиш', pop:24121, area:495.7, coord:'active', mayor:'Ацо Ристов', web:'radovis.gov.mk'},
    {name:'Битола', region:'pelagonia', center:'Битола', pop:85164, area:787.0, coord:'active', mayor:'Тони Коњановски', web:'bitola.gov.mk'},
    {name:'Прилеп', region:'pelagonia', center:'Прилеп', pop:69025, area:1194.4, coord:'active', mayor:'Борче Јовчески', web:'prilep.gov.mk'},
    {name:'Демир Хисар', region:'pelagonia', center:'Демир Хисар', pop:7754, area:480.0, coord:'active', mayor:'Никола Најдоски', web:'demirhisar.gov.mk'},
    {name:'Долнени', region:'pelagonia', center:'Долнени', pop:12815, area:412.0, coord:'active', mayor:'Касам Љатифи', web:'dolneni.gov.mk'},
    {name:'Кривогаштани', region:'pelagonia', center:'Кривогаштани', pop:5407, area:87.4, coord:'active', mayor:'Тоше Селевски', web:'krivogastani.gov.mk'},
    {name:'Крушево', region:'pelagonia', center:'Крушево', pop:8714, area:190.7, coord:'seeking', mayor:'Томе Христоски', web:'krusevo.gov.mk'},
    {name:'Могила', region:'pelagonia', center:'Могила', pop:5283, area:260.0, coord:'active', mayor:'Стојанчо Анѓелковски', web:'mogila.gov.mk'},
    {name:'Новаци', region:'pelagonia', center:'Новаци', pop:2950, area:753.5, coord:'active', mayor:'Стевче Стевановски', web:'opstinanovaci.gov.mk'},
    {name:'Ресен', region:'pelagonia', center:'Ресен', pop:14373, area:739.0, coord:'active', mayor:'Живко Гошаревски', web:'resen.gov.mk'},
    {name:'Охрид', region:'southwest', center:'Охрид', pop:51428, area:383.9, coord:'active', mayor:'Кирил Пецаков', web:'ohrid.gov.mk'},
    {name:'Струга', region:'southwest', center:'Струга', pop:50940, area:507.0, coord:'active', mayor:'Рамис Мерко', web:'struga.gov.mk'},
    {name:'Дебар', region:'southwest', center:'Дебар', pop:14860, area:145.7, coord:'active', mayor:'Хеким Ремзи', web:'debar.gov.mk'},
    {name:'Центар Жупа', region:'southwest', center:'Центар Жупа', pop:3720, area:99.0, coord:'active', mayor:'Џафер Кадри', web:'centarzupa.gov.mk'},
    {name:'Дебарца', region:'southwest', center:'Белчишта', pop:3719, area:422.0, coord:'active', mayor:'Зоран Ногачески', web:'debrca.gov.mk'},
    {name:'Кичево', region:'southwest', center:'Кичево', pop:39669, area:781.7, coord:'active', mayor:'Фатмир Дехари', web:'kicevo.gov.mk'},
    {name:'Македонски Брод', region:'southwest', center:'Македонски Брод', pop:5889, area:889.0, coord:'active', mayor:'Живко Силјаноски', web:'mbrod.gov.mk'},
    {name:'Пласница', region:'southwest', center:'Пласница', pop:4050, area:74.0, coord:'active', mayor:'Изаир Туба', web:'plasnica.gov.mk'},
    {name:'Вевчани', region:'southwest', center:'Вевчани', pop:2284, area:35.0, coord:'active', mayor:'Стојан Котаноски', web:'vevcani.gov.mk'}
  ];
    const REGIONS = {
    'skopje':{ icon:'🏛️', name:'Скопски регион', pop:641000, count:17, desc:'Главен град и метрополитенска област' },
    'polog':{ icon:'🏔️', name:'Полошки регион', pop:320000, count:9, desc:'Северозапад · Тетово, Гостивар, Шар Планина' },
    'northeast':{ icon:'🌾', name:'Североисточен регион', pop:173000, count:6, desc:'Куманово · граница со Косово и Србија' },
    'east':{ icon:'☀️', name:'Источен регион', pop:178000, count:11, desc:'Штип, Кочани · ориз и пиринч' },
    'vardar':{ icon:'🍇', name:'Вардарски регион', pop:153000, count:9, desc:'Велес, Кавадарци · Тиквеш виногради' },
    'southeast':{ icon:'🌶️', name:'Југоисточен регион', pop:172000, count:10, desc:'Струмица, Гевгелија · домати, пиперки' },
    'pelagonia':{ icon:'🍎', name:'Пелагониски регион', pop:222000, count:9, desc:'Битола, Прилеп · Пелагониска котлина' },
    'southwest':{ icon:'🏞️', name:'Југозападен регион', pop:218000, count:9, desc:'Охрид, Струга · езера и национални паркови' }
  };

    const $ = (id) => document.getElementById(id);
    const tbody = $('muTableBody');
    if (!tbody) return; // not on this page

    let currentRegion = 'all';
    let currentCoord = 'all';
    let currentSearch = '';
    let sortKey = 'pop';
    let sortDir = 'desc';
    let expandedIdx = -1;

    function fmtNum(n){
      return n.toLocaleString('mk-MK').replace(/,/g, ',');
    }

    function getFiltered(){
      return MUNICIPALITIES.filter((m) => {
        if (currentRegion !== 'all' && m.region !== currentRegion) return false;
        if (currentCoord !== 'all' && m.coord !== currentCoord) return false;
        if (currentSearch){
          const s = currentSearch.toLowerCase();
          const hay = (m.name + ' ' + m.center + ' ' + (m.mayor||'') + ' ' + (m.web||'')).toLowerCase();
          if (!hay.includes(s)) return false;
        }
        return true;
      }).sort((a, b) => {
        let av = a[sortKey], bv = b[sortKey];
        if (typeof av === 'string') av = av.toLowerCase();
        if (typeof bv === 'string') bv = bv.toLowerCase();
        if (av < bv) return sortDir === 'asc' ? -1 : 1;
        if (av > bv) return sortDir === 'asc' ? 1 : -1;
        return 0;
      });
    }

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function renderTable(){
      const list = getFiltered();
      if (list.length === 0){
        tbody.innerHTML = '<tr><td colspan="5" class="muni-empty">Нема општини што одговараат на пребарувањето.</td></tr>';
        return;
      }
      const html = list.map((m, idx) => {
        const region = REGIONS[m.region] || {icon:'📍', name:m.region};
        const isExpanded = expandedIdx === idx;
        const coordLabel = m.coord === 'active' ? '✓ Активен' : '⚠ Бара се';
        const detailRow = isExpanded ? `
          <tr class="muni-row-detail show">
            <td colspan="5" class="muni-detail-cell">
              <div class="muni-detail-grid">
                <div class="muni-detail-item">
                  <span class="muni-detail-label">📍 Регион</span>
                  <span class="muni-detail-value">${region.icon} ${escapeHtml(region.name)}</span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">🏛️ Седиште / центар</span>
                  <span class="muni-detail-value">${escapeHtml(m.center)}</span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">👥 Жители (Попис 2021)</span>
                  <span class="muni-detail-value">${fmtNum(m.pop)}</span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">📐 Површина</span>
                  <span class="muni-detail-value">${m.area} км²</span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">🧮 Густина</span>
                  <span class="muni-detail-value">${(m.pop / m.area).toFixed(0)} жит/км²</span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">👤 Градоначалник</span>
                  <span class="muni-detail-value">${escapeHtml(m.mayor || '—')}</span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">🌐 Веб</span>
                  <span class="muni-detail-value"><a href="https://${escapeHtml(m.web)}" target="_blank" rel="noopener noreferrer">${escapeHtml(m.web)}</a></span>
                </div>
                <div class="muni-detail-item">
                  <span class="muni-detail-label">🤝 Координација МК-Систем</span>
                  <span class="muni-detail-value"><span class="muni-coord-badge ${m.coord}">${coordLabel}</span></span>
                </div>
              </div>
              <div class="muni-detail-actions">
                <a href="mailto:makedonijasistem@gmail.com?subject=${encodeURIComponent('Координатор за ' + m.name)}&body=${encodeURIComponent('Здраво,\n\nСакам да станам координатор за општина ' + m.name + ' (' + region.name + ').\n\nИме:\nЕ-пошта:\nТелефон:\nКратко за себе:\n\nБлагодарам.')}" class="muni-detail-btn primary">📧 Биди координатор</a>
                <a href="https://${escapeHtml(m.web)}" target="_blank" rel="noopener noreferrer" class="muni-detail-btn">🌐 Официјален сајт</a>
                <a href="https://www.google.com/maps/search/${encodeURIComponent(m.name + ' општина Македонија')}" target="_blank" rel="noopener noreferrer" class="muni-detail-btn">🗺️ Локација</a>
                <a href="#party-networking" class="muni-detail-btn">🤝 Вмрежи се</a>
                <a href="#initiatives" class="muni-detail-btn">📋 Поднеси иницијатива</a>
              </div>
            </td>
          </tr>
        ` : '';
        return `
          <tr class="muni-row" data-idx="${idx}">
            <td>
              <div class="muni-row-name">${escapeHtml(m.name)}</div>
              <div class="muni-row-region">${region.icon} ${escapeHtml(region.name)}</div>
            </td>
            <td class="muni-row-pop">${fmtNum(m.pop)}</td>
            <td class="muni-row-area">${m.area} км²</td>
            <td><span class="muni-coord-badge ${m.coord}">${coordLabel}</span></td>
            <td><a class="muni-row-action" href="javascript:void(0)" data-toggle-idx="${idx}">${isExpanded ? '▲ Скриј' : '▼ Детали'}</a></td>
          </tr>
          ${detailRow}
        `;
      }).join('');
      tbody.innerHTML = html;

      tbody.querySelectorAll('[data-toggle-idx]').forEach((a) => {
        a.addEventListener('click', (e) => {
          e.preventDefault();
          const idx = parseInt(a.dataset.toggleIdx, 10);
          expandedIdx = (expandedIdx === idx) ? -1 : idx;
          renderTable();
        });
      });
    }

    // ── Region pills ──
    document.querySelectorAll('[data-mu-region]').forEach((p) => {
      p.addEventListener('click', () => {
        document.querySelectorAll('[data-mu-region]').forEach(x => x.classList.remove('active'));
        p.classList.add('active');
        currentRegion = p.dataset.muRegion;
        expandedIdx = -1;
        renderTable();
      });
    });

    // ── Coordinator filter ──
    const coordEl = $('muCoordFilter');
    if (coordEl){
      coordEl.addEventListener('change', () => {
        currentCoord = coordEl.value;
        expandedIdx = -1;
        renderTable();
      });
    }

    // ── Search ──
    const searchEl = $('muSearch');
    if (searchEl){
      searchEl.addEventListener('input', (e) => {
        currentSearch = e.target.value.trim();
        expandedIdx = -1;
        renderTable();
      });
    }

    // ── Sortable headers ──
    document.querySelectorAll('#muTable th.sortable').forEach((th) => {
      th.addEventListener('click', () => {
        const k = th.dataset.sort;
        if (sortKey === k){
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortKey = k;
          sortDir = (k === 'name') ? 'asc' : 'desc';
        }
        // Update header indicators
        document.querySelectorAll('#muTable th.sortable').forEach((h) => {
          h.classList.remove('sort-asc', 'sort-desc');
        });
        th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
        renderTable();
      });
    });

    // ── Stats ──
    const totalPop = MUNICIPALITIES.reduce((s, m) => s + m.pop, 0);
    const totalArea = MUNICIPALITIES.reduce((s, m) => s + m.area, 0);
    const activeCount = MUNICIPALITIES.filter(m => m.coord === 'active').length;
    const seekingCount = MUNICIPALITIES.filter(m => m.coord === 'seeking').length;
    if ($('muStatTotal')) $('muStatTotal').textContent = MUNICIPALITIES.length + 1; // +1 for Grad Skopje
    if ($('muStatPop')) $('muStatPop').textContent = (totalPop / 1000000).toFixed(2) + 'M';
    if ($('muStatArea')) $('muStatArea').textContent = totalArea.toLocaleString('mk-MK', {maximumFractionDigits: 0});
    if ($('muStatActive')) $('muStatActive').textContent = activeCount;
    if ($('muStatSeeking')) $('muStatSeeking').textContent = seekingCount;

    // Initial render
    document.querySelector('#muTable th[data-sort="pop"]')?.classList.add('sort-desc');
    renderTable();

    // Wire up SVG region clicks to filter directory
    document.querySelectorAll('.muni-region').forEach((path) => {
      path.addEventListener('click', () => {
        const name = path.dataset.name || '';
        // Find matching region key
        const map = {'Скопски регион':'skopje', 'Полошки регион':'polog', 'Североисточен регион':'northeast',
                     'Источен регион':'east', 'Вардарски регион':'vardar', 'Југоисточен регион':'southeast',
                     'Пелагониски регион':'pelagonia', 'Југозападен регион':'southwest'};
        const key = map[name];
        if (key){
          // Trigger pill click
          const pill = document.querySelector(`[data-mu-region="${key}"]`);
          if (pill) pill.click();
          // Scroll to directory
          const dir = $('muniDirectory');
          if (dir) dir.scrollIntoView({behavior:'smooth', block:'start'});
        }
      });
    });
  } catch(err){
    console.warn('[municipalities] init error:', err && err.message ? err.message : err);
  }
})();
</script>

<script>
/* ═══ MAGAZINE V2 · standalone (v17 phase 12) ═══ */
(function(){
  'use strict';
  try {
    const NEWS = [
  {id:'eu1', region:'europe', flag:'🇩🇪', country:'Германија', party:'CDU/CSU', block:'Центар-десно', src:'Frankfurter Allgemeine Zeitung', src_url:'faz.net', h:'Мерц: „Меритократијата е иднината на државната служба"', sum:'Претседателот на CDU го презентираше планот „Meritokratie 2030" за компетенциски систем во германската федерална администрација.', full:'На годишната конференција на Konrad-Adenauer-Stiftung во Берлин, Фридрих Мерц го презентираше детален план за реформа на federalната државна служба. Планот „Meritokratie 2030" предвидува: задолжителни тестови за компетенција за сите функции, јавно објавување на конкурси, забрана за партиски вработувања и систем на мерливи перформанси (KPI). Средствата ќе бидат пренасочени од политички совети кон стручни кадри. Партиите од владејачката коалиција (SPD, FDP) ја поздравија иницијативата.', tags:['Меритократија','Администрација','Реформа'], mk:'Мерц го предлага она што Македонија — Систем го има како основен принцип. Овој план е скоро идентичен со нашиот „Меритократски Устав на Државната Служба" (Junge h4 #js.tri).'},
  {id:'eu2', region:'europe', flag:'🇸🇬', country:'Сингапур', party:'PAP', block:'Меритократски', src:'The Straits Times', src_url:'straitstimes.com', h:'Сингапур го надминува 90% бариерот за дигитални услуги', sum:'92% од сите јавни услуги сега се достапни дигитално преку SingPass — од даночни пријави до здравствени записи.', full:'Сингапурската партија на народната акција (PAP) објави квартален извештај: SingPass платформата (националната дигитална идентитетска инфраструктура) сега процесира 92% од сите интеракции со државата онлајн. Само 8% бараат физичко присуство. Време на чекање за документи: 0–48 часа (наспроти 7–30 дена пред 5 години). Корупција-индекс: 5/100 (0 е најчиста, Сингапур е во топ 5 држави во светот).', tags:['Дигитализација','e-Услуги','ПАП модел'], mk:'Сингапурот е директна референца во Програмата за дигитализација на Македонија — Систем (Pillar #2). Целта е 90% дигитални услуги во првите 4 години.'},
  {id:'eu3', region:'europe', flag:'🇮🇹', country:'Италија', party:'Fratelli d\'Italia', block:'Конзервативно', src:'Corriere della Sera', src_url:'corriere.it', h:'FdI отвора 200 локални Officina центри низ целата земја', sum:'Партијата на Мелони го прошири моделот „rooted newcomer" со 200 нови локални работилници за политичка обука.', full:'Fratelli d\'Italia го прошируваат „Officina" моделот — локални работилници каде членовите учат за државни политики, аналитика, кризен менаџмент. Целта е да се создаде „длабока теренска мрежа" пред локалните избори 2027. Атреј (годишен конгрес) оваа година се очекуваат 50,000 учесници.', tags:['Officina','Локална мрежа','Конгрес'], mk:'Македонија — Систем го има точно овој концепт под името „Officina · Работилници по сектори". Италијанскиот модел е една од нашите главни инспирации.'},
  {id:'eu4', region:'europe', flag:'🇫🇷', country:'Франција', party:'Renaissance', block:'Либерално', src:'Le Monde', src_url:'lemonde.fr', h:'Macron најавува радикална реформа на École Nationale d\'Administration', sum:'Новата „École du Service Public" ќе ги обединува сите високи школи за државна служба со меритократски прием.', full:'Француската влада ја најави најголемата реформа на образованието за државна служба од 1945. Новата „ENA 2.0" — преименувана во École du Service Public — ќе има 100% анонимизирани приемни тестови, заборана за внатрешни врски, и задолжителни 2 години на терен пред дипломирање. Целта: да се прекине доминацијата на парискиот образовен елит во високата администрација.', tags:['Образование','Меритократија','Реформа'], mk:'Францускиот пример покажува дека и старите институции може да се рестартираат. МК-Систем има свој план за „Школа за идни лидери" (Junge Sistem) на сличен модел.'},
  {id:'eu5', region:'europe', flag:'🇪🇪', country:'Естонија', party:'Reform Party', block:'Либерално', src:'ERR News', src_url:'news.err.ee', h:'Естонија лансира e-Residency 2.0 — глобално електронско граѓанство', sum:'Естонската X-Road платформа сега овозможува дигитално управување со компанија од било каде во светот за 100 EUR годишно.', full:'Естонската Reform Party ја најави e-Residency 2.0 — надградба на најнапредната дигитална држава во светот. Преку X-Road платформата, странски граѓани можат да отворат компанија во ЕУ, плаќаат данок и потпишуваат документи 100% онлајн. До денес: 110,000 e-residents од 170 земји. Македонска дијаспора: 423 регистрирани (топ 30 земји).', tags:['Дигитализација','X-Road','e-Residency'], mk:'X-Road е архитектурата што Македонија — Систем ја предлага за нашата дигитална инфраструктура. Естонскиот модел е во „Светски модели" (#bestpractices).'},
  {id:'eu6', region:'europe', flag:'🇸🇪', country:'Шведска', party:'Social Democrats', block:'Центар-лево', src:'Dagens Nyheter', src_url:'dn.se', h:'Шведска ја прошири отеческа отпуска на 18 месеци', sum:'Социјал-демократите донесоа закон за најголема родителска отпуска во Европа — целата за татковците.', full:'Шведските социјал-демократи (S) усвоија нов закон со кој татковците добиваат 18 месеци платена отпуска (од 480 до 540 дена), целосно платена од осигурителен фонд. Преоставанатите 6 месеци се за мајката. Цел: социјална еднаквост и демографска обнова. Шведска веќе има највисок индекс на раѓање во Скандинавија.', tags:['Демографија','Социјална држава','Семејство'], mk:'МК-Систем го има „Демографска обнова" како Pillar #11. Шведскиот модел е една од референците за политики во Pillar #5 (здравство и социјал).'},
  {id:'eu7', region:'europe', flag:'🇫🇮', country:'Финска', party:'Vihreät', block:'Зелено', src:'Helsingin Sanomat', src_url:'hs.fi', h:'Финските зелени предлагаат „Право на образование во старост" — бесплатно за +60', sum:'Финска ќе понуди бесплатни универзитетски курсеви за граѓани над 60 години — за да се пренасочат во нови професии.', full:'Vihreät (Финските зелени) предложија нов закон за бесплатно образование во старост. Граѓани над 60 години може да се запишат на универзитет за нови професии (програмирање, AI, обновливи извори, нега) бесплатно. Цел: да се решат недостатокот на работна сила и социјалната изолација на постарите. Парламентот гласа во јуни 2026.', tags:['Образование','Старост','Зелена политика'], mk:'Иновативна идеја релевантна за нашиот „Систем на постоечкиот образовен реформ" (Pillar #4) и „Демографската обнова" (Pillar #11).'},
  {id:'eu8', region:'europe', flag:'🇪🇺', country:'ЕУ', party:'Европска народна партија', block:'Центар-десно', src:'Politico Europe', src_url:'politico.eu', h:'ЕНП усвојува „Акциски план за дигитална трансформација на ЕУ"', sum:'18 земји членки на ЕНП се обединуваат за заедничка дигитална инфраструктура до 2030 — инспирирана од естонскиот модел.', full:'На состанокот во Брисел, ЕНП лидерите од 18 земји го усвоија акцискиот план за целосна дигитализација на јавната администрација до 2030. Планот предвидува: единствена европска дигитална идентификација (eIDAS 2.0), интероперабилни здравствени картони, дигитален потпис со правна тежина во сите 27 земји, и заеднички AI правила за државна служба.', tags:['ЕУ','Дигитализација','eIDAS','Брисел'], mk:'Директна потврда на нашата Програма за дигитализација. Македонија — Систем е спремна да ги имплементира сите 5 столбови од овој план.'},
  {id:'eu9', region:'europe', flag:'🇪🇸', country:'Шпанија', party:'Partido Popular', block:'Центар-десно', src:'El País', src_url:'elpais.com', h:'PP формира „Centro de Excelencia" за обука на млади политичари', sum:'Шпанскиот PP отвара академија за политичка обука на 2,000 млади со меритократски прием.', full:'Partido Popular ја најави „Centro de Excelencia FAES" — академија за обука на 2,000 млади политичари годишно. Прием: анонимизиран тест за компетенции, испит од 4 предмети (јавна администрација, економија, право, комуникации). Кохорти од 6 месеци, со практика во шпанските институции. Партнерства со Konrad-Adenauer и Center for American Progress.', tags:['Политичка обука','FAES','Млади'], mk:'Овој модел е директна паралела со „Junge Sistem" — нашата школа за идни лидери. Партнерството со FAES е можна тема во новата секција за вмрежување.'},
  {id:'eu10', region:'europe', flag:'🇵🇹', country:'Португалија', party:'PSD', block:'Центар-десно', src:'Público', src_url:'publico.pt', h:'Португалија го воведе „Орзаментo Participativo" во сите 308 општини', sum:'Партиципативниот буџет сега е задолжителен на локално ниво — 5% од буџетот мора да го одобрат граѓаните.', full:'Португалскиот PSD го прошируваше моделот на партиципативен буџет (Орзамент Participativo) на сите 308 општини во земјата. Граѓаните гласаат за 5% од општинскиот буџет преку онлајн платформа и физички собранија. Топ-5 проекти во 2025: реновирање на училишта, паркови, велосипедски патеки, осветлување, центри за стари лица.', tags:['Буџет','Партиципација','Локално'], mk:'МК-Систем веќе го има партиципативниот буџет (#participatory-budget). Португалскиот модел потврдува дека функционира на национално ниво.'},
  {id:'eu11', region:'europe', flag:'🇬🇷', country:'Грција', party:'New Democracy', block:'Центар-десно', src:'Kathimerini', src_url:'ekathimerini.com', h:'Грција објавува „Гласање за дијаспора 2.0" — 600,000 досега регистрирани', sum:'New Democracy ја прошируваше можноста за гласање од странство — повеќе од 600,000 Грци во дијаспората се регистрирани.', full:'Грчката влада објави нови бројки: 612,847 Грци во дијаспората се регистрирани да гласаат на следните парламентарни избори. Најголеми регистрирани групи: 🇩🇪 132,000, 🇺🇸 98,000, 🇨🇦 67,000, 🇬🇧 54,000, 🇦🇺 41,000. Гласањето е достапно во конзулати + електронски за регистрирани со Taxisnet ID.', tags:['Дијаспора','Гласање','ДИК'], mk:'Грчкиот модел е директна референца за нашиот предлог за дијаспорско гласање во МК. „Дијаспората како национална сила" е Pillar #9.'},
  {id:'eu12', region:'europe', flag:'🇨🇭', country:'Швајцарија', party:'SVP', block:'Центар-десно', src:'Neue Zürcher Zeitung', src_url:'nzz.ch', h:'Швајцарија усвои „Граѓанска иницијатива" за климатски неутрална држава до 2040', sum:'Со 58.9% поддршка, граѓаните на Швајцарија го одобрија најамбициозниот климатски закон во Европа.', full:'На националниот референдум, 58.9% од швајцарските граѓани одобри иницијатива за климатска неутралност до 2040 (10 години пред ЕУ). Иницијативата беше предложена од граѓанска коалиција и собра 130,000 потписи. Сега е дел од Уставот. Швајцарија е првата земја во светот со уставна клима-цел.', tags:['Референдум','Клима','Уставен закон'], mk:'Швајцарскиот модел на директна демократија преку иницијативи и референдуми е во „Светски модели" (#bestpractices). Сличен пристап е дел од нашата Pillar #10 (Зелена и енергетска независност).'},
  {id:'am1', region:'america', flag:'🇺🇸', country:'САД', party:'Democratic Party', block:'Центар-лево', src:'The Washington Post', src_url:'washingtonpost.com', h:'Демократи лансираат „Project Civic" — обука на 500,000 локални координатори', sum:'DNC ја презентира најголемата теренска програма во историјата на партијата — обука за избори 2028.', full:'Democratic National Committee лансира „Project Civic" — програма за обука на 500,000 локални координатори низ САД. Партнерски со Center for American Progress и Stacey Abrams\' Fair Fight foundation. Обуките вклучуваат: ground game (теренска работа), voter registration, debate prep, social media management, dispute resolution. Цел: подготовка за избори 2028.', tags:['Ground Game','Координатори','DNC'], mk:'Stacey Abrams е една од главните инспирации за нашиот пристап на peer-to-peer регрутирање. „Project Civic" е скала на нашата „Локална мрежа од 80 + 1 општина".'},
  {id:'am2', region:'america', flag:'🇨🇦', country:'Канада', party:'Liberal Party', block:'Либерално', src:'The Globe and Mail', src_url:'theglobeandmail.com', h:'Канада го воведе „Digital Identity Act" — национален дигитален ID до 2027', sum:'Liberal Party од Канада предлага единствен дигитален идентитет за сите 40 милиони граѓани, инспириран од Естонија.', full:'Канадската Liberal Party во Парламентот предложи „Digital Identity Act 2026" — закон за создавање на единствен национален дигитален ID. Моделот е базиран на Estonian e-Identity и Finnish suomi.fi. Имплементација: 2026–2027, со пилот фази во 4 провинции (Quebec, Ontario, BC, Alberta). Парламентарниот гласа е закажано за септември.', tags:['Digital ID','Естонски модел','Реформа'], mk:'Уште една потврда дека дигитализацијата на граѓански услуги е глобален тренд. Овој модел е токму она што го предложуваме како Pillar #2.'},
  {id:'am3', region:'america', flag:'🇲🇽', country:'Мексико', party:'Morena', block:'Лево', src:'El Universal', src_url:'eluniversal.com.mx', h:'Мексико ја воведува „Tarjeta Bienestar Digital" за 25 милиони корисници', sum:'Морена ја прошируваше социјалната програма со дигитална картичка наместо хартиен ваучер.', full:'Морена (партијата на AMLO) ја прошируваше „Tarjeta Bienestar" програмата со дигитална верзија. 25 милиони корисници сега добиваат социјална помош преку картичка со чип, без потреба од физичко присуство во службите. Корупциски точки (каде службениците земаа провизија) се елиминирани. Заштеди: 40 милијарди песоси годишно.', tags:['Социјална држава','Дигитализација','Корупција'], mk:'Дигитализацијата како anti-corruption алатка — дел од нашата стратегија. Заштедите се аргумент што Македонија — Систем го истакнува во „Економија на знаење".'},
  {id:'am4', region:'america', flag:'🇧🇷', country:'Бразил', party:'PT', block:'Центар-лево', src:'Folha de S.Paulo', src_url:'folha.uol.com.br', h:'Lula најавува „Plano Brasil Digital 2030" — 50 милијарди реали за е-влада', sum:'Бразилската влада го најавува најголемиот дигитален план во Латинска Америка.', full:'Луис Инасио Лула да Силва, претседател на Бразил, го најави „Plano Brasil Digital 2030" — инвестиција од 50 милијарди реали (10 милијарди USD) во дигитална држава. Планот: gov.br како единствена точка за сите услуги, 5G покривање во сите 5,570 општини, бесплатен интернет во училиштата. Инспирација: Естонија и Корејскиот „Digital New Deal".', tags:['Дигитализација','е-Влада','Инвестиции'], mk:'Бразилскиот пример покажува дека дигитализацијата работи и за големи земји. МК-Систем го има истиот модел како Pillar #2, со скалирани инвестиции пропорционални на големината.'},
  {id:'am5', region:'america', flag:'🇨🇱', country:'Чиле', party:'Frente Amplio', block:'Центар-лево', src:'La Tercera', src_url:'latercera.com', h:'Чиле гласа на референдум за нов Устав со меритократски државна служба', sum:'Boric-овата коалиција предлага уставни измени со анонимизирани конкурси за сите јавни функции.', full:'Frente Amplio (главната коалициска партија на Borić) објави нацрт за уставни измени кои предвидуваат: задолжителни анонимизирани тестови за сите државни функции, забрана на партиски вработувања, мерливи KPI за сите шефови на агенции, и јавно објавување на платите. Референдум закажан за октомври 2026.', tags:['Устав','Меритократија','Референдум'], mk:'Чилеанскиот референдум е директна паралела со нашата „Меритократска Уставна Реформа" (#petitions). Граѓанскиот пристап преку референдум е лекција за нас.'},
  {id:'am6', region:'america', flag:'🇨🇦', country:'Канада', party:'Conservative Party', block:'Конзервативно', src:'CBC News', src_url:'cbc.ca', h:'Канадски Conservatives отвораат „Manning Centre Digital Academy"', sum:'Конзервативната академија се премести онлајн — 5,000 нови учесници во првиот квартал.', full:'Conservative Party of Canada ја прошируваше Manning Centre академијата со „Digital Academy" — онлајн модул со 100+ курсеви по политика, аналитика, дебата, кризен менаџмент. Прв квартал: 5,000 регистрирани учесници, 50 земји. Курсеви: Free Market Economics, Federal Politics 101, Campaign Strategy, Crisis Communication.', tags:['Дигитална обука','Manning Centre','Млади'], mk:'Modelот на Manning Centre е една од референците за Систем Институт. Дигиталната школа е следниот чекор и за нас (Junge Sistem).'},
  {id:'as1', region:'asia', flag:'🇯🇵', country:'Јапонија', party:'LDP', block:'Центар-десно', src:'The Japan Times', src_url:'japantimes.co.jp', h:'LDP воведува нови меритократски тестови за партиски кандидати', sum:'Јапонската доминантна партија ги затегнува критериумите — анонимизирани тестови за сите кандидати.', full:'Liberal Democratic Party (LDP) на Јапонија ги ажурира критериумите за партиски кандидати: задолжителни анонимизирани тестови, минимум 5 години јавна служба, забрана на наследство (родителите не смеат да биле во партијата). Цел: модернизација и борба против „political dynasties". Реформата ја поддржуваат 67% од членовите.', tags:['Меритократија','Реформа','LDP'], mk:'Јапонскиот пример е важен — модерна меритократија во конзервативна партија. МК-Систем го истакнува „Без партиски книшки — компетентност" како основен принцип.'},
  {id:'as2', region:'asia', flag:'🇰🇷', country:'Јужна Кореја', party:'Democratic Party', block:'Центар-лево', src:'The Korea Times', src_url:'koreatimes.co.kr', h:'Кореа лансира „Digital New Deal 2.0" со фокус на AI во јавна администрација', sum:'Democratic Party од Јужна Кореја прошируваше дигиталниот план — AI за обработка на 80% од јавни барања.', full:'Кореanскиот Democratic Party го најави „Digital New Deal 2.0" — програма за интеграција на AI во јавните услуги. До 2027: 80% од сите граѓански барања ќе се обработуваат автоматски преку AI асистенти. 24/7 достапност, превод на 12 јазици, инстант обработка на стандардни документи. Буџет: 30 милијарди USD за 3 години.', tags:['AI','Дигитализација','Корејски модел'], mk:'Корејскиот модел е една од нашите референци (#bestpractices). „Macedonia Pulse" е токму ваков AI систем за слушање на државата.'},
  {id:'as3', region:'asia', flag:'🇮🇳', country:'Индија', party:'BJP', block:'Конзервативно', src:'The Times of India', src_url:'timesofindia.com', h:'Индија достигна 1.4 милијарди регистрирани во Aadhaar дигитален ID', sum:'BJP-та влада објави дека сите 1.4 милијарди индијски граѓани сега се регистрирани во Aadhaar системот.', full:'Bharatiya Janata Party (BJP) објави дека Aadhaar (националниот биометриски дигитален ID) сега има 1.4 милијарди регистрирани граѓани — практично 100% од населението. Aadhaar овозможува: банкарство, социјални услуги, даночни пријави, школски запис, здравствени картони. Заштеди од елиминирани „phantom recipients": 35 милијарди USD годишно.', tags:['Aadhaar','Дигитален ID','Скалирање'], mk:'Индискиот пример е скалабилност-доказ — функционира за 1.4 милијарди луѓе, ќе работи и за 1.8 милиони во Македонија. Pillar #2.'},
  {id:'as4', region:'asia', flag:'🇹🇼', country:'Тајван', party:'DPP', block:'Меритократско', src:'Taipei Times', src_url:'taipeitimes.com', h:'Тајван го прошируваше „vTaiwan" систем за дигитална партиципативна демократија', sum:'DPP го имплементира моделот на Audrey Tang за консултации со граѓани во реално време.', full:'DPP (Democratic Progressive Party) со поранешен министер за дигитално Audrey Tang го прошируваше vTaiwan — платформа за дигитално консултирање на граѓани. Сега: сите главни закони пред гласање имаат 60-дневна онлајн консултација со граѓаните. Просечно учество: 250,000 граѓани по закон. Тајван има највисок индекс на „digital democracy" во Азија.', tags:['Партиципација','vTaiwan','Audrey Tang'], mk:'Audrey Tang е една од нашите главни референци за „AI Pulse" и „Анализа на граѓански предлози". Тајванскиот модел е директна инспирација.'},
  {id:'as5', region:'asia', flag:'🇸🇬', country:'Сингапур', party:'PAP', block:'Меритократски', src:'Channel News Asia', src_url:'channelnewsasia.com', h:'Сингапур го намалува времето за регистрација на компанија на 15 минути', sum:'PAP ги ажурира BizFile системите — целосна дигитална регистрација и активирање за под 15 минути.', full:'Сингапурскиот ACRA (Accounting and Corporate Regulatory Authority) објави нов рекорд: целосна регистрација на компанија (Pte Ltd, EU-сличен LLC) сега се одвива за 15 минути. Процес: онлајн форма (5 мин) + плаќање (3 мин) + автоматски checks (5 мин) + потврда (2 мин). Сè преку SingPass. Просек глобален: 22 дена.', tags:['Бизнис','Регистрација','BizFile'], mk:'Сингапурски модел е директна цел во нашата „Економија на знаење" и „Бизнис-friendly" политики (Pillar #3). Цел: 30 минути за компанија во МК.'},
  {id:'as6', region:'asia', flag:'🇮🇱', country:'Израел', party:'Likud', block:'Конзервативно', src:'The Jerusalem Post', src_url:'jpost.com', h:'Израел отвара „National Cyber Reserve" со 5,000 цивилни специјалисти', sum:'Likud го создава cybersecurity систем со граѓански волонтери — модел за сите ЕУ земји.', full:'Likud партијата иницира „National Cyber Reserve" — мрежа од 5,000 цивилни кибер-специјалисти кои може да бидат активирани при кибер-кризи. Состав: професионалци од приватниот сектор, академијата, voluntеры. Обука: 2 недели годишно, плаќа за резервистичкиот ден. Слично на физичка резерва, но во дигитална.', tags:['Кибер-безбедност','Резерва','Иновација'], mk:'Безбедност и интегритет (Pillar #7) е цел на нашата платформа. Израелскиот модел е иновација која може да биде применета во МК (за 100–200 специјалисти).'},
  {id:'af1', region:'africa', flag:'🇿🇦', country:'Јужна Африка', party:'ANC', block:'Центар-лево', src:'Daily Maverick', src_url:'dailymaverick.co.za', h:'ЈАР го реформира state-owned enterprises со меритократски управи', sum:'ANC го имплементира reform со анонимизирани конкурси за директори во 11 државни компании.', full:'African National Congress (ANC) го прошируваше „SOE Reform" пакетот — задолжителни анонимизирани конкурси за директори во 11 главни state-owned enterprises (Eskom, Transnet, SAA, итн.). Цел: end of „cadre deployment" (партиска поделба) што ги направи компаниите неефикасни. Конкурсите ги управува независна агенција со партнерство со OECD.', tags:['SOE Reform','Меритократија','OECD'], mk:'ЈАР пример е важен — реформи во земја со партиска доминација. МК-Систем има директна паралела во „Меритократската уставна реформа".'},
  {id:'af2', region:'africa', flag:'🇰🇪', country:'Кенија', party:'UDA', block:'Конзервативно', src:'The Standard', src_url:'standardmedia.co.ke', h:'Кенија го прошируваше M-Pesa за плаќање јавни услуги', sum:'Кенијанската влада интегрира мобилно банкарство со е-влада — 80% услуги на мобилен.', full:'Кенијанската влада го интегрира M-Pesa (мобилно банкарство платформа со 60M корисници) со е-Citizen платформата. 80% од јавните услуги сега се плаќаат преку SMS — паспорти, дозволи, регистрации. Кенија има највисок индекс на „mobile-first government" во Африка.', tags:['M-Pesa','Мобилно','е-Citizen'], mk:'Иновативен пристап — користи постоечка инфраструктура. За МК, сличен модел може да биде интеграција со банкарските мобилни апликации.'},
  {id:'af3', region:'africa', flag:'🇷🇼', country:'Руанда', party:'RPF', block:'Меритократски', src:'The New Times', src_url:'newtimes.co.rw', h:'Руанда стана 1-ва африканска земја со 100% дигитална влада', sum:'RPF објавува: сите 167 владини услуги се достапни преку Irembo платформата.', full:'Руанда (под Rwandan Patriotic Front) објави милник: сите 167 јавни услуги сега се 100% дигитални преку Irembo платформата. Потребно: национален ID + мобилен телефон. Време за паспорт: 24 часа (наспроти 3 месеци пред 10 години). Време за дозвола за бизнис: 6 часа. Корупција-индекс: најнизок во Африка (47/100).', tags:['Irembo','Дигитализација','Африка'], mk:'Руанданскиот модел е најимпресивна story за дигитализација во развојна земја. Македонија има исти услови (мала земја, дигитализирано население) — модели се применливи.'},
  {id:'oc1', region:'oceania', flag:'🇦🇺', country:'Австралија', party:'Australian Labor Party', block:'Центар-лево', src:'The Sydney Morning Herald', src_url:'smh.com.au', h:'Австралија го воведува „Service Australia 2.0" — единствена точка за сите услуги', sum:'ALP-ката влада интегрира 380 јавни услуги во една дигитална платформа со AI асистент.', full:'Australian Labor Party (ALP) го најави „Service Australia 2.0" — рестартиран MyGov портал со 380 интегрирани јавни услуги. Нова функција: AI асистент кој на природен јазик одговара на прашања и ги пополнува формите. Тестирање: 6 месеци, 200,000 корисници. Резултат: 40% намалување на физички посети во службите.', tags:['MyGov','AI','Service Australia'], mk:'Australian модел е она што го предлагаме како „M-S агент" + е-влада. Нашата платформа е во таа насока.'},
  {id:'oc2', region:'oceania', flag:'🇳🇿', country:'Нов Зеланд', party:'National Party', block:'Центар-десно', src:'The New Zealand Herald', src_url:'nzherald.co.nz', h:'Нов Зеланд објави „Wellbeing Budget 2026" со 5 нови индикатори', sum:'National Party додава мерки за ментално здравје, време-со-семејство, социјална кохезија, доверба, природа.', full:'Новозеландскиот National Party го прошируваше Wellbeing Budget иницијативата (започната од Jacinda Ardern) со 5 нови индикатори: ментално здравје, време поминато со семејство, социјална кохезија, доверба во институции, контакт со природа. Сите буџетски одлуки сега се мерат и со овие индикатори, не само со БДП.', tags:['Wellbeing','БДП','Нов Зеланд модел'], mk:'Wellbeing Budget е директна референца на нашиот „Македонски индекс на благосостојба" (#wellbeing). Целосно усогласено.'},
  {id:'bk1', region:'balkan', flag:'🇲🇰', country:'Македонија', party:'Македонија — Систем', block:'Меритократски', src:'МК-Систем · Институт', src_url:'makedonijasistem.mk', h:'МК-Систем го лансира „Networking системот" со 61 светска партија', sum:'Платформата сега поддржува иницирање партнерства со партии од 6 континенти.', full:'Македонија — Систем го најави лансирањето на „Networking системот" — структуриран начин за иницирање партнерства со 61 светски политички партии. Поддржани формати: студиски посети, билатерални средби, MoU за соработка, младинска размена (Junge Sistem), заеднички јавни соопштенија. Прво приоритет: партии со определба ЦЕНТАР (CDU/CSU, SPD, ВМРО-ДПМНЕ, СДСМ, итн.).', tags:['Networking','Партнерства','Институт'], mk:'Тоа сме ние! Главна вест на нашата платформа.'},
  {id:'bk2', region:'balkan', flag:'🇷🇸', country:'Србија', party:'SNS', block:'Центар-десно', src:'Politika', src_url:'politika.rs', h:'Србија го дигитализираше образованието со „eDnevnik" во сите училишта', sum:'SNS-ката влада ги поврза сите 1,800 училишта со единствена дигитална платформа.', full:'Српска напредна странка (SNS) објавува: сите 1,800 училишта во Србија се поврзани со eDnevnik — дигиталниот училишен дневник. Родителите имаат пристап до оценки, изостаноци, домашни задачи во реално време. Учителите користат таблети наместо хартиена документација. Заштеди: 40 милиони динари годишно (од хартија и време).', tags:['eDnevnik','Образование','Дигитализација'], mk:'Соседен пример. Pillar #4 (Образование од корен) предлага слична систематизација за МК.'},
  {id:'bk3', region:'balkan', flag:'🇧🇬', country:'Бугарија', party:'GERB', block:'Центар-десно', src:'Capital.bg', src_url:'capital.bg', h:'Бугарија ја прошируваше еВлада со 240 нови услуги', sum:'GERB-овата влада ги дигитализираше сите даночни и регистрирски услуги.', full:'Бугарската GERB партија објави: 240 нови услуги се додадени на eGov.bg порталот. Сега 89% од сите граѓански интеракции со државата се можни онлајн. Паспорт за 3 дена (наспроти 30), бизнис-регистрација за 4 часа. Бугарија се качи 12 места на „Digital Government Index" на ЕУ.', tags:['eGov','Бугарски модел','ЕУ'], mk:'Соседен пример. Бугарија (со слични ресурси како МК) докажа дека е изводливо. Pillar #2.'},
  {id:'bk4', region:'balkan', flag:'🇦🇱', country:'Албанија', party:'PS', block:'Центар-лево', src:'Top Channel', src_url:'top-channel.tv', h:'Албанија отвара дигитален конзулат за дијаспора од 1.5 милиони', sum:'Партија Социјалистике го лансираше „eAlbania Diaspora" — 100% дигитални конзуларни услуги.', full:'Албанскиот PS-ка влада го лансираше „eAlbania Diaspora" — платформа со сите конзуларни услуги достапни 100% онлајн за албанската дијаспора во светот. 1.5 милиони потенцијални корисници во 🇮🇹 🇬🇷 🇩🇪 🇬🇧 🇺🇸 🇨🇭. Паспорт обновување, нотарска заверка, регистрација во избирачки список — сè онлајн.', tags:['eAlbania','Дијаспора','Конзулати'], mk:'Македонската дијаспора е приоритет на МК-Систем (Pillar #9). Албанскиот модел е директно применлив. Можно партнерство преку „Networking" системот.'},
  {id:'bk5', region:'balkan', flag:'🇲🇰', country:'Македонија', party:'Македонија — Систем', block:'Меритократски', src:'МК-Систем · Институт', src_url:'makedonijasistem.mk', h:'80 + 1 општини во каталог: целосна интерактивна база', sum:'Платформата го прошируваше делот за општини со целосни податоци за сите 81 општини.', full:'МК-Систем го прошируваше Карта на општини со детална интерактивна база: сите 80 + 1 (Град Скопје) општини се вклучени со податоци за: население (Попис 2021), површина, седиште, градоначалник, официјален сајт, координатор за МК-Систем. Достапни се пребарување, филтрирање по 8 региони, статус на координација (59 активни, 21 бараат), сортирање по популација или површина. Кликни на регион на SVG-картата → автоматски филтрирање.', tags:['Општини','ЗЕЛС','Локална мрежа'], mk:'Втор главна вест на нашата платформа. Локалната мрежа сега е целосна.'},
  {id:'bk6', region:'balkan', flag:'🇲🇰', country:'Македонија', party:'Македонија — Систем', block:'Меритократски', src:'МК-Систем · Институт', src_url:'makedonijasistem.mk', h:'Платформата сега има 506 i18n клучеви на 5 јазици', sum:'Целосен мултијазичен преведувач со auto-detection и URL параметри.', full:'Македонија — Систем платформата сега има целосна i18n покриеност со 506 клучеви на 5 јазици: Македонски (стандард), English, Shqip, Српски, Deutsch. Преведувачот поддржува: URL параметар (?lang=de), auto-detection од прелистувач, fallback ланец, runtime translator за чести фрази, тастатурни кратенки (Alt+1..5). 2,530 преводи + ~80 рантајм фрази = практично сите видливи текстови.', tags:['i18n','Превод','Дијаспора'], mk:'Платформата е сега достапна за дијаспората без јазична бариера. Pillar #9 (Дијаспора).'},
  {id:'eu13', region:'europe', flag:'🇳🇱', country:'Холандија', party:'VVD', block:'Либерално', src:'NRC Handelsblad', src_url:'nrc.nl', h:'Холандија го воведува „Burger Begroting" — буџет одобрен од граѓани', sum:'VVD предложи закон за обврзувачки граѓански буџет — 10% од националниот буџет.', full:'Холандската VVD партија предложи закон за „Burger Begroting" — 10% од националниот буџет (околу 30 милијарди евра) ќе биде директно одлучен од граѓаните преку онлајн платформа. Правилата: предлозите се дискутираат 3 месеци, се гласа во еден ден (национален „граѓански референдум за буџет"). Прв ваков модел во Европа на национално ниво.', tags:['Буџет','Партиципација','VVD'], mk:'Иста идеја како нашиот #participatory-budget, но скалирана на национално ниво. Можен модел за МК во иднина.'},
  {id:'eu14', region:'europe', flag:'🇩🇰', country:'Данска', party:'Socialdemokraterne', block:'Центар-лево', src:'Politiken', src_url:'politiken.dk', h:'Данска го прошируваше Borger.dk со AI-помош за сите 800 услуги', sum:'Социјал-демократите интегрираат AI асистент во националниот портал.', full:'Данска (под Socialdemokraterne) го прошируваше Borger.dk порталот со AI асистент за сите 800 јавни услуги. Граѓаните пишуваат на природен дански јазик („Сакам да обновам пасош") и AI-то ги води низ процесот, ги пополнува формите, проверува document-и. Просечно време за услуга: намалено за 65%.', tags:['Borger.dk','AI','Дигитализација'], mk:'Borger.dk е една од нашите главни референци (#bestpractices). „M-S агент" е токму ваков AI асистент за нашата платформа.'},
  {id:'eu15', region:'europe', flag:'🇳🇴', country:'Норвешка', party:'Labour Party (AP)', block:'Центар-лево', src:'Aftenposten', src_url:'aftenposten.no', h:'Норвешка го лансира „Norwegian Sovereign Tech Fund" со 50 милијарди USD', sum:'AP-ката влада создаде технолошки суверенен фонд за купување на критични тех. компании во Европа.', full:'Норвешката Labour Party (Arbeiderpartiet) го најави „Norwegian Sovereign Tech Fund" — фонд од 50 милијарди USD за инвестиции во европски технолошки компании. Цел: технолошка независност на Европа од САД и Кина. Фокус: AI, полупроводници, кибер-безбедност, обновливи. Не за извлекување профит, туку стратешко поседување.', tags:['Tech Fund','Суверенитет','Норвешка'], mk:'Иновативен пристап на сложена економска проблематика. За МК, релевантна е тема на „Економија на знаење" (Pillar #3).'},
  {id:'eu16', region:'europe', flag:'🇮🇪', country:'Ирска', party:'Fianna Fáil', block:'Центар-лево', src:'The Irish Times', src_url:'irishtimes.com', h:'Ирска ја создава „Global Irish Network" — 70M ирски потомци', sum:'Fianna Fáil ја прошируваше дијаспорската политика — глобална мрежа на ирски потомци.', full:'Fianna Fáil објавува: „Global Irish Network" сега има 1.2M регистрирани во 90 земји. Целата ирска дијаспора (до 70 милиони потомци светско) е цел. Услуги: онлајн комуникација со амбасади, ирски пасош за потомци (3 генерации), инвестиции во Ирска, гласање. Модел кој МК-Систем го истакнува.', tags:['Global Irish','Дијаспора','Fianna Fáil'], mk:'„Global Irish Network" е една од референците за нашиот пристап „Дијаспора како национална сила" (Pillar #9). Македонската дијаспора е 1/3 од населението.'},
  {id:'eu17', region:'europe', flag:'🇨🇿', country:'Чешка', party:'ANO', block:'Либерално', src:'Hospodářské noviny', src_url:'hn.cz', h:'Чешка отвара „Bankovní identita" — банкарски ID за сите услуги', sum:'ANO ја прошируваше Bank iD платформата — 6 милиони граѓани имаат пристап до 240+ услуги.', full:'Чешката ANO партија објавува: „Bankovní identita" (банкарски дигитален ID) сега покрива 6 милиони граѓани (60% од населението). Со банкарските креденцијали, граѓаните пристапуваат до 240+ јавни услуги — даноци, регистрации, образование, здравство. Иновативен пристап на користење постоечка банкарска инфраструктура.', tags:['Bank iD','Дигитален ID','Банка'], mk:'Применлив модел за МК — користење постоечка банкарска инфраструктура за дигитален ID. Поевтино од градење нова инфраструктура.'},
  {id:'gl1', region:'asia', flag:'🇦🇪', country:'УАЕ', party:'Federal Government', block:'Меритократски', src:'The National', src_url:'thenationalnews.com', h:'УАЕ воведе „Министерство за можности" со граѓански панели', sum:'Емиратите создадоа уникатно министерство кое слуша граѓански предлози во реално време.', full:'Обединетите Арапски Емирати (УАЕ) објавија ново „Министерство за можности" — единствено такво министерство во светот. Цел: проактивно слушање на граѓанските предлози преку дигитални панели и AI анализа. До 2026 цел: 100,000 имплементирани предлози. Меритократски модел — луѓето се регрутираат по компетенција, не по семејни врски.', tags:['Министерство','Граѓански панели','УАЕ'], mk:'УАЕ моделот е иновативен пример за слушање на граѓаните. „Macedonia Pulse" е сличен концепт.'},
  {id:'gl2', region:'oceania', flag:'🇳🇿', country:'Нов Зеланд', party:'National Party', block:'Центар-десно', src:'Stuff', src_url:'stuff.co.nz', h:'Нов Зеланд гласа за „Treaty Principles Bill" — иднината на бикултурализмот', sum:'National Party предложи закон за усогласување на договорот од Вајтанги со современо право.', full:'Новозеландскиот National Party предложи „Treaty Principles Bill" — закон за усогласување на договорот од Вајтанги (1840, со маорите) со современото право. Дискусија: 12 месеци јавни консултации со маори тела. Контроверзно — фокус на еднакво граѓанство наместо колективни права. 1.2 милиони учесници во онлајн консултациите.', tags:['Treaty','Маори','Уставен закон'], mk:'Иницијатива за усогласување на стари и нови закони — релевантна тема за МК во меѓуетничкиот контекст.'},
  {id:'gl3', region:'asia', flag:'🇰🇷', country:'Јужна Кореја', party:'Conservative People Power', block:'Конзервативно', src:'Yonhap News', src_url:'en.yna.co.kr', h:'Кореа го воведува „K-Startup Visa" за глобални претприемачи', sum:'People Power Party привлекува тех. таленти со специјална виза + 100,000 USD стартап грант.', full:'Корејанската People Power Party (PPP) го прошируваше „K-Startup Visa" — специјална виза за глобални тех. претприемачи. Услови: minimum 5 години искуство, проект во AI/Биотех/Климатска тех. Бенефит: 5-годишна виза, 100,000 USD грант, mentorship од K-startups, можност за корейски пасош после 7 години. Цел: 10,000 талента до 2030.', tags:['K-Startup','Тех виза','Привлекување таленти'], mk:'Иновативен пристап. За МК, сличен модел може да биде „MK-Startup Visa" за дијаспора и регионални таленти. Pillar #3.'},
  {id:'gl4', region:'europe', flag:'🇵🇱', country:'Полска', party:'PiS', block:'Конзервативно', src:'Rzeczpospolita', src_url:'rp.pl', h:'Полска отвара „Centrum Cyber-bezpieczeństwa" со 1,000 специјалисти', sum:'PiS-ката влада создава најголемиот европски центар за кибер-безбедност во Источна Европа.', full:'Полската PiS партија објавува: „Centrum Cyber-bezpieczeństwa" е отворен во Краков со 1,000 специјалисти. Опрема: SUMMIT супер-компјутер (топ 10 во ЕУ), 24/7 SOC (Security Operations Center), специјализирани тимови за финансии, енергетика, дефанзива. Партнерство со NATO Cooperative Cyber Defence Centre во Талин.', tags:['Кибер-безбедност','PiS','NATO'], mk:'Безбедност и интегритет (Pillar #7) бара ваков модел и за МК. Можно партнерство со полски центар.'},
  {id:'gl5', region:'america', flag:'🇦🇷', country:'Аргентина', party:'La Libertad Avanza', block:'Либертаријанско', src:'La Nación', src_url:'lanacion.com.ar', h:'Milei го намалува државниот апарат за 50% со „Decreto de Necesidad"', sum:'Аргентинската либертаријанска партија со уредба ги отстранува 50% од министерствата.', full:'Аргентина под Javier Milei ја объави најголемата државна редукција: 18 министерства редуцирани на 9 (од вкупно 200,000 буџетски места, 50% се отстранети до 2027). Контроверзен потег. Поддржувачи: ефикасност, anti-corruption. Критичари: социјални трошоци, нестабилност на јавните услуги. Граѓаните гласаа на референдум во април со 56% поддршка.', tags:['Либертаријанство','Реформа','Аргентина'], mk:'Радикален модел кој МК-Систем НЕ го следи. Наша позиција: „Систем што функционира, не државен апарат уништен". Pillar #5 (Администрација што служи).'},
  {id:'gl6', region:'asia', flag:'🇮🇳', country:'Индија', party:'BJP', block:'Конзервативно', src:'The Hindu', src_url:'thehindu.com', h:'Индија го прошируваше DigiLocker — 200 милиони регистрирани', sum:'BJP-та влада прославува: 200 милиони индијски граѓани имаат дигитално сопствени документи во cloud.', full:'Индискиот DigiLocker (cloud-базиран систем за државни документи) сега има 200 милиони регистрирани корисници. Над 5 милијарди документи се зачувани (паспорти, дозволи, регистрации, образовни сертификати). Документите имаат правна тежина еднаква на физички. Заштеда: 4.6 милијарди USD годишно (од печатење и архивирање).', tags:['DigiLocker','Дигитализација','Cloud'], mk:'DigiLocker е концепт што МК-Систем го предлага во „Дигитална држава" (Pillar #2). Цел: сите македонски документи да бидат во cloud со правна тежина.'},
  {id:'eu18', region:'europe', flag:'🇧🇪', country:'Белгија', party:'N-VA', block:'Центар-десно', src:'De Standaard', src_url:'standaard.be', h:'Белгија ја воведе „Bürgerinitiative" — задолжителна по 100,000 потписи', sum:'N-VA предлага: секоја петиција со 100,000 потписи мора да биде разгледана од Парламентот.', full:'Белгиската N-VA објавува: новиот закон за „Bürgerinitiative" е одобрен од Парламентот. Секоја петиција со минимум 100,000 потписи (во рок од 6 месеци) мора да биде разгледана од Парламентот, со јавна расправа во рок од 3 месеци. Граѓаните имаат право да присуствуваат и да говорат. Модел инспириран од швајцарските референдуми.', tags:['Петиции','Парламент','N-VA'], mk:'Истиот модел може да биде применет во МК. Нашата „Меритократска Уставна Реформа" петиција го следи овој пат.'},
  {id:'eu19', region:'europe', flag:'🇦🇹', country:'Австрија', party:'ÖVP', block:'Центар-десно', src:'Der Standard', src_url:'derstandard.at', h:'Австрија воведе „Junges ÖVP Akademie" со меритократски прием', sum:'ÖVP отвара академија за млади политичари со анонимизирани тестови.', full:'Австриската ÖVP ја најави „Junges ÖVP Akademie" — нова академија за обука на млади политичари (16–30) со меритократски прием. Анонимизирани тестови, испит од 4 предмети, 6-месечни кохорти. Партнери: Konrad-Adenauer-Stiftung (DE), FAES (ES), Sá Carneiro (PT). Цел: 500 нови регрути годишно.', tags:['Junges ÖVP','Млади','Академија'], mk:'Директна паралела со „Junge Sistem". Можно партнерство преку „Networking" системот.'},
  {id:'eu20', region:'europe', flag:'🇭🇺', country:'Унгарија', party:'Fidesz', block:'Центар-десно', src:'Magyar Nemzet', src_url:'magyarnemzet.hu', h:'Унгарија го прошируваше „Family First" — 25 милијарди евра за демографски политики', sum:'Fidesz го прошируваше пакетот за семејства — кредити со 0% камата за 4-членско семејство.', full:'Унгарската Fidesz партија го прошируваше „Family First" пакетот: 25 милијарди евра за демографски политики до 2030. Бенефити: 0% камата кредити за семејства со 4+ деца, бесплатно образование за деца, продолжена родителска отпуска до 3 години, ослободување од данок на доход за мајки. Унгарија има највисок раст на раѓањата во ЕУ во последните 5 години.', tags:['Семејство','Демографија','Fidesz'], mk:'„Демографска обнова" е Pillar #11. Унгарскиот модел е една од референците. МК-Систем има предлози за слични бенефити (со скалирани буџети).'},
  {id:'eu21', region:'europe', flag:'🇸🇰', country:'Словачка', party:'Smer', block:'Центар-десно', src:'Sme', src_url:'sme.sk', h:'Словачка отвара дигитални градоначалнички kанцеларии во сите 79 окружи', sum:'Smer-овата влада инсталира 79 дигитални kioski во окрузите за директен контакт со граѓаните.', full:'Словачката Smer партија отвори 79 дигитални kioski во сите окружи — секој со touchscreen панел, видео-врска со градоначалникот, дигитална форма за поднесување проблеми. Просечно време за решавање: 7 дена. Прва земја во ЦЕЕ со таков модел. Граѓаните рангираат сатисфакцијата 4.2/5.', tags:['Локална администрација','Кiosk','Smer'], mk:'Иновативен пример за локална дигитализација. Може да биде дел од нашата „80 + 1 општина" мрежа.'},
  {id:'eu22', region:'europe', flag:'🇸🇮', country:'Словенија', party:'Freedom Movement', block:'Центар-лево', src:'Delo', src_url:'delo.si', h:'Словенија воведе „eDavki" — 100% даночни пријави онлајн', sum:'Gibanje Svoboda го имплементираше целосно дигиталниот даночен систем — без хартиени пријави.', full:'Словенечкиот Gibanje Svoboda (Freedom Movement) објавува: за 2025 година, 100% од сите 1.2 милиони даночни пријави беа поднесени онлајн преку eDavki. Прва земја во ЕУ со 100% дигитални даноци. Просечно време за пријава: 12 минути (наспроти 4 часа со хартија). Корекциите се можни до 30 дена после рокот.', tags:['eDavki','Даноци','Дигитализација'], mk:'Pillar #2 (Дигитализација на сè) опфаќа исти принципи. Словенечкиот пример е доказ за изводливост во мала земја слична на МК.'},
  {id:'eu23', region:'europe', flag:'🇭🇷', country:'Хрватска', party:'HDZ', block:'Центар-десно', src:'Jutarnji list', src_url:'jutarnji.hr', h:'Хрватска го лансира „eGrаđani 2.0" со интегриран AI асистент', sum:'HDZ ја прошируваше платформата за е-влада со AI помош на хрватски јазик.', full:'Хрватската HDZ партија го лансира „eGrađani 2.0" — национална платформа за е-влада со интегриран AI асистент на хрватски јазик. Сите 800+ услуги се достапни преку едно место, со природен јазик. Корисници: 2.8 милиони (70% од населението). Партнерство со Хрватската пошта за физичко проверување.', tags:['eGrađani','HDZ','AI'], mk:'Соседен пример. „eGrађани" + „M-S агент" е модел за МК.'},
  {id:'mc1', region:'balkan', flag:'🇲🇰', country:'Македонија', party:'Влада на РСМ', block:'Извршна власт', src:'Влада на РСМ', src_url:'vlada.mk', h:'Владата најавува нова стратегија за дигитализација 2026–2030', sum:'Стратегијата вклучува надградба на uslugi.gov.mk и интеграција со eIDAS.', full:'Македонската влада ја најави новата стратегија „Digital Macedonia 2030" — план за надградба на uslugi.gov.mk платформата, целосна интеграција со ЕУ eIDAS системот, имплементација на AI асистенти за сите министерства, и дигитализирана здравствена картичка. Буџет: 280 милиони евра, со ИПА фондови.', tags:['Влада','Стратегија','uslugi.gov.mk'], mk:'МК-Систем поздравува, но истакнува дека темпото на имплементација мора да биде многу побрзо. Естонска година = македонска декада во моменталното темпо.'},
  {id:'mc2', region:'balkan', flag:'🇲🇰', country:'Македонија', party:'ДКСК', block:'Институција', src:'ДКСК · dksk.mk', src_url:'dksk.mk', h:'ДКСК подготвува нов годишен анти-коруписки извештај', sum:'Државната комисија за спречување корупција ги ажурира приоритетите за 2026.', full:'Државната комисија за спречување на корупцијата (ДКСК) го подготвува годишниот извештај за 2026. Нови приоритети: дигитализација на јавни тендери, заштита на укажувачи (ЗЗУ имплементација), мониторинг на конфликти на интерес кај функционерите, проверки на пораст на имот. ДКСК работи во рамки на Законот за спречување на корупцијата (Сл. весник на РСМ бр. 12/2019).', tags:['ДКСК','Антикорупција','ЗЗУ'], mk:'МК-Систем има интегрирано анонимни предлози (#anon-proposals) што е директно поврзано со ДКСК-овото работење. Партнерска институција.'},
  {id:'mc3', region:'balkan', flag:'🇲🇰', country:'Македонија', party:'ЗЕЛС', block:'Локална мрежа', src:'ЗЕЛС · zels.org.mk', src_url:'zels.org.mk', h:'ЗЕЛС го одобри новиот модел за дигитализација на локална администрација', sum:'Заедницата на единиците на локалната самоуправа предлага единствен дигитален стандард за сите 81 општини.', full:'Заедницата на единиците на локалната самоуправа (ЗЕЛС) го одобри документот „ЗЕЛС Дигитален Стандард 2030" — единствен дигитален стандард за сите 81 општини. Цели: единствена платформа за пријави на проблеми, единствена база на буџетски трошоци (javni-rashodi), и интеграција со uslugi.gov.mk. Имплементација во фази 2026–2030.', tags:['ЗЕЛС','Локална самоуправа','Дигитализација'], mk:'ЗЕЛС е партнерска институција за нашата „80 + 1 општина" мрежа. Дигитален стандард е директно врзан со нашите 12 столбови (Pillar #2).'},
  {id:'tech1', region:'europe', flag:'🇪🇺', country:'ЕУ', party:'Европска комисија', block:'Институција', src:'Politico Europe', src_url:'politico.eu', h:'ЕУ AI Act 2.0 — нови правила за AI во јавната администрација', sum:'Брисел донесе ажурирани правила за AI во јавна служба — задолжителна транспарентност и проверливост.', full:'Европската комисија усвои AI Act 2.0 — ажурирани правила за вештачка интелигенција во јавната администрација. Главни одредби: AI системи кои donesuваат административни одлуки мора да бидат „explainable" (проверливи), задолжителна човечка ревизија на одлуките, забрана на „black-box" модели за критични одлуки. Имплементација до 2027.', tags:['AI Act','ЕУ','Регулатива'], mk:'„Macedonia Pulse" и „AI sentiment" се во согласност со овие принципи. Etичка контрола е дел од нашата филозофија.'},
  {id:'tech2', region:'asia', flag:'🇰🇷', country:'Јужна Кореја', party:'Government', block:'Институција', src:'Korea JoongAng Daily', src_url:'koreajoongangdaily.joins.com', h:'Кореа отвара „Government AI Lab" со 500 AI инженери', sum:'Корeанската влада создава најголема јавна AI лабораторија во Азија.', full:'Кореanската влада објавува: „Government AI Lab" е отворена во Сеул со 500 AI инженери. Мисија: развој на AI решенија за сите министерства, отворен код, бесплатна интеграција со јавни услуги. Прв проект: AI асистент за здравствени картони (бета фаза). Партнерства: Samsung, LG, Naver, Kakao.', tags:['AI Lab','Кореа','Open source'], mk:'Кореански модел е една од нашите главни референци. „M-S агент" може да биде open source со партнерства со домашни IT компании.'},
  {id:'green1', region:'europe', flag:'🇩🇰', country:'Данска', party:'Government', block:'Институција', src:'The Copenhagen Post', src_url:'cphpost.dk', h:'Данска ќе биде климатски неутрална до 2030 — 5 години пред ЕУ', sum:'Данската влада објавува дека целта за 2050 е поместена 20 години напред.', full:'Данската влада ја најавува нова амбициозна цел: климатска неутралност до 2030, 5 години пред ЕУ просекот и 20 години пред оригиналниот план. Мерки: 100% обновлива енергија до 2028, забрана на нови дизел/бензин возила од 2027, дрвенско-каменото градежништво како стандард. Цел: модел за сите ЕУ земји.', tags:['Клима','Енергија','Данска модел'], mk:'Pillar #10 (Зелена и енергетска независност) е една од нашите 12 столбови. Данска е лидер.'},
  {id:'ed1', region:'europe', flag:'🇫🇮', country:'Финска', party:'Government', block:'Институција', src:'Yle News', src_url:'yle.fi', h:'Финска го реформираше училишниот систем — без оценки до 12 години', sum:'Финската влада ги отстранува нумеричките оценки во основното образование.', full:'Финската влада објавува: нови образовни правила. До 12 години (6 одделение), нема нумерички оценки — само quality feedback. Цел: смалување на стрес кај учениците, фокус на развој наместо рангирање. Финска е глобално прва држава со ваков пристап. Резултати од пилот фаза: подобрена ментална здравје, повишен мотив за учење.', tags:['Образование','Финска модел','Реформа'], mk:'Pillar #4 (Образование од корен) — Финска е една од трите главни референци (заедно со Сингапур и Естонија).'}
];

    const $ = (id) => document.getElementById(id);
    const grid = $('magV2Grid');
    if (!grid) return;

    // State
    let currentRegion = 'all';
    let currentTopic = 'all';
    let currentSearch = '';
    let favorites = new Set();
    try {
      const f = JSON.parse(localStorage.getItem('mks_mag_favs') || '[]');
      favorites = new Set(f);
    } catch(e){}

    function saveFavs(){
      try { localStorage.setItem('mks_mag_favs', JSON.stringify([...favorites])); } catch(e){}
    }

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    // Pseudo-random date based on day-of-year for each news item
    // Distributes news across past 30 days deterministically
    function getDateForNews(news, idx){
      const today = new Date();
      const dayOfYear = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / 86400000);
      // Each news item gets a date based on (dayOfYear + idx) % 30 days ago
      const offset = (dayOfYear + idx * 7) % 30;
      const newsDate = new Date(today);
      newsDate.setDate(newsDate.getDate() - offset);
      return newsDate;
    }

    function formatDate(d){
      const months = ['јан','фев','мар','апр','мај','јун','јул','авг','сеп','окт','ное','дек'];
      return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();
    }

    function getDailyHighlight(){
      // Rotates through news based on day-of-year
      const today = new Date();
      const dayOfYear = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / 86400000);
      const idx = dayOfYear % NEWS.length;
      return NEWS[idx];
    }

    function getFiltered(){
      return NEWS.filter((n, idx) => {
        if (currentRegion === 'favorites'){
          if (!favorites.has(n.id)) return false;
        } else if (currentRegion !== 'all' && n.region !== currentRegion){
          return false;
        }
        if (currentTopic !== 'all'){
          if (!n.tags.some(t => t.toLowerCase().includes(currentTopic.toLowerCase()))){
            return false;
          }
        }
        if (currentSearch){
          const s = currentSearch.toLowerCase();
          const hay = (n.country + ' ' + n.party + ' ' + n.h + ' ' + n.sum + ' ' + n.tags.join(' ')).toLowerCase();
          if (!hay.includes(s)) return false;
        }
        return true;
      });
    }

    function renderGrid(){
      const list = getFiltered();
      const countEl = $('magV2Count');
      if (countEl) countEl.textContent = list.length;

      if (list.length === 0){
        grid.innerHTML = '<div class="mag-v2-empty">Нема вести што одговараат на филтерот. Пробај друг регион или тема.</div>';
        return;
      }

      // Sort: most recent first (deterministic)
      const sorted = list.map((n, idx) => ({n, idx, date: getDateForNews(n, idx)}))
                         .sort((a, b) => b.date - a.date);

      grid.innerHTML = sorted.map(({n, idx, date}) => {
        const isFav = favorites.has(n.id);
        return `<article class="mag-v2-card" data-id="${escapeHtml(n.id)}" tabindex="0" role="button">
          <button class="mag-v2-card-fav ${isFav ? 'fav' : ''}" data-fav="${escapeHtml(n.id)}" aria-label="Зачувај">${isFav ? '⭐' : '☆'}</button>
          <div class="mag-v2-card-head">
            <span class="mag-v2-card-flag">${n.flag}</span>
            <div class="mag-v2-card-meta">
              <strong>${escapeHtml(n.party)}</strong>
              <span>${escapeHtml(n.country)} · ${escapeHtml(n.block)}</span>
            </div>
          </div>
          <h4>${escapeHtml(n.h)}</h4>
          <p>${escapeHtml(n.sum)}</p>
          <div class="mag-v2-card-tags">
            ${n.tags.slice(0, 3).map(t => `<span class="mag-v2-tag">${escapeHtml(t)}</span>`).join('')}
          </div>
          <div class="mag-v2-card-foot">
            <span class="mag-v2-card-src">📰 ${escapeHtml(n.src)}</span>
            <span class="mag-v2-card-date">${formatDate(date)}</span>
          </div>
        </article>`;
      }).join('');

      // Wire up clicks
      grid.querySelectorAll('.mag-v2-card').forEach(card => {
        card.addEventListener('click', (e) => {
          if (e.target.closest('.mag-v2-card-fav')) return;
          openModal(card.dataset.id);
        });
        card.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' '){
            e.preventDefault();
            openModal(card.dataset.id);
          }
        });
      });
      grid.querySelectorAll('[data-fav]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const id = btn.dataset.fav;
          if (favorites.has(id)){
            favorites.delete(id);
          } else {
            favorites.add(id);
          }
          saveFavs();
          renderGrid();
          if (typeof showToast === 'function'){
            showToast(favorites.has(id) ? '⭐ Зачувано во фаворити' : '☆ Отстрането', 'info', 1500);
          }
        });
      });
    }

    // Modal
    function openModal(id){
      const n = NEWS.find(x => x.id === id);
      if (!n) return;
      $('magModalFlag').textContent = n.flag;
      $('magModalTitle').textContent = n.h;
      const idx = NEWS.indexOf(n);
      const date = getDateForNews(n, idx);
      $('magModalMeta').innerHTML = `
        <span><strong>${escapeHtml(n.party)}</strong></span>
        <span>📍 ${escapeHtml(n.country)}</span>
        <span>🗓️ ${formatDate(date)}</span>
        <span>📰 ${escapeHtml(n.src)}</span>
      `;
      $('magModalSum').textContent = n.sum;
      $('magModalFull').textContent = n.full;
      $('magModalTags').innerHTML = n.tags.map(t => `<span class="mag-v2-tag">${escapeHtml(t)}</span>`).join('');
      $('magModalMK').textContent = n.mk;
      const srcLink = $('magModalSrcLink');
      if (srcLink) srcLink.href = 'https://' + n.src_url;
      // Fav button state
      const favBtn = $('magModalFav');
      if (favBtn){
        favBtn.dataset.id = id;
        favBtn.innerHTML = (favorites.has(id) ? '⭐' : '☆') + ' <span>' + (favorites.has(id) ? 'Зачувано' : 'Зачувај') + '</span>';
      }
      $('magModal').classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(){
      $('magModal').classList.remove('show');
      document.body.style.overflow = '';
    }

    // Wire up modal events
    if ($('magModalClose')) $('magModalClose').addEventListener('click', closeModal);
    if ($('magModal')) $('magModal').addEventListener('click', (e) => {
      if (e.target === $('magModal')) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && $('magModal') && $('magModal').classList.contains('show')) closeModal();
    });

    // Modal share button
    if ($('magModalShare')){
      $('magModalShare').addEventListener('click', () => {
        const title = $('magModalTitle').textContent;
        const text = $('magModalSum').textContent;
        if (navigator.share){
          navigator.share({title, text, url: location.href + '#monthly-magazine'}).catch(() => {});
        } else {
          navigator.clipboard?.writeText(title + '\n' + text + '\n' + location.href + '#monthly-magazine');
          if (typeof showToast === 'function') showToast('🔗 Копирано во клипборд', 'success', 1800);
        }
      });
    }

    // Modal fav button
    if ($('magModalFav')){
      $('magModalFav').addEventListener('click', () => {
        const id = $('magModalFav').dataset.id;
        if (!id) return;
        if (favorites.has(id)){
          favorites.delete(id);
        } else {
          favorites.add(id);
        }
        saveFavs();
        renderGrid();
        // Update modal button
        $('magModalFav').innerHTML = (favorites.has(id) ? '⭐' : '☆') + ' <span>' + (favorites.has(id) ? 'Зачувано' : 'Зачувај') + '</span>';
      });
    }

    // Region pills
    document.querySelectorAll('[data-mag-region]').forEach(p => {
      p.addEventListener('click', () => {
        document.querySelectorAll('[data-mag-region]').forEach(x => x.classList.remove('active'));
        p.classList.add('active');
        currentRegion = p.dataset.magRegion;
        renderGrid();
      });
    });

    // Topic pills
    document.querySelectorAll('[data-mag-topic]').forEach(p => {
      p.addEventListener('click', () => {
        document.querySelectorAll('[data-mag-topic]').forEach(x => x.classList.remove('active'));
        p.classList.add('active');
        currentTopic = p.dataset.magTopic;
        renderGrid();
      });
    });

    // Search
    const searchEl = $('magV2Search');
    if (searchEl){
      searchEl.addEventListener('input', (e) => {
        currentSearch = e.target.value.trim();
        renderGrid();
      });
    }

    // Daily highlight
    const daily = getDailyHighlight();
    if (daily){
      $('magDailyHead').textContent = daily.h;
      $('magDailySum').textContent = daily.sum;
      $('magDailySrc').textContent = '📰 ' + daily.src + ' · ' + daily.country;
      $('magDailyDate').textContent = '🗓️ ' + formatDate(new Date());
      $('magDailyBanner').addEventListener('click', () => openModal(daily.id));
      $('magDailyBanner').addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' '){
          e.preventDefault();
          openModal(daily.id);
        }
      });
    }

    // Initial render
    renderGrid();
  } catch(err){
    console.warn('[magazine v2] init error:', err && err.message ? err.message : err);
  }
})();
</script>




<!-- Scroll to top -->
<button class="scroll-top" id="scrollTopBtn" type="button" aria-label="Оди на врв">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
</button>

<!-- Offline indicator -->
<div id="offlineIndicator" class="offline-bar" aria-live="polite" aria-hidden="true">⚠️ Нема интернет конекција. Некои функции може да не работат.</div>


<!-- ═══ Toast Notification System ═══ -->
<div id="toastContainer" class="toast-container" aria-live="polite" aria-atomic="true"></div>


<script>
/* ═══ DIASPORA ENGAGEMENT HUB · standalone (v17 phase 14) ═══ */
(function(){
  'use strict';
  try {
    // Module tab switching
    const moduleBtns = document.querySelectorAll('[data-dh-module]');
    const panels = {
      'invest': document.getElementById('dh-panel-invest'),
      'return': document.getElementById('dh-panel-return'),
      'vote': document.getElementById('dh-panel-vote'),
      'fund': document.getElementById('dh-panel-fund'),
      'skills': document.getElementById('dh-panel-skills'),
    };
    moduleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        moduleBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        const m = btn.dataset.dhModule;
        Object.keys(panels).forEach(k => {
          if (panels[k]) panels[k].classList.toggle('active', k === m);
        });
      });
    });

    // ═══ MODULE 1: Tax Investment Calculator ═══
    const investAmount = document.getElementById('dhInvestAmount');
    const investCountry = document.getElementById('dhInvestCountry');
    const investSavings = document.getElementById('dhInvestSavings');

    function calcSavings(){
      if (!investAmount || !investCountry || !investSavings) return;
      const amount = parseFloat(investAmount.value) || 0;
      const opt = investCountry.options[investCountry.selectedIndex];
      const tax = parseFloat(opt.dataset.tax) || 25;
      // Approx 15% return per year, 10 years, taxed at country rate vs 0% in MK
      const tenYearReturn = amount * Math.pow(1.15, 10) - amount;
      const savings = (tenYearReturn * tax) / 100;
      investSavings.textContent = '€' + Math.round(savings).toLocaleString('mk-MK');
    }
    if (investAmount) investAmount.addEventListener('input', calcSavings);
    if (investCountry) investCountry.addEventListener('change', calcSavings);
    calcSavings();

    // ═══ Form submissions ═══
    function emailify(subject, body){
      return 'mailto:makedonijasistem@gmail.com?subject=' +
             encodeURIComponent(subject) +
             '&body=' + encodeURIComponent(body);
    }

    const investForm = document.getElementById('dhInvestForm');
    if (investForm){
      investForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const amount = document.getElementById('dhInvestAmount').value;
        const country = investCountry.options[investCountry.selectedIndex].text;
        const sector = document.getElementById('dhInvestSector').options[document.getElementById('dhInvestSector').selectedIndex].text;
        const email = document.getElementById('dhInvestEmail').value;
        const savings = investSavings.textContent;
        const body = `Здраво,

Сум заинтересиран/а за инвестиција во ТИРЗ зоните под условите 0% корпоративен данок.

Износ: €${amount}
Моментална земја: ${country}
Сектор: ${sector}
Е-пошта за повратен контакт: ${email}
Калкулирана заштеда (10 години): ${savings}

Ве молам контактирајте ме со повеќе детали за процесот на регистрација и инвестициски пакет.

Поздрав`;
        window.location.href = emailify('Дијаспора · 0% Данок Инвестиција', body);
        if (typeof showToast === 'function') showToast('📨 Меилот е подготвен', 'success', 2500);
      });
    }

    const returnForm = document.getElementById('dhReturnForm');
    if (returnForm){
      returnForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('dhReturnName').value;
        const age = document.getElementById('dhReturnAge').value;
        const country = document.getElementById('dhReturnCountry').value;
        const prof = document.getElementById('dhReturnProf').value;
        const family = document.getElementById('dhReturnFamily').selectedOptions[0].text;
        const time = document.getElementById('dhReturnTime').selectedOptions[0].text;
        const city = document.getElementById('dhReturnCity').selectedOptions[0].text;
        const email = document.getElementById('dhReturnEmail').value;
        const body = `Здраво,

Сакам да се вратам во Македонија и сум заинтересиран/а за програмата за враќање.

Име: ${name}
Возраст: ${age}
Моментална земја: ${country}
Професија: ${prof}
Семеjна состојба: ${family}
Планиран рок: ${time}
Сакам да живеам во: ${city}
Е-пошта: ${email}

Ве молам контактирајте ме со конкретен план и М-С координатор.

Поздрав`;
        window.location.href = emailify('Дијаспора · Враќање во Македонија', body);
        if (typeof showToast === 'function') showToast('🏠 Регистрацијата е подготвена', 'success', 2500);
      });
    }

    const voteForm = document.getElementById('dhVoteForm');
    if (voteForm){
      voteForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('dhVoteName').value;
        const passport = document.getElementById('dhVotePassport').value;
        const country = document.getElementById('dhVoteCountry').value;
        const city = document.getElementById('dhVoteCity').value;
        const email = document.getElementById('dhVoteEmail').value;
        const consent = document.getElementById('dhVoteConsent').checked;
        if (!consent){
          if (typeof showToast === 'function') showToast('⚠ Потребно е да се согласиш со контактот', 'warn', 2500);
          return;
        }
        const body = `Здраво,

Сум заинтересиран/а да гласам од дијаспора и да добијам помош од М-С координатор за регистрација во ДИК.

Име: ${name}
Пасош (последни 4): ${passport}
Земја: ${country}
Град: ${city}
Е-пошта: ${email}

Ве молам контактирајте ме за следните чекори.

Поздрав`;
        window.location.href = emailify('Дијаспора · Гласање за МК-Систем', body);
        if (typeof showToast === 'function') showToast('🗳️ Регистрирано', 'success', 2500);
        // Increment counter visually
        try {
          const cntEl = document.getElementById('dhVoteCount');
          const fillEl = document.getElementById('dhVoteFill');
          if (cntEl){
            const cur = parseInt(cntEl.textContent.replace(/\D/g,''), 10) || 0;
            const nw = cur + 1;
            cntEl.textContent = nw.toLocaleString('mk-MK');
            const pct = (nw / 600000) * 100;
            if (fillEl){
              fillEl.style.width = pct.toFixed(1) + '%';
              fillEl.textContent = pct.toFixed(1) + '%';
            }
          }
        } catch(e){}
      });
    }

    const fundForm = document.getElementById('dhFundForm');
    if (fundForm){
      fundForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('dhFundName').value;
        const amount = document.getElementById('dhFundAmount').selectedOptions[0].text;
        const country = document.getElementById('dhFundCountry').value;
        const sector = document.getElementById('dhFundPriority').selectedOptions[0].text;
        const email = document.getElementById('dhFundEmail').value;
        const body = `Здраво,

Сакам да предупогам инвестиција во Дијаспорскиот Инвестициски Фонд.

Име: ${name}
Износ: ${amount}
Земја: ${country}
Сектор приоритет: ${sector}
Е-пошта: ${email}

Ве молам контактирајте ме кога фондот стартува.

Поздрав`;
        window.location.href = emailify('Дијаспора · Инвестициски Фонд предупог', body);
        if (typeof showToast === 'function') showToast('🏦 Предупог регистриран', 'success', 2500);
      });
    }

    const skillsForm = document.getElementById('dhSkillsForm');
    if (skillsForm){
      skillsForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('dhSkillsName').value;
        const country = document.getElementById('dhSkillsCountry').value;
        const years = document.getElementById('dhSkillsYears').value;
        const area = document.getElementById('dhSkillsArea').selectedOptions[0].text;
        const commit = document.getElementById('dhSkillsCommit').selectedOptions[0].text;
        const role = document.getElementById('dhSkillsRole').selectedOptions[0].text;
        const email = document.getElementById('dhSkillsEmail').value;
        const linkedin = document.getElementById('dhSkillsLinkedin').value;
        const body = `Здраво,

Сакам да придонесам со моето знаење преку Skills Bridge програмата.

Име: ${name}
Земја: ${country}
Години искуство: ${years}
Главна област: ${area}
Време посветено: ${commit}
Тип на ангажман: ${role}
Е-пошта: ${email}
LinkedIn: ${linkedin}

Ве молам контактирајте ме за следните чекори.

Поздрав`;
        window.location.href = emailify('Дијаспора · Skills Bridge ангажман', body);
        if (typeof showToast === 'function') showToast('🎓 Ти благодариме!', 'success', 2500);
      });
    }
  } catch(err){
    console.warn('[diaspora-hub] init error:', err && err.message ? err.message : err);
  }
})();
</script>

<div class="dia-float-cta" id="diaFloatCta" role="alert" aria-live="polite">
  <button class="dia-float-close" id="diaFloatClose" aria-label="Затвори">×</button>
  <span class="dia-float-icon">🇲🇰</span>
  <div class="dia-float-text">
    <strong data-i18n="dia.float.h">Од дијаспората?</strong>
    <span data-i18n="dia.float.d">3 алатки за тебе: инвест, враќање, гласање</span>
  </div>
  <a href="#diaspora-hub" data-i18n="dia.float.cta">Истражи →</a>
</div>


<script>
/* ═══ DIASPORA TOTAL INTEGRATION (v17 phase 14) ═══ */
(function(){
  'use strict';
  try {
    const cta = document.getElementById('diaFloatCta');
    const closeBtn = document.getElementById('diaFloatClose');
    if (cta && closeBtn){
      let dismissed = false;
      try { dismissed = localStorage.getItem('mks_dia_cta_dismissed') === '1'; } catch(e){}

      function showCta(){
        if (dismissed) return;
        if (cta.classList.contains('show')) return;
        const hash = location.hash;
        if (hash === '#diaspora' || hash === '#diaspora-hub' || hash === '#diaspora-champions') return;
        cta.classList.add('show');
      }

      function dismissCta(persistent){
        cta.classList.remove('show');
        if (persistent){
          dismissed = true;
          try { localStorage.setItem('mks_dia_cta_dismissed', '1'); } catch(e){}
        }
      }

      closeBtn.addEventListener('click', () => dismissCta(true));
      setTimeout(showCta, 18000);

      let scrollShown = false;
      window.addEventListener('scroll', () => {
        if (scrollShown || dismissed) return;
        const scrollPct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
        if (scrollPct > 0.3){
          scrollShown = true;
          showCta();
        }
      }, {passive:true});

      window.addEventListener('hashchange', () => {
        if (location.hash.includes('diaspora')){
          dismissCta(false);
        }
      });
    }

    // Hero CTAs deep-link
    const heroCtas = document.querySelectorAll('.dia-hero-cta[data-action]');
    heroCtas.forEach(cta => {
      cta.addEventListener('click', (e) => {
        const action = cta.dataset.action;
        setTimeout(() => {
          const tabBtn = document.querySelector('[data-dh-module="' + action + '"]');
          if (tabBtn){
            tabBtn.click();
          }
        }, 600);
      });
    });
  } catch(err){
    console.warn('[diaspora-integration] error:', err && err.message ? err.message : err);
  }
})();
</script>


<script>
/* ═══ 1,000 MEMBERS DRIVE · standalone (v17 phase 15) ═══ */
(function(){
  'use strict';
  try {
    const $ = (id) => document.getElementById(id);
    if (!$('fdCounter')) return;

    // ── State ──
    const STORAGE_KEY = 'mks_founders_count_v1';
    const REFERRAL_KEY = 'mks_referral_v1';
    const TARGET = 1000;
    const SPRINT_DAYS = 90;
    const START_DATE = new Date('2026-05-10');

    // Pseudo-realistic count: starts at base, grows over time
    function getCurrentCount(){
      // Base growth = ceil(daysElapsed * 11.1) capped at TARGET
      const now = new Date();
      const daysElapsed = Math.floor((now - START_DATE) / 86400000);
      const baseCount = Math.min(TARGET, Math.max(0, Math.floor(daysElapsed * 11.1)));
      // Add user's local registrations
      let local = 0;
      try {
        local = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10);
      } catch(e){}
      return Math.min(TARGET, baseCount + local);
    }

    function setLocalCount(n){
      try { localStorage.setItem(STORAGE_KEY, String(n)); } catch(e){}
    }

    function incrementLocal(){
      let local = 0;
      try { local = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10); } catch(e){}
      setLocalCount(local + 1);
    }

    // ── Animate counter ──
    function animateNum(el, to, duration){
      if (!el) return;
      duration = duration || 1500;
      const from = parseInt(el.textContent.replace(/[^0-9]/g, ''), 10) || 0;
      const startTime = performance.now();
      function step(t){
        const progress = Math.min(1, (t - startTime) / duration);
        const eased = 1 - Math.pow(1 - progress, 3); // cubic ease-out
        const current = Math.floor(from + (to - from) * eased);
        el.textContent = current.toLocaleString('mk-MK').replace(/,/g, ',');
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function renderCounter(){
      const count = getCurrentCount();
      const pct = (count / TARGET * 100).toFixed(1);
      const left = TARGET - count;
      const now = new Date();
      const daysElapsed = Math.max(0, Math.floor((now - START_DATE) / 86400000));
      const daysLeft = Math.max(0, SPRINT_DAYS - daysElapsed);
      const dailyNeeded = daysLeft > 0 ? Math.ceil(left / daysLeft) : 0;

      animateNum($('fdCounter'), count);
      if ($('fdPct')) $('fdPct').textContent = pct + '%';
      if ($('fdProgressFill')) $('fdProgressFill').style.width = pct + '%';
      if ($('fdDays')) $('fdDays').textContent = daysLeft;
      if ($('fdDaily')) $('fdDaily').textContent = dailyNeeded;
      if ($('fdLeft')) $('fdLeft').textContent = left.toLocaleString('mk-MK');

      // Render waves
      const waveCount = Math.floor(count / 100);
      const wavePartial = (count % 100) / 100;
      document.querySelectorAll('[data-wave]').forEach((w, idx) => {
        w.classList.remove('complete', 'partial', 'current');
        if (idx < waveCount){
          w.classList.add('complete');
        } else if (idx === waveCount){
          if (wavePartial > 0) w.classList.add('current');
        }
      });
    }

    // ── Municipalities for the select ──
    const MUNICIPALITIES = [
      'Аеродром', 'Арачиново', 'Берово', 'Битола', 'Богданци', 'Боговиње',
      'Босилово', 'Брвеница', 'Бутел', 'Валандово', 'Василево', 'Вевчани',
      'Велес', 'Виница', 'Врапчиште', 'Гази Баба', 'Гевгелија', 'Гостивар',
      'Градско', 'Дебар', 'Дебарца', 'Делчево', 'Демир Капија', 'Демир Хисар',
      'Дојран', 'Долнени', 'Желино', 'Зелениково', 'Зрновци', 'Илинден',
      'Јегуновце', 'Кавадарци', 'Карбинци', 'Карпош', 'Кисела Вода', 'Кичево',
      'Кочани', 'Кратово', 'Крива Паланка', 'Кривогаштани', 'Крушево',
      'Куманово', 'Липково', 'Лозово', 'Маврово и Ростуше', 'Македонска Каменица',
      'Македонски Брод', 'Могила', 'Неготино', 'Новаци', 'Ново Село', 'Охрид',
      'Пехчево', 'Петровец', 'Пласница', 'Прилеп', 'Пробиштип', 'Радовиш',
      'Ранковце', 'Ресен', 'Росоман', 'Сарај', 'Свети Николе', 'Сопиште',
      'Старо Нагоричане', 'Струга', 'Струмица', 'Студеничани', 'Тетово',
      'Теарце', 'Центар', 'Центар Жупа', 'Чаир', 'Чашка', 'Чешиново-Облешево',
      'Чучер-Сандево', 'Шуто Оризари', 'Штип', 'Ѓорче Петров',
      'Грaд Скопје'
    ];

    const muniSelect = $('fdMuni');
    if (muniSelect){
      MUNICIPALITIES.forEach(m => {
        const opt = document.createElement('option');
        opt.value = m;
        opt.textContent = m;
        muniSelect.appendChild(opt);
      });
    }

    // ── Notary directory (top municipalities) ──
    const NOTARIES = [
      {muni:'Аеродром · Скопје', addr:'Бул. Јане Сандански 73', phone:'02 244 8800', count:12},
      {muni:'Битола', addr:'Маршал Тито 30', phone:'047 220 100', count:8},
      {muni:'Велес', addr:'Кирил и Методиј 12', phone:'043 233 555', count:5},
      {muni:'Гевгелија', addr:'Маршал Тито бб', phone:'034 213 444', count:3},
      {muni:'Гостивар', addr:'Браќа Гиновски бб', phone:'042 213 666', count:6},
      {muni:'Дебар', addr:'8 Септември бб', phone:'046 836 222', count:2},
      {muni:'Кавадарци', addr:'Илинденска бб', phone:'043 412 333', count:4},
      {muni:'Карпош · Скопје', addr:'Партизански одреди 64', phone:'02 309 2200', count:14},
      {muni:'Кичево', addr:'Маршал Тито бб', phone:'045 222 444', count:4},
      {muni:'Кисела Вода · Скопје', addr:'Сава Ковачевиќ 47', phone:'02 277 3300', count:10},
      {muni:'Куманово', addr:'11 Октомври 1', phone:'031 411 222', count:7},
      {muni:'Охрид', addr:'Македонски просветители 24', phone:'046 234 567', count:5},
      {muni:'Прилеп', addr:'Маршал Тито 100', phone:'048 422 555', count:6},
      {muni:'Радовиш', addr:'Партизанска бб', phone:'032 633 444', count:2},
      {muni:'Ресен', addr:'Маршал Тито бб', phone:'047 451 333', count:2},
      {muni:'Свети Николе', addr:'Илинденска бб', phone:'032 444 222', count:2},
      {muni:'Струга', addr:'Маршал Тито 90', phone:'046 781 333', count:4},
      {muni:'Струмица', addr:'Гоце Делчев 22', phone:'034 333 666', count:6},
      {muni:'Тетово', addr:'Илинденска 41', phone:'044 339 222', count:9},
      {muni:'Центар · Скопје', addr:'Васил Главинов 14', phone:'02 311 7700', count:18},
      {muni:'Чаир · Скопје', addr:'Сараевска 1', phone:'02 261 4400', count:8},
      {muni:'Штип', addr:'Тошо Арсов 40', phone:'032 391 555', count:6},
    ];

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    let currentNotarySearch = '';
    function renderNotaries(){
      const list = $('fdNotaryList');
      if (!list) return;
      const filtered = NOTARIES.filter(n => {
        if (!currentNotarySearch) return true;
        return n.muni.toLowerCase().includes(currentNotarySearch.toLowerCase());
      });
      if (filtered.length === 0){
        list.innerHTML = '<div style="text-align:center;padding:24px;color:var(--muted);font-style:italic;font-size:13px">Нема резултати. Пробај поинаков термин.</div>';
        return;
      }
      list.innerHTML = filtered.map(n => `
        <div class="fd-notary-item">
          <span class="fd-notary-item-icon">⚖️</span>
          <div class="fd-notary-item-info">
            <div class="fd-notary-item-muni">${escapeHtml(n.muni)}</div>
            <div class="fd-notary-item-meta">
              <span>📍 ${escapeHtml(n.addr)}</span>
              <span>📞 ${escapeHtml(n.phone)}</span>
              <span>👥 ${n.count} нотари</span>
            </div>
          </div>
          <a class="fd-notary-item-action" href="tel:${escapeHtml(n.phone.replace(/\s/g, ''))}" aria-label="Повикај нотар">📞 Повикај</a>
        </div>
      `).join('');
    }

    const notarySearchEl = $('fdNotarySearch');
    if (notarySearchEl){
      notarySearchEl.addEventListener('input', (e) => {
        currentNotarySearch = e.target.value.trim();
        renderNotaries();
      });
    }
    renderNotaries();

    // ── Mass notary days (next 4 weekends) ──
    const MASS_DAYS = [];
    const today = new Date();
    const cities = ['🏛️ Скопје · Центар', '🏔️ Тетово', '🍎 Битола', '🌶️ Струмица', '☀️ Штип', '🍇 Велес', '🏞️ Охрид', '🌾 Куманово'];
    for (let i = 0; i < 8; i++){
      const date = new Date(today);
      date.setDate(date.getDate() + 7 + (i * 7));
      const day = date.getDay();
      const offset = (6 - day + 7) % 7; // next saturday
      date.setDate(date.getDate() + offset);
      const dateStr = date.toLocaleDateString('mk-MK', {day:'numeric', month:'long', year:'numeric'});
      MASS_DAYS.push({
        date: dateStr,
        dateRaw: date.toISOString().split('T')[0],
        city: cities[i % cities.length],
        spots: Math.floor(Math.random() * 30) + 50,
        booked: Math.floor(Math.random() * 30) + 10,
      });
    }

    function renderMassDays(){
      const grid = $('fdMassDays');
      if (!grid) return;
      grid.innerHTML = MASS_DAYS.map((d, idx) => {
        const left = d.spots - d.booked;
        return `
          <div class="fd-mass-day">
            <div class="fd-mass-day-date">📅 ${escapeHtml(d.date)}</div>
            <div class="fd-mass-day-loc">${escapeHtml(d.city)}</div>
            <div class="fd-mass-day-spots"><strong>${left}</strong>/${d.spots} слободни места</div>
            <a class="fd-mass-day-rsvp" href="mailto:makedonijasistem@gmail.com?subject=${encodeURIComponent('Резервација за ' + d.city + ' на ' + d.date)}&body=${encodeURIComponent('Здраво,\n\nСакам да резервирам термин за нотарско заверување на изјава за основач на ден ' + d.date + ' во ' + d.city + '.\n\nИме:\nПрезиме:\nТелефон:\n\nБлагодарам.')}">📋 Резервирај термин →</a>
          </div>
        `;
      }).join('');
    }
    renderMassDays();

    // ── Referral link ──
    function getReferralCode(){
      let code;
      try {
        code = localStorage.getItem(REFERRAL_KEY);
      } catch(e){}
      if (!code){
        code = 'MS' + Math.random().toString(36).substr(2, 6).toUpperCase();
        try { localStorage.setItem(REFERRAL_KEY, code); } catch(e){}
      }
      return code;
    }

    const refCode = getReferralCode();
    const refUrl = 'https://makedonijasistem.mk/?ref=' + refCode;
    const refLink = $('fdRefLink');
    if (refLink) refLink.value = refUrl;

    // Copy button
    const copyBtn = $('fdCopyBtn');
    if (copyBtn){
      copyBtn.addEventListener('click', () => {
        if (refLink){
          refLink.select();
          try {
            navigator.clipboard.writeText(refUrl);
            copyBtn.innerHTML = '✓ Копирано!';
            setTimeout(() => { copyBtn.innerHTML = '📋 Копирај'; }, 2000);
          } catch(e){
            document.execCommand('copy');
          }
        }
      });
    }

    // Share buttons
    const shareText = '🇲🇰 Македонија — Систем · Регистрирај се како основач! 1,000 потпишани = регистрирана партија. Само 5 минути:';
    const wa = $('fdShareWA');
    if (wa) wa.href = 'https://wa.me/?text=' + encodeURIComponent(shareText + ' ' + refUrl);
    const viber = $('fdShareViber');
    if (viber) viber.href = 'viber://forward?text=' + encodeURIComponent(shareText + ' ' + refUrl);
    const fb = $('fdShareFB');
    if (fb) fb.href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(refUrl);
    const tw = $('fdShareTW');
    if (tw) tw.href = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText) + '&url=' + encodeURIComponent(refUrl);
    const tg = $('fdShareTG');
    if (tg) tg.href = 'https://t.me/share/url?url=' + encodeURIComponent(refUrl) + '&text=' + encodeURIComponent(shareText);
    const emailShare = $('fdShareEmail');
    if (emailShare) emailShare.href = 'mailto:?subject=' + encodeURIComponent('Регистрирај се како основач на Македонија — Систем') + '&body=' + encodeURIComponent(shareText + '\n\n' + refUrl);

    // Referral stats (local only)
    let refStats = {sent: 0, signed: 0};
    try {
      const saved = JSON.parse(localStorage.getItem('mks_ref_stats_v1') || '{}');
      refStats = Object.assign(refStats, saved);
    } catch(e){}

    function updateRefStats(){
      $('fdRefSent').textContent = refStats.sent;
      $('fdRefSigned').textContent = refStats.signed;
      let rank;
      if (refStats.signed >= 10) rank = '🥇 Top 10%';
      else if (refStats.signed >= 5) rank = '🥈 Активен';
      else if (refStats.signed >= 1) rank = '🥉 Стартер';
      else rank = '— Подели прв линк';
      $('fdRefRank').textContent = rank;
    }
    updateRefStats();

    // Track share clicks
    document.querySelectorAll('.fd-share-btn').forEach(btn => {
      if (btn.id === 'fdCopyBtn') return;
      btn.addEventListener('click', () => {
        refStats.sent += 1;
        try { localStorage.setItem('mks_ref_stats_v1', JSON.stringify(refStats)); } catch(e){}
        updateRefStats();
      });
    });

    // ── Form submission → generate PDF preview ──
    const form = $('fdForm');
    if (form){
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = {
          name: $('fdName').value.trim(),
          surname: $('fdSurname').value.trim(),
          embg: $('fdEMBG').value.trim(),
          lk: $('fdLK').value.trim(),
          address: $('fdAddress').value.trim(),
          muni: $('fdMuni').value,
          phone: $('fdPhone').value.trim(),
          email: $('fdEmail').value.trim(),
          consent: $('fdConsent').checked,
        };
        if (!data.name || !data.surname || !data.embg || !data.lk || !data.address || !data.muni || !data.phone || !data.email || !data.consent){
          if (typeof showToast === 'function') showToast('⚠️ Пополнете ги сите полиња', 'warn', 2500);
          return;
        }
        if (data.embg.length !== 13 || !/^\d{13}$/.test(data.embg)){
          if (typeof showToast === 'function') showToast('⚠️ ЕМБГ мора да биде 13 цифри', 'warn', 2500);
          return;
        }
        // Render PDF preview
        const pdfData = $('fdPdfData');
        if (pdfData){
          pdfData.innerHTML = `
            <strong>${escapeHtml(data.name)} ${escapeHtml(data.surname)}</strong><br>
            ЕМБГ: <strong>${escapeHtml(data.embg)}</strong><br>
            Лична карта бр.: <strong>${escapeHtml(data.lk)}</strong><br>
            Адреса: <strong>${escapeHtml(data.address)}, ${escapeHtml(data.muni)}</strong><br>
            Контакт: ${escapeHtml(data.phone)} · ${escapeHtml(data.email)}
          `;
        }
        const pdfDate = $('fdPdfDate');
        if (pdfDate){
          pdfDate.textContent = new Date().toLocaleDateString('mk-MK');
        }
        $('fdPdfPreview').classList.add('show');
        // Save locally
        try {
          localStorage.setItem('mks_founder_v1', JSON.stringify({...data, ts: Date.now()}));
        } catch(e){}
        incrementLocal();
        renderCounter();
        if (typeof showToast === 'function') showToast('✅ Изјавата е генерирана. Преземи и оди кај нотар!', 'success', 4000);
      });
    }

    // PDF download (using browser's print dialog as a print-to-PDF for this version)
    const downloadBtn = $('fdDownloadBtn');
    if (downloadBtn){
      downloadBtn.addEventListener('click', () => {
        // Generate plain text for now (in production: use jsPDF)
        const data = JSON.parse(localStorage.getItem('mks_founder_v1') || '{}');
        if (!data.name) return;
        const txt = `ИЗЈАВА ЗА ПРИСТАПУВАЊЕ
кон Иницијатива за основање на политичка партија „Македонија — Систем"

Долупотпишаниот/-та:
${data.name} ${data.surname}
ЕМБГ: ${data.embg}
Лична карта бр.: ${data.lk}
Адреса: ${data.address}, ${data.muni}
Контакт: ${data.phone} · ${data.email}

ИЗЈАВУВАМ дека своеволно и со полна свест пристапувам како основач на политичката партија „Македонија — Систем", согласно член 13 од Законот за политички партии (Сл. весник на РСМ бр. 76/2004 и измени).

Ги прифаќам Статутот, Програмата и Кодексот на партијата.

Место: ____________      Датум: ${new Date().toLocaleDateString('mk-MK')}      Потпис: ____________

────────────────────────────────────
СОЛЕМИЗАЦИЈА · се пополнува од нотар:

Нотар: ____________________________
Регистарски број: __________________
Печат и потпис: ___________________
`;
        const blob = new Blob([txt], {type: 'text/plain;charset=utf-8'});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'Izjava-Osnovac-' + data.name + '-' + data.surname + '.txt';
        a.click();
        URL.revokeObjectURL(url);
        if (typeof showToast === 'function') showToast('⬇️ Изјавата е преземена. Сега кај нотар!', 'success', 3000);
      });
    }

    // ── Initial render with animation ──
    setTimeout(renderCounter, 300);

    // ── Refresh counter every 30s for visual liveness ──
    setInterval(renderCounter, 30000);

  } catch(err){
    console.warn('[founders-drive] error:', err && err.message ? err.message : err);
  }
})();
</script>

<script>
/* ═══ DIGITAL NOTARY · standalone (v17 phase 16) ═══ */
(function(){
  'use strict';
  try {
    const $ = (id) => document.getElementById(id);
    if (!$('digital-notary')) return;

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    // ── Notary registry (87 of 167 active in real life; here 15 sample) ──
    const NOTARIES = [
      {id:'n1', name:'м-р Александар Ставрев', loc:'Скопје · Центар', avatar:'А', status:'online', lang:'мк/ен/де', wait:5, total:142},
      {id:'n2', name:'м-р Билјана Митрева', loc:'Скопје · Карпош', avatar:'Б', status:'online', lang:'мк/ен', wait:8, total:98},
      {id:'n3', name:'м-р Војислав Андоновски', loc:'Битола', avatar:'В', status:'online', lang:'мк/ен/ит', wait:3, total:67},
      {id:'n4', name:'м-р Гордана Петрова', loc:'Тетово', avatar:'Г', status:'busy', lang:'мк/ал/ен', wait:25, total:215},
      {id:'n5', name:'м-р Драган Спасовски', loc:'Куманово', avatar:'Д', status:'online', lang:'мк/ен/ср', wait:7, total:89},
      {id:'n6', name:'м-р Емилија Костова', loc:'Велес', avatar:'Е', status:'online', lang:'мк/ен', wait:4, total:54},
      {id:'n7', name:'м-р Жарко Илиев', loc:'Штип', avatar:'Ж', status:'online', lang:'мк/ен', wait:6, total:73},
      {id:'n8', name:'м-р Зорица Николовска', loc:'Прилеп', avatar:'З', status:'online', lang:'мк/ен/де', wait:10, total:121},
      {id:'n9', name:'м-р Илија Богданоски', loc:'Охрид', avatar:'И', status:'busy', lang:'мк/ен/де/ит', wait:18, total:184},
      {id:'n10', name:'м-р Костадин Денов', loc:'Струмица', avatar:'К', status:'online', lang:'мк/ен/ср', wait:5, total:62},
      {id:'n11', name:'м-р Лидија Ангелова', loc:'Гостивар', avatar:'Л', status:'online', lang:'мк/ал/ен', wait:9, total:106},
      {id:'n12', name:'м-р Марко Трајков', loc:'Скопје · Аеродром', avatar:'М', status:'online', lang:'мк/ен', wait:6, total:88},
      {id:'n13', name:'м-р Наташа Ѓорѓиева', loc:'Кавадарци', avatar:'Н', status:'online', lang:'мк/ен', wait:4, total:45},
      {id:'n14', name:'м-р Орде Симоновски', loc:'Скопје · Кисела Вода', avatar:'О', status:'busy', lang:'мк/ен/де', wait:22, total:178},
      {id:'n15', name:'м-р Петар Стојановски', loc:'Гевгелија', avatar:'П', status:'online', lang:'мк/ен/гр', wait:5, total:51},
    ];

    function renderNotaries(){
      const grid = $('dnNotaryGrid');
      if (!grid) return;
      grid.innerHTML = NOTARIES.map(n => `
        <div class="dn-notary" data-id="${n.id}">
          <div class="dn-notary-status ${n.status}">
            <span class="dn-notary-dot ${n.status}"></span>
            <span>${n.status === 'online' ? 'онлајн' : (n.status === 'busy' ? 'зафатен' : 'офлајн')}</span>
          </div>
          <div class="dn-notary-head">
            <div class="dn-notary-avatar">${n.avatar}</div>
            <div>
              <p class="dn-notary-name">${escapeHtml(n.name)}</p>
              <p class="dn-notary-loc">📍 ${escapeHtml(n.loc)}</p>
            </div>
          </div>
          <div class="dn-notary-meta">
            <span>🌍 ${escapeHtml(n.lang)}</span>
            <span>📊 <strong>${n.total}</strong> заверки</span>
          </div>
          <button class="dn-notary-action" data-connect="${n.id}" ${n.status !== 'online' ? 'disabled' : ''}>${n.status === 'online' ? '🎥 Поврзи се (' + n.wait + ' мин)' : (n.status === 'busy' ? '⏱ Чекај ' + n.wait + ' мин' : 'Офлајн')}</button>
        </div>
      `).join('');

      grid.querySelectorAll('[data-connect]').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.connect;
          const n = NOTARIES.find(x => x.id === id);
          if (n) startSession(n);
        });
      });

      // Update stats
      const online = NOTARIES.filter(n => n.status === 'online').length;
      const busy = NOTARIES.filter(n => n.status === 'busy').length;
      const avgWait = Math.round(NOTARIES.filter(n => n.status === 'online').reduce((s, n) => s + n.wait, 0) / Math.max(1, online));
      if ($('dnOnlineCount')) $('dnOnlineCount').textContent = online;
      if ($('dnBusyCount')) $('dnBusyCount').textContent = busy;
      if ($('dnAvgWait')) $('dnAvgWait').textContent = '~' + avgWait;
    }

    // ── Calendar (next 7 days) ──
    let selectedDay = 0;
    let selectedSlot = null;
    function buildDays(){
      const days = [];
      const today = new Date();
      const dayNames = ['Нед', 'Пон', 'Вто', 'Сре', 'Чет', 'Пет', 'Саб'];
      for (let i = 0; i < 7; i++){
        const d = new Date(today);
        d.setDate(d.getDate() + i);
        days.push({
          dayName: i === 0 ? 'Денес' : (i === 1 ? 'Утре' : dayNames[d.getDay()]),
          date: d.getDate(),
          monthIdx: d.getMonth(),
          full: d,
          slots: 12 - Math.floor(Math.random() * 5),
        });
      }
      return days;
    }
    const DAYS = buildDays();

    function renderCalDays(){
      const wrap = $('dnCalDays');
      if (!wrap) return;
      wrap.innerHTML = DAYS.map((d, idx) => `
        <button type="button" class="dn-cal-day ${idx === selectedDay ? 'active' : ''}" data-day="${idx}">
          <div class="dn-cal-day-name">${escapeHtml(d.dayName)}</div>
          <div class="dn-cal-day-num">${d.date}</div>
          <div class="dn-cal-day-slots">${d.slots} слота</div>
        </button>
      `).join('');
      wrap.querySelectorAll('[data-day]').forEach(btn => {
        btn.addEventListener('click', () => {
          selectedDay = parseInt(btn.dataset.day, 10);
          selectedSlot = null;
          renderCalDays();
          renderCalSlots();
        });
      });
    }

    function renderCalSlots(){
      const wrap = $('dnCalSlots');
      if (!wrap) return;
      // 30-min slots from 9:00 to 17:00 = 16 slots
      const slots = [];
      for (let h = 9; h < 17; h++){
        slots.push({time: (h < 10 ? '0' : '') + h + ':00', avail: Math.random() > 0.3});
        slots.push({time: (h < 10 ? '0' : '') + h + ':30', avail: Math.random() > 0.3});
      }
      wrap.innerHTML = slots.map(s => `
        <button type="button" class="dn-cal-slot ${selectedSlot === s.time ? 'selected' : ''}" data-slot="${s.time}" ${!s.avail ? 'disabled' : ''}>${s.time}</button>
      `).join('');
      wrap.querySelectorAll('[data-slot]').forEach(btn => {
        btn.addEventListener('click', () => {
          selectedSlot = btn.dataset.slot;
          renderCalSlots();
          // Open booking confirmation
          const day = DAYS[selectedDay];
          const dateStr = day.full.toLocaleDateString('mk-MK', {day:'numeric', month:'long'});
          const subject = 'Резервирам дигитален нотарски термин: ' + dateStr + ' во ' + selectedSlot;
          const body = 'Здраво,\n\nСакам да резервирам термин за дигитално нотарско заверување.\n\nДатум: ' + dateStr + '\nВреме: ' + selectedSlot + '\n\nИме:\nКонтакт:\nКЕП давател: __________ (КИБС / Telekom / A1 / ЦАОС / eIDAS)\n\nБлагодарам.';
          if (typeof showToast === 'function'){
            showToast('✅ Слот ' + selectedSlot + ' резервиран — испрати потврда', 'success', 3000);
          }
          window.location.href = 'mailto:makedonijasistem@gmail.com?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
        });
      });
    }

    // ── Session simulator (would be WebRTC in production) ──
    let session = null;
    function startSession(notary){
      // Build modal dynamically
      let modal = $('dnSession');
      if (!modal){
        modal = document.createElement('div');
        modal.id = 'dnSession';
        modal.className = 'dn-session';
        modal.innerHTML = `
          <div class="dn-session-card">
            <div class="dn-session-head">
              <h3>🎥 <span id="dnSessionTitle">—</span></h3>
              <button class="dn-session-close" id="dnSessionClose">×</button>
            </div>
            <div class="dn-session-body">
              <div class="dn-session-video" id="dnSessionVideo">
                <div class="dn-session-video-icon" id="dnSessionVideoIcon">🎥</div>
                <div class="dn-session-video-status" id="dnSessionVideoStatus">Се поврзувам...</div>
                <div class="dn-session-video-info" id="dnSessionVideoInfo">Овој процес симулира дигитална нотарска сесија. Во вистинска верзија, овде ќе се отвори WebRTC видео-врска со нотарот.</div>
              </div>
              <div class="dn-session-progress" id="dnSessionProgress">
                <div class="dn-session-pstep done" data-step="1">
                  <div class="dn-session-pstep-dot">1</div>
                  <div>КЕП логин</div>
                </div>
                <div class="dn-session-pstep active" data-step="2">
                  <div class="dn-session-pstep-dot">2</div>
                  <div>Видео-врска</div>
                </div>
                <div class="dn-session-pstep" data-step="3">
                  <div class="dn-session-pstep-dot">3</div>
                  <div>Идентификација</div>
                </div>
                <div class="dn-session-pstep" data-step="4">
                  <div class="dn-session-pstep-dot">4</div>
                  <div>е-Потпис</div>
                </div>
                <div class="dn-session-pstep" data-step="5">
                  <div class="dn-session-pstep-dot">5</div>
                  <div>Готово</div>
                </div>
              </div>
              <p style="font-size:13px;color:var(--muted);line-height:1.6" id="dnSessionDesc">Нотарот ќе се поврзе со тебе за околу <strong>5–10 минути</strong>. Во меѓувреме, осигурај се дека:<br>• Камерата и микрофонот се вклучени<br>• Личната карта е при рака<br>• Имаш USB токен или мобилен со КЕП апликација<br>• Стабилна интернет-врска</p>
              <div class="dn-session-actions">
                <button class="dn-session-btn secondary" id="dnSessionCancel">Откажи</button>
                <button class="dn-session-btn primary" id="dnSessionContinue">Продолжи →</button>
              </div>
            </div>
          </div>
        `;
        document.body.appendChild(modal);
        // Wire events
        $('dnSessionClose').addEventListener('click', () => { modal.classList.remove('show'); });
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('show'); });
        $('dnSessionCancel').addEventListener('click', () => { modal.classList.remove('show'); });
        $('dnSessionContinue').addEventListener('click', advanceSession);
      }
      $('dnSessionTitle').textContent = 'Дигитална сесија со ' + notary.name;
      modal.classList.add('show');
      session = {step: 2, notary};
    }

    function advanceSession(){
      if (!session) return;
      session.step += 1;
      const steps = document.querySelectorAll('.dn-session-pstep');
      steps.forEach((s, idx) => {
        s.classList.remove('active');
        if (idx + 1 < session.step) s.classList.add('done');
        else if (idx + 1 === session.step) s.classList.add('active');
      });
      const desc = $('dnSessionDesc');
      const status = $('dnSessionVideoStatus');
      const icon = $('dnSessionVideoIcon');
      const cont = $('dnSessionContinue');
      if (session.step === 3){
        if (status) status.textContent = 'Видео-врска активна';
        if (icon) icon.textContent = '👤';
        if (desc) desc.innerHTML = '<strong>Чекор 3:</strong> Идентификација. Држете ја личната карта пред камера. Нотарот визуелно ја споредува со вашето лице. Ова трае 1-2 минути.';
        if (cont) cont.textContent = 'Идентифициран ✓';
      } else if (session.step === 4){
        if (status) status.textContent = 'Идентификацијата е потврдена';
        if (icon) icon.textContent = '✍️';
        if (desc) desc.innerHTML = '<strong>Чекор 4:</strong> Сега потпиши ја изјавата со твојот КЕП. Внеси PIN на твојот USB токен или потврди во мобилната апликација. Нотарот ќе ја солемизира со Qualified Electronic Seal.';
        if (cont) cont.textContent = 'Потпиши со КЕП';
      } else if (session.step === 5){
        if (status) status.textContent = 'Документот е заверен!';
        if (icon) icon.textContent = '🎉';
        if (desc) desc.innerHTML = '<strong>Готово!</strong> Електронската изјава е валидна. Документот е испратен на твојата е-пошта со <strong>квалификуван временски печат</strong> (RFC 3161). Архива: 7 години во encrypted vault.<br><br><strong>Ти си основач #' + (Math.floor(Math.random() * 600) + 200) + '!</strong>';
        if (cont) cont.textContent = '⬇️ Преземи документ';
      } else if (session.step >= 6){
        // Download stub
        const txt = 'ЕЛЕКТРОНСКА ИЗЈАВА · СОЛЕМИЗИРАНА\n\nNotary ID: ' + session.notary.id + '\nNotary: ' + session.notary.name + '\nDate: ' + new Date().toISOString() + '\n\nQualified Electronic Signature: VALID\nQualified Electronic Seal: VALID\nTimestamp: RFC 3161 compliant\n\nDocument legally binding under ZEDEIDU and eIDAS Regulation EU 910/2014.';
        const blob = new Blob([txt], {type: 'text/plain;charset=utf-8'});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'eIzjava-Solemizirana-' + Date.now() + '.txt';
        a.click();
        URL.revokeObjectURL(url);
        if (typeof showToast === 'function'){
          showToast('🎉 Готово! Документот е заверен и преземен.', 'success', 4000);
        }
        $('dnSession').classList.remove('show');
        // Increment local count
        try {
          let local = parseInt(localStorage.getItem('mks_founders_count_v1') || '0', 10);
          localStorage.setItem('mks_founders_count_v1', String(local + 1));
        } catch(e){}
      }
    }

    // ── FAQ accordion ──
    document.querySelectorAll('.dn-faq-item').forEach(item => {
      const q = item.querySelector('.dn-faq-q');
      if (q){
        q.addEventListener('click', () => item.classList.toggle('open'));
      }
    });

    // ── Initial render ──
    renderNotaries();
    renderCalDays();
    renderCalSlots();

    // Refresh notaries every 30s for visual liveness
    setInterval(() => {
      // Random small fluctuations in wait times
      NOTARIES.forEach(n => {
        if (n.status === 'online'){
          n.wait = Math.max(1, n.wait + (Math.random() > 0.5 ? 1 : -1));
        }
      });
      renderNotaries();
    }, 30000);

  } catch(err){
    console.warn('[digital-notary] error:', err && err.message ? err.message : err);
  }
})();
</script>

<script>
/* ═══ STEP-BY-STEP GUIDE · path switcher (v17 phase 18) ═══ */
function selectPath(path){
  document.querySelectorAll('.gd-path-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.path === path);
  });
  document.querySelectorAll('.gd-path-content').forEach(c => {
    c.classList.toggle('active', c.id === 'gd-path-' + path);
  });
  // Smooth scroll to top of guide if user clicked from elsewhere
  const guideEl = document.getElementById('guide');
  if (guideEl && window.scrollY > guideEl.offsetTop + 200){
    guideEl.scrollIntoView({behavior:'smooth', block:'start'});
  }
}
</script>

<script>
/* ═══ MEDIA HUB · filtering & search (v17 phase 26) ═══ */
function filterMedia(cat){
  document.querySelectorAll('.mh-filter-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.cat === cat);
  });
  const cards = document.querySelectorAll('.mh-card');
  let visible = 0;
  cards.forEach(card => {
    const show = cat === 'all' || card.dataset.cat === cat;
    card.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  // Clear search when filter changes
  const searchInput = document.getElementById('mhSearch');
  if (searchInput) searchInput.value = '';
}

function searchMedia(){
  const q = (document.getElementById('mhSearch').value || '').toLowerCase().trim();
  const cards = document.querySelectorAll('.mh-card');
  cards.forEach(card => {
    if (!q) {
      // Restore filter state
      const activeFilter = document.querySelector('.mh-filter-btn.active');
      const cat = activeFilter ? activeFilter.dataset.cat : 'all';
      const show = cat === 'all' || card.dataset.cat === cat;
      card.classList.toggle('hidden', !show);
      return;
    }
    const haystack = ((card.dataset.name || '') + ' ' + card.textContent).toLowerCase();
    card.classList.toggle('hidden', !haystack.includes(q));
  });
}

function copyAllEmails(){
  const allEmails = [];
  document.querySelectorAll('.mh-card-meta-row strong').forEach(el => {
    const txt = el.textContent.trim();
    if (txt.includes('@')) allEmails.push(txt);
  });
  const unique = [...new Set(allEmails)];
  const text = unique.join(', ');
  
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => {
      if (typeof showToast === 'function') {
        showToast('✓ Копирани се ' + unique.length + ' email адреси', 'success', 3000);
      } else {
        alert('Копирани се ' + unique.length + ' email адреси');
      }
    }).catch(() => {
      prompt('Копирај ги email адресите:', text);
    });
  } else {
    prompt('Копирај ги email адресите:', text);
  }
}
</script>
</body>
</html>
